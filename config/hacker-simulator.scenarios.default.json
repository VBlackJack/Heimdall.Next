        { "kind": "line", "text": { "en": "  ROLE [sshd_hardening     ] would_change={{number:0-4}}", "fr": "  ROLE [sshd_hardening     ] changements_prevus={{number:0-4}}" }, "color": "white", "delayMs": 80 },
