        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 140 },
        { "kind": "type", "text": { "en": "ROLE CONVERGENCE ACHIEVED", "fr": "CONVERGENCE DES ROLES ATTEINTE" }, "color": "green", "delayMs": 42 },
        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 160 },
        { "kind": "loop", "delayMs": 5000 }
