        { "kind": "line", "text": { "en": "PLAY [Apply baseline and security roles]", "fr": "PLAY [Appliquer les roles de base et de securite]" }, "color": "yellow", "delayMs": 130 },
        { "kind": "progress", "label": { "en": "  [baseline]", "fr": "  [baseline]" }, "suffix": { "en": "corrected={{number:1-4}} handlers={{number:0-2}}", "fr": "corriges={{number:1-4}} handlers={{number:0-2}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [cis_level1]", "fr": "  [cis_level1]" }, "suffix": { "en": "corrected={{number:1-3}} handlers={{number:0-2}}", "fr": "corriges={{number:1-3}} handlers={{number:0-2}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [nginx_front]", "fr": "  [nginx_front]" }, "suffix": { "en": "corrected={{number:1-3}} handlers={{number:0-1}}", "fr": "corriges={{number:1-3}} handlers={{number:0-1}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 130 },
        { "kind": "line", "text": { "en": "[*] Serial rollout policy: 1 host at a time", "fr": "[*] Politique de deploiement serie : 1 hote a la fois" }, "color": "yellow", "delayMs": 140 },
        { "kind": "progress", "label": { "en": "  [edge-api-01]", "fr": "  [edge-api-01]" }, "suffix": { "en": "drained -> deployed -> healthy", "fr": "vidange -> deploye -> sain" }, "steps": [0, 35, 75, 100], "completeColor": "cyan", "delayMs": 90 },
        { "kind": "progress", "label": { "en": "  [edge-api-02]", "fr": "  [edge-api-02]" }, "suffix": { "en": "drained -> deployed -> healthy", "fr": "vidange -> deploye -> sain" }, "steps": [0, 35, 75, 100], "completeColor": "cyan", "delayMs": 90 },
        { "kind": "progress", "label": { "en": "  [app-core-01]", "fr": "  [app-core-01]" }, "suffix": { "en": "drained -> deployed -> healthy", "fr": "vidange -> deploye -> sain" }, "steps": [0, 35, 75, 100], "completeColor": "cyan", "delayMs": 90 },
        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 130 },
        { "kind": "line", "text": { "en": "PLAY RECAP", "fr": "PLAY RECAP" }, "color": "gray", "delayMs": 100 },
        { "kind": "line", "text": { "en": "edge-api-01        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0", "fr": "edge-api-01        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0" }, "color": "white", "delayMs": 55 },
        { "kind": "line", "text": { "en": "edge-api-02        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0", "fr": "edge-api-02        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0" }, "color": "white", "delayMs": 55 },
        { "kind": "line", "text": { "en": "app-core-01        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0", "fr": "app-core-01        : ok={{number:18-27}} changed={{number:3-8}} unreachable=0 failed=0" }, "color": "white", "delayMs": 55 },
        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 130 },
        { "kind": "line", "text": { "en": "[+] Rolling deployment completed successfully for release {{release}}", "fr": "[+] Deploiement progressif termine avec succes pour la release {{release}}" }, "color": "cyan", "delayMs": 140 },
        { "kind": "type", "text": { "en": "CHANGE WINDOW CLOSED - NO FAILURES", "fr": "FENETRE DE CHANGEMENT FERMEE - AUCUN ECHEC" }, "color": "green", "delayMs": 42 },
        { "kind": "line", "text": { "en": "", "fr": "" }, "delayMs": 160 },
        { "kind": "loop", "delayMs": 5000 }
      ]
    },
    {
      "id": "rolerollout",
