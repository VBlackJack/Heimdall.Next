        { "kind": "progress", "label": { "en": "  [base_linux         ]", "fr": "  [base_linux         ]" }, "suffix": { "en": "corrected={{number:1-4}} handlers={{number:0-2}}", "fr": "corriges={{number:1-4}} handlers={{number:0-2}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [sshd_hardening     ]", "fr": "  [sshd_hardening     ]" }, "suffix": { "en": "corrected={{number:1-3}} handlers={{number:0-1}}", "fr": "corriges={{number:1-3}} handlers={{number:0-1}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [auditd             ]", "fr": "  [auditd             ]" }, "suffix": { "en": "corrected={{number:1-3}} handlers={{number:0-1}}", "fr": "corriges={{number:1-3}} handlers={{number:0-1}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [falco              ]", "fr": "  [falco              ]" }, "suffix": { "en": "corrected={{number:1-4}} handlers={{number:0-2}}", "fr": "corriges={{number:1-4}} handlers={{number:0-2}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
        { "kind": "progress", "label": { "en": "  [node_exporter      ]", "fr": "  [node_exporter      ]" }, "suffix": { "en": "corrected={{number:1-3}} handlers={{number:0-1}}", "fr": "corriges={{number:1-3}} handlers={{number:0-1}}" }, "steps": [0, 50, 100], "completeColor": "green", "delayMs": 85 },
