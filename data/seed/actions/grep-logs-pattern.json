{
  "id": "grep-logs-pattern",
  "title": "Rechercher un pattern dans les logs",
  "description": "Recherche un pattern spécifique dans les fichiers de logs système",
  "category": "📊 Monitoring & Logs",
  "platform": 1,
  "level": 0,
  "tags": [
    "grep",
    "logs",
    "search",
    "pattern"
  ],
  "linuxCommandTemplateId": "grep-logs-cmd",
  "linuxCommandTemplate": {
    "id": "grep-logs-cmd",
    "platform": 1,
    "name": "grep",
    "commandPattern": "grep -i \"{pattern}\" {logfile} | tail -n {lines}",
    "parameters": [
      {
        "name": "pattern",
        "label": "Pattern de recherche",
        "type": "string",
        "defaultValue": "error",
        "required": true,
        "description": "Texte ou regex à rechercher"
      },
      {
        "name": "logfile",
        "label": "Fichier de log",
        "type": "string",
        "defaultValue": "/var/log/syslog",
        "required": true,
        "description": "Chemin vers le fichier de log"
      },
      {
        "name": "lines",
        "label": "Nombre de lignes",
        "type": "number",
        "defaultValue": "50",
        "required": true,
        "description": "Nombre de résultats à afficher"
      }
    ]
  },
  "examples": [
    {
      "command": "grep -i \"error\" /var/log/syslog | tail -n 50",
      "description": "Recherche 'error' dans syslog (insensible à la casse)",
      "platform": 1
    },
    {
      "command": "grep \"failed\" /var/log/auth.log",
      "description": "Recherche les échecs d'authentification",
      "platform": 1
    },
    {
      "command": "grep -i \"error\" /var/log/syslog | tail -n 100",
      "description": "Exemple utilisant le paramètre 'pattern': Texte ou regex à rechercher. Remplacez *.txt par la valeur appropriée selon votre environnement.",
      "platform": 1
    },
    {
      "command": "grep -i \"error|warning\" /var/log/syslog | tail -n 100",
      "description": "Exemple utilisant le paramètre 'logfile': Chemin vers le fichier de log. Remplacez /var/log/syslog par la valeur appropriée selon votre environnement.",
      "platform": 1
    },
    {
      "command": "grep -i \"failed|denied\" /var/log/auth.log | tail -n 50",
      "description": "Recherche les tentatives d'authentification échouées dans le journal d'authentification. Remplacez le fichier et le pattern selon votre environnement.",
      "platform": 1
    },
    {
      "command": "grep -r \"error\" /var/log",
      "description": "Rechercher \"error\" récursivement dans les logs",
      "platform": 1
    },
    {
      "command": "grep -i \"warning\" app.log",
      "description": "Recherche insensible à la casse",
      "platform": 1
    },
    {
      "command": "grep -v \"debug\" app.log",
      "description": "Exclure les lignes contenant \"debug\"",
      "platform": 1
    },
    {
      "command": "grep -n \"TODO\" *.py",
      "description": "Afficher les numéros de ligne",
      "platform": 1
    }
  ],
  "notes": "Option -i pour ignorer la casse. Peut nécessiter sudo selon les permissions du fichier.",
  "links": [
    {
      "title": "grep command guide",
      "url": "https://www.gnu.org/software/grep/manual/grep.html"
    }
  ]
}