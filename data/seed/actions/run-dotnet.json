  "linuxCommandTemplate": {
    "id": "run-dotnet-linux-cmd",
    "platform": 1,
    "name": "dotnet run",
    "commandPattern": "dotnet run --project \"{projectPath}\"",
    "parameters": [
      {
        "name": "projectPath",
        "label": "Projet",
        "type": "string",
        "defaultValue": ".",
        "required": false,
        "description": "Chemin du projet .csproj"
      }
    ]
  },
  "examples": [],
