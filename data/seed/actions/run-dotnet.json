      "description": "Lance avec des arguments",
      "platform": 0
    },
    {
      "command": "dotnet run --project \".\"",
      "description": "Exemple utilisant le paramètre 'projectPath': Chemin du projet .csproj. Remplacez C:\\Projects\\MyApp par la valeur appropriée selon votre environnement.",
      "platform": 0
    }
  ],
  "linuxExamples": [
    {
      "command": "dotnet run --project \"./MyApp\"",
