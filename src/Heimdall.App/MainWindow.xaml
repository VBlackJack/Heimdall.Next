<Window x:Class="Heimdall.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition x:Name="ToolbarRow" Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition x:Name="StatusBarRow" Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <!-- Left: App title + navigation tabs -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Heimdall"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <RadioButton x:Name="TabServers"
                                 Content="Servers"
                                 GroupName="NavTabs"
                                 IsChecked="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabTunnels"
                                 Content="Tunnels"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabScheduled"
                                 Content="Scheduled"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabSettings"
                                 Content="Settings"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"/>
                </StackPanel>

                <!-- Right: Quick actions -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="AddButton" Content="+ Add"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="4,0" Click="OnAddButtonClick">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AddMenu"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Add Server" Command="{Binding ServerList.AddServerCommand}"/>
                                <MenuItem Header="Add Gateway" Command="{Binding Settings.AddGatewayCommand}"/>
                                <MenuItem Header="Add Project" Command="{Binding AddProjectCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <TextBox x:Name="SearchBox"
                             Width="200"
                             Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Tag="Search servers... (Ctrl+F)"
                             Margin="4,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <!-- ============================================================ -->
            <!-- SERVERS TAB: TreeView left panel + detail/sessions right      -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsServersTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <!-- Left: TreeView panel -->
                    <ColumnDefinition x:Name="ServerTreeColumn" Width="260" MinWidth="180" MaxWidth="500"/>
                    <!-- Splitter -->
                    <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                    <!-- Right: Detail / session content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: TreeView with filter -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <DockPanel>
                        <!-- Filter box at top of TreeView -->
                        <TextBox DockPanel.Dock="Top"
                                 Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource SearchTextBoxStyle}"
                                 Tag="Filter servers..."
                                 Margin="8,8,8,4"/>

                        <!-- Hierarchical TreeView -->
                        <TreeView x:Name="ServerTreeView"
                                  ItemsSource="{Binding ServerList.GroupedServers}"
                                  Style="{DynamicResource ThemedTreeViewStyle}"
                                  Padding="0,4,0,0"
                                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                                  MouseDoubleClick="OnTreeViewDoubleClick"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewMouseRightButtonDown"
                                  ContextMenuOpening="OnTreeViewContextMenuOpening"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <TreeView.Resources>
                                <!-- Project node template (top level) -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:ServerProjectViewModel}"
                                                          ItemsSource="{Binding Groups}">
                                    <Grid Margin="0,1" ToolTip="{Binding ProjectName}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Height="14"
                                                CornerRadius="2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AccentBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProjectName}"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="3"
                                                CornerRadius="7"
                                                MinWidth="18"
                                                Height="14"
                                                Padding="4,0"
                                                Margin="6,0,0,0"
                                                Background="{DynamicResource CardBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ServerCount}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </HierarchicalDataTemplate>

                                <!-- Group node template (mid level) -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:ServerGroupViewModel}"
                                                          ItemsSource="{Binding Servers}">
                                    <Grid Margin="0,1" ToolTip="{Binding GroupName}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding GroupName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                CornerRadius="7"
                                                MinWidth="18"
                                                Height="14"
                                                Padding="4,0"
                                                Margin="6,0,0,0"
                                                Background="{DynamicResource CardBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ServerCount}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </HierarchicalDataTemplate>

                                <!-- Server leaf node template -->
                                <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                                    <Grid Margin="0,1" ToolTip="{Binding DisplayName}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,6,0"
                                                CornerRadius="8"
                                                Background="{Binding ConnectionType, Converter={StaticResource ConnectionTypeToBrushConverter}}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ConnectionTypeBadge}"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Ellipse Grid.Column="2"
                                                 Width="6" Height="6" Margin="6,0,0,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding ConnectionState,
                                                     Converter={StaticResource ConnectionStateToBrushConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </TreeView.Resources>

                            <!-- TreeViewItem container style: groups expanded by default -->
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem"
                                       BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                    <Setter Property="IsExpanded" Value="True"/>
                                </Style>
                            </TreeView.ItemContainerStyle>

                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- SPLITTER -->
                <GridSplitter Grid.Column="1"
                              Width="3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              ShowsPreview="True"/>

                <!-- RIGHT PANEL: Active sessions or selected server details -->
                <Grid Grid.Column="2">
                    <Border Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource BackgroundBrush}">
                        <TabControl x:Name="SessionTabControl"
                                    ItemsSource="{Binding Connection.ActiveSessions}"
                                    SelectedItem="{Binding Connection.ActiveSession}"
                                    Background="{DynamicResource BackgroundBrush}"
                                    BorderThickness="0"
                                    Style="{DynamicResource ThemedTabControlStyle}"
                                    PreviewMouseRightButtonDown="OnSessionTabRightClick"
                                    ItemContainerStyle="{DynamicResource ThemedTabItemStyle}">
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Width="18"
                                                Height="18"
                                                Margin="8,0,0,0"
                                                Padding="0"
                                                Focusable="False"
                                                Content="×"
                                                Command="{Binding DataContext.Connection.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>

                            <TabControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                    <ContentControl Content="{Binding HostControl}"/>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </Border>

                    <Grid Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <!-- Server detail panel (shown when a server is selected) -->
                        <Border Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                                Padding="24">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{Binding ServerList.SelectedServer.DisplayName}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                            Background="{Binding ServerList.SelectedServer.ConnectionType,
                                                Converter={StaticResource ConnectionTypeToBrushConverter}}">
                                        <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionType}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ServerList.SelectedServer.ConnectionState,
                                                 Converter={StaticResource ConnectionStateToBrushConverter}}"/>
                                    <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionState}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="13">
                                    <Run Text="{Binding ServerList.SelectedServer.RemoteServer, Mode=OneWay}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding ServerList.SelectedServer.RemotePort, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="12"
                                           Visibility="{Binding ServerList.SelectedServer.Group, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run Text="Group: "/>
                                    <Run Text="{Binding ServerList.SelectedServer.Group, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="12"
                                           Visibility="{Binding ServerList.SelectedServer.Environment, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run Text="Environment: "/>
                                    <Run Text="{Binding ServerList.SelectedServer.Environment, Mode=OneWay}"/>
                                </TextBlock>

                                <Button Content="Connect"
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="120" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state when nothing selected -->
                        <StackPanel Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="True">
                            <!-- Show empty state overlay when no servers exist -->
                            <StackPanel Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="No servers configured" FontSize="18"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Click '+ Add' or press Ctrl+N to add your first server"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,16"/>
                                <Button Content="+ Add Server"
                                        Command="{Binding ServerList.AddServerCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Show hint when servers exist but none selected -->
                            <TextBlock Text="Select a server to view details"
                                       Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TUNNELS TAB: Active tunnels + Gateway management              -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsTunnelsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Active Tunnels -->
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="Active Tunnels" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="16,12,16,8"/>
                    <DataGrid ItemsSource="{Binding TunnelList}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="*"/>
                            <DataGridTextColumn Header="Local Port" Binding="{Binding LocalPort}" Width="100"/>
                            <DataGridTextColumn Header="Remote" Binding="{Binding RemoteHost}" Width="*"/>
                            <DataGridTextColumn Header="Remote Port" Binding="{Binding RemotePort}" Width="100"/>
                            <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat=HH:mm:ss}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="16,8"/>

                <!-- SSH Gateways -->
                <DockPanel Grid.Row="2" MinHeight="180" MaxHeight="300">
                    <DockPanel DockPanel.Dock="Top" Margin="16,4,16,8">
                        <TextBlock Text="SSH Gateways" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+ Add" Command="{Binding Settings.AddGatewayCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="11" Margin="0,0,4,0"/>
                            <Button Content="Edit" Command="{Binding Settings.EditGatewayCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="11" Margin="0,0,4,0"/>
                            <Button Content="Delete" Command="{Binding Settings.DeleteGatewayCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="11"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding Settings.Gateways}"
                              SelectedItem="{Binding Settings.SelectedGateway}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="16,0,16,12"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="*"/>
                            <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="60"/>
                            <DataGridTextColumn Header="User" Binding="{Binding User}" Width="120"/>
                            <DataGridTemplateColumn Header="Auth" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="KEY" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SshBadgeBrush}"
                                                       Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="PWD" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

            <!-- ============================================================ -->
            <!-- SCHEDULED TAB: Placeholder                                    -->
            <!-- ============================================================ -->
            <StackPanel Visibility="{Binding IsScheduledTabSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Scheduled connections"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="No scheduled tasks configured."
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ============================================================ -->
            <!-- SETTINGS TAB: Full-width form                                 -->
            <!-- ============================================================ -->
            <ScrollViewer Visibility="{Binding IsSettingsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="Language" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding Settings.DefaultLocale}"
                              SelectedValuePath="Content" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="en"/>
                        <ComboBoxItem Content="fr"/>
                    </ComboBox>

                    <TextBlock Text="Theme" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <ComboBox SelectedValue="{Binding Settings.DefaultTheme}"
                              SelectedValuePath="Content" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>

                    <TextBlock Text="Connections" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,24,0,12"/>

                    <TextBlock Text="PuTTY/Plink Path" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Settings.PlinkPath}" Width="400" HorizontalAlignment="Left"/>

                    <TextBlock Text="External Editor Path" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Settings.ExternalEditorPath}" Width="400" HorizontalAlignment="Left"/>

                    <CheckBox Content="Enable logging" IsChecked="{Binding Settings.EnableLogging}" Margin="0,12,0,0"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <CheckBox Content="Auto-open SFTP on SSH" IsChecked="{Binding Settings.SftpAutoOpenOnSsh}" Margin="0,8,0,0"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="Anti-idle interval (seconds)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Settings.AntiIdleInterval}" Width="100" HorizontalAlignment="Left"/>

                    <TextBlock Text="Max embedded sessions" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Settings.MaxEmbeddedSessions}" Width="100" HorizontalAlignment="Left"/>

                    <!-- SSH Gateways -->
                    <TextBlock Text="SSH Gateways" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,24,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="+ Add Gateway" Command="{Binding Settings.AddGatewayCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Edit" Command="{Binding Settings.EditGatewayCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Delete" Command="{Binding Settings.DeleteGatewayCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Settings.Gateways}"
                             SelectedItem="{Binding Settings.SelectedGateway}"
                             MinHeight="100" MaxHeight="250"
                             Background="{DynamicResource CardBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding User, Mode=OneWay}"/>
                                        <Run Text="@"/>
                                        <Run Text="{Binding Host, Mode=OneWay}"/>
                                        <Run Text=":"/>
                                        <Run Text="{Binding Port, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text=" [KEY]" FontSize="9" Foreground="{DynamicResource SshBadgeBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Save / Reset -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                        <Button Content="Save Settings" Command="{Binding Settings.SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Width="120" Margin="0,0,8,0"/>
                        <Button Content="Reset Defaults" Command="{Binding Settings.ResetToDefaultsCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Width="120"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="11"/>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding ServerCount, Mode=OneWay}"/>
                        <Run Text=" servers | "/>
                        <Run Text="{Binding TunnelCount, Mode=OneWay}"/>
                        <Run Text=" tunnels"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
