<Window x:Class="Heimdall.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        xmlns:views="clr-namespace:Heimdall.App.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition x:Name="ToolbarRow" Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition x:Name="StatusBarRow" Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <!-- Left: App title + navigation tabs -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="Mw_AppTitle" Text=""
                               FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <RadioButton x:Name="TabServers"
                                 Content=""
                                 GroupName="NavTabs"
                                 IsChecked="True"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabTunnels"
                                 Content=""
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabScheduled"
                                 Content=""
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabSettings"
                                 Content=""
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabAbout"
                                 Content=""
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"/>
                </StackPanel>

                <!-- Right: Search box + Share Folder -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Share Folder toggle -->
                    <Button x:Name="ShareFolderButton"
                            Click="OnShareFolderClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="6,4" FontSize="{StaticResource FontSizeBody}"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Share folder">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="Mw_ShareFolderLabel" Text="" FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Quick Connect shortcut button -->
                    <Button x:Name="QuickConnectButton"
                            Click="OnQuickConnectButtonClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,4" FontSize="{StaticResource FontSizeCaption}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="Mw_QuickConnectLabel" Text=""
                                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Global busy indicator -->
        <ProgressBar Grid.Row="1"
                     VerticalAlignment="Top"
                     Panel.ZIndex="10"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1"
              ClipToBounds="True">

            <!-- ============================================================ -->
            <!-- SERVERS TAB: TreeView left panel + detail/sessions right      -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsServersTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <!-- Left: TreeView panel -->
                    <ColumnDefinition x:Name="ServerTreeColumn" Width="260" MinWidth="180" MaxWidth="500"/>
                    <!-- Splitter -->
                    <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                    <!-- Right: Detail / session content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: TreeView with filter (only on Servers tab) -->
                <Border x:Name="TreeViewPanel" Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        >
                    <DockPanel>
                        <!-- Filter + collapse button at top of TreeView -->
                        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
                            <Button x:Name="ToggleSidebarButton"
                                    DockPanel.Dock="Right"
                                    Content="&#xE89F;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Click="OnToggleSidebarClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                    Width="32" Height="32"
                                    Margin="4,0,0,0"/>
                            <Button x:Name="CollapseAllButton"
                                    DockPanel.Dock="Right"
                                    Content="&#xE70D;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Click="OnCollapseAllClick"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeCaption}"
                                    Width="32" Height="32"
                                    Margin="2,0,0,0"/>
                            <Button x:Name="ExpandAllButton"
                                    DockPanel.Dock="Right"
                                    Content="&#xE70E;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Click="OnExpandAllClick"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeCaption}"
                                    Width="32" Height="32"
                                    Margin="2,0,0,0"/>
                            <Button x:Name="AddButton"
                                    DockPanel.Dock="Right"
                                    Click="OnAddButtonClick"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                    Width="32" Height="32"
                                    Margin="4,0,0,0">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"/>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddMenu"
                                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem x:Name="Mw_AddMenuServer" Header="" Command="{Binding ServerList.AddServerCommand}"/>
                                        <MenuItem x:Name="Mw_AddMenuTool" Header="" SubmenuOpened="OnAddToolSubmenuOpened">
                                            <MenuItem Header="..." IsEnabled="False"/>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem x:Name="Mw_AddMenuGateway" Header="" Command="{Binding Settings.AddGatewayCommand}"/>
                                        <MenuItem x:Name="Mw_AddMenuFolder" Header="" Click="OnAddFolderFromMenu"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Grid>
                                <TextBox x:Name="Mw_FilterBox" Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource SearchTextBoxStyle}"
                                         Tag="" Padding="10,6,28,6"
                                         AutomationProperties.Name="Search and filter servers"/>
                                <Button x:Name="Mw_FilterClearBtn"
                                        Content="&#xE711;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="{StaticResource FontSizeSmallCaption}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,4,0"
                                        Padding="4"
                                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                                        MinHeight="0"
                                        Click="OnFilterClearClick"
                                        Visibility="Collapsed"
                                        AutomationProperties.Name="Clear search filter"/>
                            </Grid>
                            <TextBlock x:Name="Mw_FilterResultCount"
                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right"
                                       Margin="0,2,4,0"
                                       Visibility="Collapsed"/>
                        </DockPanel>

                        <!-- TOOLS: Expandable panel (above toggle, collapsed by default) -->
                        <Border x:Name="ToolsQuickPanel" DockPanel.Dock="Bottom"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                MaxHeight="300"
                                Visibility="Collapsed">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="8,6,8,4">
                                    <TextBlock x:Name="Mw_ToolsPanelTitle" Text=""
                                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnCollapseTools" DockPanel.Dock="Right"
                                            Content="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                            Click="OnToggleToolsPanel"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="4,4" FontSize="{StaticResource FontSizeCaption}"
                                            HorizontalAlignment="Right"/>
                                </DockPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0,4,4">
                                    <StackPanel x:Name="ToolsCategoryStack"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- TOOLS: Toggle button (always at bottom) -->
                        <Border DockPanel.Dock="Bottom"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="4,2">
                            <Button x:Name="BtnToggleToolsPanel"
                                    Click="OnToggleToolsPanel"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="4,3" FontSize="{StaticResource FontSizeCaption}"
                                    AutomationProperties.Name="Toggle tools panel">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="Mw_ToolsToggleLabel" Text=""
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" (Ctrl+Shift+T)"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Hierarchical TreeView (fills remaining space) -->
                        <TreeView x:Name="ServerTreeView"
                                  ItemsSource="{Binding ServerList.GroupedServers}"
                                  Style="{DynamicResource ThemedTreeViewStyle}"
                                  Padding="0,4,0,0"
                                  AllowDrop="True"
                                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                                  MouseDoubleClick="OnTreeViewDoubleClick"
                                  PreviewMouseLeftButtonDown="OnTreeViewDragStart"
                                  PreviewMouseMove="OnTreeViewDragMove"
                                  DragOver="OnTreeViewDragOver"
                                  DragLeave="OnTreeViewDragLeave"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewMouseRightButtonDown"
                                  ContextMenuOpening="OnTreeViewContextMenuOpening"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <TreeView.Resources>
                                <!-- Folder node template (recursive — unlimited nesting) -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:FolderViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <Grid Margin="0,2,0,0" ToolTip="{Binding FullPath}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0"
                                              Data="{StaticResource Geo.Tree.Group}"
                                              Fill="{DynamicResource InfoBrush}"
                                              Width="14" Height="14"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Padding="6,2" CornerRadius="{StaticResource CornerRadiusMd}" Margin="6,0,0,0"
                                                Background="{DynamicResource CardBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ServerCount}" FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </HierarchicalDataTemplate>

                                <!-- Server leaf node template -->
                                <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                                ToolTip="{Binding DisplayName}">
                                        <!-- Protocol glyph icon -->
                                        <TextBlock x:Name="TypeIcon" Text="&#xE7F4;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{Binding ConnectionType, Converter={StaticResource TypeToColorConverter}}"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <!-- Status dot -->
                                        <Ellipse Width="7" Height="7" Margin="2,0,8,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource ServerStatusToColorConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="ConnectionState"/>
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <!-- Server name -->
                                        <TextBlock Text="{Binding DisplayName}" FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <!-- Protocol-specific glyph and color overrides -->
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE756;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8B7;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE756;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE753;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE7F4;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE756;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8B7;"/>
                                        </DataTrigger>
                                        <!-- ── Network tools (blue) ── -->
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:PING">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE93E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:DNS">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE774;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:CERT">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8D7;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:NETMAP">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE826;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:PORTSCAN">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE71E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:SUBNET">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8EF;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:IPCONV">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8AB;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:HTTP">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE774;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:WHOIS">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE946;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:NETCALC">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8EF;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolNetworkBrush}"/>
                                        </DataTrigger>
                                        <!-- ── Security tools (amber) ── -->
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:HASH">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE72E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:PASSWORD">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8D7;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:SSHKEY">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8F7;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:JWT">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8AC;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:HMAC">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE72E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:CERTGEN">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8D7;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:TOTP">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE823;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSecurityBrush}"/>
                                        </DataTrigger>
                                        <!-- ── Encoding & Format tools (purple) ── -->
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:BASE64">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8AB;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:URLENC">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE774;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:JSON">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE7BC;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:REGEX">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE71E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:DIFF">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8AC;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:TEXTCASE">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8AB;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolEncodingBrush}"/>
                                        </DataTrigger>
                                        <!-- ── System tools (teal) ── -->
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:CHMOD">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE72E;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:DATETIME">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE823;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:UUID">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8C3;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:CRONTAB">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE823;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:LOGVIEW">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE7BC;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:HOSTS">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE90F;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:SSHCONFIG">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE90F;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:CRONJOB">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE823;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:SERVICES">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE7BC;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="TOOL:DIAGRAM">
                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE826;"/>
                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource ToolSystemBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </TreeView.Resources>

                            <!-- TreeViewItem container style: expand state bound to ViewModel -->
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem"
                                       BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="1,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </TreeView.ItemContainerStyle>

                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- SPLITTER -->
                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource CardBrush}"
                              Cursor="SizeWE"
                              ShowsPreview="True">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                    <!-- Visual drag handle (three dots) -->
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Border Background="{TemplateBinding Background}">
                                <TextBlock Text="&#xE784;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- Show sidebar button (visible only when sidebar is hidden) -->
                <Button x:Name="ShowSidebarButton"
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="&#xE76C;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnToggleSidebarClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="4,6" FontSize="{StaticResource FontSizeCaption}"
                        Margin="4,8,0,0"
                        Panel.ZIndex="10"
                        Visibility="Collapsed"/>

                <!-- RIGHT PANEL: sessions + tunnel bottom panel -->
                <Grid Grid.Column="2"
                      ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <!-- Row 0: Sessions / server details -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: GridSplitter (visible when tunnel panel open) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Retractable tunnel panel -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- SESSIONS (visible when active) -->
                    <TabControl x:Name="SessionTabControl"
                                Grid.Row="0"
                                ItemsSource="{Binding Connection.ActiveSessions}"
                                SelectedItem="{Binding Connection.ActiveSession}"
                                Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{DynamicResource BackgroundBrush}"
                                BorderThickness="0"
                                ClipToBounds="True"
                                Style="{DynamicResource ThemedTabControlStyle}"
                                PreviewMouseRightButtonDown="OnSessionTabRightClick"
                                PreviewMouseLeftButtonDown="OnTabDragStart"
                                PreviewMouseMove="OnTabDragMove"
                                DragOver="OnTabDragOver"
                                Drop="OnTabDrop"
                                AllowDrop="True"
                                ItemContainerStyle="{DynamicResource ThemedTabItemStyle}">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                <Border x:Name="TabHeaderBorder" Padding="10,6" Background="Transparent">
                                    <DockPanel LastChildFill="True">
                                        <!-- Close button always occupies layout space (Hidden, not Collapsed)
                                             so the tab width stays constant on hover. Only opacity toggles.
                                             IsHitTestVisible stays True; the Border's Background="Transparent"
                                             ensures IsMouseOver persists when hovering over child elements. -->
                                        <Button x:Name="TabCloseButton" DockPanel.Dock="Right"
                                                Width="20" Height="20" Margin="6,0,0,0" Padding="2"
                                                Focusable="False" Content="&#xE711;"
                                                FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSmallCaption}"
                                                Opacity="0.3" IsHitTestVisible="True"
                                                Command="{Binding DataContext.Connection.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="Close session tab"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE7F4;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{Binding ConnectionType, Converter={StaticResource TypeToColorConverter}}"
                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                            <TextBlock x:Name="TunnelRouteText" Text="{Binding TunnelRoute}" FontSize="{StaticResource FontSizeSmallCaption}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Show close button at full opacity on hover or active tab -->
                                    <Trigger SourceName="TabHeaderBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                        <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                <Grid>
                                    <views:SplitPaneHost
                                        PrimaryContent="{Binding HostControl}"
                                        SecondaryContent="{Binding SecondaryHostControl}"
                                        IsSplit="{Binding IsSplit}"
                                        Orientation="{Binding SplitOrientation}"/>
                                    <!-- Loading overlay (visible while HostControl is null during connection) -->
                                    <Border x:Name="SessionLoadingOverlay"
                                            Style="{StaticResource FadeInPanelStyle}"
                                            Background="{DynamicResource OverlayBackground}"
                                            Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ProgressBar IsIndeterminate="True"
                                                         Width="200" Height="3"
                                                         Margin="0,0,0,12"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TunnelRoute}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HostControl}" Value="{x:Null}">
                                        <Setter TargetName="SessionLoadingOverlay" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- SERVER DETAILS (visible when no sessions) -->
                    <Grid Grid.Row="0"
                          Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <!-- Server detail panel (shown when a non-tool server is selected) -->
                        <Border x:Name="ServerDetailPanel"
                                Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{Binding ServerList.SelectedServer.DisplayName}"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0"
                                            Background="{Binding ServerList.SelectedServer.ConnectionType,
                                                Converter={StaticResource ConnectionTypeToBrushConverter}}">
                                        <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionType}"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ServerList.SelectedServer.ConnectionState,
                                                 Converter={StaticResource ConnectionStateToBrushConverter}}"/>
                                    <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionState}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock x:Name="Mw_DetailHostPort"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}">
                                    <Run Text="{Binding ServerList.SelectedServer.RemoteServer, Mode=OneWay}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding ServerList.SelectedServer.RemotePort, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Group, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailGroupLabel" Text=""/>
                                    <Run Text="{Binding ServerList.SelectedServer.Group, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Environment, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailEnvLabel" Text=""/>
                                    <Run Text="{Binding ServerList.SelectedServer.Environment, Mode=OneWay}"/>
                                </TextBlock>

                                <Button x:Name="Mw_DetailConnectBtn" Content=""
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="120" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Tool detail panel (shown when a TOOL:* entry is selected) -->
                        <Border x:Name="ToolDetailPanel"
                                Visibility="Collapsed"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock x:Name="Mw_ToolDetailName"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0"
                                            Background="{DynamicResource ToolBadgeBrush}">
                                        <TextBlock x:Name="Mw_ToolDetailCategory"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="Mw_ToolDetailDescription"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}" TextWrapping="Wrap"/>

                                <Button x:Name="Mw_ToolDetailOpenBtn" Content=""
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="140" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state when nothing selected -->
                        <StackPanel Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="True">
                            <!-- Show empty state overlay when no servers exist -->
                            <StackPanel Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="&#xE774;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeHero}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Opacity="0.5"
                                           Margin="0,0,0,16"/>
                                <TextBlock x:Name="Mw_EmptyStateTitle" Text="" FontSize="{StaticResource FontSizeHeadline}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Mw_EmptyStateSubtitle" Text=""
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,24"
                                           TextWrapping="Wrap" MaxWidth="400"
                                           TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="Mw_EmptyBtnAddServer" Content=""
                                            Command="{Binding ServerList.AddServerCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"/>
                                    <Button x:Name="Mw_EmptyBtnImport" Content=""
                                            Command="{Binding Settings.ImportConfigCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Show hint when servers exist but none selected -->
                            <TextBlock x:Name="Mw_EmptySelectServer" Text=""
                                       Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- TUNNEL BOTTOM PANEL: GridSplitter + compact active tunnels -->
                    <GridSplitter Grid.Row="1"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBrush}"
                                  ShowsPreview="True"
                                  Visibility="{Binding IsTunnelPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Grid.Row="2"
                            MinHeight="120" MaxHeight="300"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding IsTunnelPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DockPanel>
                            <!-- Header: "Tunnels (N)" + collapse button -->
                            <Border DockPanel.Dock="Top"
                                    Padding="8,4"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button x:Name="Mw_TunnelPanelCollapseBtn" DockPanel.Dock="Right"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="{StaticResource FontSizeCaption}"
                                            Command="{Binding ToggleTunnelPanelCommand}"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,2" Margin="4,0,0,0"
                                            AutomationProperties.Name="Collapse tunnel panel"/>
                                    <Button x:Name="Mw_TunnelPanelCloseAllBtn" DockPanel.Dock="Right"
                                            Content=""
                                            Command="{Binding CloseAllTunnelsCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource ErrorTextBrush}"
                                            Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"
                                            AutomationProperties.Name="Close all tunnels"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run x:Name="Mw_TunnelPanelHeaderPrefix" Text=""/>
                                            <Run Text="{Binding TunnelCount, Mode=OneWay}"/>
                                            <Run x:Name="Mw_TunnelPanelHeaderSuffix" Text=""/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Content: compact tunnel DataGrid -->
                            <Grid>
                                <DataGrid x:Name="Mw_TunnelPanelGrid"
                                          ItemsSource="{Binding TunnelList}"
                                          SelectedItem="{Binding SelectedTunnel}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Margin="0"
                                          Style="{DynamicResource ThemedDataGridStyle}"
                                          ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                                          CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                                          RowStyle="{DynamicResource ThemedDataGridRowStyle}"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeight="24"
                                          FontSize="{StaticResource FontSizeCaption}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="Mw_TpCtxClose"
                                                      Command="{Binding CloseTunnelCommand}"
                                                      CommandParameter="{Binding SelectedTunnel}"/>
                                            <MenuItem x:Name="Mw_TpCtxCopyPort"
                                                      Command="{Binding CopyTunnelPortCommand}"
                                                      CommandParameter="{Binding SelectedTunnel}"/>
                                            <Separator/>
                                            <MenuItem x:Name="Mw_TpCtxCloseAll"
                                                      Command="{Binding CloseAllTunnelsCommand}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="24">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="7" Height="7"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                                        <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn x:Name="Mw_TpColGateway" Header="" Binding="{Binding ServerName}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColLocal" Header="" Binding="{Binding LocalPort}" Width="60"/>
                                        <DataGridTextColumn x:Name="Mw_TpColRemote" Header="" Binding="{Binding RemoteHost}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColPort" Header="" Binding="{Binding RemotePort}" Width="50"/>
                                        <DataGridTemplateColumn Header="" Width="28">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="&#xE711;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="{StaticResource FontSizeCaption}"
                                                            Command="{Binding DataContext.CloseTunnelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                            Padding="2" Margin="0"
                                                            ToolTip="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            AutomationProperties.Name="Close tunnel"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state -->
                                <TextBlock x:Name="Mw_TunnelPanelEmpty" Text=""
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TUNNELS TAB: Visual tunnel editor + Gateway management        -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsTunnelsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Active Tunnels -->
                <DockPanel Grid.Row="0">
                    <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                        <TextBlock x:Name="Mw_TunnelsTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Mw_TunnelsCloseSelectedBtn" Content=""
                                    Command="{Binding CloseTunnelCommand}"
                                    CommandParameter="{Binding SelectedTunnel}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                            <Button x:Name="Mw_TunnelsCloseAllBtn" Content=""
                                    Command="{Binding CloseAllTunnelsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Foreground="{DynamicResource ErrorTextBrush}"
                                    Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid>
                        <!-- Tunnel DataGrid -->
                        <DataGrid ItemsSource="{Binding TunnelList}"
                                  SelectedItem="{Binding SelectedTunnel}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  Margin="16,0,16,8"
                                  Style="{DynamicResource ThemedDataGridStyle}"
                                  ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                                  RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="28">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="8" Height="8"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                                <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="Mw_TunnelsColGateway" Header="" Binding="{Binding ServerName}" Width="*"/>
                                <DataGridTextColumn x:Name="Mw_TunnelsColLocalPort" Header="" Binding="{Binding LocalPort}" Width="90"/>
                                <DataGridTextColumn x:Name="Mw_TunnelsColRemoteHost" Header="" Binding="{Binding RemoteHost}" Width="*"/>
                                <DataGridTextColumn x:Name="Mw_TunnelsColRemotePort" Header="" Binding="{Binding RemotePort}" Width="90"/>
                                <DataGridTextColumn x:Name="Mw_TunnelsColStarted" Header="" Binding="{Binding StartedAt, StringFormat=HH:mm:ss}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->
                        <TextBlock x:Name="Mw_TunnelsEmpty" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </DockPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="16,4"/>

                <!-- SSH Gateways -->
                <DockPanel Grid.Row="2" MinHeight="180" MaxHeight="300">
                    <DockPanel DockPanel.Dock="Top" Margin="16,4,16,8">
                        <TextBlock x:Name="Mw_GatewaysTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Mw_GatewaysAddBtn" Content="" Command="{Binding Settings.AddGatewayCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                            <Button x:Name="Mw_GatewaysEditBtn" Content="" Command="{Binding Settings.EditGatewayCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                            <Button x:Name="Mw_GatewaysDeleteBtn" Content="" Command="{Binding Settings.DeleteGatewayCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding Settings.Gateways}"
                              SelectedItem="{Binding Settings.SelectedGateway}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="16,0,16,12"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="Mw_GatewaysColName" Header="" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_GatewaysColHost" Header="" Binding="{Binding Host}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_GatewaysColPort" Header="" Binding="{Binding Port}" Width="60"/>
                            <DataGridTextColumn x:Name="Mw_GatewaysColUser" Header="" Binding="{Binding User}" Width="120"/>
                            <DataGridTemplateColumn x:Name="Mw_GatewaysColAuth" Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource SshBadgeBrush}"
                                                       Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource WarningTextBrush}"
                                                       Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

            <!-- ============================================================ -->
            <!-- SCHEDULED TAB: Scheduled connection management               -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsScheduledTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Header bar -->
                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                    <TextBlock x:Name="Mw_ScheduledTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Mw_ScheduledAddBtn" Content=""
                                Command="{Binding AddScheduledTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                        <Button x:Name="Mw_ScheduledDeleteBtn" Content=""
                                Command="{Binding DeleteScheduledTaskCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                </DockPanel>

                <Grid>
                    <!-- Scheduled tasks DataGrid -->
                    <DataGrid ItemsSource="{Binding ScheduledTasks}"
                              SelectedItem="{Binding SelectedScheduledTask}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              Margin="16,0,16,8"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn x:Name="Mw_ScheduledColEnabled" Header="" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColServer" Header="" Binding="{Binding ServerName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColType" Header="" Binding="{Binding ConnectionType}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColSchedule" Header="" Binding="{Binding Schedule}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColLastRun" Header="" Binding="{Binding LastRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColNextRun" Header="" Binding="{Binding NextRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasNoScheduledTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock x:Name="Mw_ScheduledEmpty" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Button x:Name="Mw_ScheduledCreateBtn" Content=""
                                Command="{Binding AddScheduledTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="12,6" FontSize="{StaticResource FontSizeBody}"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- SETTINGS TAB: Left-navigation sub-tabs                        -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsSettingsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Action buttons pinned at bottom -->
                <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="24,8,24,16">
                    <Button x:Name="Mw_SettingsSaveBtn" Content="" Command="{Binding Settings.SaveCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" MinWidth="130" Margin="0,0,16,4"/>
                    <Button x:Name="Mw_SettingsResetBtn" Content="" Command="{Binding Settings.ResetToDefaultsCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Width="130" Margin="0,0,8,4"/>
                    <Button x:Name="Mw_SettingsExportBtn" Content="" Command="{Binding Settings.ExportConfigCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Width="130" Margin="0,0,8,4"/>
                    <Button x:Name="Mw_SettingsImportBtn" Content="" Command="{Binding Settings.ImportConfigCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Width="130" Margin="0,0,8,4"/>
                    <Button x:Name="Mw_SettingsCitrixBtn" Content="" Command="{Binding Settings.ImportCitrixAppsCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Width="160" Margin="0,0,8,4"/>
                </WrapPanel>

                <TabControl TabStripPlacement="Top" Margin="16,8,16,0"
                            Background="Transparent" BorderThickness="0">

                    <!-- ═══════ GENERAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabGeneral" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsAppearanceTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsLanguageLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultLocale}" SelectedValuePath="Content">
                                                    <ComboBoxItem Content="en"/>
                                                    <ComboBoxItem Content="fr"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsThemeLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultTheme}" SelectedValuePath="Tag">
                                                    <ComboBoxItem x:Name="Mw_ThemeDark" Content="Dark" Tag="Dark"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeLight" Content="Light" Tag="Light"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsMaxSessionsLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.MaxEmbeddedSessions}" Width="100" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsPreventSleep" Content="" IsChecked="{Binding Settings.PreventSleepDuringSession}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsEditorPathLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.ExternalEditorPath}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ TERMINAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabTerminal" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsTerminalTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.TerminalFontFamily}" Width="200" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontSizeLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.TerminalFontSize}" Width="80" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsTerminalColorSchemeLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.TerminalColorScheme}" SelectedValuePath="Content" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem Content="Default"/>
                                                <ComboBoxItem Content="Dracula"/>
                                                <ComboBoxItem Content="Solarized Dark"/>
                                                <ComboBoxItem Content="Monokai"/>
                                                <ComboBoxItem Content="Nord"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsPsPolicyLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.PowerShellExecutionPolicy}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem Content="Default" Tag="Default"/>
                                                <ComboBoxItem Content="Bypass" Tag="Bypass"/>
                                                <ComboBoxItem Content="RemoteSigned" Tag="RemoteSigned"/>
                                                <ComboBoxItem Content="Unrestricted" Tag="Unrestricted"/>
                                                <ComboBoxItem Content="AllSigned" Tag="AllSigned"/>
                                            </ComboBox>
                                            <TextBlock x:Name="Mw_SettingsPsPolicyHint" Text="" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ SSH & SFTP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabSsh" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsSshTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="Mw_SettingsPlinkPathLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Settings.PlinkPath}"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsSshModeLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.SshDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_SshModeEmbedded" Content="Embedded" Tag="Embedded"/>
                                                <ComboBoxItem x:Name="Mw_SshModeExternal" Content="External" Tag="External"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsAntiIdleLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.AntiIdleInterval}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsSshTmoutLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.SshTmoutResetInterval}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                        <CheckBox x:Name="Mw_SettingsAutoOpenSftp" Content="" IsChecked="{Binding Settings.SftpAutoOpenOnSsh}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsX11PathLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.X11ServerPath}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsX11AutoStart" Content="" IsChecked="{Binding Settings.X11AutoStart}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- SSH Gateways -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="Mw_SettingsGatewaysTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="Mw_SettingsGatewaysAddBtn" Content="" Command="{Binding Settings.AddGatewayCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                                                <Button x:Name="Mw_SettingsGatewaysEditBtn" Content="" Command="{Binding Settings.EditGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                                                <Button x:Name="Mw_SettingsGatewaysDeleteBtn" Content="" Command="{Binding Settings.DeleteGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding Settings.Gateways}" SelectedItem="{Binding Settings.SelectedGateway}" MinHeight="80" MaxHeight="200" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding User, Mode=OneWay}"/><Run Text="@"/><Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text=" &#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource SshBadgeBrush}" VerticalAlignment="Center" Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ RDP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabRdp" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpDefaultsTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock x:Name="Mw_SettingsRdpModeLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.RdpDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_RdpModeEmbedded" Content="Embedded" Tag="Embedded"/>
                                                <ComboBoxItem x:Name="Mw_RdpModeExternal" Content="External" Tag="External"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsRdpWidthLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.DefaultResolutionWidth}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsRdpHeightLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.DefaultResolutionHeight}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock x:Name="Mw_SettingsRdpColorDepthLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.RdpDefaultColorDepth}" SelectedValuePath="Tag" Width="120" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_ColorDepth16" Content="16 bit" Tag="16"/>
                                                <ComboBoxItem x:Name="Mw_ColorDepth24" Content="24 bit" Tag="24"/>
                                                <ComboBoxItem x:Name="Mw_ColorDepth32" Content="32 bit" Tag="32"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock x:Name="Mw_SettingsRdpAudioLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.RdpDefaultAudioMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioDisabled" Content="" Tag="0"/>
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioLocal" Content="" Tag="1"/>
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioRemote" Content="" Tag="2"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsRdpNla" Content="" IsChecked="{Binding Settings.RdpDefaultNla}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpDynRes" Content="" IsChecked="{Binding Settings.RdpDefaultDynamicResolution}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpMultiMon" Content="" IsChecked="{Binding Settings.RdpDefaultMultiMonitor}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpAutoReconnect" Content="" IsChecked="{Binding Settings.RdpDefaultAutoReconnect}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpBitmapCache" Content="" IsChecked="{Binding Settings.RdpDefaultBitmapCaching}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpCompression" Content="" IsChecked="{Binding Settings.RdpDefaultCompression}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <TextBlock x:Name="Mw_SettingsRdpRedirTitle" Text="" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,8"/>
                                        <CheckBox x:Name="Mw_SettingsRdpClipboard" Content="" IsChecked="{Binding Settings.RdpDefaultRedirectClipboard}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpDrives" Content="" IsChecked="{Binding Settings.RdpDefaultRedirectDrives}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsRdpPrinters" Content="" IsChecked="{Binding Settings.RdpDefaultRedirectPrinters}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ SECURITY ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabSecurity" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsCredProviderTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsCredProviderEnabled" Content="" IsChecked="{Binding Settings.UseExternalCredentialProvider}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}">
                                            <TextBlock x:Name="Mw_SettingsCredProviderCmdLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.CredentialProviderCommand}" Tag="keepassxc-cli show -s -a Password &quot;{Database}&quot; &quot;{Title}&quot;"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}">
                                            <TextBlock x:Name="Mw_SettingsCredProviderDbLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.CredentialProviderDatabase}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsCredGuard" Content="" IsChecked="{Binding Settings.RequireCredentialGuard}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ ADVANCED ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabAdvanced" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="600">
                                <!-- Logging -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsSessionLoggingTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsEnableLogging" Content="" IsChecked="{Binding Settings.EnableLogging}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <CheckBox x:Name="Mw_SettingsSessionLoggingEnabled" Content="" IsChecked="{Binding Settings.SessionLoggingEnabled}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.SessionLoggingEnabled}">
                                            <TextBlock x:Name="Mw_SettingsSessionLogDirLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.SessionLogDirectory}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Timeouts -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsTimeoutsTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsTunnelDelayLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.TunnelEstablishmentDelayMs}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsRdpTimeoutLabel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.EmbeddedRdpTimeoutMs}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- External Tools -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="Mw_SettingsExtToolsTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="Mw_SettingsExtToolsAddBtn" Content="" Command="{Binding Settings.AddExternalToolCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                                                <Button x:Name="Mw_SettingsExtToolsRemoveBtn" Content="" Command="{Binding Settings.RemoveExternalToolCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding Settings.ExternalTools}" SelectedItem="{Binding Settings.SelectedExternalTool}" MinHeight="60" MaxHeight="120" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding ExecutablePath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- Inline edit panel for selected tool -->
                                        <Border Margin="0,12,0,0" Padding="{StaticResource SpacingMd}" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusMd}"
                                                DataContext="{Binding Settings.SelectedExternalTool}"
                                                Visibility="{Binding DataContext.Settings.SelectedExternalTool, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock x:Name="Mw_ExtToolLblName" Grid.Row="0" Grid.Column="0" Text="" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" FontSize="{StaticResource FontSizeBody}"/>

                                                <TextBlock x:Name="Mw_ExtToolLblPath" Grid.Row="1" Grid.Column="0" Text="" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                                                    <Button x:Name="Mw_ExtToolBrowseBtn" DockPanel.Dock="Right" Content="..." Padding="6,2" Margin="4,0,0,0" Click="OnExtToolBrowseClick" Style="{DynamicResource SecondaryButtonStyle}" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="Browse for executable"/>
                                                    <TextBox Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}" FontSize="{StaticResource FontSizeBody}"/>
                                                </DockPanel>

                                                <TextBlock x:Name="Mw_ExtToolLblArgs" Grid.Row="2" Grid.Column="0" Text="" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"/>

                                                <TextBlock x:Name="Mw_ExtToolLblWorkDir" Grid.Row="3" Grid.Column="0" Text="" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" FontSize="{StaticResource FontSizeBody}"/>

                                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,6">
                                                    <CheckBox x:Name="Mw_ExtToolChkAdmin" Content="" IsChecked="{Binding RunAsAdministrator}" Margin="0,0,16,0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                    <CheckBox x:Name="Mw_ExtToolChkHidden" Content="" IsChecked="{Binding RunHidden}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="{}{Host}  {Port}  {User}  {ServerName}  {Protocol}  {Project}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas" Opacity="0.7" Margin="0,2,0,0"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- ABOUT TAB: Application info                                   -->
            <!-- ============================================================ -->
            <ScrollViewer Visibility="{Binding IsAboutTabSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="{StaticResource SpacingXl}" MaxWidth="500"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border Padding="28"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusXl}">
                        <StackPanel>
                            <!-- Logo + Title -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="&#xE7F4;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource IconSizeHero}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBlock x:Name="Mw_AboutAppName" Text=""
                                           FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="AboutVersionText"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="Mw_AboutTagline" Text=""
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                            <!-- Info grid -->
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="Mw_AboutAuthorLabel" Grid.Row="0" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Julien Bombled"
                                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutLicenseLabel" Grid.Row="1" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutLicenseValue" Grid.Row="1" Grid.Column="1" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutRuntimeLabel" Grid.Row="2" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="AboutRuntimeText"
                                           Grid.Row="2" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutPlatformLabel" Grid.Row="3" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="AboutPlatformText"
                                           Grid.Row="3" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,16"/>

                            <!-- Features -->
                            <TextBlock x:Name="Mw_AboutFeaturesTitle" Text="" FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock x:Name="Mw_AboutFeature1" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                                <TextBlock x:Name="Mw_AboutFeature2" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                                <TextBlock x:Name="Mw_AboutFeature3" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                                <TextBlock x:Name="Mw_AboutFeature4" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                                <TextBlock x:Name="Mw_AboutFeature5" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                                <TextBlock x:Name="Mw_AboutFeature6" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3"
                                           Text=""/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Sessions overlay removed — now inside Servers Grid Column 2 -->
        </Grid>

        <!-- FULLSCREEN EXIT ICON (small icon top-right, hidden by default) -->
        <Button x:Name="FullscreenBar"
                Grid.Row="0" Grid.RowSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,2,4,0"
                Width="24" Height="24"
                Content="⛶"
                FontSize="{StaticResource FontSizeSubtitle}"
                Click="OnExitFullscreenClick"
                Visibility="Collapsed"
                Panel.ZIndex="999"
                Opacity="0.6"
                Cursor="Hand"
                AutomationProperties.Name="Exit fullscreen">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="{StaticResource CornerRadiusSm}" Padding="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}"/>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- File sharing status -->
                    <TextBlock x:Name="Mw_SharingStatus"
                               FontSize="{StaticResource FontSizeCaption}" Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SuccessTextBrush}"
                               Visibility="Collapsed"/>
                    <!-- Tunnel panel toggle badge -->
                    <Button x:Name="Mw_StatusTunnelToggle" Command="{Binding ToggleTunnelPanelCommand}"
                            Padding="4,2" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            AutomationProperties.Name="Toggle tunnel panel">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding TunnelCount, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <!-- Broadcast mode toggle -->
                    <Button Command="{Binding ToggleBroadcastCommand}"
                            ToolTip="{Binding BroadcastToggleTooltip}"
                            Padding="4,2" FontSize="{StaticResource FontSizeSubtitle}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Toggle broadcast mode">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE704;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock x:Name="Mw_BroadcastLabel" Text="" FontWeight="SemiBold" FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarGhostButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBroadcastMode}" Value="True">
                                        <Setter Property="Background" Value="#33FF5555"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding ServerCount, Mode=OneWay}"/>
                        <Run x:Name="Mw_StatusBarServersLabel" Text=""/>
                        <Run Text="{Binding TunnelCount, Mode=OneWay}"/>
                        <Run x:Name="Mw_StatusBarTunnelsLabel" Text=""/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- Quick Connect Command Palette (Ctrl+K) -->
        <Grid x:Name="CommandPaletteOverlay"
              Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="{DynamicResource OverlayBackground}"
              Panel.ZIndex="9999"
              MouseDown="OnPaletteBackdropClick">
            <Border Width="550" VerticalAlignment="Top" Margin="0,80,0,0"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}"
                    MouseDown="OnPaletteBorderClick">
                <StackPanel>
                    <TextBox x:Name="PaletteInput"
                             Text="{Binding PaletteSearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{StaticResource FontSizeSubtitle}" Padding="14,10"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             KeyDown="OnPaletteKeyDown"/>
                    <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                    <ListBox x:Name="PaletteResultsList"
                             ItemsSource="{Binding PaletteResults}"
                             SelectedItem="{Binding SelectedPaletteItem}"
                             MaxHeight="350"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="OnPaletteItemDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="8,4">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Group}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Protocol icon -->
                                        <TextBlock x:Name="PaletteTypeIcon" Text="&#xE7F4;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{Binding ConnectionType, Converter={StaticResource TypeToColorConverter}}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <!-- Status dot -->
                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource ServerStatusToColorConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="ConnectionState"/>
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="{StaticResource FontSizeBodyLarge}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Endpoint hint -->
                                        <TextBlock Text="{Binding RemoteServer}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextDisabledBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <TextBlock x:Name="Mw_PaletteNoResults" Text=""
                               FontSize="{StaticResource FontSizeBody}" Padding="14,10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasNoPaletteResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock x:Name="Mw_PaletteHints" Text=""
                               FontSize="{StaticResource FontSizeCaption}" Padding="14,6"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
