                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ SSH & SFTP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabSsh" Header="{loc:Translate SettingsTabSshSftp}" Style="{StaticResource ThemedTabItemStyle}">
