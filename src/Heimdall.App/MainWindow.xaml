<Window x:Class="Heimdall.App.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        xmlns:views="clr-namespace:Heimdall.App.Views"
        xmlns:models="clr-namespace:Heimdall.Core.Models;assembly=Heimdall.Core"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <!-- Implicit DataTemplates for recursive split pane tree rendering -->
        <DataTemplate DataType="{x:Type models:SessionPaneModel}">
            <views:SessionPaneControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:SplitContainerModel}">
            <views:SplitContainerControl/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition x:Name="ToolbarRow" Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition x:Name="StatusBarRow" Height="36"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <!-- Left: App title + navigation tabs -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="Mw_AppTitle" Text="{loc:Translate AppName}"
                               FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <RadioButton x:Name="TabSessions"
                                 Content="{loc:Translate NavTabSessions}"
                                 GroupName="NavTabs"
                                 IsChecked="True"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate NavTabSessions}"/>
                    <RadioButton x:Name="TabTunnels"
                                 Content="{loc:Translate NavTabTunnels}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate NavTabTunnels}"/>
                    <RadioButton x:Name="TabScheduled"
                                 Content="{loc:Translate NavTabScheduled}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate NavTabScheduled}"/>
                    <RadioButton x:Name="TabTools"
                                 Content="{loc:Translate NavTabTools}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11yToolsTab}"/>
                    <RadioButton x:Name="TabSettings"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate NavTabSettings}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="Mw_TabSettingsText" Text="{loc:Translate NavTabSettings}"/>
                            <Ellipse x:Name="Mw_SettingsUnsavedDot"
                                     Width="8" Height="8"
                                     Fill="{DynamicResource WarningBrush}"
                                     Margin="6,0,0,0"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding Settings.IsDirty, Converter={StaticResource BoolToVisibilityConverter}}"
                                     ToolTip="{loc:Translate SettingsUnsavedChanges}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="TabAbout"
                                 Content="{loc:Translate NavTabAbout}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 AutomationProperties.Name="{loc:Translate NavTabAbout}"/>
                </StackPanel>

                <!-- Right: Search box + Share Folder -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Share Folder toggle -->
                    <Button x:Name="ShareFolderButton"
                            Click="OnShareFolderClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="6,4" FontSize="{StaticResource FontSizeBody}"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{loc:Translate A11yShareFolder}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center" Margin="0,0,4,0"
                                       AutomationProperties.Name=""/>
                            <TextBlock x:Name="Mw_ShareFolderLabel" Text="" FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Quick Connect shortcut button -->
                    <Button x:Name="QuickConnectButton"
                            Click="OnQuickConnectButtonClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,4" FontSize="{StaticResource FontSizeCaption}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="{loc:Translate QuickConnectShortcut}"
                            AutomationProperties.Name="{loc:Translate QuickConnectShortcut}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="0,0,6,0"
                                       AutomationProperties.Name=""/>
                            <TextBlock x:Name="Mw_QuickConnectLabel" Text="{loc:Translate QuickConnectShortcut}"
                                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Global busy indicator -->
        <ProgressBar Grid.Row="1"
                     VerticalAlignment="Top"
                     Panel.ZIndex="10"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- MAIN CONTENT -->
        <Grid x:Name="MainContentArea" Grid.Row="1"
              ClipToBounds="True">

            <!-- ============================================================ -->
            <!-- SERVERS TAB: TreeView left panel + detail/sessions right      -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsSessionsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <!-- Left: TreeView panel -->
                    <ColumnDefinition x:Name="SessionTreeColumn" Width="260" MinWidth="180" MaxWidth="500"/>
                    <!-- Splitter -->
                    <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                    <!-- Right: Detail / session content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: TreeView with filter (only on Servers tab) -->
                <Border x:Name="TreeViewPanel" Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        >
                    <DockPanel>
                        <!-- Sidebar tab selector: Servers / Tools + collapse sidebar button -->
                        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,0">
                            <Button x:Name="ToggleSidebarButton"
                                    DockPanel.Dock="Right"
                                    Content="&#xE89F;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Click="OnToggleSidebarClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                    Width="32" Height="32"
                                    Margin="4,0,0,0"
                                    ToolTip="{loc:Translate TooltipHideSidebar}"
                                    AutomationProperties.Name="{loc:Translate TooltipHideSidebar}"/>
                            <UniformGrid Columns="2">
                                <RadioButton x:Name="SidebarTabSessions"
                                             GroupName="SidebarTabs"
                                             IsChecked="{Binding Sidebar.IsToolsTabActive, Converter={StaticResource InvertBoolConverter}, Mode=OneWay, FallbackValue=True}"
                                             Content="{loc:Translate SidebarTabSessions}"
                                             Style="{DynamicResource SidebarTabStyle}"
                                             KeyboardNavigation.TabIndex="0"
                                             Checked="OnSidebarTabSessionsChecked"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabSessions}"/>
                                <RadioButton x:Name="SidebarTabTools"
                                             GroupName="SidebarTabs"
                                             IsChecked="{Binding Sidebar.IsToolsTabActive, Mode=OneWay}"
                                             Content="{loc:Translate SidebarTabTools}"
                                             Style="{DynamicResource SidebarTabStyle}"
                                             KeyboardNavigation.TabIndex="1"
                                             Checked="OnSidebarTabToolsChecked"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabTools}"/>
                            </UniformGrid>
                        </DockPanel>

                        <!-- Sidebar tab content: Sessions (TreeView) and Tools are mutually exclusive.
                             Placed in a Grid so they both consume the remaining vertical space; only
                             one is visible at a time via the RadioButton IsChecked state. -->
                        <Grid>
                            <!-- ============ SESSIONS TAB CONTENT ============ -->
                            <DockPanel x:Name="SidebarSessionsContent"
                                       Visibility="{Binding IsChecked, ElementName=SidebarTabSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- Filter + add/expand/collapse toolbar -->
                                <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
                                    <Button x:Name="CollapseAllButton"
                                            DockPanel.Dock="Right"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            Click="OnCollapseAllClick"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,6" FontSize="{StaticResource FontSizeCaption}"
                                            Width="32" Height="32"
                                            Margin="2,0,0,0"
                                            ToolTip="{loc:Translate TooltipCollapseAll}"
                                            AutomationProperties.Name="{loc:Translate TooltipCollapseAll}"/>
                                    <Button x:Name="ExpandAllButton"
                                            DockPanel.Dock="Right"
                                            Content="&#xE70E;"
                                            FontFamily="Segoe MDL2 Assets"
                                            Click="OnExpandAllClick"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,6" FontSize="{StaticResource FontSizeCaption}"
                                            Width="32" Height="32"
                                            Margin="2,0,0,0"
                                            ToolTip="{loc:Translate TooltipExpandAll}"
                                            AutomationProperties.Name="{loc:Translate TooltipExpandAll}"/>
                                    <Button x:Name="AddButton"
                                            DockPanel.Dock="Right"
                                            Click="OnAddButtonClick"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                            Width="32" Height="32"
                                            Margin="4,0,0,0"
                                            ToolTip="{loc:Translate TooltipAddMenu}"
                                            AutomationProperties.Name="{loc:Translate TooltipAddMenu}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                   AutomationProperties.Name=""/>
                                        <Button.ContextMenu>
                                            <ContextMenu x:Name="AddMenu"
                                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem x:Name="Mw_AddMenuSession" Header="{loc:Translate AddMenuSession}" Command="{Binding ServerList.AddServerCommand}"/>
                                                <MenuItem x:Name="Mw_AddMenuTool" Header="{loc:Translate AddMenuTool}" Click="OnAddToolMenuClick"/>
                                                <Separator/>
                                                <MenuItem x:Name="Mw_AddMenuGateway" Header="{loc:Translate AddMenuGateway}" Command="{Binding Settings.AddGatewayCommand}"/>
                                                <MenuItem x:Name="Mw_AddMenuFolder" Header="{loc:Translate AddMenuFolder}" Click="OnAddFolderFromMenu"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Grid>
                                        <TextBox x:Name="Mw_FilterBox" Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource SearchTextBoxStyle}"
                                                 Tag="{loc:Translate SearchPlaceholder}" Padding="10,6,28,6"
                                                 AutomationProperties.Name="{loc:Translate A11ySearchAndFilter}"/>
                                        <Button x:Name="Mw_FilterClearBtn"
                                                Content="&#xE711;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="{StaticResource FontSizeSmallCaption}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                Padding="4"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                MinHeight="0"
                                                Click="OnFilterClearClick"
                                                Visibility="Collapsed"
                                                AutomationProperties.Name="{loc:Translate A11yClearSearchFilter}"/>
                                    </Grid>
                                    <TextBlock x:Name="Mw_FilterResultCount"
                                               FontSize="{StaticResource FontSizeSmallCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"
                                               Margin="0,2,4,0"
                                               Visibility="Collapsed"/>
                                </DockPanel>

                                <!-- Hierarchical TreeView (fills remaining space) -->
                                <TreeView x:Name="SessionTreeView"
                                  ItemsSource="{Binding ServerList.GroupedServers}"
                                  Style="{DynamicResource ThemedTreeViewStyle}"
                                  Padding="0,4,0,0"
                                  AllowDrop="True"
                                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                                  MouseDoubleClick="OnTreeViewDoubleClick"
                                  PreviewMouseLeftButtonDown="OnTreeViewDragStart"
                                  PreviewMouseMove="OnTreeViewDragMove"
                                  DragOver="OnTreeViewDragOver"
                                  DragLeave="OnTreeViewDragLeave"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewMouseRightButtonDown"
                                  ContextMenuOpening="OnTreeViewContextMenuOpening"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <TreeView.Resources>
                                <!-- Folder node template (recursive — unlimited nesting) -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:FolderViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <Grid Margin="0,2,0,0" ToolTip="{Binding FullPath}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0"
                                              Data="{StaticResource Geo.Tree.Group}"
                                              Fill="{DynamicResource InfoBrush}"
                                              Width="14" Height="14"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Padding="6,2" CornerRadius="{StaticResource CornerRadiusMd}" Margin="6,0,0,0"
                                                Background="{DynamicResource CardBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ServerCount}" FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </HierarchicalDataTemplate>

                                <!-- Server leaf node template -->
                                <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                                ToolTip="{Binding DisplayName}">
                                        <!-- Protocol / tool vector icon (resolved by converters).
                                             The ThemeRevision trigger forces re-evaluation on runtime theme swap. -->
                                        <Path Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                              Style="{StaticResource GeoIconSmall}"
                                              VerticalAlignment="Center" Margin="0,0,4,0">
                                            <Path.Fill>
                                                <MultiBinding Converter="{StaticResource TypeToColorConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                </MultiBinding>
                                            </Path.Fill>
                                        </Path>
                                        <!-- Status dot -->
                                        <Ellipse Width="7" Height="7" Margin="2,0,8,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource ServerStatusToColorConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="ConnectionState"/>
                                                    <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <!-- Server name -->
                                        <TextBlock Text="{Binding DisplayName}" FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TreeView.Resources>

                            <!-- TreeViewItem container style: expand state bound to ViewModel -->
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem"
                                       BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="1,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </TreeView.ItemContainerStyle>

                                </TreeView>
                            </DockPanel>

                            <!-- ============ TOOLS TAB CONTENT ============ -->
                            <DockPanel x:Name="SidebarToolsContent"
                                       Visibility="{Binding IsChecked, ElementName=SidebarTabTools, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                                    <TextBox x:Name="Mw_SidebarToolsFilter"
                                             Style="{DynamicResource SearchTextBoxStyle}"
                                             Tag="{loc:Translate ToolsPanelFilterPlaceholder}"
                                             Padding="10,6,28,6"
                                             Text="{Binding Sidebar.FilterText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabTools}"/>
                                </Grid>
                                <TextBlock x:Name="Mw_SidebarToolsContextText"
                                           DockPanel.Dock="Top"
                                           Margin="10,2,10,4"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Sidebar.ContextLabel}"
                                           ToolTip="{Binding Sidebar.ContextTooltip}"/>
                                <TextBlock x:Name="Mw_SidebarToolsNoResults"
                                           DockPanel.Dock="Top"
                                           Margin="10,16,10,0"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           HorizontalAlignment="Center"
                                           Text="{Binding Sidebar.NoResultsText}"
                                           Visibility="{Binding Sidebar.HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TreeView x:Name="SidebarToolsTreeView"
                                          Style="{DynamicResource ThemedTreeViewStyle}"
                                          Padding="0,2,0,0"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          ItemsSource="{Binding Sidebar.ToolsCategories}"
                                          SelectedItemChanged="OnSidebarToolsSelectedItemChanged"
                                          MouseDoubleClick="OnSidebarToolsDoubleClick"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <TreeView.Resources>
                                        <!-- Category header: accent dot + name + count badge -->
                                        <HierarchicalDataTemplate DataType="{x:Type vm:SidebarToolCategoryViewModel}"
                                                                  ItemsSource="{Binding Tools}">
                                            <Grid Margin="0,2,4,2" ToolTip="{Binding CategoryName}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0"
                                                         Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0">
                                                    <Ellipse.Fill>
                                                        <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                                            <Binding Path="BrushKey"/>
                                                            <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                        </MultiBinding>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CategoryName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           AutomationProperties.Name="{Binding CategoryName}"/>
                                                <Border Grid.Column="2"
                                                        Background="{DynamicResource CardBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusMd}"
                                                        Padding="6,1" Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VisibleCount}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </HierarchicalDataTemplate>
                                        <!-- Tool leaf: icon + name (compact single-line) -->
                                        <DataTemplate DataType="{x:Type vm:SidebarToolItemViewModel}">
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,1"
                                                        Cursor="Hand"
                                                        ToolTip="{Binding Name}">
                                                <Path Width="14" Height="14"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Data="{Binding IconGeometryKey, Converter={StaticResource ResourceKeyToGeometryConverter}}">
                                                    <Path.Fill>
                                                        <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                                            <Binding Path="BrushKey"/>
                                                            <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                        </MultiBinding>
                                                    </Path.Fill>
                                                </Path>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           AutomationProperties.Name="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </TreeView.Resources>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem"
                                               BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <Setter Property="Visibility"
                                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Setter Property="Padding" Value="1,1"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- SPLITTER -->
                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource CardBrush}"
                              Cursor="SizeWE"
                              ShowsPreview="True">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                    <!-- Visual drag handle (three dots) -->
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Border Background="{TemplateBinding Background}">
                                <TextBlock Text="&#xE784;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           AutomationProperties.Name=""
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- Show sidebar button (visible only when sidebar is hidden) -->
                <Button x:Name="ShowSidebarButton"
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="&#xE76C;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnToggleSidebarClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="4,6" FontSize="{StaticResource FontSizeCaption}"
                        Margin="4,8,0,0"
                        Panel.ZIndex="10"
                        Visibility="Collapsed"
                        ToolTip="{loc:Translate TooltipShowSidebar}"
                        AutomationProperties.Name="{loc:Translate TooltipShowSidebar}"/>

                <!-- RIGHT PANEL: sessions + tunnel bottom panel -->
                <Grid x:Name="Mw_SessionsGrid" Grid.Column="2"
                      ClipToBounds="True"
                      Tag="{loc:Translate A11yOperationInProgress}">
                    <Grid.RowDefinitions>
                        <!-- Row 0: Sessions / server details -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: GridSplitter (visible when tunnel panel open) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Retractable tunnel panel -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- SESSIONS (visible when active) -->
                    <TabControl x:Name="SessionTabControl"
                                Grid.Row="0"
                                ItemsSource="{Binding Connection.ActiveSessions}"
                                SelectedItem="{Binding Connection.ActiveSession}"
                                Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{DynamicResource BackgroundBrush}"
                                BorderThickness="0"
                                ClipToBounds="True"
                                Style="{DynamicResource ThemedTabControlStyle}"
                                PreviewMouseRightButtonDown="OnSessionTabRightClick"
                                PreviewMouseLeftButtonDown="OnTabDragStart"
                                PreviewMouseMove="OnTabDragMove"
                                DragOver="OnTabDragOver"
                                Drop="OnTabDrop"
                                AllowDrop="True"
                                Tag="{loc:Translate A11yCloseSessionTab}"
                                AutomationProperties.Name="{loc:Translate NavTabSessions}"
                                ItemContainerStyle="{DynamicResource ThemedTabItemStyle}">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                <Border x:Name="TabHeaderBorder" Padding="10,6" Background="Transparent"
                                        ToolTip="{Binding HeaderToolTip}">
                                    <DockPanel LastChildFill="True">
                                        <!-- Close button always occupies layout space (Hidden, not Collapsed)
                                             so the tab width stays constant on hover. Only opacity toggles.
                                             IsHitTestVisible stays True; the Border's Background="Transparent"
                                             ensures IsMouseOver persists when hovering over child elements. -->
                                        <Button x:Name="TabCloseButton" DockPanel.Dock="Right"
                                                Width="20" Height="20" Margin="6,0,0,0" Padding="2"
                                                Focusable="False" Content="&#xE711;"
                                                FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSmallCaption}"
                                                Opacity="0.3" IsHitTestVisible="True"
                                                Command="{Binding DataContext.Connection.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                CommandParameter="{Binding}"
                                                AutomationProperties.Name="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                                  Style="{StaticResource GeoIconSmall}"
                                                  VerticalAlignment="Center" Margin="0,0,5,0">
                                                <Path.Fill>
                                                    <MultiBinding Converter="{StaticResource TypeToColorConverter}">
                                                        <Binding Path="ConnectionType"/>
                                                        <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                    </MultiBinding>
                                                </Path.Fill>
                                            </Path>
                                            <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding HeaderToolTip}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                            <TextBlock x:Name="BusyIndicator" Text="&#x25CF;" FontSize="8"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center" Margin="5,0,0,0"
                                                       Visibility="Collapsed"
                                                       AutomationProperties.Name="{Binding Tag, RelativeSource={RelativeSource AncestorType=Grid, AncestorLevel=2}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Resources>
                                                            <Storyboard x:Key="PulseAnimation">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.2" Duration="0:0:0.6"
                                                                                 AutoReverse="True" RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </Style.Resources>
                                                        <Style.Triggers>
                                                            <Trigger Property="Visibility" Value="Visible">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard Name="PulseStoryboard" Storyboard="{StaticResource PulseAnimation}"/>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Show close button at full opacity on hover or active tab -->
                                    <Trigger SourceName="TabHeaderBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                        <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter TargetName="BusyIndicator" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                <Grid>
                                    <ContentPresenter Content="{Binding RootContent}" ClipToBounds="True"/>
                                    <!-- Loading overlay (visible while HostControl is null during connection) -->
                                    <Border x:Name="SessionLoadingOverlay"
                                            Style="{StaticResource FadeInPanelStyle}"
                                            Background="{DynamicResource OverlayBackground}"
                                            Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ProgressBar IsIndeterminate="True"
                                                         Width="200" Height="3"
                                                         Margin="0,0,0,12"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TunnelRoute}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HostControl}" Value="{x:Null}">
                                        <Setter TargetName="SessionLoadingOverlay" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- Drop zone overlay for drag-to-split (shown during tab drag over content area) -->
                    <Border x:Name="ContentDropZone" Grid.Row="0"
                            Visibility="Collapsed"
                            Background="{DynamicResource DragDropOverlayBackground}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            Margin="0,32,0,0">
                        <TextBlock Text="{Binding DataContext.DropToMergeText, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='Drop to split'}"
                                   FontSize="{StaticResource FontSizeSubtitle}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"/>
                    </Border>

                    <!-- SERVER DETAILS (visible when no sessions) -->
                    <Grid Grid.Row="0"
                          Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <!-- Server detail panel (shown when a non-tool server is selected) -->
                        <Border x:Name="SessionDetailPanel"
                                Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{Binding ServerList.SelectedServer.DisplayName}"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource ConnectionTypeToBrushConverter}">
                                                <Binding Path="ServerList.SelectedServer.ConnectionType"/>
                                                <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                            </MultiBinding>
                                        </Border.Background>
                                        <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionType}"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <MultiBinding Converter="{StaticResource ConnectionStateToBrushConverter}">
                                                <Binding Path="ServerList.SelectedServer.ConnectionState"/>
                                                <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                            </MultiBinding>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionState}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock x:Name="Mw_DetailHostPort"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}">
                                    <Run Text="{Binding ServerList.SelectedServer.RemoteServer, Mode=OneWay}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding ServerList.SelectedServer.RemotePort, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Group, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailGroupLabel" Text="{loc:Translate DetailLabelGroup}"/>
                                    <Run Text="{Binding ServerList.SelectedServer.Group, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Environment, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailEnvLabel" Text="{loc:Translate DetailLabelEnvironment}"/>
                                    <Run Text="{Binding ServerList.SelectedServer.Environment, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Enriched metadata section -->
                                <Border Margin="0,12,0,0" Padding="12,8"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="{StaticResource CornerRadiusSm}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Project -->
                                        <TextBlock x:Name="Mw_DetailProjectLabel" Grid.Row="0" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelProject}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.ProjectName, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                                    Visibility="{Binding ServerList.SelectedServer.ProjectName, Converter={StaticResource NullToVisibilityConverter}}"
                                                    Margin="0,2,0,2">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                     Fill="{Binding ServerList.SelectedServer.ProjectColor, Converter={StaticResource StringToBrushConverter}, TargetNullValue=#A67AF7}"/>
                                            <TextBlock Text="{Binding ServerList.SelectedServer.ProjectName}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Username -->
                                        <TextBlock x:Name="Mw_DetailUsernameLabel" Grid.Row="1" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelUsername}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.Username}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.Username, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Gateway -->
                                        <TextBlock x:Name="Mw_DetailGatewayLabel" Grid.Row="2" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelGateway}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.GatewayName, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.GatewayName, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="{Binding ServerList.SelectedServer.GatewayName, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- Authentication -->
                                        <TextBlock x:Name="Mw_DetailAuthLabel" Grid.Row="3" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelAuth}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.AuthSummary, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.AuthSummary}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.AuthSummary, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Tags -->
                                        <TextBlock x:Name="Mw_DetailTagsLabel" Grid.Row="4" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelTags}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.Tags, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.Tags}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2" TextWrapping="Wrap"
                                                   Visibility="{Binding ServerList.SelectedServer.Tags, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Favorite -->
                                        <TextBlock x:Name="Mw_DetailFavoriteLabel" Grid.Row="5" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelFavorite}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1"
                                                   Text="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   AutomationProperties.Name="Favorite"/>
                                    </Grid>
                                </Border>

                                <Button x:Name="Mw_DetailConnectBtn" Content="{loc:Translate DetailBtnConnect}"
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="120" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"
                                        AutomationProperties.Name="{loc:Translate AccessDetailConnect}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="Mw_DetailEditBtn" Content="{loc:Translate BtnEdit}"
                                            Command="{Binding ServerList.EditServerCommand}"
                                            CommandParameter="{Binding ServerList.SelectedServer}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTip="{loc:Translate TooltipEdit}"
                                            AutomationProperties.Name="{loc:Translate BtnEdit}"
                                            Padding="12,6" Margin="0,0,8,0"/>
                                    <Button x:Name="Mw_DetailDeleteBtn" Content="{loc:Translate BtnDelete}"
                                            Command="{Binding ServerList.DeleteServerCommand}"
                                            CommandParameter="{Binding ServerList.SelectedServer}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource ErrorTextBrush}"
                                            ToolTip="{loc:Translate TooltipDelete}"
                                            AutomationProperties.Name="{loc:Translate BtnDelete}"
                                            Padding="12,6"/>
                                </StackPanel>
                                <!-- Subtle shortcut hints for detail panel actions -->
                                <TextBlock x:Name="Mw_DetailActionHints" Text="{loc:Translate DetailActionHints}"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Tool detail panel (shown when a TOOL:* entry is selected) -->
                        <Border x:Name="ToolDetailPanel"
                                Visibility="Collapsed"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock x:Name="Mw_ToolDetailName"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0"
                                            Background="{DynamicResource ToolBadgeBrush}">
                                        <TextBlock x:Name="Mw_ToolDetailCategory"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="Mw_ToolDetailDescription"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}" TextWrapping="Wrap"/>

                                <Button x:Name="Mw_ToolDetailOpenBtn" Content=""
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="140" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"
                                        AutomationProperties.Name="{loc:Translate AccessDetailOpen}"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state when nothing selected -->
                        <StackPanel Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="True">
                            <!-- Show empty state overlay when no servers exist -->
                            <StackPanel Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="&#xE774;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeHero}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Opacity="0.5"
                                           Margin="0,0,0,16"
                                           AutomationProperties.Name=""/>
                                <TextBlock x:Name="Mw_EmptyStateTitle" Text="{loc:Translate EmptyStateTitle}" FontSize="{StaticResource FontSizeHeadline}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Mw_EmptyStateSubtitle" Text="{loc:Translate EmptyStateSubtitle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,24"
                                           TextWrapping="Wrap" MaxWidth="400"
                                           TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="Mw_EmptyBtnAddSession" Content="{loc:Translate EmptyStateBtnAddSession}"
                                            Command="{Binding ServerList.AddServerCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyAddServer}"/>
                                    <Button x:Name="Mw_EmptyBtnImport" Content="{loc:Translate EmptyStateBtnImport}"
                                            Command="{Binding Settings.ImportConfigCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTip="{loc:Translate TooltipImport}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            Margin="12,0,0,0"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyImport}"/>
                                    <Button x:Name="Mw_EmptyBtnExploreTools" Content="{loc:Translate EmptyStateBtnExploreTools}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            Margin="12,0,0,0"
                                            Click="OnEmptyExploreToolsClick"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyExploreTools}"/>
                                </StackPanel>
                                <!-- Keyboard shortcut hints for discoverability -->
                                <TextBlock x:Name="Mw_EmptyStateShortcutHints" Text="{loc:Translate EmptyStateShortcutHints}"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           HorizontalAlignment="Center" Margin="0,16,0,0"
                                           TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Show hint when servers exist but none selected -->
                            <Border Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Style="{DynamicResource EmptyStateStyle}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="48"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Opacity="0.5"
                                               Margin="0,0,0,12"
                                               AutomationProperties.Name=""/>
                                    <TextBlock x:Name="Mw_EmptySelectSession" Text="{loc:Translate EmptyStateSelectSession}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="Mw_EmptyQuickConnectHint" Text="{loc:Translate HintQuickConnect}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- TUNNEL BOTTOM PANEL: GridSplitter + compact active tunnels -->
                    <GridSplitter Grid.Row="1"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBrush}"
                                  ShowsPreview="True"
                                  Visibility="{Binding Tunnels.IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Grid.Row="2"
                            MinHeight="120" MaxHeight="300"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding Tunnels.IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DockPanel>
                            <!-- Header: "Tunnels (N)" + collapse button -->
                            <Border DockPanel.Dock="Top"
                                    Padding="8,4"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button x:Name="Mw_TunnelPanelCollapseBtn" DockPanel.Dock="Right"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="{StaticResource FontSizeCaption}"
                                            Command="{Binding Tunnels.TogglePanelCommand}"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,2" Margin="4,0,0,0"
                                            ToolTip="{loc:Translate TooltipCollapseTunnelPanel}"
                                            AutomationProperties.Name="{loc:Translate A11yCollapseTunnelPanel}"/>
                                    <Button x:Name="Mw_TunnelPanelCloseAllBtn" DockPanel.Dock="Right"
                                            Content="{loc:Translate TunnelsBtnCloseAll}"
                                            Command="{Binding Tunnels.CloseAllCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource ErrorTextBrush}"
                                            Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"
                                            AutomationProperties.Name="{loc:Translate A11yCloseAllTunnels}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.Name=""/>
                                        <TextBlock FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run x:Name="Mw_TunnelPanelHeaderPrefix" Text=""/>
                                            <Run Text="{Binding Tunnels.Count, Mode=OneWay}"/>
                                            <Run x:Name="Mw_TunnelPanelHeaderSuffix" Text=""/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Content: compact tunnel DataGrid -->
                            <Grid>
                                <DataGrid x:Name="Mw_TunnelPanelGrid"
                                          Tag="{loc:Translate TooltipCloseTunnel}"
                                          ItemsSource="{Binding Tunnels.List}"
                                          SelectedItem="{Binding Tunnels.SelectedItem}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Margin="0"
                                          Style="{DynamicResource ThemedDataGridStyle}"
                                          ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                                          CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                                          RowStyle="{DynamicResource ThemedDataGridRowStyle}"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeight="24"
                                          FontSize="{StaticResource FontSizeCaption}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="Mw_TpCtxClose"
                                                      Header="{loc:Translate TunnelCtxClose}"
                                                      Command="{Binding Tunnels.CloseCommand}"
                                                      CommandParameter="{Binding Tunnels.SelectedItem}"/>
                                            <MenuItem x:Name="Mw_TpCtxCopyPort"
                                                      Header="{loc:Translate TunnelCtxCopyPort}"
                                                      Command="{Binding Tunnels.CopyPortCommand}"
                                                      CommandParameter="{Binding Tunnels.SelectedItem}"/>
                                            <Separator/>
                                            <MenuItem x:Name="Mw_TpCtxCloseAll"
                                                      Header="{loc:Translate TunnelCtxCloseAll}"
                                                      Command="{Binding Tunnels.CloseAllCommand}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="24">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="7" Height="7"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                                        <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn x:Name="Mw_TpColGateway" Header="{loc:Translate TunnelsColGateway}" Binding="{Binding ServerName}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColLocal" Header="{loc:Translate TunnelPanelColLocal}" Binding="{Binding LocalPort}" Width="60"/>
                                        <DataGridTextColumn x:Name="Mw_TpColRemote" Header="{loc:Translate TunnelPanelColRemote}" Binding="{Binding RemoteHost}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColPort" Header="{loc:Translate TunnelPanelColPort}" Binding="{Binding RemotePort}" Width="50"/>
                                        <DataGridTemplateColumn Header="" Width="28">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="&#xE711;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="{StaticResource FontSizeCaption}"
                                                            Command="{Binding DataContext.Tunnels.CloseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                            Padding="2" Margin="0"
                                                            ToolTip="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            AutomationProperties.Name="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state -->
                                <TextBlock x:Name="Mw_TunnelPanelEmpty" Text="{loc:Translate TunnelsEmptyState}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Tunnels.HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TUNNELS TAB: Active tunnel list                              -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsTunnelsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                    <TextBlock x:Name="Mw_TunnelsTitle" Text="{loc:Translate TunnelsSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Mw_TunnelsCloseSelectedBtn" Content="{loc:Translate TunnelsBtnCloseSelected}"
                                Command="{Binding Tunnels.CloseCommand}"
                                CommandParameter="{Binding Tunnels.SelectedItem}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessTunnelsCloseSelected}"/>
                        <Button x:Name="Mw_TunnelsCloseAllBtn" Content="{loc:Translate TunnelsBtnCloseAll}"
                                Command="{Binding Tunnels.CloseAllCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Foreground="{DynamicResource ErrorTextBrush}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}"
                                AutomationProperties.Name="{loc:Translate AccessTunnelsCloseAll}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Manage gateways link -->
                <Button x:Name="Mw_TunnelsManageGatewaysLink" DockPanel.Dock="Bottom"
                        Content="{loc:Translate TunnelsManageGatewaysLink}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{DynamicResource AccentBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,8"
                        Click="OnNavigateToGatewaySettings"
                        AutomationProperties.Name="{loc:Translate TunnelsManageGatewaysLink}"/>

                <Grid>
                    <!-- Tunnel DataGrid -->
                    <DataGrid ItemsSource="{Binding Tunnels.List}"
                              SelectedItem="{Binding Tunnels.SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="16,0,16,8"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="28">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="Mw_TunnelsColGateway" Header="{loc:Translate TunnelsColGateway}" Binding="{Binding ServerName}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColLocalPort" Header="{loc:Translate TunnelsColLocalPort}" Binding="{Binding LocalPort}" Width="90"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColRemoteHost" Header="{loc:Translate TunnelsColRemoteHost}" Binding="{Binding RemoteHost}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColRemotePort" Header="{loc:Translate TunnelsColRemotePort}" Binding="{Binding RemotePort}" Width="90"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColStarted" Header="{loc:Translate TunnelsColStarted}" Binding="{Binding StartedAt, StringFormat=HH:mm:ss}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <TextBlock x:Name="Mw_TunnelsEmpty" Text="{loc:Translate TunnelsEmptyState}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding Tunnels.HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- SCHEDULED TAB: Scheduled connection management               -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsScheduledTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Header bar -->
                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                    <TextBlock x:Name="Mw_ScheduledTitle" Text="{loc:Translate ScheduledSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Mw_ScheduledAddBtn" Content="{loc:Translate ScheduledBtnAdd}"
                                Command="{Binding Scheduled.AddTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessScheduledAdd}"/>
                        <Button x:Name="Mw_ScheduledEditBtn" Content="{loc:Translate ScheduledBtnEdit}"
                                Command="{Binding Scheduled.EditTaskCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessScheduledEdit}"/>
                        <Button x:Name="Mw_ScheduledDeleteBtn" Content="{loc:Translate ScheduledBtnDelete}"
                                Command="{Binding Scheduled.DeleteTaskCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}"
                                AutomationProperties.Name="{loc:Translate AccessScheduledDelete}"/>
                    </StackPanel>
                </DockPanel>

                <Grid>
                    <!-- Scheduled tasks DataGrid -->
                    <DataGrid ItemsSource="{Binding Scheduled.Tasks}"
                              SelectedItem="{Binding Scheduled.SelectedTask}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              Margin="16,0,16,8"
                              MouseDoubleClick="OnScheduledTaskDoubleClick"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn x:Name="Mw_ScheduledColEnabled" Header="{loc:Translate ScheduledColEnabled}" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColServer" Header="{loc:Translate ScheduledColServer}" Binding="{Binding ServerName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColType" Header="{loc:Translate ScheduledColType}" Binding="{Binding ConnectionType}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColSchedule" Header="{loc:Translate ScheduledColSchedule}" Binding="{Binding Schedule}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColLastRun" Header="{loc:Translate ScheduledColLastRun}" Binding="{Binding LastRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColNextRun" Header="{loc:Translate ScheduledColNextRun}" Binding="{Binding NextRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding Scheduled.HasNoTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock x:Name="Mw_ScheduledEmpty" Text="{loc:Translate ScheduledEmptyState}"
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Button x:Name="Mw_ScheduledCreateBtn" Content="{loc:Translate ScheduledEmptyAddButton}"
                                Command="{Binding Scheduled.AddTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="12,6" FontSize="{StaticResource FontSizeBody}"
                                HorizontalAlignment="Center"
                                AutomationProperties.Name="{loc:Translate AccessScheduledCreate}"/>
                    </StackPanel>
                </Grid>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- TOOLS TAB: Dedicated tool browser                             -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsToolsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: Title + search + tool count -->
                <Border Grid.Row="0" Padding="16,12,16,8"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock x:Name="Mw_ToolsTabTitle"
                                       Text="{Binding ToolsTab.HeaderTitle}"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"
                                       Margin="0,0,16,0"/>
                            <TextBlock x:Name="Mw_ToolsTabCount"
                                       Text="{Binding ToolsTab.CountLabel}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"/>
                            <TextBox x:Name="Mw_ToolsTabSearch"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     Tag="{Binding ToolsTab.SearchPlaceholder}"
                                     Text="{Binding ToolsTab.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{StaticResource FontSizeBody}"
                                     Padding="{StaticResource PaddingInput}"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     MaxWidth="400" HorizontalAlignment="Left"
                                     AutomationProperties.Name="{loc:Translate ToolsTabSearchPlaceholder}"/>
                        </DockPanel>
                        <TextBlock x:Name="Mw_ToolsTabContextText"
                                   Text="{Binding ToolsTab.ContextLabel}"
                                   ToolTip="{Binding ToolsTab.ContextTooltip}"
                                   Foreground="{Binding ToolsTab.ContextBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                   Margin="0,8,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Content: scrollable tool grid with sections -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,16">
                    <StackPanel x:Name="ToolsTabContent"/>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================ -->
            <!-- SETTINGS TAB: Left-navigation sub-tabs                        -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsSettingsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sticky action bar -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="{StaticResource SpacingMd}">
                    <DockPanel>
                        <!-- Settings search box (right-aligned) -->
                        <Grid DockPanel.Dock="Right" Width="220" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBox x:Name="Mw_SettingsSearchBox"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Tag="{loc:Translate SettingsSearchPlaceholder}" Padding="10,5,28,5"
                                     TextChanged="OnSettingsSearchTextChanged"
                                     AutomationProperties.Name="{loc:Translate A11ySettingsSearch}"/>
                            <Button x:Name="Mw_SettingsSearchClear"
                                    Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="{StaticResource FontSizeSmallCaption}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,4,0" Padding="4"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}" MinHeight="0"
                                    Click="OnSettingsSearchClearClick"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="{loc:Translate A11yClearSearchFilter}"/>
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="Mw_SettingsSaveBtn" Content="{loc:Translate SettingsBtnSaveSettings}" Command="{Binding Settings.SaveCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" MinWidth="130" Margin="0,0,16,4"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsSave}"/>
                            <Button x:Name="Mw_SettingsResetBtn" Content="{loc:Translate SettingsBtnResetDefaults}" Command="{Binding Settings.ResetToDefaultsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsReset}"/>
                            <Button x:Name="Mw_SettingsExportBtn" Content="{loc:Translate SettingsBtnExportServers}" Command="{Binding Settings.ExportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipExport}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsExport}"/>
                            <Button x:Name="Mw_SettingsImportBtn" Content="{loc:Translate SettingsBtnImportServers}" Command="{Binding Settings.ImportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipImport}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsImport}"/>
                            <Button x:Name="Mw_SettingsCitrixBtn" Content="{loc:Translate BtnImportCitrix}" Command="{Binding Settings.ImportCitrixAppsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="160" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipImportCitrix}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsCitrix}"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Settings search hint (shown when filtering) -->
                <Border x:Name="Mw_SettingsSearchHint" Grid.Row="1" Visibility="Collapsed"
                        Padding="16,4" Background="{DynamicResource SurfaceBrush}">
                    <TextBlock x:Name="Mw_SettingsSearchHintText"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <TabControl Grid.Row="2" x:Name="Mw_SettingsSubTabControl" TabStripPlacement="Top" Margin="16,8,16,0"
                            Background="Transparent" BorderThickness="0">

                    <!-- ═══════ GENERAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabGeneral" Header="{loc:Translate SettingsTabGeneral}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsAppearanceTitle" Text="{loc:Translate SettingsSectionAppearance}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsLanguageLabel" Text="{loc:Translate SettingsLabelLanguage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultLocale}" SelectedValuePath="Content">
                                                    <ComboBoxItem Content="en"/>
                                                    <ComboBoxItem Content="fr"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsThemeLabel" Text="{loc:Translate SettingsLabelTheme}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultTheme}" SelectedValuePath="Tag">
                                                    <ComboBoxItem x:Name="Mw_ThemeDraculaPro" Content="{loc:Translate ThemeDraculaPro}" Tag="DraculaPro" AutomationProperties.Name="{loc:Translate ThemeDraculaPro}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeAlucard" Content="{loc:Translate ThemeAlucard}" Tag="Alucard" AutomationProperties.Name="{loc:Translate ThemeAlucard}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeBlade" Content="{loc:Translate ThemeBlade}" Tag="Blade" AutomationProperties.Name="{loc:Translate ThemeBlade}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeBuffy" Content="{loc:Translate ThemeBuffy}" Tag="Buffy" AutomationProperties.Name="{loc:Translate ThemeBuffy}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeLincoln" Content="{loc:Translate ThemeLincoln}" Tag="Lincoln" AutomationProperties.Name="{loc:Translate ThemeLincoln}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeMorbius" Content="{loc:Translate ThemeMorbius}" Tag="Morbius" AutomationProperties.Name="{loc:Translate ThemeMorbius}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeVanHelsing" Content="{loc:Translate ThemeVanHelsing}" Tag="VanHelsing" AutomationProperties.Name="{loc:Translate ThemeVanHelsing}"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsMaxSessionsLabel" Text="{loc:Translate SettingsLabelMaxEmbeddedSessions}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.MaxEmbeddedSessions}" Width="100" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsPreventSleep" Content="{loc:Translate SettingsLabelPreventSleep}" IsChecked="{Binding Settings.PreventSleepDuringSession}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsEnableSessionPersistence" Content="{loc:Translate SettingsWorkspaceRestore}" IsChecked="{Binding Settings.EnableSessionPersistence}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" AutomationProperties.Name="{loc:Translate SettingsWorkspaceRestore}"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsEditorPathLabel" Text="{loc:Translate SettingsLabelEditorPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="Mw_SettingsBrowseEditorPath" DockPanel.Dock="Right"
                                                        Padding="6,2" Margin="4,0,0,0" Click="OnBrowseEditorPathClick"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        AutomationProperties.Name="{loc:Translate A11yBrowseEditorPath}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBox Text="{Binding Settings.ExternalEditorPath}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ TERMINAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabTerminal" Header="{loc:Translate SettingsTabTerminal}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsTerminalTitle" Text="{loc:Translate SettingsSectionTerminal}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontLabel" Text="{loc:Translate SettingsLabelTerminalFont}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.TerminalFontFamily}" Width="200" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontSizeLabel" Text="{loc:Translate SettingsLabelTerminalFontSize}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.TerminalFontSize}" Width="80"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsTerminalColorSchemeLabel" Text="{loc:Translate SettingsLabelTerminalColorScheme}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="Mw_ColorSchemeCombo" SelectedValue="{Binding Settings.TerminalColorScheme}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_SchemeDefault" Content="{loc:Translate TerminalSchemeDefault}" Tag="Default"/>
                                                <ComboBoxItem x:Name="Mw_SchemeDracula" Content="{loc:Translate TerminalSchemeDracula}" Tag="Dracula"/>
                                                <ComboBoxItem x:Name="Mw_SchemeSolarized" Content="{loc:Translate TerminalSchemeSolarizedDark}" Tag="Solarized Dark"/>
                                                <ComboBoxItem x:Name="Mw_SchemeMonokai" Content="{loc:Translate TerminalSchemeMonokai}" Tag="Monokai"/>
                                                <ComboBoxItem x:Name="Mw_SchemeNord" Content="{loc:Translate TerminalSchemeNord}" Tag="Nord"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsPsPolicyLabel" Text="{loc:Translate SettingsPsExecutionPolicy}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.PowerShellExecutionPolicy}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_PsDefault" Content="{loc:Translate PsPolicyDefault}" Tag="Default"/>
                                                <ComboBoxItem x:Name="Mw_PsBypass" Content="{loc:Translate PsPolicyBypass}" Tag="Bypass"/>
                                                <ComboBoxItem x:Name="Mw_PsRemoteSigned" Content="{loc:Translate PsPolicyRemoteSigned}" Tag="RemoteSigned"/>
                                                <ComboBoxItem x:Name="Mw_PsUnrestricted" Content="{loc:Translate PsPolicyUnrestricted}" Tag="Unrestricted"/>
                                                <ComboBoxItem x:Name="Mw_PsAllSigned" Content="{loc:Translate PsPolicyAllSigned}" Tag="AllSigned"/>
                                            </ComboBox>
