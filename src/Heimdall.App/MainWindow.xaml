                                            </Button>
                                            <TextBox Text="{Binding Settings.PlinkPath}" TabIndex="1" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsPlinkPathLabel}"/>
                                        </DockPanel>
                                        <TextBlock x:Name="Mw_SettingsPlinkPathHint" Text="{loc:Translate SettingsPlinkPathHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="Mw_SettingsPuttyPathLabel" Text="{loc:Translate SettingsLabelPuttyPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,12,0,4"/>
                                        <DockPanel>
                                            <Button x:Name="Mw_SettingsBrowsePuttyPath" DockPanel.Dock="Right"
                                                    Padding="6,2" Margin="4,0,0,0" Click="OnBrowsePuttyPathClick"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    AutomationProperties.Name="{loc:Translate A11yBrowsePuttyPath}"
                                                    TabIndex="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBox Text="{Binding Settings.PuttyPath}" TabIndex="3" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsPuttyPathLabel}"/>
                                        </DockPanel>
                                        <TextBlock x:Name="Mw_SettingsPuttyPathHint" Text="{loc:Translate SettingsPuttyPathHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsSshModeLabel" Text="{loc:Translate SettingsLabelSshMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ComboBox SelectedValue="{Binding Settings.SshDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshModeLabel}">
                                                    <ComboBoxItem x:Name="Mw_SshModeEmbedded" Content="{loc:Translate SettingsSshModeEmbedded}" Tag="Embedded" AutomationProperties.Name="{loc:Translate SettingsSshModeEmbedded}"/>
                                                    <ComboBoxItem x:Name="Mw_SshModeExternal" Content="{loc:Translate SettingsSshModeExternal}" Tag="External" AutomationProperties.Name="{loc:Translate SettingsSshModeExternal}"/>
                                                </ComboBox>
                                                <Button x:Name="Mw_ApplySshModeAll"
                                                        Content="{loc:Translate SettingsApplyModeToAll}"
                                                        Command="{Binding Settings.ApplySshModeToAllCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,2" FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{loc:Translate TooltipApplyModeToAll}"
                                                        AutomationProperties.Name="{loc:Translate SettingsApplyModeToAll}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="Mw_SettingsSshModeHint" Text="{loc:Translate SettingsSshModeHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsAntiIdleLabel" Text="{loc:Translate SettingsLabelAntiIdleInterval}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.AntiIdleInterval}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsAntiIdleLabel}"/>
                                                    <TextBlock Text="s" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsSshTmoutLabel" Text="{loc:Translate SettingsLabelSshTmoutReset}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.SshTmoutResetInterval}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshTmoutLabel}"/>
                                                    <TextBlock Text="s" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <CheckBox x:Name="Mw_SettingsAutoOpenSftp" Content="{loc:Translate SettingsLabelAutoOpenSftp}" IsChecked="{Binding Settings.SftpAutoOpenOnSsh}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsX11PathLabel" Text="{loc:Translate SettingsLabelX11ServerPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="Mw_SettingsBrowseX11Path" DockPanel.Dock="Right"
                                                        Padding="6,2" Margin="4,0,0,0" Click="OnBrowseX11PathClick"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        AutomationProperties.Name="{loc:Translate A11yBrowseX11Path}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBox Text="{Binding Settings.X11ServerPath}" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsX11PathLabel}"/>
                                            </DockPanel>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsX11AutoStart" Content="{loc:Translate SettingsLabelX11AutoStart}" IsChecked="{Binding Settings.X11AutoStart}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- SSH Gateways -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="Mw_SettingsGatewaysTitle" Text="{loc:Translate GatewaysSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="Mw_SettingsGatewaysAddBtn" Content="{loc:Translate GatewaysBtnAdd}" Command="{Binding Settings.AddGatewayCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0" AutomationProperties.Name="{loc:Translate GatewaysBtnAdd}"/>
                                                <Button x:Name="Mw_SettingsGatewaysEditBtn" Content="{loc:Translate GatewaysBtnEdit}" Command="{Binding Settings.EditGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0" AutomationProperties.Name="{loc:Translate GatewaysBtnEdit}"/>
                                                <Button x:Name="Mw_SettingsGatewaysDeleteBtn" Content="{loc:Translate GatewaysBtnDelete}" Command="{Binding Settings.DeleteGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="{loc:Translate GatewaysBtnDelete}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding Settings.Gateways}" SelectedItem="{Binding Settings.SelectedGateway}" MinHeight="80" MaxHeight="200" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding User, Mode=OneWay}"/><Run Text="@"/><Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text=" &#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource SshBadgeBrush}" VerticalAlignment="Center" Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}" AutomationProperties.Name=""/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ RDP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabRdp" Header="{loc:Translate SettingsTabRdp}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpDefaultsTitle" Text="{loc:Translate SettingsSectionRdpDefaults}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock x:Name="Mw_SettingsRdpModeLabel" Text="{loc:Translate SettingsLabelRdpMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ComboBox SelectedValue="{Binding Settings.RdpDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpModeLabel}">
                                                    <ComboBoxItem x:Name="Mw_RdpModeEmbedded" Content="{loc:Translate SettingsRdpModeEmbedded}" Tag="Embedded" AutomationProperties.Name="{loc:Translate SettingsRdpModeEmbedded}"/>
                                                    <ComboBoxItem x:Name="Mw_RdpModeExternal" Content="{loc:Translate SettingsRdpModeExternal}" Tag="External" AutomationProperties.Name="{loc:Translate SettingsRdpModeExternal}"/>
                                                </ComboBox>
                                                <Button x:Name="Mw_ApplyRdpModeAll"
                                                        Content="{loc:Translate SettingsApplyModeToAll}"
