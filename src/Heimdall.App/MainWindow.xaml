<Window x:Class="Heimdall.App.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        xmlns:views="clr-namespace:Heimdall.App.Views"
        xmlns:models="clr-namespace:Heimdall.Core.Models;assembly=Heimdall.Core"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:theming="clr-namespace:Heimdall.App.Theming"
        xmlns:tunnels="clr-namespace:Heimdall.App.ViewModels.Tunnels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource BackgroundBrush}"
        AllowDrop="True"
        PreviewDragOver="OnWindowPreviewDragOver"
        PreviewDragLeave="OnWindowPreviewDragLeave"
        PreviewDrop="OnWindowPreviewDrop">

    <Window.Resources>
        <!-- Implicit DataTemplates for recursive split pane tree rendering -->
        <DataTemplate DataType="{x:Type models:SessionPaneModel}">
            <views:SessionPaneControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:SplitContainerModel}">
            <views:SplitContainerControl/>
        </DataTemplate>
        <DataTemplate x:Key="SessionTabContentTemplate">
            <Grid>
                <ContentPresenter Content="{Binding RootContent}" ClipToBounds="True"/>
                <!-- Loading overlay (visible while HostControl is null during connection) -->
                <Border x:Name="SessionLoadingOverlay"
                        Style="{StaticResource FadeInPanelStyle}"
                        Background="{DynamicResource OverlayBackground}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200" Height="3"
                                     Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Status}"
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TunnelRoute}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HostControl}" Value="{x:Null}"/>
                        <Condition Binding="{Binding HasFailureDetails}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SessionLoadingOverlay" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition x:Name="ToolbarRow" Height="Auto"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition x:Name="StatusBarRow" Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <!-- Left: App title + navigation tabs -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="Mw_AppTitle" Text="{loc:Translate AppName}"
                               FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <RadioButton x:Name="TabSessions"
                                 Content="{loc:Translate NavTabSessions}"
                                 GroupName="NavTabs"
                                 IsChecked="True"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11ySessionsTab}"/>
                    <RadioButton x:Name="TabTunnels"
                                 Content="{loc:Translate NavTabTunnels}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11yTunnelsTab}"/>
                    <RadioButton x:Name="TabScheduled"
                                 Content="{loc:Translate NavTabScheduled}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11yScheduledTab}"/>
                    <RadioButton x:Name="TabTools"
                                 Content="{loc:Translate NavTabTools}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11yToolsTab}"/>
                    <RadioButton x:Name="TabSettings"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"
                                 AutomationProperties.Name="{loc:Translate A11ySettingsTab}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="Mw_TabSettingsText" Text="{loc:Translate NavTabSettings}"/>
                            <Ellipse x:Name="Mw_SettingsUnsavedDot"
                                     Width="8" Height="8"
                                     Fill="{DynamicResource WarningBrush}"
                                     Margin="6,0,0,0"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding Settings.IsDirty, Converter={StaticResource BoolToVisibilityConverter}}"
                                     ToolTip="{loc:Translate SettingsUnsavedChanges}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="TabAbout"
                                 Content="{loc:Translate NavTabAbout}"
                                 GroupName="NavTabs"
                                 Focusable="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 AutomationProperties.Name="{loc:Translate A11yAboutTab}"/>
                </StackPanel>

                <!-- Right: compact shortcuts -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Share Folder toggle -->
                    <Button x:Name="ShareFolderButton"
                            Click="OnShareFolderClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="6"
                            Width="32" Height="32"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center">
                        <AutomationProperties.Name>
                            <MultiBinding Converter="{StaticResource ShareFolderLabelConverter}">
                                <Binding Path="FileShareService.IsSharing"
                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Source="{x:Static loc:LocalizationSource.Instance}"
                                         Path="[ToolsShareFolder]"/>
                                <Binding Source="{x:Static loc:LocalizationSource.Instance}"
                                         Path="[ToolsStopSharing]"/>
                            </MultiBinding>
                        </AutomationProperties.Name>
                        <Button.ToolTip>
                            <MultiBinding Converter="{StaticResource ShareFolderLabelConverter}">
                                <Binding Path="FileShareService.IsSharing"
                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Source="{x:Static loc:LocalizationSource.Instance}"
                                         Path="[ToolsShareFolder]"/>
                                <Binding Source="{x:Static loc:LocalizationSource.Instance}"
                                         Path="[ToolsStopSharing]"/>
                            </MultiBinding>
                        </Button.ToolTip>
                        <TextBlock Text="&#xE72D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                    <!-- Quick Connect shortcut button -->
                    <Button x:Name="QuickConnectButton"
                            Click="OnQuickConnectButtonClick"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="6"
                            Width="32" Height="32"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="{loc:Translate QuickConnectShortcut}"
                            AutomationProperties.Name="{loc:Translate QuickConnectShortcut}">
                        <TextBlock Text="&#xE71E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource FontSizeBody}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Global busy indicator -->
        <ProgressBar Grid.Row="1"
                     VerticalAlignment="Top"
                     Panel.ZIndex="10"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- MAIN CONTENT -->
        <Grid x:Name="MainContentArea" Grid.Row="1"
              ClipToBounds="True">

            <!-- ============================================================ -->
            <!-- SERVERS TAB: TreeView left panel + detail/sessions right      -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsSessionsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <!-- Left: TreeView panel -->
                    <ColumnDefinition x:Name="SessionTreeColumn" Width="260" MinWidth="180" MaxWidth="500"/>
                    <!-- Splitter -->
                    <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                    <!-- Right: Detail / session content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: TreeView with filter (only on Servers tab) -->
                <Border x:Name="TreeViewPanel" Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        >
                    <DockPanel>
                        <!-- Sidebar tab selector: Servers / Tools + collapse sidebar button -->
                        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,0">
                            <Button x:Name="ToggleSidebarButton"
                                    DockPanel.Dock="Right"
                                    Content="&#xE89F;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Click="OnToggleSidebarClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                    Width="32" Height="32"
                                    Margin="4,0,0,0"
                                    ToolTip="{loc:Translate TooltipHideSidebar}"
                                    AutomationProperties.Name="{loc:Translate TooltipHideSidebar}"/>
                            <UniformGrid Columns="2">
                                <RadioButton x:Name="SidebarTabSessions"
                                             GroupName="SidebarTabs"
                                             IsChecked="{Binding Sidebar.IsToolsTabActive, Converter={StaticResource InvertBoolConverter}, Mode=OneWay, FallbackValue=True}"
                                             Content="{loc:Translate SidebarTabSessions}"
                                             Style="{DynamicResource SidebarTabStyle}"
                                             KeyboardNavigation.TabIndex="0"
                                             Checked="OnSidebarTabSessionsChecked"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabSessions}"/>
                                <RadioButton x:Name="SidebarTabTools"
                                             GroupName="SidebarTabs"
                                             IsChecked="{Binding Sidebar.IsToolsTabActive, Mode=OneWay}"
                                             Content="{loc:Translate SidebarTabTools}"
                                             Style="{DynamicResource SidebarTabStyle}"
                                             KeyboardNavigation.TabIndex="1"
                                             Checked="OnSidebarTabToolsChecked"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabTools}"/>
                            </UniformGrid>
                        </DockPanel>

                        <!-- Sidebar tab content: Sessions (TreeView) and Tools are mutually exclusive.
                             Placed in a Grid so they both consume the remaining vertical space; only
                             one is visible at a time via the RadioButton IsChecked state. -->
                        <Grid>
                            <!-- ============ SESSIONS TAB CONTENT ============ -->
                            <DockPanel x:Name="SidebarSessionsContent"
                                       Visibility="{Binding IsChecked, ElementName=SidebarTabSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- Filter + add/overflow toolbar (single row to free vertical space) -->
                                <StackPanel DockPanel.Dock="Top" Margin="8,8,8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="Mw_FilterBox" Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource SearchTextBoxStyle}"
                                                     Tag="{loc:Translate SearchPlaceholder}" Padding="10,6,28,6"
                                                     AutomationProperties.Name="{loc:Translate A11ySearchAndFilter}"/>
                                            <Button x:Name="Mw_FilterClearBtn"
                                                    Content="&#xE711;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="{StaticResource FontSizeSmallCaption}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Margin="0,0,4,0"
                                                    Padding="4"
                                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                    MinHeight="0"
                                                    Click="OnFilterClearClick"
                                                    Visibility="Collapsed"
                                                    AutomationProperties.Name="{loc:Translate A11yClearSearchFilter}"/>
                                        </Grid>

                                        <Button Grid.Column="1"
                                                x:Name="AddButton"
                                                Click="OnAddButtonClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                                Width="32" Height="32"
                                                Margin="6,0,0,0"
                                                ToolTip="{loc:Translate TooltipAddMenu}"
                                                AutomationProperties.Name="{loc:Translate TooltipAddMenu}">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"/>
                                            <Button.ContextMenu>
                                                <ContextMenu x:Name="AddMenu"
                                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem x:Name="Mw_AddMenuSession" Header="{loc:Translate AddMenuSession}" Command="{Binding ServerList.AddServerCommand}"/>
                                                    <MenuItem x:Name="Mw_AddMenuTool" Header="{loc:Translate AddMenuTool}" Click="OnAddToolMenuClick"/>
                                                    <Separator/>
                                                    <MenuItem x:Name="Mw_AddMenuGateway" Header="{loc:Translate AddMenuGateway}" Command="{Binding Settings.AddGatewayCommand}"/>
                                                    <MenuItem x:Name="Mw_AddMenuFolder" Header="{loc:Translate AddMenuFolder}" Click="OnAddFolderFromMenu"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>

                                        <Button Grid.Column="2"
                                                x:Name="SidebarOverflowButton"
                                                Click="OnSidebarOverflowClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="6,6" FontSize="{StaticResource FontSizeBody}"
                                                Width="32" Height="32"
                                                Margin="2,0,0,0"
                                                ToolTip="{loc:Translate TooltipSidebarOverflow}"
                                                AutomationProperties.Name="{loc:Translate TooltipSidebarOverflow}">
                                            <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"/>
                                            <Button.ContextMenu>
                                                <ContextMenu x:Name="SidebarOverflowMenu"
                                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{loc:Translate A11yImportMenu}"
                                                              AutomationProperties.Name="{loc:Translate A11yImportMenu}">
                                                        <MenuItem Header="{loc:Translate MenuImportRdp}"
                                                                  Click="OnImportRdpClick"
                                                                  AutomationProperties.Name="{loc:Translate A11yImportRdp}"/>
                                                        <MenuItem Header="{loc:Translate MenuImportOpenSshConfig}"
                                                                  Click="OnImportOpenSshConfigClick"
                                                                  AutomationProperties.Name="{loc:Translate A11yImportOpenSshConfig}"/>
                                                        <MenuItem Header="{loc:Translate MenuImportPuttySessions}"
                                                                  Click="OnImportPuttySessionsClick"
                                                                  AutomationProperties.Name="{loc:Translate A11yImportPuttySessions}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Translate MenuImportKnownHosts}"
                                                                  Command="{Binding ServerList.ImportKnownHostsCommand}"
                                                                  AutomationProperties.Name="{loc:Translate A11yImportKnownHosts}"/>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="{loc:Translate TooltipExpandAll}"
                                                              Click="OnExpandAllClick"
                                                              AutomationProperties.Name="{loc:Translate TooltipExpandAll}"/>
                                                    <MenuItem Header="{loc:Translate TooltipCollapseAll}"
                                                              Click="OnCollapseAllClick"
                                                              AutomationProperties.Name="{loc:Translate TooltipCollapseAll}"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </Grid>

                                    <!-- Result count hint: collapses to 0 height when filter is inactive (code-behind toggles Visibility) -->
                                    <TextBlock x:Name="Mw_FilterResultCount"
                                               FontSize="{StaticResource FontSizeSmallCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="2,4,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="Collapsed"/>
                                </StackPanel>

                                <Border x:Name="SessionTreeNoGroupDropZone"
                                        DockPanel.Dock="Top"
                                        Margin="0,2,0,4"
                                        Padding="4,3"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusMd}"
                                        AllowDrop="True"
                                        DragOver="OnTreeViewDragOver"
                                        DragLeave="OnTreeViewDragLeave"
                                        Drop="OnTreeViewDrop"
                                        ToolTip="{loc:Translate TreeNodeNoGroup}"
                                        AutomationProperties.Name="{loc:Translate TreeNodeNoGroup}">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource TreeViewIndentGuideBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="theming:DropTargetVisualState.IsDropTarget" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Geo.Tree.Group}"
                                              Fill="{DynamicResource TextDisabledBrush}"
                                              Width="10"
                                              Height="10"
                                              Opacity="0.7"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Translate TreeNodeNoGroup}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextDisabledBrush}"
                                                   Opacity="0.85"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Hierarchical TreeView (fills remaining space) -->
                                <TreeView x:Name="SessionTreeView"
                                  ItemsSource="{Binding ServerList.GroupedServers}"
                                  Style="{DynamicResource ThemedTreeViewStyle}"
                                  Padding="0,4,0,0"
                                  AllowDrop="True"
                                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                                  MouseDoubleClick="OnTreeViewDoubleClick"
                                  PreviewMouseLeftButtonDown="OnTreeViewDragStart"
                                  PreviewMouseMove="OnTreeViewDragMove"
                                  DragOver="OnTreeViewDragOver"
                                  DragLeave="OnTreeViewDragLeave"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewMouseRightButtonDown"
                                  PreviewKeyDown="OnSessionTreeViewPreviewKeyDown"
                                  ContextMenuOpening="OnTreeViewContextMenuOpening"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <TreeView.Resources>
                                <!-- Folder node template (recursive — unlimited nesting) -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:FolderViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <Border Margin="0,3,4,1"
                                            Padding="4,3,6,3"
                                            MinHeight="26"
                                            Background="Transparent"
                                            ToolTip="{Binding FullPath}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0"
                                                  Data="{StaticResource Geo.Tree.Group}"
                                                  Fill="{DynamicResource InfoBrush}"
                                                  Width="13" Height="13"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ServerCount}"
                                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,2,0"/>
                                        </Grid>
                                    </Border>
                                </HierarchicalDataTemplate>

                                <!-- Server leaf node template -->
                                <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                                    <Border x:Name="ServerSelectionChrome"
                                            Margin="0,0,4,0"
                                            HorizontalAlignment="Stretch"
                                            MinHeight="24"
                                            Padding="3,2,4,2"
                                            CornerRadius="0"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent"
                                            Background="Transparent"
                                            ToolTip="{Binding DisplayName}"
                                            ToolTipService.InitialShowDelay="150">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Protocol / tool vector icon (resolved by converters).
                                                 The ThemeRevision trigger forces re-evaluation on runtime theme swap. -->
                                            <Path Grid.Column="0"
                                                  Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                                  Style="{StaticResource GeoIconSmall}"
                                                  VerticalAlignment="Center" Margin="0,0,4,0">
                                                <Path.Fill>
                                                    <MultiBinding Converter="{StaticResource TypeToColorConverter}">
                                                        <Binding Path="ConnectionType"/>
                                                        <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                    </MultiBinding>
                                                </Path.Fill>
                                            </Path>
                                            <!-- Status dot: shows session state when active, otherwise health reachability -->
                                            <Ellipse Grid.Column="1"
                                                     Width="7" Height="7" Margin="2,0,8,0"
                                                     VerticalAlignment="Center"
                                                     ToolTip="{Binding HealthTooltipText}"
                                                     ToolTipService.InitialShowDelay="200">
                                                <Ellipse.Fill>
                                                    <MultiBinding Converter="{StaticResource ServerStatusToColorConverter}">
                                                        <Binding Path="ConnectionType"/>
                                                        <Binding Path="ConnectionState"/>
                                                        <Binding Path="HealthState"/>
                                                        <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                    </MultiBinding>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <!-- Server name -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SidebarDisplayName}" FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="3"
                                                    Background="{DynamicResource CardBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="4,0"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    ToolTip="{Binding OriginDisplayName}"
                                                    Visibility="{Binding IsOriginBadgeVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding OriginBadgeCode}"
                                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, FallbackValue=False}" Value="True">
                                            <Setter TargetName="ServerSelectionChrome" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </TreeView.Resources>

                            <!-- TreeViewItem container style: expand state bound to ViewModel -->
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem"
                                       BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="1,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type TreeViewItem}">
                                                <Grid SnapsToDevicePixels="True">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <ToggleButton x:Name="Expander"
                                                                  Grid.Row="0"
                                                                  Grid.Column="0"
                                                                  Margin="0,2,2,0"
                                                                  Style="{StaticResource TreeViewExpanderToggleButtonStyle}"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  ClickMode="Press"/>
                                                    <Border x:Name="SelectionBorder"
                                                            Grid.Row="0"
                                                            Grid.Column="1"
                                                            Margin="0,1,0,1"
                                                            Padding="{TemplateBinding Padding}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="3,0,0,0"
                                                            CornerRadius="0">
                                                        <ContentPresenter x:Name="HeaderHost"
                                                                          ContentSource="Header"
                                                                          HorizontalAlignment="Stretch"/>
                                                    </Border>
                                                    <Grid Grid.Row="1"
                                                          Grid.Column="1"
                                                          Margin="0,1,0,0">
                                                        <Border x:Name="IndentGuide"
                                                                Width="1"
                                                                HorizontalAlignment="Left"
                                                                Margin="6,0,0,0"
                                                                Background="{DynamicResource TreeViewIndentGuideBrush}"
                                                                Visibility="Collapsed"/>
                                                        <ItemsPresenter x:Name="ItemsHost"
                                                                        Margin="12,1,0,0"/>
                                                    </Grid>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                        <Setter TargetName="IndentGuide" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <Trigger Property="IsExpanded" Value="False">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="IndentGuide" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="HasItems" Value="True"/>
                                                            <Condition Property="IsExpanded" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="IndentGuide" Property="Visibility" Value="Visible"/>
                                                    </MultiTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                        <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="theming:DropTargetVisualState.IsDropTarget" Value="True">
                                                        <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                        <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="SelectionBorder" Property="Opacity" Value="{StaticResource OpacityDisabled}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="PreviewMouseLeftButtonDown"
                                                 Handler="OnSessionTreeViewItemPreviewMouseLeftButtonDown"/>
                                    <Style.Triggers>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                                                        <Grid SnapsToDevicePixels="True">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <ToggleButton x:Name="Expander"
                                                                          Grid.Row="0"
                                                                          Grid.Column="0"
                                                                          Margin="0,2,2,0"
                                                                          Style="{StaticResource TreeViewExpanderToggleButtonStyle}"
                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          ClickMode="Press"/>
                                                            <Border x:Name="SelectionBorder"
                                                                    Grid.Row="0"
                                                                    Grid.Column="1"
                                                                    Margin="0,1,0,1"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="3,0,0,0"
                                                                    CornerRadius="0">
                                                                <ContentPresenter x:Name="HeaderHost"
                                                                                  ContentSource="Header"
                                                                                  HorizontalAlignment="Stretch"/>
                                                            </Border>
                                                            <ItemsPresenter x:Name="ItemsHost"
                                                                            Grid.Row="1"
                                                                            Grid.Column="1"
                                                                            Grid.ColumnSpan="2"
                                                                            Margin="2,1,0,0"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="HasItems" Value="False">
                                                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                            </Trigger>
                                                            <Trigger Property="IsExpanded" Value="False">
                                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="theming:DropTargetVisualState.IsDropTarget" Value="True">
                                                                <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="SelectionBorder" Property="Opacity" Value="{StaticResource OpacityDisabled}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>

                                </TreeView>
                            </DockPanel>

                            <!-- ============ TOOLS TAB CONTENT ============ -->
                            <DockPanel x:Name="SidebarToolsContent"
                                       Visibility="{Binding IsChecked, ElementName=SidebarTabTools, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                                    <TextBox x:Name="Mw_SidebarToolsFilter"
                                             Style="{DynamicResource SearchTextBoxStyle}"
                                             Tag="{loc:Translate ToolsPanelFilterPlaceholder}"
                                             Padding="10,6,28,6"
                                             Text="{Binding Sidebar.FilterText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{loc:Translate A11ySidebarTabTools}"/>
                                </Grid>
                                <TextBlock x:Name="Mw_SidebarToolsContextText"
                                           DockPanel.Dock="Top"
                                           Margin="10,2,10,4"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Sidebar.ContextLabel}"
                                           ToolTip="{Binding Sidebar.ContextTooltip}"/>
                                <TextBlock x:Name="Mw_SidebarToolsNoResults"
                                           DockPanel.Dock="Top"
                                           Margin="10,16,10,0"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           HorizontalAlignment="Center"
                                           Text="{Binding Sidebar.NoResultsText}"
                                           Visibility="{Binding Sidebar.HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TreeView x:Name="SidebarToolsTreeView"
                                          Style="{DynamicResource ThemedTreeViewStyle}"
                                          Padding="0,2,0,0"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          ItemsSource="{Binding Sidebar.ToolsCategories}"
                                          SelectedItemChanged="OnSidebarToolsSelectedItemChanged"
                                          PreviewMouseRightButtonDown="OnSidebarToolsRightButtonDown"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <TreeView.Resources>
                                        <!-- Category header: accent dot + name + count badge -->
                                        <HierarchicalDataTemplate DataType="{x:Type vm:SidebarToolCategoryViewModel}"
                                                                  ItemsSource="{Binding Tools}">
                                            <Grid Margin="0,2,4,2" ToolTip="{Binding CategoryName}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0"
                                                         Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0">
                                                    <Ellipse.Fill>
                                                        <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                                            <Binding Path="BrushKey"/>
                                                            <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                        </MultiBinding>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CategoryName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           AutomationProperties.Name="{Binding CategoryName}"/>
                                                <Border Grid.Column="2"
                                                        Background="{DynamicResource CardBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusMd}"
                                                        Padding="6,1" Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VisibleCount}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </HierarchicalDataTemplate>
                                        <!-- Tool leaf: icon + name (compact single-line) -->
                                        <DataTemplate DataType="{x:Type vm:SidebarToolItemViewModel}">
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,1"
                                                        Cursor="Hand"
                                                        ToolTip="{Binding Name}">
                                                <Path Width="14" Height="14"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Data="{Binding IconGeometryKey, Converter={StaticResource ResourceKeyToGeometryConverter}}">
                                                    <Path.Fill>
                                                        <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                                            <Binding Path="BrushKey"/>
                                                            <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                        </MultiBinding>
                                                    </Path.Fill>
                                                </Path>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           AutomationProperties.Name="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </TreeView.Resources>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem"
                                               BasedOn="{StaticResource ThemedTreeViewItemStyle}">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <Setter Property="Visibility"
                                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Setter Property="Padding" Value="1,1"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- SPLITTER -->
                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource CardBrush}"
                              Cursor="SizeWE"
                              ShowsPreview="True">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                    <!-- Visual drag handle (three dots) -->
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Border Background="{TemplateBinding Background}">
                                <TextBlock Text="&#xE784;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- Show sidebar button (visible only when sidebar is hidden) -->
                <Button x:Name="ShowSidebarButton"
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="&#xE76C;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnToggleSidebarClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="4,6" FontSize="{StaticResource FontSizeCaption}"
                        Margin="4,8,0,0"
                        Panel.ZIndex="10"
                        Visibility="Collapsed"
                        ToolTip="{loc:Translate TooltipShowSidebar}"
                        AutomationProperties.Name="{loc:Translate TooltipShowSidebar}"/>

                <!-- RIGHT PANEL: sessions + tunnel bottom panel -->
                <Grid x:Name="Mw_SessionsGrid" Grid.Column="2"
                      ClipToBounds="True"
                      Tag="{loc:Translate A11yOperationInProgress}">
                    <Grid.RowDefinitions>
                        <!-- Row 0: Sessions / server details -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: GridSplitter (visible when tunnel panel open) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Retractable tunnel panel -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- SESSIONS (visible when active) -->
                    <Grid x:Name="SessionDragDropHost"
                          Grid.Row="0"
                          Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TabControl x:Name="SessionTabControl"
                                    Grid.Row="0"
                                    ItemsSource="{Binding Connection.ActiveSessions}"
                                    SelectedItem="{Binding Connection.ActiveSession}"
                                    AllowDrop="True"
                                    Background="{DynamicResource BackgroundBrush}"
                                    BorderThickness="0"
                                    ClipToBounds="True"
                                    PreviewDragOver="OnTabDragOver"
                                    PreviewDrop="OnTabDrop"
                                    DragOver="OnTabDragOver"
                                    Drop="OnTabDrop"
                                    Style="{DynamicResource HeaderOnlyTabControlStyle}"
                                    PreviewMouseRightButtonDown="OnSessionTabRightClick"
                                    PreviewMouseLeftButtonDown="OnTabDragStart"
                                    PreviewMouseMove="OnTabDragMove"
                                    QueryContinueDrag="OnTabQueryContinueDrag"
                                    Tag="{loc:Translate A11yCloseSessionTab}"
                                    AutomationProperties.Name="{loc:Translate NavTabSessions}">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="{x:Type TabItem}"
                                       BasedOn="{StaticResource ThemedTabItemStyle}">
                                    <Setter Property="AutomationProperties.Name"
                                            Value="{Binding DisplayTitle}"/>
                                </Style>
                            </TabControl.ItemContainerStyle>
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                                    <Border x:Name="TabHeaderBorder" Padding="10,6" Background="Transparent"
                                            ToolTip="{Binding HeaderToolTip}">
                                        <DockPanel LastChildFill="True">
                                            <!-- Close button always occupies layout space (Hidden, not Collapsed)
                                                 so the tab width stays constant on hover. Only opacity toggles.
                                                 IsHitTestVisible stays True; the Border's Background="Transparent"
                                                 ensures IsMouseOver persists when hovering over child elements. -->
                                            <Button x:Name="TabCloseButton" DockPanel.Dock="Right"
                                                    Width="20" Height="20" Margin="6,0,0,0" Padding="2"
                                                    Focusable="False" Content="&#xE711;"
                                                    FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSmallCaption}"
                                                    Opacity="0.3" IsHitTestVisible="True"
                                                    Command="{Binding DataContext.Connection.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                    CommandParameter="{Binding}"
                                                    AutomationProperties.Name="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Grid Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0">
                                                    <Path Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                                          Style="{StaticResource GeoIconSmall}">
                                                        <Path.Fill>
                                                            <MultiBinding Converter="{StaticResource TypeToColorConverter}">
                                                                <Binding Path="ConnectionType"/>
                                                                <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                            </MultiBinding>
                                                        </Path.Fill>
                                                    </Path>
                                                    <Ellipse Width="7" Height="7"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"
                                                             Margin="0,0,-1,-1"
                                                             Stroke="{DynamicResource BackgroundBrush}"
                                                             StrokeThickness="1"
                                                             Fill="{Binding TunnelBadgeState, Converter={StaticResource TunnelBadgeStateToBrushConverter}}"
                                                             AutomationProperties.Name="{loc:Translate A11yTunnelTabBadge}">
                                                        <Ellipse.Visibility>
                                                            <MultiBinding Converter="{StaticResource TunnelBadgeVisibilityConverter}">
                                                                <Binding Path="TunnelBadgeState"/>
                                                                <Binding Path="DataContext.Tunnels.IsPanelOpen" ElementName="MainWindowRoot"/>
                                                            </MultiBinding>
                                                        </Ellipse.Visibility>
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="ToolTip" Value=""/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TunnelBadgeState}" Value="{x:Static tunnels:TunnelBadgeState.Healthy}">
                                                                        <Setter Property="ToolTip" Value="{loc:Translate TooltipTunnelTabBadgeHealthy}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TunnelBadgeState}" Value="{x:Static tunnels:TunnelBadgeState.Unhealthy}">
                                                                        <Setter Property="ToolTip" Value="{loc:Translate TooltipTunnelTabBadgeUnhealthy}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding DisplayTitle}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding HeaderToolTip}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                                <TextBlock x:Name="BusyIndicator" Text="&#x25CF;" FontSize="8"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           VerticalAlignment="Center" Margin="5,0,0,0"
                                                           Visibility="Collapsed"
                                                           AutomationProperties.Name="{Binding Tag, RelativeSource={RelativeSource AncestorType=Grid, AncestorLevel=2}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Resources>
                                                                <Storyboard x:Key="PulseAnimation">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1" To="0.2" Duration="0:0:0.6"
                                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                                </Storyboard>
                                                            </Style.Resources>
                                                            <Style.Triggers>
                                                                <Trigger Property="Visibility" Value="Visible">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard Name="PulseStoryboard" Storyboard="{StaticResource PulseAnimation}"/>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                        </TextBlock.Style>
                                                </TextBlock>
                                                <Button x:Name="PostConnectIndicator"
                                                        Margin="6,0,0,0"
                                                        Padding="4,1"
                                                        MinWidth="34"
                                                        Height="20"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding CancelPostConnectCommand}"
                                                        ToolTip="{Binding PostConnectTooltip}"
                                                        Visibility="Collapsed"
                                                        AutomationProperties.Name="{Binding PostConnectTooltip}"
                                                        Style="{DynamicResource SecondaryButtonStyle}">
                                                    <TextBlock Text="{Binding PostConnectProgressText}"
                                                               FontSize="{StaticResource FontSizeSmallCaption}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <!-- Show close button at full opacity on hover or active tab -->
                                        <Trigger SourceName="TabHeaderBorder" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                            <Setter TargetName="TabCloseButton" Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter TargetName="BusyIndicator" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPostConnectRunning}" Value="True">
                                            <Setter TargetName="PostConnectIndicator" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <Grid x:Name="SessionContentHost"
                              Grid.Row="1"
                              Background="Transparent"
                              ClipToBounds="True"
                              AllowDrop="True"
                              PreviewDragOver="OnTabDragOver"
                              PreviewDrop="OnTabDrop"
                              DragOver="OnTabDragOver"
                              Drop="OnTabDrop">
                            <Border Background="{DynamicResource CardBrush}"
                                    CornerRadius="0,0,12,12"
                                    Padding="12">
                                <ContentControl Content="{Binding DisplayedSession}"
                                                ContentTemplate="{StaticResource SessionTabContentTemplate}"
                                                ClipToBounds="True"/>
                            </Border>

                            <!-- Drop zone overlay for drag-to-split (shown during tab drag over content area) -->
                            <Border x:Name="ContentDropZone"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource DragDropOverlayBackground}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    IsHitTestVisible="False">
                                <TextBlock Text="{Binding DataContext.DropToMergeText, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='Drop to split'}"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.8"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- SERVER DETAILS (visible when no sessions) -->
                    <Grid Grid.Row="0"
                          Visibility="{Binding Connection.HasActiveSessions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <!-- Server detail panel (shown when a non-tool server is selected) -->
                        <Border x:Name="SessionDetailPanel"
                                Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{Binding ServerList.SelectedServer.DisplayName}"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource ConnectionTypeToBrushConverter}">
                                                <Binding Path="ServerList.SelectedServer.ConnectionType"/>
                                                <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                            </MultiBinding>
                                        </Border.Background>
                                        <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionType}"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <MultiBinding Converter="{StaticResource ConnectionStateToBrushConverter}">
                                                <Binding Path="ServerList.SelectedServer.ConnectionState"/>
                                                <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                            </MultiBinding>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ServerList.SelectedServer.ConnectionStateDisplayName}"
                                               ToolTip="{Binding ServerList.SelectedServer.ConnectionStateTooltip}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock x:Name="Mw_DetailHostPort"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}">
                                    <Run Text="{Binding ServerList.SelectedServer.RemoteServer, Mode=OneWay}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding ServerList.SelectedServer.RemotePort, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Group, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailGroupLabel" Text="{loc:Translate DetailLabelGroup}"/>
                                    <Run Text="{Binding ServerList.SelectedServer.Group, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Visibility="{Binding ServerList.SelectedServer.Environment, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run x:Name="Mw_DetailEnvLabel" Text="{loc:Translate DetailLabelEnvironment}"/>
                                    <Run Text="{Binding ServerList.SelectedServer.Environment, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Enriched metadata section -->
                                <Border Margin="0,12,0,0" Padding="12,8"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="{StaticResource CornerRadiusSm}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Project -->
                                        <TextBlock x:Name="Mw_DetailProjectLabel" Grid.Row="0" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelProject}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.ProjectName, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                                    Visibility="{Binding ServerList.SelectedServer.ProjectName, Converter={StaticResource NullToVisibilityConverter}}"
                                                    Margin="0,2,0,2">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                     Fill="{Binding ServerList.SelectedServer.ProjectColor, Converter={StaticResource StringToBrushConverter}, TargetNullValue=#A67AF7}"/>
                                            <TextBlock Text="{Binding ServerList.SelectedServer.ProjectName}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Username -->
                                        <TextBlock x:Name="Mw_DetailUsernameLabel" Grid.Row="1" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelUsername}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.Username}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.Username, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Gateway -->
                                        <TextBlock x:Name="Mw_DetailGatewayLabel" Grid.Row="2" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelGateway}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.GatewayName, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.GatewayName, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="{Binding ServerList.SelectedServer.GatewayName, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- Authentication -->
                                        <TextBlock x:Name="Mw_DetailAuthLabel" Grid.Row="3" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelAuth}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.AuthSummary, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.AuthSummary}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.AuthSummary, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Tags -->
                                        <TextBlock x:Name="Mw_DetailTagsLabel" Grid.Row="4" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelTags}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.Tags, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="{Binding ServerList.SelectedServer.Tags}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,2,0,2" TextWrapping="Wrap"
                                                   Visibility="{Binding ServerList.SelectedServer.Tags, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <!-- Favorite -->
                                        <TextBlock x:Name="Mw_DetailFavoriteLabel" Grid.Row="5" Grid.Column="0"
                                                   Text="{loc:Translate DetailLabelFavorite}" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,12,2" VerticalAlignment="Center"
                                                   Visibility="{Binding ServerList.SelectedServer.IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1"
                                                   Text="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource WarningTextBrush}"
                                                   Margin="0,2,0,2"
                                                   Visibility="{Binding ServerList.SelectedServer.IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   AutomationProperties.Name="Favorite"/>
                                    </Grid>
                                </Border>

                                <Button x:Name="Mw_DetailConnectBtn" Content="{loc:Translate DetailBtnConnect}"
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="120" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"
                                        AutomationProperties.Name="{loc:Translate AccessDetailConnect}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="Mw_DetailEditBtn" Content="{loc:Translate BtnEdit}"
                                            Command="{Binding ServerList.EditServerCommand}"
                                            CommandParameter="{Binding ServerList.SelectedServer}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTip="{loc:Translate TooltipEdit}"
                                            AutomationProperties.Name="{loc:Translate BtnEdit}"
                                            Padding="12,6" Margin="0,0,8,0"/>
                                    <Button x:Name="Mw_DetailDeleteBtn" Content="{loc:Translate BtnDelete}"
                                            Command="{Binding ServerList.DeleteServerCommand}"
                                            CommandParameter="{Binding ServerList.SelectedServer}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource ErrorTextBrush}"
                                            ToolTip="{loc:Translate TooltipDelete}"
                                            AutomationProperties.Name="{loc:Translate BtnDelete}"
                                            Padding="12,6"/>
                                </StackPanel>
                                <!-- Subtle shortcut hints for detail panel actions -->
                                <TextBlock x:Name="Mw_DetailActionHints" Text="{loc:Translate DetailActionHints}"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Tool detail panel (shown when a TOOL:* entry is selected) -->
                        <Border x:Name="ToolDetailPanel"
                                Visibility="Collapsed"
                                Padding="{StaticResource SpacingXl}">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock x:Name="Mw_ToolDetailName"
                                           FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border CornerRadius="{StaticResource CornerRadiusSm}" Padding="6,2" Margin="0,0,8,0"
                                            Background="{DynamicResource ToolBadgeBrush}">
                                        <TextBlock x:Name="Mw_ToolDetailCategory"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BadgeTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="Mw_ToolDetailDescription"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeBodyLarge}" TextWrapping="Wrap"/>

                                <Button x:Name="Mw_ToolDetailOpenBtn" Content=""
                                        Command="{Binding ServerList.ConnectCommand}"
                                        CommandParameter="{Binding ServerList.SelectedServer}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Width="140" HorizontalAlignment="Left"
                                        Margin="0,20,0,0"
                                        AutomationProperties.Name="{loc:Translate AccessDetailOpen}"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state when nothing selected -->
                        <StackPanel Visibility="{Binding ServerList.HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="True">
                            <!-- Show empty state overlay when no servers exist -->
                            <StackPanel Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="&#xE774;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeHero}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Opacity="0.5"
                                           Margin="0,0,0,16"/>
                                <TextBlock x:Name="Mw_EmptyStateTitle" Text="{loc:Translate EmptyStateTitle}" FontSize="{StaticResource FontSizeHeadline}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Mw_EmptyStateSubtitle" Text="{loc:Translate EmptyStateSubtitle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,24"
                                           TextWrapping="Wrap" MaxWidth="400"
                                           TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="Mw_EmptyBtnAddSession" Content="{loc:Translate EmptyStateBtnAddSession}"
                                            Command="{Binding ServerList.AddServerCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyAddServer}"/>
                                    <Button x:Name="Mw_EmptyBtnImport" Content="{loc:Translate EmptyStateBtnImport}"
                                            Command="{Binding Settings.ImportConfigCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTip="{loc:Translate TooltipImport}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            Margin="12,0,0,0"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyImport}"/>
                                    <Button x:Name="Mw_EmptyBtnExploreTools" Content="{loc:Translate EmptyStateBtnExploreTools}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="16,8" FontSize="{StaticResource FontSizeBodyLarge}"
                                            Margin="12,0,0,0"
                                            Click="OnEmptyExploreToolsClick"
                                            AutomationProperties.Name="{loc:Translate AccessEmptyExploreTools}"/>
                                </StackPanel>
                                <!-- Keyboard shortcut hints for discoverability -->
                                <TextBlock x:Name="Mw_EmptyStateShortcutHints" Text="{loc:Translate EmptyStateShortcutHints}"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextDisabledBrush}"
                                           HorizontalAlignment="Center" Margin="0,16,0,0"
                                           TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Show hint when servers exist but none selected -->
                            <Border Visibility="{Binding ServerList.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Style="{DynamicResource EmptyStateStyle}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="48"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Opacity="0.5"
                                               Margin="0,0,0,12"/>
                                    <TextBlock x:Name="Mw_EmptySelectSession" Text="{loc:Translate EmptyStateSelectSession}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="Mw_EmptyQuickConnectHint" Text="{loc:Translate HintQuickConnect}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- TUNNEL BOTTOM PANEL: GridSplitter + compact active tunnels -->
                    <GridSplitter Grid.Row="1"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBrush}"
                                  ShowsPreview="True"
                                  Visibility="{Binding Tunnels.IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Grid.Row="2"
                            MinHeight="120" MaxHeight="300"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding Tunnels.IsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DockPanel>
                            <!-- Header: "Tunnels (N)" + collapse button -->
                            <Border DockPanel.Dock="Top"
                                    Padding="8,4"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button x:Name="Mw_TunnelPanelCollapseBtn" DockPanel.Dock="Right"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="{StaticResource FontSizeCaption}"
                                            Command="{Binding Tunnels.TogglePanelCommand}"
                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                            Padding="6,2" Margin="4,0,0,0"
                                            ToolTip="{loc:Translate TooltipCollapseTunnelPanel}"
                                            AutomationProperties.Name="{loc:Translate A11yCollapseTunnelPanel}"/>
                                    <Button x:Name="Mw_TunnelPanelNewBtn" DockPanel.Dock="Right"
                                            Content="{loc:Translate TunnelsBtnNew}"
                                            Command="{Binding Tunnels.NewTunnelCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"
                                            AutomationProperties.Name="{loc:Translate TunnelsBtnNew}"/>
                                    <Button x:Name="Mw_TunnelPanelCloseAllBtn" DockPanel.Dock="Right"
                                            Content="{loc:Translate TunnelsBtnCloseAll}"
                                            Command="{Binding Tunnels.CloseAllCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource ErrorTextBrush}"
                                            Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"
                                            AutomationProperties.Name="{loc:Translate A11yCloseAllTunnels}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Tunnels.TunnelPanelHeaderPrefix, Mode=OneWay}"/>
                                            <Run Text="{Binding Tunnels.Count, Mode=OneWay}"/>
                                            <Run Text="{Binding Tunnels.TunnelPanelHeaderSuffix, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Content: compact tunnel DataGrid -->
                            <Grid>
                                <DataGrid x:Name="Mw_TunnelPanelGrid"
                                          Tag="{loc:Translate TooltipCloseTunnel}"
                                          ItemsSource="{Binding Tunnels.List}"
                                          SelectedItem="{Binding Tunnels.SelectedItem}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Margin="0"
                                          Style="{DynamicResource ThemedDataGridStyle}"
                                          ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                                          CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                                          RowStyle="{DynamicResource ThemedDataGridRowStyle}"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeight="24"
                                          FontSize="{StaticResource FontSizeCaption}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="Mw_TpCtxClose"
                                                      Header="{loc:Translate TunnelCtxClose}"
                                                      Command="{Binding Tunnels.CloseCommand}"
                                                      CommandParameter="{Binding Tunnels.SelectedItem}"/>
                                            <MenuItem x:Name="Mw_TpCtxCopyPort"
                                                      Header="{loc:Translate TunnelCtxCopyPort}"
                                                      Command="{Binding Tunnels.CopyPortCommand}"
                                                      CommandParameter="{Binding Tunnels.SelectedItem}"/>
                                            <Separator/>
                                            <MenuItem x:Name="Mw_TpCtxCloseAll"
                                                      Header="{loc:Translate TunnelCtxCloseAll}"
                                                      Command="{Binding Tunnels.CloseAllCommand}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="24">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="7" Height="7"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                                        <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn x:Name="Mw_TpColGateway" Header="{loc:Translate TunnelsColGateway}" Binding="{Binding ServerName}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColLabel" Header="{loc:Translate TunnelPanelColLabel}" Binding="{Binding Label}" Width="90"/>
                                        <DataGridTextColumn x:Name="Mw_TpColLocal" Header="{loc:Translate TunnelPanelColLocal}" Binding="{Binding LocalPort}" Width="60"/>
                                        <DataGridTextColumn x:Name="Mw_TpColRemote" Header="{loc:Translate TunnelPanelColRemote}" Binding="{Binding RemoteHost}" Width="*"/>
                                        <DataGridTextColumn x:Name="Mw_TpColPort" Header="{loc:Translate TunnelPanelColPort}" Binding="{Binding RemotePort}" Width="50"/>
                                        <DataGridTemplateColumn Header="" Width="28">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="&#xE711;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="{StaticResource FontSizeCaption}"
                                                            Command="{Binding DataContext.Tunnels.CloseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                            Padding="2" Margin="0"
                                                            ToolTip="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            AutomationProperties.Name="{loc:Translate A11yCloseTunnel}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state -->
                                <TextBlock x:Name="Mw_TunnelPanelEmpty" Text="{loc:Translate TunnelsEmptyState}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Tunnels.HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TUNNELS TAB: Active tunnel list                              -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsTunnelsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                    <TextBlock x:Name="Mw_TunnelsTitle" Text="{loc:Translate TunnelsSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Mw_TunnelsNewBtn" Content="{loc:Translate TunnelsBtnNew}"
                                Command="{Binding Tunnels.NewTunnelCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate TunnelsBtnNew}"/>
                        <Button x:Name="Mw_TunnelsCloseSelectedBtn" Content="{loc:Translate TunnelsBtnCloseSelected}"
                                Command="{Binding Tunnels.CloseCommand}"
                                CommandParameter="{Binding Tunnels.SelectedItem}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessTunnelsCloseSelected}"/>
                        <Button x:Name="Mw_TunnelsCloseAllBtn" Content="{loc:Translate TunnelsBtnCloseAll}"
                                Command="{Binding Tunnels.CloseAllCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Foreground="{DynamicResource ErrorTextBrush}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}"
                                AutomationProperties.Name="{loc:Translate AccessTunnelsCloseAll}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Manage gateways link -->
                <Button x:Name="Mw_TunnelsManageGatewaysLink" DockPanel.Dock="Bottom"
                        Content="{loc:Translate TunnelsManageGatewaysLink}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{DynamicResource AccentBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,8"
                        Click="OnNavigateToGatewaySettings"
                        AutomationProperties.Name="{loc:Translate TunnelsManageGatewaysLink}"/>

                <Grid>
                    <!-- Tunnel DataGrid -->
                    <DataGrid ItemsSource="{Binding Tunnels.List}"
                              SelectedItem="{Binding Tunnels.SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="16,0,16,8"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="28">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlive}" Value="False">
                                                            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="Mw_TunnelsColGateway" Header="{loc:Translate TunnelsColGateway}" Binding="{Binding ServerName}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColLabel" Header="{loc:Translate TunnelsColLabel}" Binding="{Binding Label}" Width="120"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColLocalPort" Header="{loc:Translate TunnelsColLocalPort}" Binding="{Binding LocalPort}" Width="90"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColRemoteHost" Header="{loc:Translate TunnelsColRemoteHost}" Binding="{Binding RemoteHost}" Width="*"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColRemotePort" Header="{loc:Translate TunnelsColRemotePort}" Binding="{Binding RemotePort}" Width="90"/>
                            <DataGridTextColumn x:Name="Mw_TunnelsColStarted" Header="{loc:Translate TunnelsColStarted}" Binding="{Binding StartedAt, StringFormat=HH:mm:ss}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <TextBlock x:Name="Mw_TunnelsEmpty" Text="{loc:Translate TunnelsEmptyState}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding Tunnels.HasNoTunnels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- SCHEDULED TAB: Scheduled connection management               -->
            <!-- ============================================================ -->
            <DockPanel Visibility="{Binding IsScheduledTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Header bar -->
                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                    <TextBlock x:Name="Mw_ScheduledTitle" Text="{loc:Translate ScheduledSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Mw_ScheduledAddBtn" Content="{loc:Translate ScheduledBtnAdd}"
                                Command="{Binding Scheduled.AddTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessScheduledAdd}"/>
                        <Button x:Name="Mw_ScheduledEditBtn" Content="{loc:Translate ScheduledBtnEdit}"
                                Command="{Binding Scheduled.EditTaskCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                                AutomationProperties.Name="{loc:Translate AccessScheduledEdit}"/>
                        <Button x:Name="Mw_ScheduledDeleteBtn" Content="{loc:Translate ScheduledBtnDelete}"
                                Command="{Binding Scheduled.DeleteTaskCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,3" FontSize="{StaticResource FontSizeCaption}"
                                AutomationProperties.Name="{loc:Translate AccessScheduledDelete}"/>
                    </StackPanel>
                </DockPanel>

                <Grid>
                    <!-- Scheduled tasks DataGrid -->
                    <DataGrid ItemsSource="{Binding Scheduled.Tasks}"
                              SelectedItem="{Binding Scheduled.SelectedTask}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              Margin="16,0,16,8"
                              MouseDoubleClick="OnScheduledTaskDoubleClick"
                              Style="{DynamicResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                              RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn x:Name="Mw_ScheduledColEnabled" Header="{loc:Translate ScheduledColEnabled}" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColServer" Header="{loc:Translate ScheduledColServer}" Binding="{Binding ServerName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColType" Header="{loc:Translate ScheduledColType}" Binding="{Binding ConnectionType}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColSchedule" Header="{loc:Translate ScheduledColSchedule}" Binding="{Binding Schedule}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColLastRun" Header="{loc:Translate ScheduledColLastRun}" Binding="{Binding LastRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="Mw_ScheduledColNextRun" Header="{loc:Translate ScheduledColNextRun}" Binding="{Binding NextRun, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding Scheduled.HasNoTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock x:Name="Mw_ScheduledEmpty" Text="{loc:Translate ScheduledEmptyState}"
                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Button x:Name="Mw_ScheduledCreateBtn" Content="{loc:Translate ScheduledEmptyAddButton}"
                                Command="{Binding Scheduled.AddTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="12,6" FontSize="{StaticResource FontSizeBody}"
                                HorizontalAlignment="Center"
                                AutomationProperties.Name="{loc:Translate AccessScheduledCreate}"/>
                    </StackPanel>
                </Grid>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- TOOLS TAB: Dedicated tool browser                             -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsToolsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: Title + search + tool count -->
                <Border Grid.Row="0" Padding="16,12,16,8"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock x:Name="Mw_ToolsTabTitle"
                                       Text="{Binding ToolsTab.HeaderTitle}"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"
                                       Margin="0,0,16,0"/>
                            <TextBlock x:Name="Mw_ToolsTabCount"
                                       Text="{Binding ToolsTab.CountLabel}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"/>
                            <TextBox x:Name="Mw_ToolsTabSearch"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     Tag="{Binding ToolsTab.SearchPlaceholder}"
                                     Text="{Binding ToolsTab.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{StaticResource FontSizeBody}"
                                     Padding="{StaticResource PaddingInput}"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     MaxWidth="400" HorizontalAlignment="Left"
                                     AutomationProperties.Name="{loc:Translate ToolsTabSearchPlaceholder}"/>
                        </DockPanel>
                        <TextBlock x:Name="Mw_ToolsTabContextText"
                                   Text="{Binding ToolsTab.ContextLabel}"
                                   ToolTip="{Binding ToolsTab.ContextTooltip}"
                                   Foreground="{Binding ToolsTab.ContextBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                   Margin="0,8,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Content: scrollable tool grid with sections -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,16">
                    <StackPanel x:Name="ToolsTabContent"/>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================ -->
            <!-- SETTINGS TAB: Left-navigation sub-tabs                        -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsSettingsTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sticky action bar -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="{StaticResource SpacingMd}">
                    <DockPanel>
                        <!-- Settings search box (right-aligned) -->
                        <Grid DockPanel.Dock="Right" Width="220" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBox x:Name="Mw_SettingsSearchBox"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Tag="{loc:Translate SettingsSearchPlaceholder}" Padding="10,5,28,5"
                                     TextChanged="OnSettingsSearchTextChanged"
                                     AutomationProperties.Name="{loc:Translate A11ySettingsSearch}"/>
                            <Button x:Name="Mw_SettingsSearchClear"
                                    Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="{StaticResource FontSizeSmallCaption}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,4,0" Padding="4"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}" MinHeight="0"
                                    Click="OnSettingsSearchClearClick"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="{loc:Translate A11yClearSearchFilter}"/>
                        </Grid>
                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="Mw_SettingsSaveBtn" Content="{loc:Translate SettingsBtnSaveSettings}" Command="{Binding Settings.SaveCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" MinWidth="130" Margin="0,0,16,4"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsSave}"/>
                            <Button x:Name="Mw_SettingsResetBtn" Content="{loc:Translate SettingsBtnResetDefaults}" Command="{Binding Settings.ResetToDefaultsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsReset}"/>
                            <Button x:Name="Mw_SettingsExportBtn" Content="{loc:Translate SettingsBtnExportServers}" Command="{Binding Settings.ExportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipExport}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsExport}"/>
                            <Button x:Name="Mw_SettingsImportBtn" Content="{loc:Translate SettingsBtnImportServers}" Command="{Binding Settings.ImportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipImport}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsImport}"/>
                            <Button x:Name="Mw_SettingsCitrixBtn" Content="{loc:Translate BtnImportCitrix}" Command="{Binding Settings.ImportCitrixAppsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="160" Margin="0,0,8,4"
                                    ToolTip="{loc:Translate TooltipImportCitrix}"
                                    AutomationProperties.Name="{loc:Translate AccessSettingsCitrix}"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Settings search hint (shown when filtering) -->
                <Border x:Name="Mw_SettingsSearchHint" Grid.Row="1" Visibility="Collapsed"
                        Padding="16,4" Background="{DynamicResource SurfaceBrush}">
                    <TextBlock x:Name="Mw_SettingsSearchHintText"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <TabControl Grid.Row="2" x:Name="Mw_SettingsSubTabControl" TabStripPlacement="Top" Margin="16,8,16,0"
                            Background="Transparent" BorderThickness="0">

                    <!-- ═══════ GENERAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabGeneral" Header="{loc:Translate SettingsTabGeneral}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsAppearanceTitle" Text="{loc:Translate SettingsSectionAppearance}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsLanguageLabel" Text="{loc:Translate SettingsLabelLanguage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultLocale}" SelectedValuePath="Content">
                                                    <ComboBoxItem Content="en"/>
                                                    <ComboBoxItem Content="fr"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsThemeLabel" Text="{loc:Translate SettingsLabelTheme}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <ComboBox SelectedValue="{Binding Settings.DefaultTheme}" SelectedValuePath="Tag">
                                                    <!-- Light -->
                                                    <ComboBoxItem x:Name="Mw_ThemeAlucard" Content="{loc:Translate ThemeAlucard}" Tag="Alucard" AutomationProperties.Name="{loc:Translate ThemeAlucard}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeHelsing" Content="{loc:Translate ThemeHelsing}" Tag="Helsing" AutomationProperties.Name="{loc:Translate ThemeHelsing}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeNosferatu" Content="{loc:Translate ThemeNosferatu}" Tag="Nosferatu" AutomationProperties.Name="{loc:Translate ThemeNosferatu}"/>
                                                    <Separator/>
                                                    <!-- Mid-light -->
                                                    <ComboBoxItem x:Name="Mw_ThemeCarmilla" Content="{loc:Translate ThemeCarmilla}" Tag="Carmilla" AutomationProperties.Name="{loc:Translate ThemeCarmilla}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeRenfield" Content="{loc:Translate ThemeRenfield}" Tag="Renfield" AutomationProperties.Name="{loc:Translate ThemeRenfield}"/>
                                                    <Separator/>
                                                    <!-- Dark -->
                                                    <ComboBoxItem x:Name="Mw_ThemeDrakula" Content="{loc:Translate ThemeDrakula}" Tag="Drakula" AutomationProperties.Name="{loc:Translate ThemeDrakula}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeDraculaPro" Content="{loc:Translate ThemeDraculaPro}" Tag="DraculaPro" AutomationProperties.Name="{loc:Translate ThemeDraculaPro}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeBlade" Content="{loc:Translate ThemeBlade}" Tag="Blade" AutomationProperties.Name="{loc:Translate ThemeBlade}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeBuffy" Content="{loc:Translate ThemeBuffy}" Tag="Buffy" AutomationProperties.Name="{loc:Translate ThemeBuffy}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeLincoln" Content="{loc:Translate ThemeLincoln}" Tag="Lincoln" AutomationProperties.Name="{loc:Translate ThemeLincoln}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeMorbius" Content="{loc:Translate ThemeMorbius}" Tag="Morbius" AutomationProperties.Name="{loc:Translate ThemeMorbius}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeVanHelsing" Content="{loc:Translate ThemeVanHelsing}" Tag="VanHelsing" AutomationProperties.Name="{loc:Translate ThemeVanHelsing}"/>
                                                    <Separator/>
                                                    <!-- Colored dark -->
                                                    <ComboBoxItem x:Name="Mw_ThemeBathory" Content="{loc:Translate ThemeBathory}" Tag="Bathory" AutomationProperties.Name="{loc:Translate ThemeBathory}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeAkasha" Content="{loc:Translate ThemeAkasha}" Tag="Akasha" AutomationProperties.Name="{loc:Translate ThemeAkasha}"/>
                                                    <ComboBoxItem x:Name="Mw_ThemeStriga" Content="{loc:Translate ThemeStriga}" Tag="Striga" AutomationProperties.Name="{loc:Translate ThemeStriga}"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsMaxSessionsLabel" Text="{loc:Translate SettingsLabelMaxEmbeddedSessions}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Settings.MaxEmbeddedSessions}" Width="100" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsPreventSleep" Content="{loc:Translate SettingsLabelPreventSleep}" IsChecked="{Binding Settings.PreventSleepDuringSession}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <CheckBox x:Name="Mw_SettingsCollapseTunnelsPanelByDefault"
                                                  Content="{loc:Translate SettingsLabelCollapseTunnelsPanelByDefault}"
                                                  IsChecked="{Binding Settings.CollapseTunnelsPanelByDefault}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Margin="0,12,0,0"
                                                  ToolTip="{loc:Translate SettingsTooltipCollapseTunnelsPanelByDefault}"
                                                  AutomationProperties.Name="{loc:Translate SettingsLabelCollapseTunnelsPanelByDefault}"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ TERMINAL ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabTerminal" Header="{loc:Translate SettingsTabTerminal}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsTerminalTitle" Text="{loc:Translate SettingsSectionTerminal}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontLabel" Text="{loc:Translate SettingsLabelTerminalFont}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.TerminalFontFamily}" Width="200" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsTerminalFontSizeLabel" Text="{loc:Translate SettingsLabelTerminalFontSize}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.TerminalFontSize}" Width="80"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsTerminalColorSchemeLabel" Text="{loc:Translate SettingsLabelTerminalColorScheme}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="Mw_ColorSchemeCombo" SelectedValue="{Binding Settings.TerminalColorScheme}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_SchemeDefault" Content="{loc:Translate TerminalSchemeDefault}" Tag="Default"/>
                                                <ComboBoxItem x:Name="Mw_SchemeDracula" Content="{loc:Translate TerminalSchemeDracula}" Tag="Dracula"/>
                                                <ComboBoxItem x:Name="Mw_SchemeSolarized" Content="{loc:Translate TerminalSchemeSolarizedDark}" Tag="Solarized Dark"/>
                                                <ComboBoxItem x:Name="Mw_SchemeMonokai" Content="{loc:Translate TerminalSchemeMonokai}" Tag="Monokai"/>
                                                <ComboBoxItem x:Name="Mw_SchemeNord" Content="{loc:Translate TerminalSchemeNord}" Tag="Nord"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsPsPolicyLabel" Text="{loc:Translate SettingsPsExecutionPolicy}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.PowerShellExecutionPolicy}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                                <ComboBoxItem x:Name="Mw_PsDefault" Content="{loc:Translate PsPolicyDefault}" Tag="Default"/>
                                                <ComboBoxItem x:Name="Mw_PsBypass" Content="{loc:Translate PsPolicyBypass}" Tag="Bypass"/>
                                                <ComboBoxItem x:Name="Mw_PsRemoteSigned" Content="{loc:Translate PsPolicyRemoteSigned}" Tag="RemoteSigned"/>
                                                <ComboBoxItem x:Name="Mw_PsUnrestricted" Content="{loc:Translate PsPolicyUnrestricted}" Tag="Unrestricted"/>
                                                <ComboBoxItem x:Name="Mw_PsAllSigned" Content="{loc:Translate PsPolicyAllSigned}" Tag="AllSigned"/>
                                            </ComboBox>
                                            <TextBlock x:Name="Mw_SettingsPsPolicyHint" Text="{loc:Translate SettingsPsExecutionPolicyHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ SSH & SFTP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabSsh" Header="{loc:Translate SettingsTabSshSftp}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsSshTitle" Text="{loc:Translate SettingsSectionSshDefaults}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="Mw_SettingsPlinkPathLabel" Text="{loc:Translate SettingsLabelPlinkPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                        <DockPanel>
                                            <Button x:Name="Mw_SettingsBrowsePlinkPath" DockPanel.Dock="Right"
                                                    Padding="6,2" Margin="4,0,0,0" Click="OnBrowsePlinkPathClick"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    AutomationProperties.Name="{loc:Translate A11yBrowsePlinkPath}"
                                                    TabIndex="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBox Text="{Binding Settings.PlinkPath}" TabIndex="1" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsPlinkPathLabel}"/>
                                        </DockPanel>
                                        <TextBlock x:Name="Mw_SettingsPlinkPathHint" Text="{loc:Translate SettingsPlinkPathHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="Mw_SettingsPuttyPathLabel" Text="{loc:Translate SettingsLabelPuttyPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,12,0,4"/>
                                        <DockPanel>
                                            <Button x:Name="Mw_SettingsBrowsePuttyPath" DockPanel.Dock="Right"
                                                    Padding="6,2" Margin="4,0,0,0" Click="OnBrowsePuttyPathClick"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    AutomationProperties.Name="{loc:Translate A11yBrowsePuttyPath}"
                                                    TabIndex="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBox Text="{Binding Settings.PuttyPath}" TabIndex="3" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsPuttyPathLabel}"/>
                                        </DockPanel>
                                        <TextBlock x:Name="Mw_SettingsPuttyPathHint" Text="{loc:Translate SettingsPuttyPathHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsSshModeLabel" Text="{loc:Translate SettingsLabelSshMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ComboBox SelectedValue="{Binding Settings.SshDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshModeLabel}">
                                                    <ComboBoxItem x:Name="Mw_SshModeEmbedded" Content="{loc:Translate SettingsSshModeEmbedded}" Tag="Embedded" AutomationProperties.Name="{loc:Translate SettingsSshModeEmbedded}"/>
                                                    <ComboBoxItem x:Name="Mw_SshModeExternal" Content="{loc:Translate SettingsSshModeExternal}" Tag="External" AutomationProperties.Name="{loc:Translate SettingsSshModeExternal}"/>
                                                </ComboBox>
                                                <Button x:Name="Mw_ApplySshModeAll"
                                                        Content="{loc:Translate SettingsApplyModeToAll}"
                                                        Command="{Binding Settings.ApplySshModeToAllCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,2" FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{loc:Translate TooltipApplyModeToAll}"
                                                        AutomationProperties.Name="{loc:Translate SettingsApplyModeToAll}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="Mw_SettingsSshModeHint" Text="{loc:Translate SettingsSshModeHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsSshAgentPreferenceLabel" Text="{loc:Translate SettingsSshAgentPreferenceLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.SshAgentPreference}" SelectedValuePath="Tag" Width="260" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshAgentPreferenceLabel}">
                                                <ComboBoxItem Content="{loc:Translate SettingsSshAgentPreferenceAutoOpenSshFirst}" Tag="AutoOpenSshFirst" AutomationProperties.Name="{loc:Translate SettingsSshAgentPreferenceAutoOpenSshFirst}"/>
                                                <ComboBoxItem Content="{loc:Translate SettingsSshAgentPreferenceAutoPageantFirst}" Tag="AutoPageantFirst" AutomationProperties.Name="{loc:Translate SettingsSshAgentPreferenceAutoPageantFirst}"/>
                                                <ComboBoxItem Content="{loc:Translate SettingsSshAgentPreferenceOpenSshOnly}" Tag="OpenSshOnly" AutomationProperties.Name="{loc:Translate SettingsSshAgentPreferenceOpenSshOnly}"/>
                                                <ComboBoxItem Content="{loc:Translate SettingsSshAgentPreferencePageantOnly}" Tag="PageantOnly" AutomationProperties.Name="{loc:Translate SettingsSshAgentPreferencePageantOnly}"/>
                                            </ComboBox>
                                            <TextBlock Text="{loc:Translate SettingsSshAgentPreferenceHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsAntiIdleLabel" Text="{loc:Translate SettingsLabelAntiIdleInterval}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.AntiIdleInterval}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsAntiIdleLabel}"/>
                                                    <TextBlock Text="s" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsSshTmoutLabel" Text="{loc:Translate SettingsLabelSshTmoutReset}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.SshTmoutResetInterval}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshTmoutLabel}"/>
                                                    <TextBlock Text="s" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsSshAutoReconnectTitle" Text="{loc:Translate SettingsSshAutoReconnect}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{loc:Translate SettingsSshAutoReconnectDesc}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <CheckBox x:Name="Mw_SettingsSshAutoReconnect"
                                                      Content="{loc:Translate SettingsSshAutoReconnectEnable}"
                                                      IsChecked="{Binding Settings.SshAutoReconnect}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      AutomationProperties.Name="{loc:Translate SettingsSshAutoReconnectEnable}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        IsEnabled="{Binding Settings.SshAutoReconnect}"
                                                        Margin="0,8,0,0">
                                                <TextBlock x:Name="Mw_SettingsSshAutoReconnectAttemptsLabel"
                                                           Text="{loc:Translate SettingsSshAutoReconnectMaxAttempts}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Settings.SshAutoReconnectAttempts, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="64"
                                                         AutomationProperties.LabeledBy="{x:Reference Mw_SettingsSshAutoReconnectAttemptsLabel}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsAutoOpenSftp" Content="{loc:Translate SettingsLabelAutoOpenSftp}" IsChecked="{Binding Settings.SftpAutoOpenOnSsh}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock x:Name="Mw_SettingsX11PathLabel" Text="{loc:Translate SettingsLabelX11ServerPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="Mw_SettingsBrowseX11Path" DockPanel.Dock="Right"
                                                        Padding="6,2" Margin="4,0,0,0" Click="OnBrowseX11PathClick"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        AutomationProperties.Name="{loc:Translate A11yBrowseX11Path}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBox Text="{Binding Settings.X11ServerPath}" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsX11PathLabel}"/>
                                            </DockPanel>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsX11AutoStart" Content="{loc:Translate SettingsLabelX11AutoStart}" IsChecked="{Binding Settings.X11AutoStart}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Trusted host keys -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock x:Name="Mw_SettingsTrustedHostKeysTitle" Text="{loc:Translate SettingsSshTrustedHostKeysSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{loc:Translate SettingsSshTrustedHostKeysSectionHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Command="{Binding Settings.TrustedHostKeys.ImportKnownHostsCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="0,0,4,0"
                                                        AutomationProperties.Name="{loc:Translate BtnImportKnownHosts}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B5;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnImportKnownHosts}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding Settings.TrustedHostKeys.ExportKnownHostsCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="0,0,4,0"
                                                        AutomationProperties.Name="{loc:Translate BtnExportKnownHosts}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnExportKnownHosts}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding Settings.TrustedHostKeys.RefreshCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        AutomationProperties.Name="{loc:Translate BtnRefreshTrustedHostKeys}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnRefreshTrustedHostKeys}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBox Text="{Binding Settings.TrustedHostKeys.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{loc:Translate HintTrustedHostKeysSearch}"
                                                 AutomationProperties.Name="{loc:Translate HintTrustedHostKeysSearch}"
                                                 Margin="0,0,0,8"/>

                                        <Grid>
                                            <DataGrid ItemsSource="{Binding Settings.TrustedHostKeys.Rows}"
                                                      SelectedItem="{Binding Settings.TrustedHostKeys.SelectedRow, Mode=TwoWay}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserResizeRows="False"
                                                      HeadersVisibility="Column"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionUnit="FullRow"
                                                      RowHeaderWidth="0"
                                                      MaxHeight="260"
                                                      Sorting="OnTrustedHostKeysSorting"
                                                      Visibility="{Binding Settings.TrustedHostKeys.HasRows, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      AutomationProperties.Name="{loc:Translate A11yTrustedHostKeysGrid}">
                                                <DataGrid.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding Settings.TrustedHostKeys.ShowSelectedDetailsCommand}"/>
                                                    <KeyBinding Key="Delete" Command="{Binding Settings.TrustedHostKeys.RemoveSelectedCommand}"/>
                                                </DataGrid.InputBindings>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyHostPort}" Binding="{Binding HostPort}" SortMemberPath="HostPort" Width="170"/>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyAlgorithm}" Binding="{Binding Algorithm}" SortMemberPath="Algorithm" Width="140"/>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeySource}" Binding="{Binding SourceDisplay}" SortMemberPath="Source" Width="150"/>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyFirstSeen}" Binding="{Binding FirstSeenDisplay}" SortMemberPath="FirstSeen" Width="130"/>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyLastSeen}" Binding="{Binding LastSeenDisplay}" SortMemberPath="LastSeen" Width="130"/>
                                                    <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyFingerprint}" Binding="{Binding FingerprintDisplay}" SortMemberPath="Fingerprint" Width="*">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="ToolTip" Value="{Binding Fingerprint}"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTemplateColumn Header="{loc:Translate ColTrustedHostKeyActions}" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                    <Button Command="{Binding DataContext.Settings.TrustedHostKeys.CopyFingerprintCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                                            Padding="5,2"
                                                                            Margin="0,0,4,0"
                                                                            ToolTip="{loc:Translate BtnTrustedHostKeyCopyFingerprint}"
                                                                            AutomationProperties.Name="{loc:Translate BtnTrustedHostKeyCopyFingerprint}">
                                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="12"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.Settings.TrustedHostKeys.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                                            Padding="5,2"
                                                                            Margin="0,0,4,0"
                                                                            ToolTip="{loc:Translate BtnTrustedHostKeyDetails}"
                                                                            AutomationProperties.Name="{loc:Translate BtnTrustedHostKeyDetails}">
                                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="12"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.Settings.TrustedHostKeys.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                                            Padding="5,2"
                                                                            ToolTip="{loc:Translate BtnTrustedHostKeyRemove}"
                                                                            AutomationProperties.Name="{loc:Translate BtnTrustedHostKeyRemove}">
                                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="12"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Border Padding="{StaticResource SpacingLg}"
                                                    Background="{DynamicResource BackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource CornerRadiusMd}"
                                                    Visibility="{Binding Settings.TrustedHostKeys.IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{loc:Translate EmptyStateNoTrustedHostKeys}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate EmptyStateNoTrustedHostKeysHint}"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding Settings.TrustedHostKeys.StatusMessage}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding Settings.TrustedHostKeys.HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- SSH Gateways -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="Mw_SettingsGatewaysTitle" Text="{loc:Translate GatewaysSectionTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="Mw_SettingsGatewaysAddBtn" Content="{loc:Translate GatewaysBtnAdd}" Command="{Binding Settings.AddGatewayCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0" AutomationProperties.Name="{loc:Translate AccessGatewaysAdd}"/>
                                                <Button x:Name="Mw_SettingsGatewaysEditBtn" Content="{loc:Translate GatewaysBtnEdit}" Command="{Binding Settings.EditGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0" AutomationProperties.Name="{loc:Translate AccessGatewaysEdit}"/>
                                                <Button x:Name="Mw_SettingsGatewaysDeleteBtn" Content="{loc:Translate GatewaysBtnDelete}" Command="{Binding Settings.DeleteGatewayCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="{loc:Translate AccessGatewaysDelete}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding Settings.Gateways}" SelectedItem="{Binding Settings.SelectedGateway}" MinHeight="80" MaxHeight="200" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding User, Mode=OneWay}"/><Run Text="@"/><Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text=" &#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource SshBadgeBrush}" VerticalAlignment="Center" Visibility="{Binding HasKey, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ RDP ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabRdp" Header="{loc:Translate SettingsTabRdp}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpDefaultsTitle" Text="{loc:Translate SettingsSectionRdpDefaults}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock x:Name="Mw_SettingsRdpModeLabel" Text="{loc:Translate SettingsLabelRdpMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ComboBox SelectedValue="{Binding Settings.RdpDefaultMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpModeLabel}">
                                                    <ComboBoxItem x:Name="Mw_RdpModeEmbedded" Content="{loc:Translate SettingsRdpModeEmbedded}" Tag="Embedded" AutomationProperties.Name="{loc:Translate SettingsRdpModeEmbedded}"/>
                                                    <ComboBoxItem x:Name="Mw_RdpModeExternal" Content="{loc:Translate SettingsRdpModeExternal}" Tag="External" AutomationProperties.Name="{loc:Translate SettingsRdpModeExternal}"/>
                                                </ComboBox>
                                                <Button x:Name="Mw_ApplyRdpModeAll"
                                                        Content="{loc:Translate SettingsApplyModeToAll}"
                                                        Command="{Binding Settings.ApplyRdpModeToAllCommand}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        Padding="8,2" FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{loc:Translate TooltipApplyModeToAll}"
                                                        AutomationProperties.Name="{loc:Translate SettingsApplyModeToAll}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="Mw_SettingsRdpModeHint" Text="{loc:Translate SettingsRdpModeHint}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsRdpWidthLabel" Text="{loc:Translate SettingsLabelRdpWidth}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.DefaultResolutionWidth}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpWidthLabel}"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsRdpHeightLabel" Text="{loc:Translate SettingsLabelRdpHeight}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.DefaultResolutionHeight}" Width="100" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpHeightLabel}"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock x:Name="Mw_SettingsRdpColorDepthLabel" Text="{loc:Translate SettingsLabelRdpColorDepth}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.RdpDefaultColorDepth}" SelectedValuePath="Tag" Width="120" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpColorDepthLabel}">
                                                <ComboBoxItem x:Name="Mw_ColorDepth16" Content="{loc:Translate SettingsColorDepth16}" Tag="16" AutomationProperties.Name="{loc:Translate SettingsColorDepth16}"/>
                                                <ComboBoxItem x:Name="Mw_ColorDepth24" Content="{loc:Translate SettingsColorDepth24}" Tag="24" AutomationProperties.Name="{loc:Translate SettingsColorDepth24}"/>
                                                <ComboBoxItem x:Name="Mw_ColorDepth32" Content="{loc:Translate SettingsColorDepth32}" Tag="32" AutomationProperties.Name="{loc:Translate SettingsColorDepth32}"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpDisplayTitle" Text="{loc:Translate SettingsSectionRdpDisplay}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsRdpDynRes" Content="{loc:Translate SettingsLabelRdpDynamicRes}" IsChecked="{Binding Settings.RdpDefaultDynamicResolution}" Foreground="{DynamicResource TextPrimaryBrush}" ToolTip="{loc:Translate RdpDynamicResolutionHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpMultiMon" Content="{loc:Translate SettingsLabelRdpMultiMonitor}" IsChecked="{Binding Settings.RdpDefaultMultiMonitor}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpMultiMonitorHint}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpAudioTitle" Text="{loc:Translate SettingsSectionRdpAudio}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <StackPanel>
                                            <TextBlock x:Name="Mw_SettingsRdpAudioLabel" Text="{loc:Translate SettingsLabelRdpAudio}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding Settings.RdpDefaultAudioMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpAudioLabel}">
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioDisabled" Content="{loc:Translate ServerDialogAudioDisabled}" Tag="0" AutomationProperties.Name="{loc:Translate ServerDialogAudioDisabled}"/>
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioLocal" Content="{loc:Translate ServerDialogAudioLocal}" Tag="1" AutomationProperties.Name="{loc:Translate ServerDialogAudioLocal}"/>
                                                <ComboBoxItem x:Name="Mw_SettingsRdpAudioRemote" Content="{loc:Translate ServerDialogAudioRemote}" Tag="2" AutomationProperties.Name="{loc:Translate ServerDialogAudioRemote}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <CheckBox x:Name="Mw_SettingsRdpAudioCapture" Content="{loc:Translate RdpAudioCapture}" IsChecked="{Binding Settings.RdpDefaultAudioCapture}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0" ToolTip="{loc:Translate RdpAudioCaptureHint}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpPerformanceTitle" Text="{loc:Translate SettingsSectionRdpPerformance}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsRdpBitmapCache" Content="{loc:Translate SettingsLabelRdpBitmapCache}" IsChecked="{Binding Settings.RdpDefaultBitmapCaching}" Foreground="{DynamicResource TextPrimaryBrush}" ToolTip="{loc:Translate RdpBitmapCachingHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpCompression" Content="{loc:Translate SettingsLabelRdpCompression}" IsChecked="{Binding Settings.RdpDefaultCompression}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpCompressionHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpAutoReconnect" Content="{loc:Translate SettingsLabelRdpAutoReconnect}" IsChecked="{Binding Settings.RdpDefaultAutoReconnect}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpAutoReconnectHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpNla" Content="{loc:Translate SettingsLabelRdpNla}" IsChecked="{Binding Settings.RdpDefaultNla}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpDefaultNlaHint}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsRdpDevicesTitle" Text="{loc:Translate SettingsSectionRdpDevices}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsRdpClipboard" Content="{loc:Translate ServerDialogRedirectClipboard}" IsChecked="{Binding Settings.RdpDefaultRedirectClipboard}" Foreground="{DynamicResource TextPrimaryBrush}" ToolTip="{loc:Translate RdpRedirectClipboardHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpDrives" Content="{loc:Translate ServerDialogRedirectDrives}" IsChecked="{Binding Settings.RdpDefaultRedirectDrives}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectDrivesHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpPrinters" Content="{loc:Translate ServerDialogRedirectPrinters}" IsChecked="{Binding Settings.RdpDefaultRedirectPrinters}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectPrintersHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpComPorts" Content="{loc:Translate ServerDialogRedirectComPorts}" IsChecked="{Binding Settings.RdpDefaultRedirectComPorts}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectComPortsHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpSmartCards" Content="{loc:Translate ServerDialogRedirectSmartCards}" IsChecked="{Binding Settings.RdpDefaultRedirectSmartCards}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectSmartCardsHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpWebcam" Content="{loc:Translate ServerDialogRedirectWebcam}" IsChecked="{Binding Settings.RdpDefaultRedirectWebcam}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectWebcamHint}"/>
                                        <CheckBox x:Name="Mw_SettingsRdpUsb" Content="{loc:Translate ServerDialogRedirectUsb}" IsChecked="{Binding Settings.RdpDefaultRedirectUsb}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" ToolTip="{loc:Translate RdpRedirectUsbHint}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <Expander x:Name="Mw_SettingsRdpAdvancedTimeoutsExpander"
                                              Header="{loc:Translate SettingsSectionRdpAdvancedTimeouts}"
                                              IsExpanded="False">
                                        <StackPanel Margin="16,8,0,0">
                                            <TextBlock x:Name="Mw_SettingsRdpResizeEnableDelayLabel"
                                                       Text="{loc:Translate SettingsLabelRdpResizeEnableDelay}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Margin="0,8,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Text="{Binding Settings.RdpResizeEnableDelayMs}"
                                                         Width="120"
                                                         AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpResizeEnableDelayLabel}"/>
                                                <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                            </StackPanel>

                                            <TextBlock x:Name="Mw_SettingsRdpArtifactCleanupDelayLabel"
                                                       Text="{loc:Translate SettingsLabelRdpArtifactCleanupDelay}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Margin="0,12,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Text="{Binding Settings.RdpArtifactCleanupDelayMs}"
                                                         Width="120"
                                                         AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpArtifactCleanupDelayLabel}"/>
                                                <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                            </StackPanel>

                                            <TextBlock x:Name="Mw_SettingsRdpCredentialAutofillTimeoutLabel"
                                                       Text="{loc:Translate SettingsLabelRdpCredentialAutofillTimeout}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Margin="0,12,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Text="{Binding Settings.RdpCredentialAutofillTimeoutMs}"
                                                         Width="120"
                                                         AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpCredentialAutofillTimeoutLabel}"/>
                                                <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                            </StackPanel>

                                            <TextBlock x:Name="Mw_SettingsRdpAutoReconnectMaxAttemptsLabel"
                                                       Text="{loc:Translate SettingsLabelRdpAutoReconnectMaxAttempts}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Margin="0,12,0,4"/>
                                            <TextBox Text="{Binding Settings.RdpAutoReconnectMaxAttempts, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="120"
                                                     HorizontalAlignment="Left"
                                                     AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpAutoReconnectMaxAttemptsLabel}"/>

                                            <TextBlock x:Name="Mw_SettingsRdpKeepAliveIntervalLabel"
                                                       Text="{loc:Translate SettingsLabelRdpKeepAliveInterval}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Margin="0,12,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Text="{Binding Settings.RdpKeepAliveIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="120"
                                                         AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpKeepAliveIntervalLabel}"/>
                                                <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Translate SettingsSectionRdpDialog}"
                                                   FontSize="{StaticResource FontSizeSubtitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsRdpDialogAdvancedDefault"
                                                  Content="{loc:Translate SettingsLabelRdpDialogAdvancedDefault}"
                                                  IsChecked="{Binding Settings.RdpDialogAdvancedDefault}"
                                                  ToolTip="{loc:Translate SettingsLabelRdpDialogAdvancedDefaultHint}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{loc:Translate SettingsLabelRdpResolutionPresets}"
                                                   x:Name="Mw_SettingsRdpResolutionPresetsLabel"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Margin="0,16,0,4"/>
                                        <TextBlock Text="{loc:Translate SettingsRdpResolutionPresetsHint}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Margin="0,0,0,6"
                                                   TextWrapping="Wrap"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{loc:Translate SettingsRdpResolutionPresetWidth}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{loc:Translate SettingsRdpResolutionPresetHeight}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="{StaticResource FontSizeCaption}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Settings.RdpResolutionPresetItems}"
                                                      AutomationProperties.LabeledBy="{x:Reference Mw_SettingsRdpResolutionPresetsLabel}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <Button Grid.Column="4"
                                                                    Content="{loc:Translate SettingsRdpResolutionPresetRemove}"
                                                                    Command="{Binding DataContext.Settings.RemoveRdpResolutionPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                                    FontSize="{StaticResource FontSizeCaption}"
                                                                    Padding="6,3"
                                                                    AutomationProperties.Name="{loc:Translate SettingsRdpResolutionPresetRemove}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Error}"
                                                                   Foreground="{DynamicResource ErrorTextBrush}"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   Margin="0,4,0,0"
                                                                   Visibility="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="{loc:Translate SettingsRdpResolutionPresetAdd}"
                                                    Command="{Binding Settings.AddRdpResolutionPresetCommand}"
                                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    Foreground="{DynamicResource TextTertiaryBrush}"
                                                    Padding="0,4"
                                                    AutomationProperties.Name="{loc:Translate SettingsRdpResolutionPresetAdd}"/>
                                            <Button Content="{loc:Translate SettingsRdpResolutionPresetsReset}"
                                                    Command="{Binding Settings.ResetRdpResolutionPresetsCommand}"
                                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    Foreground="{DynamicResource TextTertiaryBrush}"
                                                    Padding="0,4"
                                                    Margin="16,0,0,0"
                                                    AutomationProperties.Name="{loc:Translate SettingsRdpResolutionPresetsReset}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="Mw_SettingsResetRdpDefaults"
                                        Content="{loc:Translate SettingsResetRdpDefaults}"
                                        Command="{Binding Settings.ResetRdpDefaultsCommand}"
                                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                                        FontSize="{StaticResource FontSizeCaption}"
                                        Foreground="{DynamicResource TextTertiaryBrush}"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12"
                                        Padding="0,4"
                                        ToolTip="{loc:Translate SettingsResetRdpDefaultsTooltip}"
                                        AutomationProperties.Name="{loc:Translate SettingsResetRdpDefaults}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ SECURITY ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabSecurity" Header="{loc:Translate SettingsTabSecurity}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsCredProviderTitle" Text="{loc:Translate SettingsSectionCredentialProvider}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsCredProviderEnabled" Content="{loc:Translate SettingsLabelCredProviderEnabled}" IsChecked="{Binding Settings.UseExternalCredentialProvider}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}" AutomationProperties.HelpText="{Binding Settings.CredProvHelpText}">
                                            <TextBlock x:Name="Mw_SettingsCredProvPresetLabel" Text="{loc:Translate CredProvPresetLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="Mw_SettingsCredProvPreset" SelectionChanged="OnCredProvPresetChanged" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,12"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}" AutomationProperties.HelpText="{Binding Settings.CredProvHelpText}">
                                            <TextBlock x:Name="Mw_SettingsCredProviderCmdLabel" Text="{loc:Translate SettingsLabelCredProviderCommand}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="Mw_SettingsCredProvCmd" Text="{Binding Settings.CredentialProviderCommand}" Tag="{loc:Translate SettingsCredProvCmdPlaceholder}"/>
                                            <TextBlock x:Name="Mw_SettingsCredProvCmdHint" Text="{loc:Translate CredProvCmdHint}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmallCaption}" FontFamily="Consolas" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}" AutomationProperties.HelpText="{Binding Settings.CredProvHelpText}">
                                            <TextBlock x:Name="Mw_SettingsCredProviderDbLabel" Text="{loc:Translate SettingsLabelCredProviderDatabase}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="Mw_SettingsCredProvDbBrowseBtn" DockPanel.Dock="Right" Padding="6,2" Margin="4,0,0,0" Click="OnCredProvDbBrowseClick" Style="{DynamicResource SecondaryButtonStyle}" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="{loc:Translate A11yBrowseDatabase}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBox Text="{Binding Settings.CredentialProviderDatabase}" AutomationProperties.LabeledBy="{x:Reference Mw_SettingsCredProviderDbLabel}"/>
                                            </DockPanel>
                                        </StackPanel>
                                        <DockPanel Margin="0,16,0,0" IsEnabled="{Binding Settings.UseExternalCredentialProvider}" AutomationProperties.HelpText="{Binding Settings.CredProvHelpText}">
                                            <Button x:Name="Mw_SettingsCredProvTestBtn" DockPanel.Dock="Right" Content="{loc:Translate CredProvBtnTest}" Command="{Binding Settings.TestCredentialProviderCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="{loc:Translate CredProvBtnTest}"/>
                                            <TextBlock x:Name="Mw_SettingsCredProvTestResult" Text="{Binding Settings.CredentialProviderTestResult}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" FontStyle="Italic" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <CheckBox x:Name="Mw_SettingsCredGuard" Content="{loc:Translate SettingsLabelCredentialGuard}" IsChecked="{Binding Settings.RequireCredentialGuard}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ═══════ ADVANCED ═══════ -->
                    <TabItem x:Name="Mw_SettingsTabAdvanced" Header="{loc:Translate SettingsTabAdvanced}" Style="{StaticResource ThemedTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="{StaticResource SpacingLg}" MaxWidth="900">
                                <!-- Logging -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsSessionLoggingTitle" Text="{loc:Translate SettingsSectionSessionLogging}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsEnableLogging" Content="{loc:Translate SettingsLabelEnableLogging}" IsChecked="{Binding Settings.EnableLogging}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <CheckBox x:Name="Mw_SettingsSessionLoggingEnabled" Content="{loc:Translate SettingsLabelSessionLoggingEnabled}" IsChecked="{Binding Settings.SessionLoggingEnabled}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding Settings.SessionLoggingEnabled}">
                                            <TextBlock x:Name="Mw_SettingsSessionLogDirLabel" Text="{loc:Translate SettingsLabelSessionLogDirectory}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="Mw_SettingsBrowseSessionLogDir" DockPanel.Dock="Right"
                                                        Padding="6,2" Margin="4,0,0,0" Click="OnBrowseSessionLogDirClick"
                                                        Style="{DynamicResource SecondaryButtonStyle}"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        AutomationProperties.Name="{loc:Translate A11yBrowseSessionLogDir}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBox Text="{Binding Settings.SessionLogDirectory}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Timeouts -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsTimeoutsTitle" Text="{loc:Translate SettingsSectionTimeouts}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsTunnelDelayLabel" Text="{loc:Translate SettingsLabelTunnelDelay}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.TunnelEstablishmentDelayMs}" Width="100"/>
                                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsRdpTimeoutLabel" Text="{loc:Translate SettingsLabelRdpTimeout}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.EmbeddedRdpTimeoutMs}" Width="100"/>
                                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock x:Name="Mw_SettingsExtToolTimeoutLabel" Text="{loc:Translate SettingsLabelExtToolTimeout}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.ExternalToolTimeoutMs}" Width="100"/>
                                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Session Health Monitor -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsHealthMonitorTitle" Text="{loc:Translate SettingsSectionSessionHealthMonitor}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsHealthMonitorEnabledCheckBox"
                                                  IsChecked="{Binding Settings.SessionHealthMonitorEnabled, Mode=TwoWay}"
                                                  Content="{loc:Translate SettingsLabelSessionHealthMonitorEnabled}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  FontSize="{StaticResource FontSizeBody}"
                                                  Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock x:Name="Mw_SettingsHealthIntervalLabel" Text="{loc:Translate SettingsLabelSessionHealthCheckInterval}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.SessionHealthCheckIntervalSeconds}" Width="100"/>
                                                    <TextBlock Text="s" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="Mw_SettingsHealthTimeoutLabel" Text="{loc:Translate SettingsLabelSessionHealthProbeTimeout}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Settings.SessionHealthProbeTimeoutMs}" Width="100"/>
                                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" IsHitTestVisible="False"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,8,0">
                                                <TextBlock x:Name="Mw_SettingsHealthMaxConcurrentLabel" Text="{loc:Translate SettingsLabelSessionHealthMaxConcurrent}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Settings.SessionHealthMaxConcurrent}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- File Sharing -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsFileSharingTitle" Text="{loc:Translate SettingsSectionFileSharing}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsEnableTftpShareCheckBox"
                                                  IsChecked="{Binding Settings.FileShareEnableTftp, Mode=TwoWay}"
                                                  Content="{loc:Translate CbxEnableTftpShare}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  FontSize="{StaticResource FontSizeBody}"/>
                                        <TextBlock Text="{loc:Translate LblTftpNoAuthWarning}"
                                                   Margin="20,4,0,0"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource WarningTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- External Editor -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsExternalEditorTitle" Text="{loc:Translate SettingsSectionExternalEditor}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="Mw_SettingsEditorPathLabel" Text="{loc:Translate SettingsLabelEditorPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,4"/>
                                        <DockPanel>
                                            <Button x:Name="Mw_SettingsBrowseEditorPath" DockPanel.Dock="Right"
                                                    Padding="6,2" Margin="4,0,0,0" Click="OnBrowseEditorPathClick"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    AutomationProperties.Name="{loc:Translate A11yBrowseEditorPath}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBox Text="{Binding Settings.ExternalEditorPath}"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- External Tools -->
                                <!-- Third-Party Tool Detection (NirSoft / Sysinternals / NanaRun) -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsExtProvTitle" Text="{loc:Translate SettingsSectionExternalToolProviders}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="Mw_SettingsExtProvDesc" Text="{loc:Translate SettingsExternalToolProvidersDesc}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock x:Name="Mw_SettingsLblSysintPath" Grid.Row="0" Grid.Column="0" Text="{loc:Translate SettingsLblSysinternalsPath}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBox x:Name="Mw_SettingsTxtSysintPath" Grid.Row="0" Grid.Column="1" Text="{Binding Settings.SysinternalsPath, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}"/>
                                            <Button x:Name="Mw_SettingsBtnSysintBrowse" Grid.Row="0" Grid.Column="2" Padding="6,2" Margin="4,0,0,8" Click="OnSysinternalsPathBrowseClick" Style="{DynamicResource SecondaryButtonStyle}" FontSize="{StaticResource FontSizeCaption}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock x:Name="Mw_SettingsLblNirSoftPath" Grid.Row="1" Grid.Column="0" Text="{loc:Translate SettingsLblNirSoftPath}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBox x:Name="Mw_SettingsTxtNirSoftPath" Grid.Row="1" Grid.Column="1" Text="{Binding Settings.NirSoftPath, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}"/>
                                            <Button x:Name="Mw_SettingsBtnNirSoftBrowse" Grid.Row="1" Grid.Column="2" Padding="6,2" Margin="4,0,0,8" Click="OnNirSoftPathBrowseClick" Style="{DynamicResource SecondaryButtonStyle}" FontSize="{StaticResource FontSizeCaption}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock x:Name="Mw_SettingsLblNanaRunPath" Grid.Row="2" Grid.Column="0" Text="{loc:Translate SettingsLblNanaRunPath}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBox x:Name="Mw_SettingsTxtNanaRunPath" Grid.Row="2" Grid.Column="1" Text="{Binding Settings.NanaRunPath, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,0" FontSize="{StaticResource FontSizeBody}"/>
                                            <Button x:Name="Mw_SettingsBtnNanaRunBrowse" Grid.Row="2" Grid.Column="2" Padding="6,2" Margin="4,0,0,0" Click="OnNanaRunPathBrowseClick" Style="{DynamicResource SecondaryButtonStyle}" FontSize="{StaticResource FontSizeCaption}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <DockPanel Margin="0,8,0,0">
                                            <Button x:Name="Mw_SettingsBtnRescan" DockPanel.Dock="Right" Content="{loc:Translate ExtToolBtnRescan}" Click="OnRescanExternalToolsClick" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}"/>
                                            <TextBlock x:Name="Mw_SettingsExtProvStatus" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" FontStyle="Italic" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Command Library Git Sync -->
                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="Mw_SettingsCmdLibSyncTitle" Text="{loc:Translate SettingsCmdLibSyncTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="Mw_SettingsCmdLibSyncEnable" Content="{loc:Translate SettingsCmdLibSyncEnable}" IsChecked="{Binding Settings.CmdLibGitSyncEnabled}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock x:Name="Mw_SettingsCmdLibSyncLblUrl" Grid.Row="0" Grid.Column="0" Text="{loc:Translate SettingsCmdLibSyncUrl}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.CmdLibGitSyncUrl, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBlock x:Name="Mw_SettingsCmdLibSyncLblBranch" Grid.Row="1" Grid.Column="0" Text="{loc:Translate SettingsCmdLibSyncBranch}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.CmdLibGitSyncBranch, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}"/>
                                            <TextBlock x:Name="Mw_SettingsCmdLibSyncLblToken" Grid.Row="2" Grid.Column="0" Text="{loc:Translate SettingsCmdLibSyncToken}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                                <Button x:Name="Mw_SettingsCmdLibSyncTokenClear" DockPanel.Dock="Right" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Click="OnCmdLibSyncTokenClear" Style="{DynamicResource ToolbarGhostButtonStyle}" FontSize="12" Width="24" Height="24" Margin="4,0,0,0" Visibility="Collapsed" ToolTip="{loc:Translate SettingsCmdLibSyncTokenClear}" AutomationProperties.Name="{loc:Translate SettingsCmdLibSyncTokenClear}"/>
                                                <TextBlock x:Name="Mw_SettingsCmdLibSyncTokenStatus" DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource SuccessTextBrush}" Margin="8,0,0,0"/>
                                                <PasswordBox x:Name="Mw_SettingsCmdLibSyncToken" FontSize="{StaticResource FontSizeBody}" PasswordChanged="OnCmdLibSyncTokenChanged"/>
                                            </DockPanel>
                                            <TextBlock x:Name="Mw_SettingsCmdLibSyncLblAuthor" Grid.Row="3" Grid.Column="0" Text="{loc:Translate SettingsCmdLibSyncAuthor}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                            <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                                                <TextBox Text="{Binding Settings.CmdLibGitSyncAuthorEmail, UpdateSourceTrigger=LostFocus}" DockPanel.Dock="Right" Width="180" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Text="{Binding Settings.CmdLibGitSyncAuthorName, UpdateSourceTrigger=LostFocus}" Margin="0,0,8,0" FontSize="{StaticResource FontSizeBody}"/>
                                            </DockPanel>
                                        </Grid>
                                        <CheckBox x:Name="Mw_SettingsCmdLibSyncOnStartup" Content="{loc:Translate SettingsCmdLibSyncOnStartup}" IsChecked="{Binding Settings.CmdLibGitSyncOnStartup}" Margin="0,4,0,4" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <CheckBox x:Name="Mw_SettingsCmdLibSyncAutoPush" Content="{loc:Translate SettingsCmdLibSyncAutoPush}" IsChecked="{Binding Settings.CmdLibGitSyncAutoPush}" Margin="0,0,0,8" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Button x:Name="Mw_SettingsCmdLibSyncTestBtn" Content="{loc:Translate SettingsCmdLibSyncTestConnection}" Click="OnCmdLibSyncTestClick" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="{StaticResource SpacingLg}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="Mw_SettingsExtToolsTitle" Text="{loc:Translate SettingsSectionExternalToolsList}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="Mw_SettingsExtToolsAddBtn" Content="{loc:Translate BtnAdd}" Command="{Binding Settings.AddExternalToolCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0" AutomationProperties.Name="{loc:Translate AccessSettingsExtToolsAdd}"/>
                                                <Button x:Name="Mw_SettingsExtToolsRemoveBtn" Content="{loc:Translate BtnRemove}" Command="{Binding Settings.RemoveExternalToolCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" AutomationProperties.Name="{loc:Translate AccessSettingsExtToolsRemove}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding Settings.ExternalTools}" SelectedItem="{Binding Settings.SelectedExternalTool}" MinHeight="60" MaxHeight="120" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding ExecutablePath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- Inline edit panel for selected tool -->
                                        <Border Margin="0,12,0,0" Padding="{StaticResource SpacingMd}" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusMd}"
                                                DataContext="{Binding Settings.SelectedExternalTool}"
                                                Visibility="{Binding DataContext.Settings.SelectedExternalTool, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock x:Name="Mw_ExtToolLblName" Grid.Row="0" Grid.Column="0" Text="{loc:Translate ExternalToolLabelName}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" FontSize="{StaticResource FontSizeBody}"/>

                                                <TextBlock x:Name="Mw_ExtToolLblPath" Grid.Row="1" Grid.Column="0" Text="{loc:Translate ExternalToolLabelPath}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                                                    <Button x:Name="Mw_ExtToolBrowseBtn" DockPanel.Dock="Right"
                                                            Padding="6,2" Margin="4,0,0,0" Click="OnExtToolBrowseClick"
                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                            FontSize="{StaticResource FontSizeCaption}"
                                                            AutomationProperties.Name="{loc:Translate A11yBrowseExecutable}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <TextBox Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}" FontSize="{StaticResource FontSizeBody}"/>
                                                </DockPanel>

                                                <TextBlock x:Name="Mw_ExtToolLblArgs" Grid.Row="2" Grid.Column="0" Text="{loc:Translate ExternalToolLabelArguments}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"/>

                                                <TextBlock x:Name="Mw_ExtToolLblWorkDir" Grid.Row="3" Grid.Column="0" Text="{loc:Translate ExternalToolLabelWorkDir}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,6">
                                                    <Button x:Name="Mw_ExtToolWorkDirBrowseBtn" DockPanel.Dock="Right"
                                                            Padding="6,2" Margin="4,0,0,0" Click="OnExtToolWorkDirBrowseClick"
                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                            FontSize="{StaticResource FontSizeCaption}"
                                                            AutomationProperties.Name="{loc:Translate A11yBrowseWorkDir}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xED25;" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{loc:Translate BtnBrowse}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" FontSize="{StaticResource FontSizeBody}"/>
                                                </DockPanel>

                                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,6">
                                                    <CheckBox x:Name="Mw_ExtToolChkAdmin" Content="{loc:Translate ExternalToolRunAsAdmin}" IsChecked="{Binding RunAsAdministrator}" Margin="0,0,16,0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                    <CheckBox x:Name="Mw_ExtToolChkHidden" Content="{loc:Translate ExternalToolRunHidden}" IsChecked="{Binding RunHidden}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeBody}"/>
                                                </StackPanel>

                                                <ItemsControl x:Name="Mw_ExtToolPlaceholderList" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>

                                                <!-- Preview + Test -->
                                                <DockPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                    <Button x:Name="Mw_ExtToolTestBtn" DockPanel.Dock="Right" Content="{loc:Translate ExtToolBtnTest}" Click="OnExtToolTestClick" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"/>
                                                    <TextBlock x:Name="Mw_ExtToolPreview" Text="" FontFamily="Consolas" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                               AutomationProperties.Name="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Grid>

            <!-- ============================================================ -->
            <!-- ABOUT TAB: Application info                                   -->
            <!-- ============================================================ -->
            <ScrollViewer Visibility="{Binding IsAboutTabSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="{StaticResource SpacingXl}" MaxWidth="560"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Identity card -->
                    <Border Padding="28"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusXl}">
                        <StackPanel>
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                                <TextBlock Text="&#xE7F4;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource IconSizeHero}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBlock x:Name="Mw_AboutAppName" Text="{loc:Translate AppName}"
                                           FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="AboutVersionText"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                            <!-- Info grid -->
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="Mw_AboutAuthorLabel" Grid.Row="0" Grid.Column="0" Text="{loc:Translate AboutLabelAuthor}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Julien Bombled"
                                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutLicenseLabel" Grid.Row="1" Grid.Column="0" Text="{loc:Translate AboutLabelLicense}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="Mw_AboutLicenseValue" Grid.Row="1" Grid.Column="1" Text="{loc:Translate AboutLicenseValue}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- System section -->
                    <Border Padding="20" Margin="0,12,0,0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusXl}">
                        <StackPanel>
                            <TextBlock Text="{loc:Translate AboutSectionSystem}" FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="Mw_AboutRuntimeLabel" Grid.Row="0" Grid.Column="0" Text="{loc:Translate AboutLabelRuntime}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutRuntimeText" Grid.Row="0" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="Mw_AboutPlatformLabel" Grid.Row="1" Grid.Column="0" Text="{loc:Translate AboutLabelPlatform}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutPlatformText" Grid.Row="1" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate AboutLabelWebView2}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutWebView2Text" Grid.Row="2" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Translate AboutLabelSshNet}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutSshNetText" Grid.Row="3" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Translate AboutLabelBuildDate}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutBuildDateText" Grid.Row="4" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Data section -->
                    <Border Padding="20" Margin="0,12,0,0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusXl}">
                        <StackPanel>
                            <TextBlock Text="{loc:Translate AboutSectionData}" FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate AboutLabelServers}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutServersText" Grid.Row="0" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate AboutLabelGateways}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutGatewaysText" Grid.Row="1" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate AboutLabelConfigPath}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutConfigPathText" Grid.Row="2" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" ToolTipService.ShowOnDisabled="True" Margin="0,0,0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Translate AboutLabelLogPath}"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AboutLogPathText" Grid.Row="3" Grid.Column="1"
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" ToolTipService.ShowOnDisabled="True" Margin="0,0,0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <Border Padding="20" Margin="0,12,0,0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusXl}">
                        <StackPanel>
                            <TextBlock Text="{loc:Translate AboutSectionLinks}" FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <Button x:Name="AboutBtnOpenConfig" Content="{loc:Translate AboutBtnOpenConfig}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8" Padding="12,6" Click="OnAboutOpenConfigClick"/>
                                <Button x:Name="AboutBtnOpenLogs" Content="{loc:Translate AboutBtnOpenLogs}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8" Padding="12,6" Click="OnAboutOpenLogsClick"/>
                                <Button x:Name="AboutBtnGitHub" Content="{loc:Translate AboutBtnGitHub}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8" Padding="12,6" Click="OnAboutGitHubClick"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Sessions overlay removed — now inside Servers Grid Column 2 -->
        </Grid>

        <!-- Fullscreen exit chrome uses a Popup (own HWND) so it stays visible above ActiveX/WebView content. -->
        <Popup x:Name="FullscreenChromePopup"
               PlacementTarget="{Binding ElementName=MainWindowRoot}"
               Placement="Relative"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="False"
               PopupAnimation="None"
               IsOpen="False">
            <Border x:Name="FullscreenChromeRoot"
                    Opacity="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="3"
                    MouseEnter="OnFullscreenChromeMouseActivity"
                    MouseMove="OnFullscreenChromeMouseActivity">
                <Button x:Name="FullscreenBar"
                        Width="42"
                        Height="32"
                        Content="&#xE799;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBodyLarge}"
                        Click="OnExitFullscreenClick"
                        Cursor="Hand"
                        ToolTip="{loc:Translate TooltipExitFullscreenEsc}"
                        AutomationProperties.Name="{loc:Translate A11yExitFullscreen}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonBorder"
                                                        Property="Background"
                                                Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource TextOnAccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Popup>

        <Border x:Name="RdpImportDropOverlay"
                Grid.Row="1"
                Panel.ZIndex="200"
                Margin="24"
                CornerRadius="12"
                Background="{DynamicResource DragDropOverlayBackground}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="&#xE8B7;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="40"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Margin="0,12,0,0"
                           Text="{loc:Translate DialogImportRdpDropOverlay}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}"
                AutomationProperties.Name="Status">
            <DockPanel Margin="8,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}"
                           AutomationProperties.LiveSetting="Polite"/>
                <!-- Subtle F1 shortcut hint — visible when status shows default ready text -->
                <TextBlock x:Name="Mw_StatusBarShortcutHint" Text="{loc:Translate StatusBarShortcutHint}"
                           FontSize="{StaticResource FontSizeSmallCaption}"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- File sharing status -->
                    <StackPanel x:Name="Mw_SharingStatusPanel"
                                Margin="0,4,12,4"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="Mw_SharingStatus"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SuccessTextBrush}"/>
                            <Button x:Name="Mw_CopyShareUrlButton"
                                    Click="OnCopyShareUrlClick"
                                    Margin="8,0,0,0"
                                    Padding="4,2"
                                    VerticalAlignment="Center"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    ToolTip="{loc:Translate CtxMenuCopy}"
                                    AutomationProperties.Name="{loc:Translate CtxMenuCopy}">
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeCaption}"/>
                            </Button>
                        </StackPanel>
                        <StackPanel x:Name="Mw_TftpTemplatePanel"
                                    Margin="0,2,0,0"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="Mw_TftpCommandText"
                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="Mw_TftpDisabledHint"
                                   Margin="0,2,0,0"
                                   FontSize="{StaticResource FontSizeSmallCaption}"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   Text="{loc:Translate LblTftpDisabledHint}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                    <!-- Tunnel panel toggle badge -->
                    <Button x:Name="Mw_StatusTunnelToggle" Command="{Binding Tunnels.TogglePanelCommand}"
                            Padding="4,2" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            ToolTip="{loc:Translate TunnelPanelToggle}"
                            AutomationProperties.Name="{loc:Translate A11yToggleTunnelPanel}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding Tunnels.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <!-- Broadcast mode toggle -->
                    <Button x:Name="Mw_BroadcastToggleBtn" Command="{Binding Session.ToggleBroadcastCommand}"
                            ToolTip="{Binding Session.BroadcastToggleTooltip}"
                            Padding="4,2" FontSize="{StaticResource FontSizeSubtitle}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{loc:Translate A11yToggleBroadcast}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE704;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock x:Name="Mw_BroadcastLabel" Text="{loc:Translate BroadcastBadgeLabel}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarGhostButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Session.IsBroadcastMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BroadcastActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding ServerCount, Mode=OneWay}"/>
                        <Run Text=" "/>
                        <Run Text="{loc:Translate StatusBarSessions}"/>
                        <Run Text=" "/>
                        <Run Text="{loc:Translate StatusBarSeparator}"/>
                        <Run Text="{Binding Tunnels.Count, Mode=OneWay}"/>
                        <Run Text=" "/>
                        <Run Text="{loc:Translate StatusBarTunnels}"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- Quick Connect Command Palette (Ctrl+K) — uses a Popup so it gets its own
             HWND and renders above WindowsFormsHost / ActiveX surfaces (airspace fix). -->
        <Popup x:Name="CommandPalettePopup"
               IsOpen="{Binding CommandPalette.IsOpen}"
               StaysOpen="True"
               AllowsTransparency="True"
               Placement="Center"
               PlacementTarget="{Binding ElementName=MainContentArea}"
               Opened="OnCommandPaletteOpened">
            <Border MinWidth="550"
                    MaxWidth="700"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusLg}"
                    PreviewKeyDown="OnPaletteKeyDown"
                    MouseDown="OnPaletteBorderClick">
                <Border.Resources>
                    <!-- Groups palette results by their Group property so each
                         category (Servers, Tools, Snippets, Quick Connect, …)
                         renders under its own header. The converter normalises
                         empty groups to a localized fallback. -->
                    <CollectionViewSource x:Key="PaletteResultsView"
                                          Source="{Binding CommandPalette.Results}">
                        <CollectionViewSource.GroupDescriptions>
                            <PropertyGroupDescription PropertyName="Group"
                                                      Converter="{StaticResource PaletteGroupHeaderConverter}"/>
                        </CollectionViewSource.GroupDescriptions>
                    </CollectionViewSource>
                </Border.Resources>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.4" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="PaletteModeLabel"
                               Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold"
                               Visibility="Collapsed"
                               Margin="14,8,14,0"/>
                    <TextBox x:Name="PaletteInput"
                             Text="{Binding CommandPalette.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding CommandPalette.Placeholder}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             FontSize="{StaticResource FontSizeSubtitle}" Padding="14,10"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             AutomationProperties.Name="{loc:Translate PaletteSearchPlaceholder}"/>
                    <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                    <ListBox x:Name="PaletteResultsList"
                             ItemsSource="{Binding Source={StaticResource PaletteResultsView}}"
                             SelectedItem="{Binding CommandPalette.SelectedItem}"
                             MaxHeight="450"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="OnPaletteItemDoubleClick">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,10,14,4"
                                                Background="Transparent">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.85"/>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="10,6">
                                    <Border DockPanel.Dock="Left"
                                            Width="3"
                                            CornerRadius="1.5"
                                            Margin="0,2,8,2"
                                            VerticalAlignment="Stretch">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PaletteActiveIndicatorConverter}">
                                                <Binding Path="ConnectionType"/>
                                                <Binding Path="ConnectionState"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>

                                    <Grid DockPanel.Dock="Right"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center">
                                        <Border CornerRadius="{StaticResource CornerRadiusXs}"
                                                Opacity="0.15">
                                            <Border.Background>
                                                <MultiBinding Converter="{StaticResource ConnectionTypeToBrushConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                </MultiBinding>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Margin="6,2"
                                                   Text="{Binding ConnectionTypeBadge}"
                                                   FontSize="{StaticResource FontSizeSmallCaption}"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource ConnectionTypeToBrushConverter}">
                                                    <Binding Path="ConnectionType"/>
                                                    <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0"
                                                  Width="14"
                                                  Height="14"
                                                  Stretch="Uniform"
                                                  Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,6,0">
                                                <Path.Fill>
                                                    <MultiBinding Converter="{StaticResource TypeToColorConverter}">
                                                        <Binding Path="ConnectionType"/>
                                                        <Binding Path="DataContext.ThemeRevision" ElementName="MainWindowRoot"/>
                                                    </MultiBinding>
                                                </Path.Fill>
                                            </Path>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="20,2,0,0">
                                            <TextBlock Text="{Binding Endpoint}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       Visibility="{Binding Endpoint, Converter={StaticResource NullToVisibilityConverter}}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="220"/>
                                            <TextBlock Text="{Binding Username, StringFormat={}  ·  {0}}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       Visibility="{Binding Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding ProjectName, StringFormat={}  ·  {0}}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Visibility="{Binding ProjectName, Converter={StaticResource NullToVisibilityConverter}}"/>
<!-- group now rendered as a section header above the row, suffix removed -->
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="2,0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="{StaticResource CornerRadiusSm}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource CardBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource HighlightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <TextBlock x:Name="Mw_PaletteNoResults" Text="{loc:Translate QuickConnectNoResults}"
                               FontSize="{StaticResource FontSizeBody}" Padding="14,10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding CommandPalette.HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock x:Name="Mw_PaletteHints" Text="{loc:Translate QuickConnectHints}"
                               FontSize="{StaticResource FontSizeCaption}" Padding="14,6"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ============================================================ -->
        <!-- ONBOARDING OVERLAY (first launch)                             -->
        <!-- ============================================================ -->
        <Border x:Name="OnboardingOverlay"
                Grid.Row="0" Grid.RowSpan="3"
                Panel.ZIndex="500"
                Focusable="True"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                Background="{DynamicResource OverlayBackground}"
                AutomationProperties.Name="{loc:Translate A11yOnboardingOverlay}">
            <Border.InputBindings>
                <KeyBinding Key="Escape" Command="{Binding EscapeCommand}"/>
            </Border.InputBindings>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="480" MaxWidth="560"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}"
                    Padding="32,24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="12" Opacity="0.3" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Step indicator dots -->
                    <ItemsControl ItemsSource="{Binding StepIndicatorStates}"
                                  HorizontalAlignment="Center" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="8" Height="8" Margin="4,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource TextDisabledBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Step content (swapped via VM) -->
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SubtitleText}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <!-- Navigation buttons -->
                    <DockPanel HorizontalAlignment="Stretch"
                               KeyboardNavigation.TabNavigation="Cycle">
                        <Button Content="{Binding SkipLabel}"
                                Command="{Binding SkipCommand}"
                                AutomationProperties.Name="{Binding SkipLabel}"
                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                Padding="12,6" FontSize="{StaticResource FontSizeBody}"
                                DockPanel.Dock="Left"
                                Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button x:Name="OnboardingNextBtn"
                                Content="{Binding NextLabel}"
                                Command="{Binding NextCommand}"
                                AutomationProperties.Name="{Binding NextLabel}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="20,8" FontSize="{StaticResource FontSizeBody}"
                                HorizontalAlignment="Right"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
