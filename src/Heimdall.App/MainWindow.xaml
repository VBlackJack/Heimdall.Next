<Window x:Class="Heimdall.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <!-- Left: App title + navigation tabs -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Heimdall"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>

                    <RadioButton x:Name="TabServers"
                                 Content="Servers"
                                 GroupName="NavTabs"
                                 IsChecked="True"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabTunnels"
                                 Content="Tunnels"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabScheduled"
                                 Content="Scheduled"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"
                                 Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabSettings"
                                 Content="Settings"
                                 GroupName="NavTabs"
                                 Style="{DynamicResource ToolbarTabStyle}"/>
                </StackPanel>

                <!-- Right: Quick actions -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="+ Add"
                            Command="{Binding ServerList.AddServerCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="4,0"/>
                    <TextBox Width="200"
                             Text="{Binding ServerList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Tag="Search servers... (Ctrl+F)"
                             Margin="4,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="240" MinWidth="160" MaxWidth="400"/>
                <!-- Splitter -->
                <ColumnDefinition Width="Auto"/>
                <!-- Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR: Projects, groups, filters -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Projects section -->
                        <TextBlock Text="PROJECTS"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,8,0,4"/>
                        <ItemsControl x:Name="ProjectList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Cursor="Hand" Margin="0,1">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Groups section -->
                        <TextBlock Text="GROUPS"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,16,0,4"/>
                        <TreeView x:Name="GroupTree"
                                  Style="{DynamicResource ThemedTreeViewStyle}"
                                  ItemContainerStyle="{DynamicResource ThemedTreeViewItemStyle}"/>

                        <!-- Connection type filters -->
                        <TextBlock Text="TYPE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,16,0,4"/>
                        <StackPanel Margin="0,2">
                            <CheckBox Content="RDP" IsChecked="True" Margin="8,2"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <CheckBox Content="SSH" IsChecked="True" Margin="8,2"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <CheckBox Content="SFTP" IsChecked="True" Margin="8,2"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          ShowsPreview="True"/>

            <!-- CONTENT AREA -->
            <Grid Grid.Column="2">
                <TabControl x:Name="ContentTabs"
                            Style="{DynamicResource ThemedTabControlStyle}"
                            BorderThickness="0">

                    <!-- Servers tab -->
                    <TabItem Style="{DynamicResource ThemedTabItemStyle}">
                        <TabItem.Header>
                            <TextBlock Text="Servers"/>
                        </TabItem.Header>
                        <DataGrid x:Name="ServerGrid"
                                  ItemsSource="{Binding ServerList.Servers}"
                                  SelectedItem="{Binding ServerList.SelectedServer}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  Style="{DynamicResource ThemedDataGridStyle}"
                                  ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                                  RowStyle="{DynamicResource ThemedDataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Server" Binding="{Binding RemoteServer}" Width="*"/>
                                <DataGridTemplateColumn Header="Type" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding ConnectionType,
                                                        Converter={StaticResource ConnectionTypeToBrushConverter},
                                                        FallbackValue={StaticResource InfoBrush}}">
                                                <TextBlock Text="{Binding ConnectionType}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                         Fill="{Binding ConnectionState,
                                                             Converter={StaticResource ConnectionStateToBrushConverter},
                                                             FallbackValue={StaticResource TextSecondaryBrush}}"/>
                                                <TextBlock Text="{Binding ConnectionState}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Active sessions placeholder (dynamic tabs added at runtime) -->
                </TabControl>
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel Margin="8,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="11"/>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding ServerCount, Mode=OneWay}"/>
                        <Run Text=" servers | "/>
                        <Run Text="{Binding TunnelCount, Mode=OneWay}"/>
                        <Run Text=" tunnels"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
