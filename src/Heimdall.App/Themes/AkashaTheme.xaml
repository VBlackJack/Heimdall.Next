<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Akasha — Dark crimson/blood variant, Queen of the Damned -->
    <Color x:Key="PrimaryColor">#2C2428</Color>
    <Color x:Key="SecondaryColor">#241C22</Color>
    <Color x:Key="SurfaceColor">#40343C</Color>
    <Color x:Key="AccentColor">#F08888</Color>
    <Color x:Key="AccentHoverColor">#F8A8A8</Color>
    <Color x:Key="AccentPressedColor">#D07070</Color>
    <Color x:Key="TextPrimaryColor">#F8F2F4</Color>
    <Color x:Key="TextSecondaryColor">#BCA8B2</Color>
    <Color x:Key="TextDisabledColor">#907882</Color>
    <Color x:Key="SuccessColor">#6CF7A1</Color>
    <Color x:Key="WarningColor">#FFB870</Color>
    <Color x:Key="ErrorColor">#FF7080</Color>
    <Color x:Key="InfoColor">#88D8F8</Color>
    <Color x:Key="BorderColor">#6E5864</Color>
    <Color x:Key="HighlightColor">#4E3E48</Color>

    <!-- WCAG-safe text variants for semantic colors on dark backgrounds -->
    <Color x:Key="SuccessTextColor">#6CF7A1</Color>
    <Color x:Key="WarningTextColor">#FFB870</Color>
    <Color x:Key="ErrorTextColor">#FF7080</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#A08892"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TreeViewIndentGuideBrush" Color="{StaticResource BorderColor}" Opacity="0.35"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (dark theme) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#68A0FF"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#6CF7A1"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#88D8F8"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#BCA8B2"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#6070C8"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#F08888"/>

    <!-- Connection type badge colors -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#68A0FF"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#6CF7A1"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#88D8F8"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#6070C8"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#BCA8B2"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#F08888"/>
    <Color x:Key="ToolBadgeColor">#40D8B8</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#40D8B8"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#68A0FF"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#D0A0F0"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#40D8B8"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#F08888"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#6098D0</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#70B050</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#E87830</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (dark on bright badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#181418"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#181418"/>

    <!-- Keyboard focus indicator -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#88D8F8"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B32C2428"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#662C2428"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44FF5555"/>

    <!-- File type icon colors -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#6CF7A1"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#88D8F8"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#BCA8B2"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#FFB870"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#F08888"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#FFE798"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#BCA8B2"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#2C2428"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical across all themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
