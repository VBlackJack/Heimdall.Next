<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Dracula Theme — https://draculatheme.com/contribute -->
    <Color x:Key="PrimaryColor">#282A36</Color>
    <Color x:Key="SecondaryColor">#21222C</Color>
    <Color x:Key="SurfaceColor">#44475A</Color>
    <Color x:Key="AccentColor">#BD93F9</Color>
    <Color x:Key="AccentHoverColor">#D6ACFF</Color>
    <Color x:Key="AccentPressedColor">#A87AF7</Color>
    <Color x:Key="TextPrimaryColor">#F8F8F2</Color>
    <Color x:Key="TextSecondaryColor">#7986AC</Color>
    <Color x:Key="TextDisabledColor">#5A5D6A</Color>
    <Color x:Key="SuccessColor">#50FA7B</Color>
    <Color x:Key="WarningColor">#FFB86C</Color>
    <Color x:Key="ErrorColor">#FF5555</Color>
    <Color x:Key="InfoColor">#8BE9FD</Color>
    <Color x:Key="BorderColor">#6272A4</Color>
    <Color x:Key="HighlightColor">#343746</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (dark theme) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#5B9FFF"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#A0A0B0"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#4B6FD1"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#BD93F9"/>

    <!-- Connection type badge colors (Dracula palette) -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#FFB86C"/>
    <Color x:Key="ToolBadgeColor">#36D7B7</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#36D7B7"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#5B9FFF"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#36D7B7"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#5B9BD5</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#70AD47</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#ED7D31</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- Badge text (dark on bright badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#282A36"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#A0000000"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#66282A36"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44FF5555"/>

    <!-- Scrollbar (Dracula) -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#6B7282"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#282A36"/>

</ResourceDictionary>
