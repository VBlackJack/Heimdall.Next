<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dialog Form Label (secondary text, body size, bottom margin) -->
    <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Dialog Section Title -->
    <Style x:Key="DialogSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,4,0,8"/>
    </Style>

    <!-- Dialog Section Description -->
    <Style x:Key="DialogSectionDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <!-- Dialog Hint Text (caption size, wrapping) -->
    <Style x:Key="DialogHintTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <!-- Dialog Section Card (rounded border with padding) -->
    <Style x:Key="DialogSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- Dialog Form TextBox -->
    <Style x:Key="DialogFormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- Dialog Form ComboBox -->
    <Style x:Key="DialogFormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- Dialog Form PasswordBox -->
    <Style x:Key="DialogFormPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- Dialog Form CheckBox -->
    <Style x:Key="DialogFormCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- Inline field validation error (shown below invalid fields) -->
    <Style x:Key="FieldValidationErrorStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

</ResourceDictionary>
