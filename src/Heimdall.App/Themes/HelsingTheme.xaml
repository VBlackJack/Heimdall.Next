<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Helsing — Warm ivory paper light variant -->
    <Color x:Key="PrimaryColor">#F2EDE6</Color>
    <Color x:Key="SecondaryColor">#E6E0D8</Color>
    <Color x:Key="SurfaceColor">#DAD4CC</Color>
    <Color x:Key="AccentColor">#7858B8</Color>
    <Color x:Key="AccentHoverColor">#9070D0</Color>
    <Color x:Key="AccentPressedColor">#6248A0</Color>
    <Color x:Key="TextPrimaryColor">#1C1A18</Color>
    <Color x:Key="TextSecondaryColor">#4A4640</Color>
    <Color x:Key="TextDisabledColor">#8A8680</Color>
    <Color x:Key="SuccessColor">#0C7A0C</Color>
    <Color x:Key="WarningColor">#C45418</Color>
    <Color x:Key="ErrorColor">#BE2C2C</Color>
    <Color x:Key="InfoColor">#006CB0</Color>
    <Color x:Key="BorderColor">#8A8680</Color>
    <Color x:Key="HighlightColor">#CCC8C0</Color>

    <!-- WCAG-safe text variants for semantic colors on light backgrounds -->
    <Color x:Key="SuccessTextColor">#065806</Color>
    <Color x:Key="WarningTextColor">#963E10</Color>
    <Color x:Key="ErrorTextColor">#961E1E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#6A6660"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TreeViewIndentGuideBrush" Color="{StaticResource BorderColor}" Opacity="0.35"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (light theme — darker for readability) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#0C7A0C"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#9A5808"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#006CB0"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#585450"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#2558E0"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#4820B0"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#7858B8"/>

    <!-- Connection type badge colors -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#0C7A0C"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#9A5808"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#006CB0"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#2558E0"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#4820B0"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#585450"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#7858B8"/>
    <Color x:Key="ToolBadgeColor">#0C8070</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#0C8070"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#9A5808"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#7858B8"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#0C8070"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#A01448"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#2868A0</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#2C7848</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#B04C1C</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (light on dark badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#F2EDE6"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#F2EDE6"/>

    <!-- Keyboard focus indicator -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#006CB0"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B3F2EDE6"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#66F2EDE6"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44BE2C2C"/>

    <!-- File type icon colors -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#0C7A0C"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#006CB0"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#4A4640"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#C45418"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#A01448"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#807014"/>

    <!-- Scrollbar colors -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#8A8680"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#F2EDE6"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical across all themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
