<!-- ====================================================================
     ICON CONVENTION — Two-Tier System
     ====================================================================

     1. VECTOR GEOMETRIES (this file)
        Key pattern: Geo.<Category>.<Name>
        Used for all DOMAIN-SPECIFIC icons: protocols, tools, status, tree nodes.
        Consumed via XAML Path elements + ConnectionTypeToGeometryConverter,
        ConnectionStateToGeometryConverter, and ToolRegistry static lookups.
        Categories: Protocol (8), Tree (7), Status (5), Tool (33).

     2. SEGOE MDL2 ASSETS (inline in XAML)
        Used for STANDARD UI CHROME only: toolbar buttons, navigation,
        context menus, file type glyphs (FileIconConverter), message dialog
        status icons, and decorative empty-state glyphs.
        These are system-standard icons that render pixel-perfect at all sizes
        and do not need a centralized registry.

     Adding a new tool: one entry in ToolRegistry.cs (with Geo.Tool.* key)
     + one Geometry in this file + one View class. No XAML triggers needed.
     ==================================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================ -->
    <!-- Reusable Path styles                                             -->
    <!-- ================================================================ -->

    <Style x:Key="GeoIconSmall" TargetType="Path">
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
    </Style>

    <Style x:Key="GeoIcon" TargetType="Path">
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
