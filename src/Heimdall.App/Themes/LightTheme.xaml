<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Colors -->
    <Color x:Key="PrimaryColor">#F5F5F5</Color>
    <Color x:Key="SecondaryColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#FAFAFA</Color>
    <Color x:Key="AccentColor">#5B21B6</Color>
    <Color x:Key="AccentHoverColor">#4C1D95</Color>
    <Color x:Key="AccentPressedColor">#3B0F7A</Color>
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#4B5563</Color>
    <Color x:Key="TextDisabledColor">#6B7888</Color>
    <Color x:Key="SuccessColor">#15803D</Color>
    <Color x:Key="WarningColor">#B45309</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="InfoColor">#1D4ED8</Color>
    <Color x:Key="BorderColor">#708090</Color>
    <Color x:Key="HighlightColor">#EEF2FF</Color>

    <!-- WCAG-safe text variants for semantic colors on light backgrounds -->
    <Color x:Key="SuccessTextColor">#15803D</Color>
    <Color x:Key="WarningTextColor">#B45309</Color>
    <Color x:Key="ErrorTextColor">#DC2626</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (light theme — darker for readability on white) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#0D6E3F"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#B8620A"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#0891B2"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#7C3AED"/>

    <!-- Connection type badge colors (aligned with protocol accent brushes) -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#0D6E3F"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#B8620A"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#0891B2"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#7C3AED"/>
    <Color x:Key="ToolBadgeColor">#0D9488</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#0D9488"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#0D9488"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#DB2777"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#2B6CB0</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#2F855A</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#C05621</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes (for text rendered on light backgrounds) -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (white on dark badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#FFFFFF"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF"/>

    <!-- Keyboard focus indicator (high-contrast ring for accessibility) -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#1D4ED8"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#A0FFFFFF"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#66E8E8E8"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44DC2626"/>

    <!-- File type icon colors (WCAG-safe on light backgrounds) -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#0891B2"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#B45309"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#BE185D"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#7C3AED"/>

    <!-- Scrollbar colors -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#999999"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#F5F5F5"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical in both themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
