<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Colors -->
    <Color x:Key="PrimaryColor">#F5F5F5</Color>
    <Color x:Key="SecondaryColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#FAFAFA</Color>
    <Color x:Key="AccentColor">#6D28D9</Color>
    <Color x:Key="AccentHoverColor">#5B21B6</Color>
    <Color x:Key="AccentPressedColor">#4C1D95</Color>
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#4B5563</Color>
    <Color x:Key="TextDisabledColor">#8892A2</Color>
    <Color x:Key="SuccessColor">#15803D</Color>
    <Color x:Key="WarningColor">#B45309</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="InfoColor">#1D4ED8</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    <Color x:Key="HighlightColor">#EEF2FF</Color>

    <!-- WCAG-safe text variants for semantic colors on light backgrounds -->
    <Color x:Key="SuccessTextColor">#15803D</Color>
    <Color x:Key="WarningTextColor">#B45309</Color>
    <Color x:Key="ErrorTextColor">#DC2626</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (light theme — darker for readability on white) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#0891B2"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#7C3AED"/>

    <!-- Connection type badge colors -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#D97706"/>
    <Color x:Key="ToolBadgeColor">#0D9488</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#0D9488"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#0D9488"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#2B6CB0</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#2F855A</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#C05621</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes (for text rendered on light backgrounds) -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (white on dark badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#FFFFFF"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#A0FFFFFF"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#66E8E8E8"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44DC2626"/>

    <!-- Scrollbar colors -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#C0C0C0"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#F5F5F5"/>

</ResourceDictionary>
