<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Renfield — Cool slate mid-light variant, Dracula's loyal servant -->
    <Color x:Key="PrimaryColor">#B8BCC8</Color>
    <Color x:Key="SecondaryColor">#AAAFBC</Color>
    <Color x:Key="SurfaceColor">#9EA3B2</Color>
    <Color x:Key="AccentColor">#6B4DAE</Color>
    <Color x:Key="AccentHoverColor">#8468C4</Color>
    <Color x:Key="AccentPressedColor">#573D96</Color>
    <Color x:Key="TextPrimaryColor">#141620</Color>
    <Color x:Key="TextSecondaryColor">#363A4A</Color>
    <Color x:Key="TextDisabledColor">#6E7286</Color>
    <Color x:Key="SuccessColor">#0A6B0A</Color>
    <Color x:Key="WarningColor">#B84E18</Color>
    <Color x:Key="ErrorColor">#B32828</Color>
    <Color x:Key="InfoColor">#0065AB</Color>
    <Color x:Key="BorderColor">#6E7286</Color>
    <Color x:Key="HighlightColor">#A4A8B6</Color>

    <!-- WCAG-safe text variants for semantic colors on mid-light backgrounds -->
    <Color x:Key="SuccessTextColor">#055405</Color>
    <Color x:Key="WarningTextColor">#8C3A0E</Color>
    <Color x:Key="ErrorTextColor">#8C1C1C</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#555A6C"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TreeViewIndentGuideBrush" Color="{StaticResource BorderColor}" Opacity="0.35"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (mid-light — strong saturation for readability) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#1A44C0"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#0A6B0A"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#8E5504"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#0065AB"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#484C5C"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#2056D0"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#3F1AA0"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#6B4DAE"/>

    <!-- Connection type badge colors -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#1A44C0"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#0A6B0A"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#8E5504"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#0065AB"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#2056D0"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#3F1AA0"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#484C5C"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#6B4DAE"/>
    <Color x:Key="ToolBadgeColor">#0B766A</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#0B766A"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#1A44C0"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#8E5504"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#6B4DAE"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#0B766A"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#901242"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#24609E</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#287550</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#A84C1C</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (light on dark badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#ECEEF2"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#ECEEF2"/>

    <!-- Keyboard focus indicator -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#0065AB"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B3B8BCC8"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#66B8BCC8"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44B32828"/>

    <!-- File type icon colors -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#0A6B0A"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#0065AB"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#363A4A"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#B84E18"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#901242"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#7A6E12"/>

    <!-- Scrollbar colors -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#6E7286"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#B8BCC8"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical across all themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
