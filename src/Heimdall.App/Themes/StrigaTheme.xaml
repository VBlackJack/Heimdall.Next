<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Striga — Dark forest green variant, terminal-inspired -->
    <Color x:Key="PrimaryColor">#1C2A22</Color>
    <Color x:Key="SecondaryColor">#16221A</Color>
    <Color x:Key="SurfaceColor">#2E3E34</Color>
    <Color x:Key="AccentColor">#80E8A8</Color>
    <Color x:Key="AccentHoverColor">#A0F0C0</Color>
    <Color x:Key="AccentPressedColor">#60C888</Color>
    <Color x:Key="TextPrimaryColor">#EAF5EE</Color>
    <Color x:Key="TextSecondaryColor">#98B8A6</Color>
    <Color x:Key="TextDisabledColor">#6E9480</Color>
    <Color x:Key="SuccessColor">#6CF7A1</Color>
    <Color x:Key="WarningColor">#FFBE75</Color>
    <Color x:Key="ErrorColor">#FF6C7A</Color>
    <Color x:Key="InfoColor">#80D8F0</Color>
    <Color x:Key="BorderColor">#4A6856</Color>
    <Color x:Key="HighlightColor">#384E40</Color>

    <!-- WCAG-safe text variants for semantic colors on dark backgrounds -->
    <Color x:Key="SuccessTextColor">#6CF7A1</Color>
    <Color x:Key="WarningTextColor">#FFBE75</Color>
    <Color x:Key="ErrorTextColor">#FF6C7A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#80A690"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TreeViewIndentGuideBrush" Color="{StaticResource BorderColor}" Opacity="0.35"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (dark theme) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#5BA0FF"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#80E8A8"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#80D8F0"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#98B8A6"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#5878C8"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#80E8A8"/>

    <!-- Connection type badge colors -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#5BA0FF"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#80E8A8"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#80D8F0"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#5878C8"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#98B8A6"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#80E8A8"/>
    <Color x:Key="ToolBadgeColor">#40D8B8</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#40D8B8"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#5BA0FF"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#F5A020"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#C0A0F0"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#80E8A8"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#FF80C8"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#5B9BD5</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#70B050</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#E88030</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (dark on bright badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#0C1610"/>

    <!-- Explicit white text for content displayed on accent-colored backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#0C1610"/>

    <!-- Keyboard focus indicator -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#80D8F0"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B31C2A22"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#661C2A22"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44FF5555"/>

    <!-- File type icon colors -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#80E8A8"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#80D8F0"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#98B8A6"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#FFBE75"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#FF80C8"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#FFE798"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#98B8A6"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#1C2A22"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical across all themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
