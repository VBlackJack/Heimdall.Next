<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="CommonControls.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Dracula VanHelsing Theme — https://draculatheme.com/contribute -->
    <Color x:Key="PrimaryColor">#18211C</Color>
    <Color x:Key="SecondaryColor">#111813</Color>
    <Color x:Key="SurfaceColor">#2D4034</Color>
    <Color x:Key="AccentColor">#B8A5FF</Color>
    <Color x:Key="AccentHoverColor">#CCBEFF</Color>
    <Color x:Key="AccentPressedColor">#9E8CE0</Color>
    <Color x:Key="TextPrimaryColor">#F6FFF4</Color>
    <Color x:Key="TextSecondaryColor">#ACC0B4</Color>
    <Color x:Key="TextDisabledColor">#8DA597</Color>
    <Color x:Key="SuccessColor">#7CFF7A</Color>
    <Color x:Key="WarningColor">#FFCC72</Color>
    <Color x:Key="ErrorColor">#FF756C</Color>
    <Color x:Key="InfoColor">#8DF5E6</Color>
    <Color x:Key="BorderColor">#8DA597</Color>
    <Color x:Key="HighlightColor">#395645</Color>

    <!-- WCAG-safe text variants for semantic colors on dark backgrounds -->
    <Color x:Key="SuccessTextColor">#7CFF7A</Color>
    <Color x:Key="WarningTextColor">#FFCC72</Color>
    <Color x:Key="ErrorTextColor">#FF756C</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9DAAA2"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TreeViewIndentGuideBrush" Color="{StaticResource BorderColor}" Opacity="0.35"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Protocol accent color brushes (dark theme) -->
    <SolidColorBrush x:Key="ProtocolRdpBrush" Color="#5B9FFF"/>
    <SolidColorBrush x:Key="ProtocolSshBrush" Color="#7CFF7A"/>
    <SolidColorBrush x:Key="ProtocolSftpBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ProtocolVncBrush" Color="#8DF5E6"/>
    <SolidColorBrush x:Key="ProtocolTelnetBrush" Color="#B0B4C8"/>
    <SolidColorBrush x:Key="ProtocolFtpBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="ProtocolCitrixBrush" Color="#4B6FD1"/>
    <SolidColorBrush x:Key="ProtocolLocalBrush" Color="#B8A5FF"/>

    <!-- Connection type badge colors (aligned with protocol accent brushes) -->
    <SolidColorBrush x:Key="RdpBadgeBrush" Color="#5B9FFF"/>
    <SolidColorBrush x:Key="SshBadgeBrush" Color="#7CFF7A"/>
    <SolidColorBrush x:Key="SftpBadgeBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="VncBadgeBrush" Color="#8DF5E6"/>
    <SolidColorBrush x:Key="FtpBadgeBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="CitrixBadgeBrush" Color="#4B6FD1"/>
    <SolidColorBrush x:Key="TelnetBadgeBrush" Color="#B0B4C8"/>
    <SolidColorBrush x:Key="LocalBadgeBrush" Color="#B8A5FF"/>
    <Color x:Key="ToolBadgeColor">#36D7B7</Color>
    <SolidColorBrush x:Key="ToolBadgeBrush" Color="#36D7B7"/>
    <!-- Per-category tool icon brushes -->
    <SolidColorBrush x:Key="ToolNetworkBrush" Color="#5B9FFF"/>
    <SolidColorBrush x:Key="ToolSecurityBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ToolEncodingBrush" Color="#B8A5FF"/>
    <SolidColorBrush x:Key="ToolSystemBrush" Color="#36D7B7"/>
    <SolidColorBrush x:Key="ToolExternalBrush" Color="#FF97C8"/>

    <!-- JWT section colors -->
    <Color x:Key="JwtHeaderColor">#5B9BD5</Color>
    <SolidColorBrush x:Key="JwtHeaderBrush" Color="{StaticResource JwtHeaderColor}"/>
    <Color x:Key="JwtPayloadColor">#70AD47</Color>
    <SolidColorBrush x:Key="JwtPayloadBrush" Color="{StaticResource JwtPayloadColor}"/>
    <Color x:Key="JwtSignatureColor">#ED7D31</Color>
    <SolidColorBrush x:Key="JwtSignatureBrush" Color="{StaticResource JwtSignatureColor}"/>

    <!-- WCAG-safe semantic text brushes (for text rendered on dark backgrounds) -->
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>

    <!-- Badge text (dark on bright badge backgrounds) -->
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#0A100C"/>

    <!-- WCAG-safe dark text for content displayed on light pastel accent backgrounds -->
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#18211C"/>

    <!-- Keyboard focus indicator (high-contrast ring for accessibility) -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#8DF5E6"/>

    <!-- Overlay and feedback brushes -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B3000000"/>
    <SolidColorBrush x:Key="DragDropOverlayBackground" Color="#6618211C"/>
    <SolidColorBrush x:Key="BroadcastActiveBrush" Color="#44FF5555"/>

    <!-- File type icon colors (Dracula palette) -->
    <SolidColorBrush x:Key="FileScriptBrush" Color="#7CFF7A"/>
    <SolidColorBrush x:Key="FileConfigBrush" Color="#8DF5E6"/>
    <SolidColorBrush x:Key="FileDocumentBrush" Color="#ACC0B4"/>
    <SolidColorBrush x:Key="FileArchiveBrush" Color="#FFCC72"/>
    <SolidColorBrush x:Key="FileExecutableBrush" Color="#FF97C8"/>
    <SolidColorBrush x:Key="FileImageBrush" Color="#E4FF87"/>

    <!-- Scrollbar (Dracula) -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#ACC0B4"/>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#18211C"/>

    <!-- Hacker Simulator: retro-terminal aesthetic (identical in both themes) -->
    <SolidColorBrush x:Key="HackerSimBackgroundBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimSurfaceBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HackerSimToolbarBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="HackerSimBorderBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HackerSimInputBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HackerSimTextPrimaryBrush" Color="#D4FFD9"/>
    <SolidColorBrush x:Key="HackerSimTextSecondaryBrush" Color="#6FAF7C"/>
    <SolidColorBrush x:Key="HackerSimTextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HackerSimButtonForegroundBrush" Color="#777777"/>
    <SolidColorBrush x:Key="HackerSimButtonBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HackerSimAccentBrush" Color="#00FF41"/>
    <SolidColorBrush x:Key="HackerSimHighlightBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="HackerSimGlowBrush" Color="#1000FF41"/>
    <SolidColorBrush x:Key="HackerSimGlowStrongBrush" Color="#2200FF41"/>
    <SolidColorBrush x:Key="HackerSimOverlayBrush" Color="#16FFFFFF"/>

</ResourceDictionary>
