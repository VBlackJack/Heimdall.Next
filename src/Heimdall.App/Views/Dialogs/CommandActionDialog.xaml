<Window x:Class="Heimdall.App.Views.Dialogs.CommandActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:CommandActionDialogViewModel}"
        Title="{Binding DialogTitle}"
        Width="620" SizeToContent="Height" MaxHeight="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="400"
        ShowInTaskbar="False"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ FORM FIELDS (scrollable) ═══════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Title -->
                <TextBlock x:Name="LblTitle" Style="{StaticResource DialogLabelStyle}"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         MaxLength="200" x:Name="TxtTitle" TabIndex="0"/>
                <TextBlock Text="{Binding TitleError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding TitleError, Converter={StaticResource NullToVis}}"/>

                <!-- Category (editable ComboBox) -->
                <TextBlock x:Name="LblCategory" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableCategories}"
                          Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          Style="{StaticResource DialogFormComboBoxStyle}"
                          x:Name="CmbCategory" TabIndex="1"/>
                <TextBlock Text="{Binding CategoryError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding CategoryError, Converter={StaticResource NullToVis}}"/>

                <!-- Platform + Risk (horizontal) -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblPlatform" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="CmbPlatform"
                                  SelectedIndex="{Binding Platform}"
                                  Style="{StaticResource DialogFormComboBoxStyle}" TabIndex="2">
                            <ComboBoxItem Content="Windows"/>
                            <ComboBoxItem Content="Linux"/>
                            <ComboBoxItem Content="Both"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblRisk" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="CmbRisk"
                                  SelectedIndex="{Binding Level}"
                                  Style="{StaticResource DialogFormComboBoxStyle}" TabIndex="3">
                            <ComboBoxItem x:Name="RiskInfo" Content="Info"/>
                            <ComboBoxItem x:Name="RiskRun" Content="Run"/>
                            <ComboBoxItem x:Name="RiskDangerous" Content="Dangerous"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <TextBlock x:Name="LblDescription" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="60" VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="2000" TabIndex="4"/>

                <!-- ── Windows Template ────────────────────── -->
                <StackPanel x:Name="WindowsSection"
                            Visibility="{Binding ShowWindowsSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="LblWindowsSection"
                           Style="{StaticResource DialogSectionTitleStyle}"
                           Margin="0,16,0,4"/>

                <TextBlock x:Name="LblWinPattern" Style="{StaticResource DialogLabelStyle}"/>
                <TextBox Text="{Binding WindowsPattern, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         FontFamily="Consolas" TabIndex="5"/>

                <TextBlock x:Name="LblWinName" Style="{StaticResource DialogLabelStyle}" Margin="0,4,0,4"/>
                <TextBox Text="{Binding WindowsTemplateName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}" TabIndex="6"/>

                <!-- Windows parameters -->
                <Grid Margin="0,8,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/><ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="LblWinParamName" Text="Name" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="LblWinParamLabel" Text="Label" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" x:Name="LblWinParamType" Text="Type" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding WindowsParameters}" Margin="0,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" Margin="0,0,4,0" Padding="4,3"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" Padding="4,3"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{x:Static vm:ParameterEntryVm.AvailableTypes}"
                                              SelectedValue="{Binding Type}" Margin="0,0,4,0"
                                              FontSize="{StaticResource FontSizeCaption}"/>
                                    <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="10" Width="20" Height="20"
                                        Command="{Binding DataContext.RemoveWindowsParameterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{DynamicResource ToolbarGhostButtonStyle}"/>
                                </Grid>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" Padding="4,3"
                                             Tag="{loc:Translate ToolCmdLibDialogParamDefault}"
                                             FontSize="{StaticResource FontSizeSmallCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding Required}"
                                              Content="{loc:Translate ToolCmdLibDialogParamRequired}"
                                              FontSize="{StaticResource FontSizeSmallCaption}"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button x:Name="BtnAddWinParam" Content="+ Parameter"
                        Command="{Binding AddWindowsParameterCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0" TabIndex="7"/>
                </StackPanel>

                <!-- ── Linux Template ──────────────────────── -->
                <StackPanel x:Name="LinuxSection"
                            Visibility="{Binding ShowLinuxSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="LblLinuxSection"
                           Style="{StaticResource DialogSectionTitleStyle}"
                           Margin="0,16,0,4"/>

                <TextBlock x:Name="LblLinuxPattern" Style="{StaticResource DialogLabelStyle}"/>
                <TextBox Text="{Binding LinuxPattern, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         FontFamily="Consolas" TabIndex="8"/>

                <TextBlock x:Name="LblLinuxName" Style="{StaticResource DialogLabelStyle}" Margin="0,4,0,4"/>
                <TextBox Text="{Binding LinuxTemplateName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}" TabIndex="9"/>

                <!-- Linux parameters -->
                <Grid Margin="0,8,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/><ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="LblLinuxParamName" Text="Name" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="LblLinuxParamLabel" Text="Label" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" x:Name="LblLinuxParamType" Text="Type" FontSize="{StaticResource FontSizeSmallCaption}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding LinuxParameters}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" Margin="0,0,4,0" Padding="4,3"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" Padding="4,3"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{x:Static vm:ParameterEntryVm.AvailableTypes}"
                                              SelectedValue="{Binding Type}" Margin="0,0,4,0"
                                              FontSize="{StaticResource FontSizeCaption}"/>
                                    <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="10" Width="20" Height="20"
                                        Command="{Binding DataContext.RemoveLinuxParameterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{DynamicResource ToolbarGhostButtonStyle}"/>
                                </Grid>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" Padding="4,3"
                                             Tag="{loc:Translate ToolCmdLibDialogParamDefault}"
                                             FontSize="{StaticResource FontSizeSmallCaption}"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding Required}"
                                              Content="{loc:Translate ToolCmdLibDialogParamRequired}"
                                              FontSize="{StaticResource FontSizeSmallCaption}"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button x:Name="BtnAddLinuxParam" Content="+ Parameter"
                        Command="{Binding AddLinuxParameterCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0" TabIndex="10"/>

                </StackPanel>

                <!-- Tags -->
                <TextBlock x:Name="LblTags" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}" TabIndex="11"/>

                <!-- Notes -->
                <TextBlock x:Name="LblNotes" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="50" VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="5000" TabIndex="12"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════ VALIDATION ERROR ═══════════ -->
        <TextBlock Grid.Row="1" Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="0,8,0,0" TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVis}}"/>

        <!-- ═══════════ BUTTONS ═══════════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelBtn" IsCancel="True" MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="SaveBtn" IsDefault="True" MinWidth="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
