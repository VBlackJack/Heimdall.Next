<Window x:Class="Heimdall.App.Views.Dialogs.CommandLibraryPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:CommandLibraryPickerDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="780"
        Height="620"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{loc:Translate DialogTitleCommandLibraryPicker}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="{StaticResource FontSizeBodyLarge}"
                   FontWeight="SemiBold"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:Translate LabelCommandLibraryPickerSearch}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         AutomationProperties.Name="{loc:Translate LabelCommandLibraryPickerSearch}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <TextBlock Text="{loc:Translate LabelCommandLibraryPickerPlatform}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <ComboBox SelectedValue="{Binding PlatformFilter}"
                          SelectedValuePath="Tag"
                          Style="{StaticResource DialogFormComboBoxStyle}"
                          AutomationProperties.Name="{loc:Translate LabelCommandLibraryPickerPlatform}">
                    <ComboBoxItem Content="{loc:Translate ToolCmdLibFilterPlatformAll}" Tag="{x:Null}"/>
                    <ComboBoxItem Content="{loc:Translate ToolCmdLibPlatformLinux}" Tag="Linux"/>
                    <ComboBoxItem Content="{loc:Translate ToolCmdLibPlatformWindows}" Tag="Windows"/>
                    <ComboBoxItem Content="{loc:Translate ToolCmdLibPlatformBoth}" Tag="Both"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <ListView ItemsSource="{Binding ActionsView}"
                      SelectedItem="{Binding SelectedAction}"
                      Background="{DynamicResource CardBrush}"
                      BorderThickness="0"
                      Foreground="{DynamicResource TextPrimaryBrush}">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CommandLibraryPickerItem}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Title}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Text="{Binding Category}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       Text="{Binding PlatformBadgeText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{loc:Translate LabelCommandLibraryPickerParameters}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                <ItemsControl ItemsSource="{Binding Parameters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TemplateParameterInputViewModel}">
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text=" *"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Visibility="{Binding Required, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Type}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="{Binding Label}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource DialogFormTextBoxStyle}">
                                            <Setter Property="ToolTip" Value="{Binding Description}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAutoPrefilled}" Value="True">
                                                    <Setter Property="ToolTip" Value="{loc:Translate TooltipCommandLibraryParamAutoPrefilled}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{loc:Translate BtnCancel}"
                    AutomationProperties.Name="{loc:Translate BtnCancel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="ConfirmButton"
                    Content="{loc:Translate BtnOk}"
                    AutomationProperties.Name="{loc:Translate BtnOk}"
                    Command="{Binding ConfirmCommand}"
                    MinWidth="100"
                    IsDefault="True"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
