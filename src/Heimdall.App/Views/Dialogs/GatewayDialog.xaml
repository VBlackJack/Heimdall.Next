<Window x:Class="Heimdall.App.Views.Dialogs.GatewayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:GatewayDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="500" SizeToContent="Height" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="400"
        MinHeight="400"
        ShowInTaskbar="False"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock x:Name="LblName" Style="{StaticResource DialogLabelStyle}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{Binding Text, ElementName=LblName}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         x:Name="TxtName" TabIndex="0"/>
                <TextBlock Text="{Binding NameError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding NameError, Converter={StaticResource NullToVisibilityConverter}}"/>

                <TextBlock x:Name="LblHost" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{Binding Text, ElementName=LblHost}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         x:Name="TxtHost" TabIndex="1"/>
                <TextBlock Text="{Binding HostError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding HostError, Converter={StaticResource NullToVisibilityConverter}}"/>

                <TextBlock x:Name="LblPort" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding Port}"
                         AutomationProperties.Name="{Binding Text, ElementName=LblPort}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         Width="100" HorizontalAlignment="Left"
                         MaxLength="5"
                         x:Name="TxtPort" TabIndex="2"/>
                <TextBlock Text="{Binding PortError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding PortError, Converter={StaticResource NullToVisibilityConverter}}"/>

                <TextBlock x:Name="LblUsername" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding User, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{Binding Text, ElementName=LblUsername}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         x:Name="TxtUsername" TabIndex="3"/>
                <TextBlock Text="{Binding UserError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding UserError, Converter={StaticResource NullToVisibilityConverter}}"/>

                <TextBlock x:Name="LblKeyPath" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <DockPanel>
                    <Button x:Name="BtnBrowse"
                            DockPanel.Dock="Right"
                            Command="{Binding BrowseKeyCommand}"
                            AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="4,0,0,0"
                            ToolTip=""
                            TabIndex="5"
                            Click="OnBrowseKeyClick"/>
                    <TextBox Text="{Binding KeyPath}"
                             AutomationProperties.Name="{Binding Text, ElementName=LblKeyPath}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             x:Name="TxtKeyPath" TabIndex="4"/>
                </DockPanel>

                <TextBlock x:Name="LblPassword" Text="{Binding GatewayPasswordLabel}" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             AutomationProperties.Name="{Binding Text, ElementName=LblPassword}"
                             Style="{StaticResource DialogFormPasswordBoxStyle}"
                             TabIndex="6"/>
                <TextBlock Text="{Binding GatewayAuthHint}"
                           Style="{StaticResource DialogHintTextStyle}" Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding GatewayAuthHint, Converter={StaticResource NullToVisibilityConverter}}"/>
                <StackPanel Visibility="{Binding HasKeyPath, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock x:Name="LblKeyPassphrase"
                               Style="{StaticResource DialogLabelStyle}"
                               Margin="0,12,0,4"/>
                    <PasswordBox x:Name="KeyPassphraseBox"
                                 AutomationProperties.Name="{Binding Text, ElementName=LblKeyPassphrase}"
                                 Style="{StaticResource DialogFormPasswordBoxStyle}"
                                 TabIndex="7"/>
                    <TextBlock Text="{Binding GatewayKeyPassphraseHint}"
                               Style="{StaticResource DialogHintTextStyle}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding GatewayKeyPassphraseHint, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>

                <TextBlock x:Name="LblParentGateway" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableParents}"
                          AutomationProperties.Name="{Binding Text, ElementName=LblParentGateway}"
                          SelectedValue="{Binding SelectedParentGatewayId}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="DisplayText"
                          Style="{StaticResource DialogFormComboBoxStyle}"
                          x:Name="CmbParentGateway" TabIndex="8"/>
                <TextBlock Text="{Binding GatewayChainSummary}"
                           Style="{StaticResource DialogHintTextStyle}" Margin="0,4,0,0"
                           Visibility="{Binding GatewayChainSummary, Converter={StaticResource NullToVisibilityConverter}}"/>

                <TextBlock x:Name="LblHostKeyFingerprint" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
                <TextBox Text="{Binding HostKeyFingerprint, Mode=OneWay}"
                         AutomationProperties.Name="{Binding Text, ElementName=LblHostKeyFingerprint}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         IsReadOnly="True"
                         x:Name="TxtHostKeyFingerprint"
                         TabIndex="9"/>
                <TextBlock x:Name="LblHostKeyFingerprintHint"
                           Style="{StaticResource DialogHintTextStyle}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Validation error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelBtn"
                    IsCancel="True"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="SaveBtn"
                    IsDefault="True"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
