<Window x:Class="Heimdall.App.Views.Dialogs.GatewayOverviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:GatewayOverviewDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="780"
        Height="620"
        MinWidth="640"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="{StaticResource FontSizeBodyLarge}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding Description}"
                       Margin="0,6,0,0"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,8,0">
                <TextBlock Text="{Binding GatewaySummary}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Column="1"
                    Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="4,0,4,0">
                <TextBlock Text="{Binding RoutedSessionSummary}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Column="2"
                    Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="8,0,0,0">
                <TextBlock Text="{Binding MissingReferenceSummary}"
                           Foreground="{DynamicResource WarningTextBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="2"
                      Margin="0,16,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="10,8"
                        Margin="0,0,0,10"
                        CornerRadius="6"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        Visibility="{Binding HasWarningMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding WarningMessage}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <TextBlock Text="{loc:Translate GatewayOverviewConfiguredTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="{StaticResource FontSizeBody}"/>

                <TextBlock Text="{Binding EmptyGatewaysText}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasGateways}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Gateways}"
                              Margin="0,8,0,0"
                              Visibility="{Binding HasGateways, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GatewayOverviewGatewayItemViewModel}">
                            <Border Padding="12"
                                    Margin="0,0,0,10"
                                    CornerRadius="6"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0">
                                        <Border DockPanel.Dock="Right"
                                                Padding="6,1"
                                                CornerRadius="3"
                                                Background="{DynamicResource BackgroundBrush}"
                                                BorderBrush="{DynamicResource InfoBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding SessionCountText}"
                                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding GatewayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Endpoint}"
                                                       Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ParentText}"
                                                       Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       Visibility="{Binding HasParent, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding Sessions}"
                                                  Margin="0,10,0,0"
                                                  Visibility="{Binding HasSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GatewayOverviewSessionItemViewModel}">
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Metadata}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding EmptySessionsText}"
                                               Margin="0,10,0,0"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="{StaticResource FontSizeCaption}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSessions}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding HasMissingReferences, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{loc:Translate GatewayOverviewUnresolvedTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource WarningTextBrush}"
                               FontSize="{StaticResource FontSizeBody}"/>
                    <TextBlock Text="{Binding MissingReferencesDescription}"
                               Margin="0,4,0,8"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding MissingReferences}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GatewayOverviewMissingReferenceItemViewModel}">
                                <Border Padding="12"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource WarningTextBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding SessionCountText}"
                                                       Foreground="{DynamicResource WarningTextBrush}"
                                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding HeaderText}"
                                                       Foreground="{DynamicResource WarningTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding AvailableGateways}"
                                                      SelectedValue="{Binding SelectedGatewayId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="DisplayText"
                                                      MinWidth="220"
                                                      MaxWidth="340"
                                                      HorizontalAlignment="Left"
                                                      Style="{DynamicResource DialogFormComboBoxStyle}"
                                                      AutomationProperties.Name="{loc:Translate AccessGatewayOverviewTarget}"
                                                      Visibility="{Binding HasAvailableGateways, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Grid.Column="1"
                                                    Content="{loc:Translate GatewayOverviewReassignButton}"
                                                    Command="{Binding ReassignCommand}"
                                                    Margin="8,0,0,0"
                                                    Padding="8,3"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    AutomationProperties.Name="{loc:Translate AccessGatewayOverviewReassign}"/>
                                            <Button Grid.Column="2"
                                                    Content="{loc:Translate GatewayOverviewClearButton}"
                                                    Command="{Binding ClearCommand}"
                                                    Margin="8,0,0,0"
                                                    Padding="8,3"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    AutomationProperties.Name="{loc:Translate AccessGatewayOverviewClear}"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Sessions}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:GatewayOverviewSessionItemViewModel}">
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="260"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Metadata}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Button x:Name="CloseButton"
                Grid.Row="3"
                Content="{Binding CloseLabel}"
                IsDefault="True"
                IsCancel="True"
                MinWidth="110"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Style="{DynamicResource PrimaryButtonStyle}"
                AutomationProperties.Name="{Binding CloseLabel}"
                Click="OnCloseClick"/>
    </Grid>
</Window>
