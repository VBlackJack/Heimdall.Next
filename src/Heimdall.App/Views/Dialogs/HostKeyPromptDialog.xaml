<Window x:Class="Heimdall.App.Views.Dialogs.HostKeyPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:HostKeyPromptDialogViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="{Binding HeaderText}"
        Width="640"
        SizeToContent="Height"
        MaxHeight="760"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="FingerprintBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="FontFamily" Value="{StaticResource FontFamilyMonospace}"/>
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="MinHeight" Value="62"/>
            </Style>

            <Style x:Key="AcceptButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TrustOnceButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding TrustOnceIsDefault}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WarningCardStyle" TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WarningTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogSectionDescriptionStyle}">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="HeaderIconStyle" TargetType="Path">
                <Setter Property="Width" Value="26"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Data" Value="{DynamicResource Geo.Status.Error}"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                        <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Path Style="{StaticResource HeaderIconStyle}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="{Binding HeaderText}"
                               Style="{StaticResource HeaderTitleStyle}"/>
                    <TextBlock Text="{Binding EndpointText}"
                               Margin="0,6,0,0"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource DialogSectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Style="{StaticResource DialogLabelStyle}"
                           Text="{loc:Translate HostKeyAlgorithmLabel}"/>
                <TextBlock Grid.Row="1"
                           Margin="0,0,0,12"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{Binding Algorithm}"/>

                <Grid Grid.Row="2"
                      Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource DialogLabelStyle}"
                               Text="{loc:Translate HostKeyPresentedFingerprintLabel}"/>
                    <Button x:Name="CopyFingerprintButton"
                            Grid.Column="1"
                            Content="{loc:Translate HostKeyCopyFingerprintButton}"
                            Command="{Binding CopyFingerprintCommand}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="6,2"
                            MinHeight="0"
                            FontSize="{StaticResource FontSizeCaption}"
                            ToolTip="{loc:Translate HostKeyCopyFingerprintTooltip}"
                            AutomationProperties.Name="{loc:Translate HostKeyCopyFingerprintButton}"/>
                </Grid>
                <TextBox x:Name="PresentedFingerprintBox"
                         Grid.Row="3"
                         Margin="0,0,0,12"
                         Style="{StaticResource FingerprintBoxStyle}"
                         Text="{Binding PresentedFingerprint, Mode=OneWay}"/>

                <StackPanel Grid.Row="4"
                            Visibility="{Binding IsMismatch, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Style="{StaticResource DialogLabelStyle}"
                               Text="{loc:Translate HostKeyStoredFingerprintLabel}"/>
                    <TextBox x:Name="StoredFingerprintBox"
                             Style="{StaticResource FingerprintBoxStyle}"
                             Text="{Binding StoredFingerprint, Mode=OneWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource WarningCardStyle}">
            <TextBlock Text="{Binding WarningText}"
                       Style="{StaticResource WarningTextStyle}"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="RejectButton"
                    Margin="0,0,8,0"
                    MinWidth="132"
                    IsCancel="True"
                    Content="{Binding RejectButtonText}"
                    Command="{Binding RejectCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    AutomationProperties.Name="{loc:Translate HostKeyRejectButton}"/>
            <Button x:Name="TrustOnceButton"
                    Margin="0,0,8,0"
                    MinWidth="172"
                    IsDefault="{Binding TrustOnceIsDefault}"
                    Content="{Binding TrustOnceButtonText}"
                    Command="{Binding TrustOnceCommand}"
                    Style="{StaticResource TrustOnceButtonStyle}"
                    AutomationProperties.Name="{Binding TrustOnceButtonText}"/>
            <Button x:Name="AcceptButton"
                    MinWidth="184"
                    IsDefault="{Binding AcceptIsDefault}"
                    Content="{Binding AcceptButtonText}"
                    Command="{Binding AcceptCommand}"
                    Style="{StaticResource AcceptButtonStyle}"
                    AutomationProperties.Name="{Binding AcceptButtonText}">
            </Button>
        </StackPanel>
    </Grid>
</Window>
