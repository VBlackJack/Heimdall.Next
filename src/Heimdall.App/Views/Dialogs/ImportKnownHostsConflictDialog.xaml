<Window x:Class="Heimdall.App.Views.Dialogs.ImportKnownHostsConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="980"
        Height="620"
        MinWidth="820"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="{StaticResource FontSizeBodyLarge}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding DialogHint}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  Margin="0,16,0,0"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyHostPort}"
                                    Binding="{Binding HostPort}"
                                    IsReadOnly="True"
                                    Width="180"/>
                <DataGridTextColumn Header="{loc:Translate DialogImportConflictExistingFingerprint}"
                                    Binding="{Binding ExistingFingerprintDisplay}"
                                    IsReadOnly="True"
                                    Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding ExistingFingerprint}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Translate DialogImportConflictImportedFingerprint}"
                                    Binding="{Binding ImportedFingerprintDisplay}"
                                    IsReadOnly="True"
                                    Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding ImportedFingerprint}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Translate ColTrustedHostKeyAlgorithm}"
                                    Binding="{Binding Algorithm}"
                                    IsReadOnly="True"
                                    Width="150"/>
                <DataGridTemplateColumn Header="{loc:Translate ColTrustedHostKeyActions}"
                                        Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{Binding DataContext.KeepExistingLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                             IsChecked="{Binding KeepExisting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,12,0"
                                             AutomationProperties.Name="{Binding DataContext.KeepExistingLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <RadioButton Content="{Binding DataContext.ReplaceLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                             IsChecked="{Binding ReplaceWithImported, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{Binding DataContext.ReplaceLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding CancelLabel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    AutomationProperties.Name="{Binding CancelLabel}"/>
            <Button x:Name="ApplyButton"
                    Content="{Binding ApplyLabel}"
                    Command="{Binding ApplyCommand}"
                    MinWidth="150"
                    IsDefault="True"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    AutomationProperties.Name="{Binding ApplyLabel}"/>
        </StackPanel>
    </Grid>
</Window>
