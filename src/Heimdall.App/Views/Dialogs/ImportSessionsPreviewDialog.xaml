<Window x:Class="Heimdall.App.Views.Dialogs.ImportSessionsPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="940"
        Height="620"
        MinWidth="780"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="{StaticResource FontSizeBodyLarge}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding SummaryText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <CheckBox Grid.Row="1"
                  Margin="0,12,0,0"
                  Content="{Binding ImportAllText}"
                  IsChecked="{Binding AllSelected, Mode=TwoWay}"
                  AutomationProperties.Name="{loc:Translate ChkImportAll}"/>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding ImportColumnHeader, Mode=OneWay}"
                                            Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsSelectable, Mode=OneWay}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding AliasColumnHeader, Mode=OneWay}"
                                        Binding="{Binding Alias, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="{Binding HostNameColumnHeader, Mode=OneWay}"
                                        Binding="{Binding HostName, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="{Binding PortColumnHeader, Mode=OneWay}"
                                        Binding="{Binding Port, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="90"/>
                    <DataGridTextColumn Header="{Binding UserColumnHeader, Mode=OneWay}"
                                        Binding="{Binding User, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="120"/>
                    <DataGridTextColumn Header="{Binding IdentityFileColumnHeader, Mode=OneWay}"
                                        Binding="{Binding IdentityFile, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="2*"/>
                    <DataGridTextColumn Header="{Binding GatewayChainColumnHeader, Mode=OneWay}"
                                        Binding="{Binding GatewayChain, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="2*"/>
                    <DataGridTextColumn Header="{Binding StatusColumnHeader, Mode=OneWay}"
                                        Binding="{Binding StatusDisplay, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>

            <Expander Grid.Row="1"
                      Margin="0,12,0,0"
                      Header="{Binding DiagnosticsHeader}"
                      IsExpanded="{Binding IsDiagnosticsExpanded, Mode=TwoWay}"
                      Visibility="{Binding HasDiagnostics, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Diagnostics}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                           Margin="0,0,8,0"
                                           Text="●">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Message, Mode=OneWay}"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding CancelText}"
                    Command="{Binding CancelCommand}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    AutomationProperties.Name="{Binding CancelText, Mode=OneWay}"/>
            <Button x:Name="ConfirmImportButton"
                    Content="{Binding ConfirmText}"
                    Command="{Binding ConfirmCommand}"
                    MinWidth="150"
                    IsDefault="True"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    AutomationProperties.Name="{Binding ConfirmText, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Window>
