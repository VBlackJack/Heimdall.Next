<Window x:Class="Heimdall.App.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="480" SizeToContent="Height" MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="350"
        MinHeight="160"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <Border CornerRadius="{StaticResource CornerRadiusXl}"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Prompt -->
        <TextBlock x:Name="PromptText"
                   Grid.Row="0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="{StaticResource FontSizeBodyLarge}"
                   Margin="0,0,0,12"/>

        <!-- Input -->
        <TextBox x:Name="InputTextBox"
                 Grid.Row="1"
                 TabIndex="0"
                 AutomationProperties.Name="{Binding Text, ElementName=PromptText}"
                 FontSize="{StaticResource FontSizeBodyLarge}"
                 Padding="8,6"
                 Background="{DynamicResource CardBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                 SelectionBrush="{DynamicResource AccentBrush}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelBtn"
                    IsCancel="True"
                    TabIndex="2"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="OkBtn"
                    IsDefault="True"
                    TabIndex="1"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Click="OnOkClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
