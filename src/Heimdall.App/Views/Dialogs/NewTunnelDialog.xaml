<Window x:Class="Heimdall.App.Views.Dialogs.NewTunnelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:NewTunnelDialogViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="{loc:Translate NewTunnelDialogTitle}"
        Width="520"
        SizeToContent="Height"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="FormLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogLabelStyle}">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,12,8"/>
            </Style>

            <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DialogFormTextBoxStyle}">
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Translate NewTunnelDialogTitle}"
                       Style="{StaticResource HeaderTitleStyle}"/>
            <TextBlock Text="{loc:Translate NewTunnelDialogDescription}"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource DialogSectionCardStyle}"
                BorderBrush="{DynamicResource WarningBrush}"
                Margin="0,0,0,12"
                Visibility="{Binding HasNoGateways, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{loc:Translate NewTunnelNoGatewaysNotice}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource WarningBrush}"/>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource DialogSectionCardStyle}">
            <Grid IsEnabled="{Binding HasGateways}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{loc:Translate NewTunnelGatewayLabel}"
                           Style="{StaticResource FormLabelStyle}"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding Gateways}"
                          SelectedItem="{Binding SelectedGateway}"
                          Margin="0,0,0,8"
                          AutomationProperties.Name="{loc:Translate NewTunnelGatewayLabel}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Name}"/>
                                <Run Text="  "/>
                                <Run Text="{Binding User}"/>
                                <Run Text="@"/>
                                <Run Text="{Binding Host}"/>
                                <Run Text=":"/>
                                <Run Text="{Binding Port}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{loc:Translate NewTunnelRemoteHostLabel}"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         AutomationProperties.Name="{loc:Translate NewTunnelRemoteHostLabel}"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{loc:Translate NewTunnelRemotePortLabel}"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding RemotePort, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         AutomationProperties.Name="{loc:Translate NewTunnelRemotePortLabel}"/>

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{loc:Translate NewTunnelLocalPortLabel}"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         AutomationProperties.Name="{loc:Translate NewTunnelLocalPortLabel}"/>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{loc:Translate NewTunnelLabelLabel}"
                           Style="{StaticResource FormLabelStyle}"
                           Margin="0,0,12,0"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}"
                         AutomationProperties.Name="{loc:Translate NewTunnelLabelLabel}"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding ValidationMessage}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   Visibility="{Binding HasValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Margin="0,0,8,0"
                    MinWidth="120"
                    IsCancel="True"
                    Content="{loc:Translate BtnCancel}"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    AutomationProperties.Name="{loc:Translate BtnCancel}"/>
            <Button x:Name="ConfirmButton"
                    MinWidth="132"
                    IsDefault="True"
                    Content="{loc:Translate NewTunnelConfirmButton}"
                    Command="{Binding ConfirmCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    AutomationProperties.Name="{loc:Translate NewTunnelConfirmButton}"/>
        </StackPanel>
    </Grid>
</Window>
