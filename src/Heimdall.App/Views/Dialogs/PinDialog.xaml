<Window x:Class="Heimdall.App.Views.Dialogs.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:PinDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{loc:Translate PinDialogTitle}"
        Width="380" SizeToContent="Height" MaxHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="320"
        MinHeight="240"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingXl}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Translate PinEnterLabel}"
                   FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- PIN input (disabled when locked out) -->
        <PasswordBox x:Name="PinBox"
                     Grid.Row="1"
                     TabIndex="0"
                     MaxLength="8"
                     AutomationProperties.Name="{loc:Translate PinEnterLabel}"
                     IsEnabled="{Binding IsLockedOut, Converter={StaticResource InvertBoolConverter}, FallbackValue=True}"
                     FontSize="{StaticResource FontSizeDisplay}"
                     HorizontalContentAlignment="Center"
                     Background="{DynamicResource CardBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="8,6"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     KeyDown="OnPinKeyDown"/>

        <!-- Error message (visible when non-empty) -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Lockout message (visible when locked out) -->
        <Border Grid.Row="3"
                Background="{DynamicResource CardBrush}"
                CornerRadius="{StaticResource CornerRadiusSm}"
                Padding="12,8"
                Margin="0,12,0,0"
                Visibility="{Binding IsLockedOut, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding LockoutMessage}"
                       Foreground="{DynamicResource WarningTextBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelBtn"
                    Content="{loc:Translate BtnCancel}"
                    AutomationProperties.Name="{loc:Translate BtnCancel}"
                    IsCancel="True"
                    TabIndex="2"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="OnCancelClick"/>
            <Button x:Name="UnlockBtn"
                    Content="{loc:Translate BtnUnlock}"
                    AutomationProperties.Name="{loc:Translate BtnUnlock}"
                    IsDefault="True"
                    TabIndex="1"
                    MinWidth="80"
                    Click="OnUnlockClick"
                    IsEnabled="{Binding IsLockedOut, Converter={StaticResource InvertBoolConverter}, FallbackValue=True}"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
