<Window x:Class="Heimdall.App.Views.Dialogs.PinSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:PinSetupDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{loc:Translate PinSetupDialogTitle}"
        Width="420" SizeToContent="Height" MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="340"
        MinHeight="320"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingXl}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{loc:Translate PinSetupHeader}"
                   FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,12"
                    Visibility="{Binding IsPinSet, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{loc:Translate PinSetupCurrentLabel}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       Margin="0,0,0,6"/>
            <PasswordBox x:Name="CurrentPinBox"
                         TabIndex="0"
                         MaxLength="8"
                         AutomationProperties.Name="{loc:Translate PinSetupCurrentLabel}"
                         FontSize="{StaticResource FontSizeSubtitle}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="8,6"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="{loc:Translate PinSetupNewLabel}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       Margin="0,0,0,6"/>
            <PasswordBox x:Name="NewPinBox"
                         TabIndex="1"
                         MaxLength="8"
                         AutomationProperties.Name="{loc:Translate PinSetupNewLabel}"
                         FontSize="{StaticResource FontSizeSubtitle}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="8,6"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="{loc:Translate PinSetupConfirmLabel}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       Margin="0,0,0,6"/>
            <PasswordBox x:Name="ConfirmPinBox"
                         TabIndex="2"
                         MaxLength="8"
                         AutomationProperties.Name="{loc:Translate PinSetupConfirmLabel}"
                         FontSize="{StaticResource FontSizeSubtitle}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="8,6"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="4"
                   Text=""
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,0">
            <Button x:Name="RemoveBtn"
                    Content="{loc:Translate PinSetupBtnRemove}"
                    AutomationProperties.Name="{loc:Translate PinSetupBtnRemove}"
                    TabIndex="5"
                    MinWidth="96"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Visibility="{Binding IsPinSet, Converter={StaticResource BoolToVisibilityConverter}}"
                    Click="OnRemoveClick"/>
            <Button x:Name="CancelBtn"
                    Content="{loc:Translate BtnCancel}"
                    AutomationProperties.Name="{loc:Translate BtnCancel}"
                    IsCancel="True"
                    TabIndex="4"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="OnCancelClick"/>
            <Button x:Name="SaveBtn"
                    Content="{loc:Translate PinSetupBtnSave}"
                    AutomationProperties.Name="{loc:Translate PinSetupBtnSave}"
                    IsDefault="True"
                    TabIndex="3"
                    MinWidth="80"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
