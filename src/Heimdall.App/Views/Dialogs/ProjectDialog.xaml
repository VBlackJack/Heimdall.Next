<Window x:Class="Heimdall.App.Views.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:ProjectDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="460" SizeToContent="Height" MaxHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="380"
        MinHeight="380"
        ShowInTaskbar="False"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

            <!-- Color swatch radio button style -->
        <Style x:Key="ColorSwatchStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse x:Name="SwatchBorder"
                                     Width="32" Height="32"
                                     StrokeThickness="2"
                                     Stroke="Transparent"
                                     Fill="{TemplateBinding Background}"/>
                            <Ellipse x:Name="CheckMark"
                                     Width="12" Height="12"
                                     Fill="White"
                                     Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwatchBorder" Property="Stroke"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="LblName" Style="{StaticResource DialogLabelStyle}"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="{Binding Text, ElementName=LblName}"
                     Style="{StaticResource DialogFormTextBoxStyle}"
                     MaxLength="50"
                     x:Name="TxtName" TabIndex="0"/>
            <TextBlock Text="{Binding NameError}"
                       Style="{StaticResource FieldValidationErrorStyle}"
                       Visibility="{Binding NameError, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Foreground="{DynamicResource TextDisabledBrush}" FontSize="{StaticResource FontSizeCaption}"
                       HorizontalAlignment="Right" Margin="0,2,0,0">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}/50">
                        <Binding Path="Name.Length"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock x:Name="LblDescription" Style="{StaticResource DialogLabelStyle}" Margin="0,8,0,4"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="{Binding Text, ElementName=LblDescription}"
                     Style="{StaticResource DialogFormTextBoxStyle}"
                     MaxLength="200"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MaxLines="4"
                     Height="60"
                     VerticalContentAlignment="Top"
                     VerticalScrollBarVisibility="Auto"
                     x:Name="TxtDescription" TabIndex="1"/>
            <TextBlock Text="{Binding DescriptionError}"
                       Style="{StaticResource FieldValidationErrorStyle}"
                       Visibility="{Binding DescriptionError, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Foreground="{DynamicResource TextDisabledBrush}" FontSize="{StaticResource FontSizeCaption}"
                       HorizontalAlignment="Right" Margin="0,2,0,0">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}/200">
                        <Binding Path="Description.Length"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock x:Name="LblColor" Style="{StaticResource DialogLabelStyle}" Margin="0,8,0,4"/>
            <WrapPanel>
                <RadioButton GroupName="ProjectColor" Tag="#3B82F6"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorBlue}"
                             Background="#3B82F6" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#3B82F6}"
                             x:Name="RbColorBlue"/>
                <RadioButton GroupName="ProjectColor" Tag="#22C55E"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorGreen}"
                             Background="#22C55E" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#22C55E}"
                             x:Name="RbColorGreen"/>
                <RadioButton GroupName="ProjectColor" Tag="#EF4444"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorRed}"
                             Background="#EF4444" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#EF4444}"
                             x:Name="RbColorRed"/>
                <RadioButton GroupName="ProjectColor" Tag="#F59E0B"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorAmber}"
                             Background="#F59E0B" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#F59E0B}"
                             x:Name="RbColorAmber"/>
                <RadioButton GroupName="ProjectColor" Tag="#8B5CF6"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorPurple}"
                             Background="#8B5CF6" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#8B5CF6}"
                             x:Name="RbColorPurple"/>
                <RadioButton GroupName="ProjectColor" Tag="#EC4899"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorPink}"
                             Background="#EC4899" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#EC4899}"
                             x:Name="RbColorPink"/>
                <RadioButton GroupName="ProjectColor" Tag="#06B6D4"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorCyan}"
                             Background="#06B6D4" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#06B6D4}"
                             x:Name="RbColorCyan"/>
                <RadioButton GroupName="ProjectColor" Tag="#F97316"
                             AutomationProperties.Name="{loc:Translate ProjectDialogColorOrange}"
                             Background="#F97316" Style="{StaticResource ColorSwatchStyle}"
                             IsChecked="{Binding Color, Converter={x:Static converters:ColorRadioConverter.Instance}, ConverterParameter=#F97316}"
                             x:Name="RbColorOrange"/>
            </WrapPanel>
            <TextBlock x:Name="SelectedColorLabel" Text=""
                       FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock x:Name="LblSshDefaults" Style="{StaticResource DialogLabelStyle}"
                       FontWeight="SemiBold" Margin="0,16,0,4"/>

            <TextBlock x:Name="LblDefaultSshUsername" Style="{StaticResource DialogLabelStyle}" Margin="0,4,0,4"/>
            <TextBox Text="{Binding DefaultSshUsername}"
                     AutomationProperties.Name="{Binding Text, ElementName=LblDefaultSshUsername}"
                     Style="{StaticResource DialogFormTextBoxStyle}"
                     x:Name="TxtDefaultSshUsername" TabIndex="2"/>

            <TextBlock x:Name="LblDefaultSshKeyPath" Style="{StaticResource DialogLabelStyle}" Margin="0,12,0,4"/>
            <TextBox Text="{Binding DefaultSshKeyPath}"
                     AutomationProperties.Name="{Binding Text, ElementName=LblDefaultSshKeyPath}"
                     Style="{StaticResource DialogFormTextBoxStyle}"
                     x:Name="TxtDefaultSshKeyPath" TabIndex="3"/>
        </StackPanel>

        <!-- Validation error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelBtn"
                    IsCancel="True"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="SaveBtn"
                    IsDefault="True"
                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                    MinWidth="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
