<Window x:Class="Heimdall.App.Views.Dialogs.RdpImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:RdpImportDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        AutomationProperties.HelpText="{Binding SubtitleText}"
        Width="840"
        Height="560"
        MinWidth="700"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="{StaticResource FontSizeBodyLarge}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding SubtitleText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding SummaryText}"
                       Foreground="{DynamicResource TextDisabledBrush}"
                       FontSize="{StaticResource FontSizeCaption}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Visibility="{Binding HasFileIssues, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding FileIssuesText}"
                       Foreground="{DynamicResource WarningTextBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock x:Name="ApplyToAllLabel"
                           Text="{Binding ApplyToAllText}"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Button Content="{Binding ApplyAllSkipText}"
                        Command="{Binding ApplyAllSkipCommand}"
                        AutomationProperties.LabeledBy="{Binding ElementName=ApplyToAllLabel}"
                        AutomationProperties.HelpText="{loc:Translate A11yRdpImportApplyAllSkipHelp}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Margin="0,0,6,0"/>
                <Button Content="{Binding ApplyAllReplaceText}"
                        Command="{Binding ApplyAllReplaceCommand}"
                        AutomationProperties.LabeledBy="{Binding ElementName=ApplyToAllLabel}"
                        AutomationProperties.HelpText="{loc:Translate A11yRdpImportApplyAllReplaceHelp}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Margin="0,0,6,0"/>
                <Button Content="{Binding ApplyAllAutoRenameText}"
                        Command="{Binding ApplyAllAutoRenameCommand}"
                        AutomationProperties.LabeledBy="{Binding ElementName=ApplyToAllLabel}"
                        AutomationProperties.HelpText="{loc:Translate A11yRdpImportApplyAllAutoRenameHelp}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding SelectAllText}"
                        Command="{Binding SelectAllCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,6,0"/>
                <Button Content="{Binding SelectNoneText}"
                        Command="{Binding SelectNoneCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="1" Margin="4,0,8,8"
                           Text="{Binding SourceColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="4,0,8,8"
                           Text="{Binding NameColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Margin="4,0,8,8"
                           Text="{Binding HostColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Margin="4,0,8,8"
                           Text="{Binding StatusColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="5" Margin="4,0,8,8"
                           Text="{Binding ConflictColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>

                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="6"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Rows}"
                                  AutomationProperties.Name="{loc:Translate A11yRdpImportEntriesList}"
                                  AutomationProperties.HelpText="{Binding SummaryText}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:RdpImportRowViewModel}">
                                <Border Padding="0,6"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Top"
                                                  AutomationProperties.Name="{Binding RowAccessibleSummary}"/>

                                        <TextBlock Grid.Column="1"
                                                   Margin="4,2,8,0"
                                                   Text="{Binding SourceFileName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="2"
                                                   Margin="4,2,8,0"
                                                   Text="{Binding ProposedName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="3"
                                                   Margin="4,2,8,0"
                                                   Text="{Binding TargetHost}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <WrapPanel Grid.Column="4" Margin="4,0,8,0">
                                            <Border Margin="0,0,6,4"
                                                    Padding="6,2"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource ErrorBrush}"
                                                    Visibility="{Binding HasParseError, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding ParseErrorText}"
                                                           Foreground="{DynamicResource TextOnAccentBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"/>
                                            </Border>
                                            <Border Margin="0,0,6,4"
                                                    Padding="6,2"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource WarningBrush}"
                                                    Visibility="{Binding HasPasswordBlob, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding PasswordText}"
                                                           Foreground="{DynamicResource BackgroundBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"/>
                                            </Border>
                                            <Border Margin="0,0,6,4"
                                                    Padding="6,2"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Visibility="{Binding HasNameConflict, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding ConflictText}"
                                                           Foreground="{DynamicResource BackgroundBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"/>
                                            </Border>
                                            <Border Margin="0,0,6,4"
                                                    Padding="6,2"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource TextSecondaryBrush}"
                                                    Visibility="{Binding HasUnknownKeys, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding UnknownKeysText}"
                                                           Foreground="{DynamicResource BackgroundBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"/>
                                            </Border>
                                            <Border Margin="0,0,6,4"
                                                    Padding="6,2"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource TextDisabledBrush}"
                                                    Visibility="{Binding HasSkippedMappings, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding SkippedMappingsText}"
                                                           Foreground="{DynamicResource BackgroundBrush}"
                                                           FontSize="{StaticResource FontSizeCaption}"/>
                                            </Border>
                                        </WrapPanel>

                                        <ComboBox Grid.Column="5"
                                                  Margin="4,0,0,0"
                                                  ItemsSource="{Binding DataContext.ConflictOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ConflictResolution}"
                                                  IsEnabled="{Binding HasNameConflict}"
                                                  AutomationProperties.Name="{Binding ConflictAccessibleName}"
                                                  Visibility="{Binding HasNameConflict, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding CancelText}"
                    Command="{Binding CancelCommand}"
                    AutomationProperties.HelpText="{loc:Translate A11yRdpImportCancelHelp}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="ConfirmImportButton"
                    Content="{Binding ConfirmText}"
                    Command="{Binding ConfirmCommand}"
                    AutomationProperties.HelpText="{loc:Translate A11yRdpImportConfirmHelp}"
                    MinWidth="150"
                    IsDefault="True"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
