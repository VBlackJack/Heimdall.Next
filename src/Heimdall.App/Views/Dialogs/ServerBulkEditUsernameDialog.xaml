<Window x:Class="Heimdall.App.Views.Dialogs.ServerBulkEditUsernameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:ServerBulkEditUsernameViewModel}"
        mc:Ignorable="d"
        Title="{loc:Translate DialogTitleBulkEditUsername}"
        Width="480"
        SizeToContent="Height"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="OnLoaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Header}"
                           Style="{StaticResource DialogSectionTitleStyle}"/>

                <TextBlock Text="{loc:Translate BulkEditUsernameInputLabel}"
                           Style="{StaticResource DialogLabelStyle}"/>

                <Grid>
                    <TextBox x:Name="UsernameTextBox"
                             Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             MinWidth="180"/>

                    <TextBlock Text="{Binding MixedValuesHint}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowMixedValuesHint}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="{Binding ValidationError}"
                           Style="{StaticResource FieldValidationErrorStyle}"
                           Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{loc:Translate BtnCancel}"
                    IsCancel="True"
                    MinWidth="88"
                    Margin="0,0,8,0"/>
            <Button Content="{loc:Translate BtnApply}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    MinWidth="96"
                    IsEnabled="{Binding IsApplyEnabled}"
                    Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
