<Window x:Class="Heimdall.App.Views.Dialogs.ServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:config="clr-namespace:Heimdall.Core.Configuration;assembly=Heimdall.Core"
        xmlns:loc="clr-namespace:Heimdall.App.Localization"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:ServerDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="650"
        SizeToContent="Height"
        MaxHeight="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="550"
        MinHeight="350"
        ShowInTaskbar="False"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- ServerDialog label extends DialogLabelStyle with SemiBold weight -->
            <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogLabelStyle}">
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="InsetCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12"/>
            </Style>

            <Style x:Key="SshAgentChipBorderStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSshFamilyConnection}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding AgentChipState}" Value="{x:Static vm:SshAgentChipState.Warn}">
                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding AgentChipState}" Value="{x:Static vm:SshAgentChipState.Ok}">
                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SshAgentChipIconStyle" TargetType="TextBlock">
                <Setter Property="Text" Value="&#x25CB;"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding AgentChipState}" Value="{x:Static vm:SshAgentChipState.Warn}">
                        <Setter Property="Text" Value="&#x26A0;"/>
                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding AgentChipState}" Value="{x:Static vm:SshAgentChipState.Ok}">
                        <Setter Property="Text" Value="&#x2713;"/>
                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SshTestChipBorderStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.InProgress}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Success}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Failure}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Cancelled}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SshTestChipIconStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.InProgress}">
                        <Setter Property="Text" Value="&#x23F3;"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Success}">
                        <Setter Property="Text" Value="&#x2713;"/>
                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Failure}">
                        <Setter Property="Text" Value="&#x2715;"/>
                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TestChipState}" Value="{x:Static vm:SshTestChipState.Cancelled}">
                        <Setter Property="Text" Value="&#x25CB;"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DiagramNodeStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Width" Value="165"/>
                <Setter Property="MinHeight" Value="86"/>
            </Style>

            <Style x:Key="ArrowCaptionStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="RdpOnlySectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SshOnlySectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SshFamilySectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Gateway/routing sections: hidden for Local shell, Citrix, VNC, FTP -->
            <Style x:Key="NetworkSectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GatewaySectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DirectSectionStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UsesGateway}" Value="False">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ManualTunnelPortStyle" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding UsesGateway}" Value="True"/>
                            <Condition Binding="{Binding UseAutomaticTunnelPort}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Protocol card button style (Step 1 selector) -->
            <Style x:Key="ProtocolCardButtonStyle" TargetType="Button">
                <Setter Property="FocusVisualStyle" Value="{StaticResource AppFocusVisualStyle}"/>
                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="MinHeight" Value="100"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource CornerRadiusLg}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Advanced settings toggle button style -->
            <Style x:Key="AdvancedToggleStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="FocusBorder"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Padding="2,0,2,2"
                                    Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Arrow" Text="&#x25B8;"
                                               Margin="0,0,6,0"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Arrow" Property="Text" Value="&#x25BE;"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="FocusBorder" Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="{StaticResource SpacingSm}">

                <!-- ================================================================ -->
                <!-- STEP 1: PROTOCOL SELECTOR (add mode only, before selection)      -->
                <!-- ================================================================ -->

                <StackPanel x:Name="ProtocolSelectorPanel"
                            Visibility="{Binding ShowProtocolSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock x:Name="DlgSrv_ProtocolSelectorTitle"
                               Style="{StaticResource DialogSectionTitleStyle}"
                               FontSize="{StaticResource FontSizeTitle}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="DlgSrv_ProtocolSelectorDesc"
                               Style="{StaticResource DialogSectionDescriptionStyle}"
                               Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ProtocolCards">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <!-- RDP -->
                        <Button x:Name="ProtocolCard_Rdp" Command="{Binding SelectProtocolCommand}" CommandParameter="RDP"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolRdpName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Rdp}"
                                      Fill="{DynamicResource ProtocolRdpBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoRdpName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoRdpDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- SSH -->
                        <Button x:Name="ProtocolCard_Ssh" Command="{Binding SelectProtocolCommand}" CommandParameter="SSH"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolSshName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Ssh}"
                                      Fill="{DynamicResource ProtocolSshBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoSshName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoSshDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- SFTP -->
                        <Button x:Name="ProtocolCard_Sftp" Command="{Binding SelectProtocolCommand}" CommandParameter="SFTP"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolSftpName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Sftp}"
                                      Fill="{DynamicResource ProtocolSftpBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoSftpName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoSftpDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- VNC -->
                        <Button x:Name="ProtocolCard_Vnc" Command="{Binding SelectProtocolCommand}" CommandParameter="VNC"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolVncName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Vnc}"
                                      Fill="{DynamicResource ProtocolVncBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoVncName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoVncDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Telnet -->
                        <Button x:Name="ProtocolCard_Telnet" Command="{Binding SelectProtocolCommand}" CommandParameter="Telnet"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolTelnetName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Telnet}"
                                      Fill="{DynamicResource ProtocolTelnetBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoTelnetName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoTelnetDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- FTP -->
                        <Button x:Name="ProtocolCard_Ftp" Command="{Binding SelectProtocolCommand}" CommandParameter="FTP"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolFtpName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Ftp}"
                                      Fill="{DynamicResource ProtocolFtpBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoFtpName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoFtpDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Citrix -->
                        <Button x:Name="ProtocolCard_Citrix" Command="{Binding SelectProtocolCommand}" CommandParameter="Citrix"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolCitrixName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.Citrix}"
                                      Fill="{DynamicResource ProtocolCitrixBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoCitrixName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoCitrixDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Local Shell -->
                        <Button x:Name="ProtocolCard_Local" Command="{Binding SelectProtocolCommand}" CommandParameter="Local"
                                AutomationProperties.Name="{loc:Translate ServerDialogProtocolLocalName}"
                                Style="{StaticResource ProtocolCardButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource Geo.Protocol.LocalShell}"
                                      Fill="{DynamicResource ProtocolLocalBrush}"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DlgSrv_ProtoLocalName" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="DlgSrv_ProtoLocalDesc" HorizontalAlignment="Center"
                                           TextAlignment="Center" TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </ItemsControl>
                </StackPanel>

                <!-- ================================================================ -->
                <!-- STEP 2: FORM FIELDS (visible after protocol selection / edit)     -->
                <!-- ================================================================ -->

                <StackPanel x:Name="FormFieldsPanel"
                            Visibility="{Binding ShowFormFields, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Protocol badge (clickable in add mode → returns to protocol selector) -->
                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                    <TextBlock x:Name="DlgSrv_ProtocolBadgeLabel"
                               DockPanel.Dock="Left"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="DlgSrv_ProtocolBadgeButton"
                            DockPanel.Dock="Left"
                            Command="{Binding BackToProtocolSelectorCommand}"
                            ToolTip="{loc:Translate ServerDialogProtocolChipChangeTooltip}"
                            ToolTipService.ShowOnDisabled="True"
                            AutomationProperties.LabeledBy="{Binding ElementName=DlgSrv_ProtocolBadgeLabel}"
                            AutomationProperties.HelpText="{loc:Translate ServerDialogProtocolChipChangeTooltip}"
                            TabIndex="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarGhostButtonStyle}">
                                <Setter Property="Padding" Value="10,4"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{Binding ConnectionType, Converter={StaticResource TypeToGeoConverter}}"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ConnectionType}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </DockPanel>

                <!-- Connection basics: Name, Type, Host, Port -->
                <Border Style="{StaticResource DialogSectionCardStyle}">
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_ConnectionBasicsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_ConnectionBasicsDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="DlgSrv_DisplayNameLabel" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="DlgSrv_DisplayNameBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                     TabIndex="0"
                                     AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_DisplayNameLabel}"
                                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                            <!-- Inline validation: Display Name -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{Binding DisplayNameError}"
                                       Style="{StaticResource FieldValidationErrorStyle}"
                                       Visibility="{Binding DisplayNameError, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <!-- Server/Port row: hidden for Local shell and Citrix -->
                            <TextBlock x:Name="DlgSrv_ServerLabel" Grid.Row="3" Grid.Column="0" Margin="0,14,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EndpointPortLabel}" Margin="12,14,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="DlgSrv_RemoteServerBox" Grid.Row="4" Grid.Column="0"
                                     TabIndex="2"
                                     AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_ServerLabel}"
                                     Text="{Binding RemoteServer, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DialogFormTextBoxStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBox x:Name="DlgSrv_EndpointPortBox" Grid.Row="4" Grid.Column="1"
                                     TabIndex="3"
                                     AutomationProperties.Name="{Binding EndpointPortLabel}"
                                     Margin="12,0,0,0"
                                     Width="120"
                                     HorizontalAlignment="Left"
                                     Text="{Binding EndpointPort, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DialogFormTextBoxStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <!-- Inline validation: Server address -->
                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="{Binding RemoteServerError}"
                                       Style="{StaticResource FieldValidationErrorStyle}"
                                       Visibility="{Binding RemoteServerError, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <!-- Inline validation: Port -->
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding EndpointPortError}"
                                       Style="{StaticResource FieldValidationErrorStyle}"
                                       Margin="12,2,0,0"
                                       Visibility="{Binding EndpointPortError, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                        <TextBlock Text="{Binding EndpointPortHelpText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DialogHintTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Project + Gateway routing (compact) -->
                <Border Style="{StaticResource DialogSectionCardStyle}">
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_ProjectLabel" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="DlgSrv_ProjectCmb" TabIndex="4"
                                  AutomationProperties.Name="{loc:Translate ServerDialogLabelProject}"
                                  ItemsSource="{Binding AvailableProjects}"
                                  SelectedValue="{Binding SelectedProjectId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource DialogFormComboBoxStyle}"/>

                        <!-- Gateway section (hidden for Local, Citrix, VNC, FTP) -->
                        <StackPanel Style="{StaticResource NetworkSectionStyle}" Margin="0,14,0,0">
                            <TextBlock x:Name="DlgSrv_GatewayRoutingTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                            <TextBlock x:Name="DlgSrv_GatewayRoutingDesc"
                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                            <CheckBox x:Name="DlgSrv_DirectConnectCb"
                                      TabIndex="5"
                                      AutomationProperties.Name="{loc:Translate A11yUseDirectConnection}"
                                      IsChecked="{Binding DirectConnection}"
                                      Style="{StaticResource DialogFormCheckBoxStyle}"
                                      Margin="0,14,0,0"/>
                            <Grid Margin="0,12,0,0">
                                <ComboBox x:Name="DlgSrv_GatewayCmb"
                                          TabIndex="6"
                                          AutomationProperties.Name="{loc:Translate ServerFieldGateway}"
                                          ItemsSource="{Binding AvailableGateways}"
                                          SelectedValue="{Binding SelectedGatewayId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayText"
                                          IsEnabled="{Binding CanSelectGateway}"
                                          AutomationProperties.HelpText="{Binding GatewayComboHelpText}"
                                          Style="{StaticResource DialogFormComboBoxStyle}"/>
                            </Grid>
                            <TextBlock Text="{Binding GatewayExplanation}" Style="{StaticResource DialogHintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ================================================================ -->
                <!-- AUTHENTICATION (always visible, per-protocol)                    -->
                <!-- ================================================================ -->

                <!-- RDP credentials -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicRdpCredentialsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicRdpCredentialsDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicRdpUsernameLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <TextBox x:Name="DlgSrv_BasicRdpUsernameBox" TabIndex="10"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelUsername}"
                                 Tag="{loc:Translate ServerDialogRdpUsernameWatermark}"
                                 ToolTip="{loc:Translate ServerDialogRdpUsernameHint}"
                                 Text="{Binding RdpUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource WatermarkTextBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicRdpPasswordLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <PasswordBox x:Name="RdpPasswordBox" TabIndex="11"
                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelPassword}"
                                     Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                        <DockPanel Margin="0,8,0,0"
                                   LastChildFill="False">
                            <Button DockPanel.Dock="Left"
                                    MinWidth="140"
                                    Content="{loc:Translate ServerDialogRdpTestButton}"
                                    Command="{Binding TestRdpConnectionCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    AutomationProperties.Name="{loc:Translate ServerDialogRdpTestButton}"/>
                            <Button DockPanel.Dock="Left"
                                    MinWidth="90"
                                    Margin="6,0,0,0"
                                    Content="{loc:Translate ServerDialogRdpTestCancel}"
                                    Command="{Binding CancelRdpTestCommand}"
                                    Style="{DynamicResource ToolbarGhostButtonStyle}"
                                    Visibility="{Binding IsTestingRdpConnection, Converter={StaticResource BoolToVisibilityConverter}}"
                                    AutomationProperties.Name="{loc:Translate ServerDialogRdpTestCancel}"/>
                        </DockPanel>
                        <Border Margin="0,6,0,0"
                                CornerRadius="{StaticResource CornerRadiusSm}"
                                Padding="8,4"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SshTestChipBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SshTestChipIconStyle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TestChipText}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="500"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           AutomationProperties.LiveSetting="Polite"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- SSH/SFTP credentials -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicSshCredentialsTitle"
                                   Text="{loc:Translate ServerDialogSshCredentials}"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicSshCredentialsDesc"
                                   Text="{loc:Translate ServerDialogSshCredentialsDesc}"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicSshUsernameLabel"
                                   Text="{loc:Translate ServerDialogLabelUsername}"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,14,0,4"/>
                        <TextBox x:Name="DlgSrv_BasicSshUsernameBox" TabIndex="10"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelUsername}"
                                 Text="{Binding SshUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicSshKeyLabel"
                                   Text="{loc:Translate ServerDialogLabelSshKey}"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,12,0,4"/>
                        <DockPanel>
                            <Button x:Name="DlgSrv_BasicBrowseBtn"
                                    DockPanel.Dock="Right"
                                    AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0"
                                    Click="OnBrowseSshKeyClick"/>
                            <TextBox x:Name="DlgSrv_SshKeyPathBox" TabIndex="11"
                                     AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_BasicSshKeyLabel}"
                                     Text="{Binding SshKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                        </DockPanel>
                        <TextBlock x:Name="DlgSrv_BasicSshPasswordLabel"
                                   Text="{loc:Translate ServerDialogLabelPassword}"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,12,0,4"/>
                        <PasswordBox x:Name="SshPasswordBox" TabIndex="12"
                                     AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_BasicSshPasswordLabel}"
                                     Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicSshAuthHint" Text="{Binding SshAuthHint}"
                                   Style="{StaticResource DialogHintTextStyle}" Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>
                        <DockPanel Margin="0,8,0,0"
                                   LastChildFill="False">
                            <Button DockPanel.Dock="Left"
                                    MinWidth="120"
                                    Content="{loc:Translate ServerDialogTestConnectionButton}"
                                    Command="{Binding TestSshConnectionCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    AutomationProperties.Name="{loc:Translate ServerDialogTestConnectionButton}"/>
                        </DockPanel>
                        <Border Margin="0,6,0,0"
                                CornerRadius="{StaticResource CornerRadiusSm}"
                                Padding="8,4"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SshTestChipBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SshTestChipIconStyle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TestChipText}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="500"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="DlgSrv_SshAgentChip"
                                Margin="0,8,0,0"
                                CornerRadius="{StaticResource CornerRadiusSm}"
                                Padding="8,4"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                ToolTip="{loc:Translate ServerDialogAgentChipTooltipRefresh}"
                                Style="{StaticResource SshAgentChipBorderStyle}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding RefreshAgentChipCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SshAgentChipIconStyle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AgentChipText}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Visibility="{Binding HasSshKeyPath, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock x:Name="DlgSrv_BasicSshKeyPassphraseLabel"
                                       Text="{loc:Translate ServerDialogLabelKeyPassphrase}"
                                       Style="{StaticResource LabelStyle}"
                                       Margin="0,12,0,4"/>
                            <PasswordBox x:Name="SshKeyPassphraseBox" TabIndex="13"
                                         AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_BasicSshKeyPassphraseLabel}"
                                         Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                            <TextBlock x:Name="DlgSrv_BasicSshKeyPassphraseHint"
                                       Text="{Binding SshKeyPassphraseHint}"
                                       Style="{StaticResource DialogHintTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- VNC credentials -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicVncCredentialsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicVncCredentialsDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicVncPasswordLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <PasswordBox x:Name="VncPasswordBox" TabIndex="10"
                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelPassword}"
                                     Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- FTP credentials -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicFtpCredentialsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicFtpCredentialsDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicFtpUsernameLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <TextBox x:Name="DlgSrv_FtpUsernameBox" TabIndex="10"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelUsername}"
                                 Text="{Binding FtpUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicFtpPasswordLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <PasswordBox x:Name="FtpPasswordBox" TabIndex="11"
                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelPassword}"
                                     Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Telnet credentials -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicTelnetCredentialsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicTelnetCredentialsDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicTelnetUsernameLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <TextBox x:Name="DlgSrv_TelnetUsernameBox" TabIndex="10"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelUsername}"
                                 Text="{Binding TelnetUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicTelnetPasswordLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <PasswordBox x:Name="TelnetPasswordBox" TabIndex="11"
                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelPassword}"
                                     Style="{StaticResource DialogFormPasswordBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Local Shell settings -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicLocalShellTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicLocalShellDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicExecutableLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <ComboBox x:Name="DlgSrv_BasicShellCombo"
                                  TabIndex="10"
                                  AutomationProperties.Name="{loc:Translate ServerDialogLabelExecutable}"
                                  IsEditable="True"
                                  TextSearch.TextPath="Tag"
                                  Text="{Binding LocalShellExecutable, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DialogFormComboBoxStyle}">
                            <ComboBoxItem x:Name="DlgSrv_BasicShellPowershell" Content="" Tag="powershell.exe"/>
                            <ComboBoxItem x:Name="DlgSrv_BasicShellPwsh" Content="" Tag="pwsh.exe"/>
                            <ComboBoxItem x:Name="DlgSrv_BasicShellCmd" Content="" Tag="cmd.exe"/>
                            <ComboBoxItem x:Name="DlgSrv_BasicShellBash" Content="" Tag="bash"/>
                            <ComboBoxItem x:Name="DlgSrv_BasicShellWsl" Content="" Tag="wsl.exe"/>
                        </ComboBox>
                        <TextBlock x:Name="DlgSrv_BasicArgumentsLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox x:Name="DlgSrv_ShellArgsBox" TabIndex="11"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelArguments}"
                                 Text="{Binding LocalShellArguments, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Citrix settings -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock x:Name="DlgSrv_BasicCitrixTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicCitrixDesc"
                                   Style="{StaticResource DialogSectionDescriptionStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicStoreFrontLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                        <TextBox x:Name="DlgSrv_StoreFrontBox" TabIndex="10"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelStoreFrontUrl}"
                                 Text="{Binding CitrixStoreFrontUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                        <TextBlock x:Name="DlgSrv_BasicAppNameLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox x:Name="DlgSrv_CitrixAppNameBox" TabIndex="11"
                                 AutomationProperties.Name="{loc:Translate ServerDialogLabelAppName}"
                                 Text="{Binding CitrixAppName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogFormTextBoxStyle}"/>
                    </StackPanel>
                </Border>

                <!-- ================================================================ -->
                <!-- ADVANCED SETTINGS TOGGLE                                         -->
                <!-- ================================================================ -->

                <ToggleButton x:Name="DlgSrv_AdvancedToggle"
                              IsChecked="{Binding IsAdvancedMode}"
                              AutomationProperties.Name="{loc:Translate ServerDialogAdvancedSettings}"
                              Style="{StaticResource AdvancedToggleStyle}"
                              Margin="0,0,0,12"/>

                <!-- ================================================================ -->
                <!-- ADVANCED PANEL (slide-down animation)                            -->
                <!-- ================================================================ -->

                <Border ClipToBounds="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="LayoutTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleY="0"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAdvancedMode}" Value="True">
                                    <Setter Property="LayoutTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Opacity" Value="1"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                                 From="0" To="1" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                                 From="1" To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TabControl x:Name="MainTabControl"
                                AutomationProperties.Name="{loc:Translate A11yServerDialogTabs}"
                                Style="{DynamicResource ThemedTabControlStyle}">

                        <!-- ============================================ -->
                        <!-- Tab: Connection details (path diagram)       -->
                        <!-- ============================================ -->
                        <TabItem x:Name="DlgSrv_TabConnection"
                                 AutomationProperties.Name="{loc:Translate ServerDialogTabConnection}"
                                 Style="{DynamicResource ThemedTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="{StaticResource SpacingSm}">
                                    <!-- Gateway detail card (visible only when gateway selected) -->
                                    <Border Margin="0,0,0,12">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedGatewayTitle}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource DialogHintTextStyle}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding GatewayRouteText}" Style="{StaticResource DialogHintTextStyle}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Connection path diagram -->
                                    <Border Style="{StaticResource DialogSectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_ConnectionPathTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock Text="{Binding ConnectionPathHeadline}" Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <StackPanel Margin="0,16,0,0"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Style="{StaticResource DirectSectionStyle}">
                                                <Border Style="{StaticResource DiagramNodeStyle}">
                                                    <StackPanel>
