                                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <TextBlock Text="{loc:Translate ServerDialogResolutionModeAutoDescription}"
                                                                           Style="{StaticResource DialogHintTextStyle}"
                                                                           Margin="0,4,0,0"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>

