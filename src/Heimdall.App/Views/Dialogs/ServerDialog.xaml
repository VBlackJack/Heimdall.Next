                                            <TextBlock x:Name="DlgSrv_GatewayAuthTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_GatewayAuthDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
