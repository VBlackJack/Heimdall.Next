                                                             AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_PostConnectDelayLabel}"
                                                             Text="{Binding PostConnectDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource DialogFormTextBoxStyle}"
                                                             MaxLength="5"
                                                             TabIndex="85"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="ms"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Local Shell advanced options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_LocalShellTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_LocalShellDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_WorkingDirLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_WorkingDirBox" TabIndex="84"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelWorkingDir}"
                                                     Text="{Binding LocalShellWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <DockPanel Margin="0,12,0,0">
                                                <TextBlock x:Name="DlgSrv_ElevationModeLabel" Text=""
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="DlgSrv_ElevationModeCmb"
                                                          TabIndex="85" Width="200"
                                                          AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_ElevationModeLabel}"
                                                          Background="{DynamicResource CardBrush}"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          BorderBrush="{DynamicResource BorderBrush}"
                                                          VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Citrix advanced options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_CitrixTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_CitrixDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_IcaFileLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_IcaFileBox" TabIndex="86"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelIcaFilePath}"
                                                     Text="{Binding CitrixIcaFilePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <TextBlock x:Name="DlgSrv_CitrixHint"
                                                       Style="{StaticResource DialogHintTextStyle}" Margin="0,8,0,0"/>
                                            <CheckBox x:Name="DlgSrv_SeamlessCb"
                                                      TabIndex="87"
                                                      AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                      IsChecked="{Binding CitrixSeamlessMode}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,12,0,0"/>
                                            <CheckBox x:Name="DlgSrv_SsoCb"
                                                      TabIndex="88"
                                                      AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                      IsChecked="{Binding CitrixUseSso}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- FTP options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_FtpOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_FtpOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <CheckBox x:Name="DlgSrv_FtpPassiveCb"
                                                      TabIndex="93"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogFtpPassiveMode}"
                                                      IsChecked="{Binding FtpPassiveMode}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,14,0,0"/>
                                            <CheckBox x:Name="DlgSrv_FtpSslCb"
                                                      TabIndex="94"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogFtpSsl}"
                                                      IsChecked="{Binding FtpUseSsl}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- VNC options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_VncOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_VncOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <CheckBox x:Name="DlgSrv_VncViewOnlyCb"
                                                      TabIndex="95"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogVncViewOnly}"
                                                      IsChecked="{Binding VncViewOnly}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Telnet options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_TelnetOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TelnetOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TelnetSecurityWarning"
                                                       Foreground="{DynamicResource WarningTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ============================================ -->
                        <!-- Tab: Info (organization + metadata)          -->
                        <!-- ============================================ -->
                        <TabItem x:Name="DlgSrv_TabInfo"
                                 AutomationProperties.Name="{loc:Translate ServerDialogTabInfo}"
                                 Style="{DynamicResource ThemedTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="{StaticResource SpacingSm}">
                                    <Border Style="{StaticResource DialogSectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_OrgTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_OrgDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="DlgSrv_FolderLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                                <TextBox x:Name="DlgSrv_FolderBox" Grid.Row="1" Grid.Column="0"
                                                         TabIndex="100"
                                                         AutomationProperties.Name="{loc:Translate ServerDialogLabelFolder}"
                                                         Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DialogFormTextBoxStyle}"/>
                                                <TextBlock x:Name="DlgSrv_EnvironmentLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                                <TextBlock x:Name="DlgSrv_FavoriteLabel" Grid.Row="2" Grid.Column="1" Style="{StaticResource LabelStyle}" Margin="12,14,0,4"/>
                                                <ComboBox x:Name="DlgSrv_EnvironmentCmb" Grid.Row="3" Grid.Column="0"
                                                          TabIndex="101"
                                                          AutomationProperties.Name="{loc:Translate ServerDialogLabelEnvironment}"
                                                          SelectedValue="{Binding Environment}"
                                                          SelectedValuePath="Tag"
                                                          Style="{StaticResource DialogFormComboBoxStyle}">
                                                    <ComboBoxItem x:Name="DlgSrv_EnvNone" Content="" Tag="None"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvProduction" Content="" Tag="Production"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvStaging" Content="" Tag="Staging"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvLab" Content="" Tag="Lab"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvPersonal" Content="" Tag="Personal"/>
                                                </ComboBox>
                                                <CheckBox Grid.Row="3" Grid.Column="1"
                                                          Margin="12,2,0,0"
                                                          x:Name="DlgSrv_MarkFavoriteCb"
                                                          TabIndex="102"
                                                          AutomationProperties.Name="{loc:Translate ServerDialogMarkFavorite}"
                                                          IsChecked="{Binding IsFavorite}"
                                                          Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DialogSectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_MetadataTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_MetadataDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TagsLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_TagsBox" TabIndex="103"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelTags}"
                                                     Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <TextBlock x:Name="DlgSrv_MacAddressLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                            <TextBox x:Name="DlgSrv_MacAddressBox" TabIndex="104"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelMacAddress}"
                                                     Text="{Binding MacAddress, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>

                </StackPanel> <!-- end FormFieldsPanel -->

            </StackPanel>
        </ScrollViewer>

        <!-- Validation error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="DlgSrv_CancelBtn"
                    IsCancel="True"
                    AutomationProperties.Name="{loc:Translate ServerDialogBtnCancel}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="DlgSrv_SaveBtn"
                    IsDefault="True"
                    AutomationProperties.Name="{loc:Translate ServerDialogBtnSave}"
                    MinWidth="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
