                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="DlgSrv_RemoteBindPortLabel" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                                <TextBox x:Name="DlgSrv_RemoteBindPortBox" Grid.Column="1"
                                                         TabIndex="23"
                                                         AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_RemoteBindPortLabel}"
                                                         Width="140"
                                                         HorizontalAlignment="Left"
                                                         MaxLength="5"
                                                         Text="{Binding RemoteBindPort, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            </Grid>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="DlgSrv_RemoteLocalPortLabel" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                                <TextBox x:Name="DlgSrv_RemoteLocalPortBox" Grid.Column="1"
                                                         TabIndex="24"
                                                         AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_RemoteLocalPortLabel}"
                                                         Width="140"
                                                         HorizontalAlignment="Left"
                                                         MaxLength="5"
                                                         Text="{Binding RemoteLocalPort, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            </Grid>
                                            <TextBlock x:Name="DlgSrv_RemoteLocalPortHint" Style="{StaticResource DialogHintTextStyle}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding RemoteForwardDisplay}" Style="{StaticResource DialogHintTextStyle}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_TunnelMappingTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock Text="{Binding TunnelSummary}" Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="DlgSrv_ChainLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GatewayRouteText}" Style="{StaticResource DialogHintTextStyle}" Margin="0,0,0,0"/>
                                                <TextBlock x:Name="DlgSrv_LocalEndpointLabel" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientNodeCaption}" Style="{StaticResource DialogHintTextStyle}" Margin="0,12,0,0"/>
                                                <TextBlock x:Name="DlgSrv_RemoteDestLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DestinationNodeCaption}" Style="{StaticResource DialogHintTextStyle}" Margin="0,12,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ============================================ -->
                        <!-- Tab: Gateway Authentication                  -->
                        <!-- ============================================ -->
                        <TabItem x:Name="DlgSrv_TabAuthentication"
                                 AutomationProperties.Name="{loc:Translate ServerDialogTabAuthentication}"
                                 ToolTipService.ShowOnDisabled="True">
                            <TabItem.Style>
                                <Style TargetType="TabItem" BasedOn="{StaticResource ThemedTabItemStyle}">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="IsEnabled" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
