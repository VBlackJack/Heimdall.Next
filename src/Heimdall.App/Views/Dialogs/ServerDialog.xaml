<Window x:Class="Heimdall.App.Views.Dialogs.ServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:ServerDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="650"
        Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="DiagramNodeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Width" Value="165"/>
            <Setter Property="MinHeight" Value="86"/>
        </Style>

        <Style x:Key="ArrowCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FormCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="RdpOnlySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SshOnlySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SshFamilySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Gateway/routing sections: hidden for Local shell and Citrix -->
        <Style x:Key="NetworkSectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewaySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DirectSectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsesGateway}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManualTunnelPortStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding UsesGateway}" Value="True"/>
                        <Condition Binding="{Binding UseAutomaticTunnelPort}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Style="{DynamicResource ThemedTabControlStyle}">
            <TabItem Header="Connection" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Connection basics" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Choose the protocol, destination host, and service port Heimdall should open."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Display name" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Connection type" Style="{StaticResource LabelStyle}" Margin="12,0,0,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              Margin="12,0,0,0"
                                              SelectedValue="{Binding ConnectionType}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="RDP"/>
                                        <ComboBoxItem Content="SSH"/>
                                        <ComboBoxItem Content="SFTP"/>
                                        <ComboBoxItem Content="Local"/>
                                        <ComboBoxItem Content="Citrix"/>
                                    </ComboBox>
                                    <!-- Server/Port row: hidden for Local shell and Citrix -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Server" Margin="0,14,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EndpointPortLabel}" Margin="12,14,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Grid.Row="3" Grid.Column="0"
                                             Text="{Binding RemoteServer, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBox Grid.Row="3" Grid.Column="1"
                                             Margin="12,0,0,0"
                                             Width="120"
                                             HorizontalAlignment="Left"
                                             Text="{Binding EndpointPort, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                                <TextBlock Text="{Binding EndpointPortHelpText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Gateway routing" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Use an SSH gateway when the target server is only reachable through a bastion or jump host."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox Content="Connect directly without an SSH gateway"
                                          IsChecked="{Binding DirectConnection}"
                                          Style="{StaticResource FormCheckBoxStyle}"
                                          Margin="0,14,0,0"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding AvailableGateways}"
                                              SelectedValue="{Binding SelectedGatewayId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayText"
                                              IsEnabled="{Binding CanSelectGateway}"
                                              Style="{StaticResource FormComboBoxStyle}"/>
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Padding="12,6"
                                            Content="Test connection"
                                            Command="{Binding TestGatewayCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                </Grid>
                                <TextBlock Text="{Binding GatewayExplanation}" Style="{StaticResource HintTextStyle}"/>
                                <Border Margin="0,12,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedGatewayTitle}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding GatewayRouteText}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding GatewayTestMessage}"
                                           Foreground="{DynamicResource InfoBrush}"
                                           FontSize="12"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding GatewayTestMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Connection path" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding ConnectionPathHeadline}" Style="{StaticResource SectionDescriptionStyle}"/>
                                <StackPanel Margin="0,16,0,0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource DirectSectionStyle}">
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Your PC" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="12,16,12,0" Width="78">
                                        <TextBlock Text="->" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding SessionKindLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Destination" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0,16,0,0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GatewaySectionStyle}">
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Your PC" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="12,16,12,0" Width="78">
                                        <TextBlock Text="->" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ClientToGatewayLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Gateway" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedGatewayTitle}" Style="{StaticResource HintTextStyle}"/>
                                            <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="12,16,12,0" Width="78">
                                        <TextBlock Text="->" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GatewayToServerLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Destination" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tunneling" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="How tunneling works" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="A tunnel listens on a local port on your PC and forwards that traffic to the remote service through the selected SSH gateway."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock Text="This is only used when a gateway is selected. Direct connections skip the local tunnel entirely."
                                           Style="{StaticResource HintTextStyle}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Direct connection" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="No tunnel will be created for this server. Heimdall connects straight to the destination host and service port."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Local tunnel port" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Heimdall uses this local port to reach the remote service through the SSH tunnel."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox Content="Choose the tunnel port automatically"
                                          IsChecked="{Binding UseAutomaticTunnelPort}"
                                          Style="{StaticResource FormCheckBoxStyle}"
                                          Margin="0,14,0,0"/>
                                <TextBlock Text="{Binding LocalTunnelPortDisplay}" Style="{StaticResource HintTextStyle}" Margin="0,8,0,0"/>
                                <Grid Margin="0,12,0,0" Style="{StaticResource ManualTunnelPortStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Manual local port" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                    <TextBox Grid.Column="1"
                                             Width="140"
                                             HorizontalAlignment="Left"
                                             Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Tunnel mapping" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding TunnelSummary}" Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway chain" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GatewayRouteText}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Local endpoint" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}" Margin="0,12,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Remote destination" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}" Margin="0,12,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Authentication" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="RDP credentials" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Credentials used by the Remote Desktop session after routing is complete."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock Text="Username" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                <TextBox Text="{Binding RdpUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBlock Text="Password" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                <PasswordBox x:Name="RdpPasswordBox" Style="{StaticResource FormPasswordBoxStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="SSH credentials" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="These credentials are used for the SSH or SFTP session itself."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock Text="Username" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                <TextBox Text="{Binding SshUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBlock Text="SSH key" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                <DockPanel>
                                    <Button Content="Browse"
                                            DockPanel.Dock="Right"
                                            Command="{Binding BrowseSshKeyCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            Click="OnBrowseSshKeyClick"/>
                                    <TextBox Text="{Binding SshKeyPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                                </DockPanel>
                                <TextBlock Text="Password or passphrase" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                <PasswordBox x:Name="SshPasswordBox" Style="{StaticResource FormPasswordBoxStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Gateway authentication" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="The selected SSH gateway uses the credentials stored in its own gateway profile."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock Text="{Binding SelectedGatewayTitle}" Style="{StaticResource HintTextStyle}" Margin="0,10,0,0"/>
                                <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Options" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="RDP session options" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Display, transport, and session mode settings for the Remote Desktop client."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Session mode" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Aspect ratio" Style="{StaticResource LabelStyle}" Margin="12,0,0,4"/>
                                    <ComboBox Grid.Row="1" Grid.Column="0"
                                              SelectedValue="{Binding RdpMode}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="Embedded"/>
                                        <ComboBoxItem Content="External"/>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              Margin="12,0,0,0"
                                              SelectedValue="{Binding RdpAspectRatio}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="Stretch"/>
                                        <ComboBoxItem Content="Preserve"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Audio mode" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Color depth" Style="{StaticResource LabelStyle}" Margin="12,14,0,4"/>
                                    <ComboBox Grid.Row="3" Grid.Column="0"
                                              SelectedValue="{Binding RdpAudioMode}"
                                              SelectedValuePath="Tag"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="Disabled" Tag="0"/>
                                        <ComboBoxItem Content="Local playback" Tag="1"/>
                                        <ComboBoxItem Content="Remote playback" Tag="2"/>
                                    </ComboBox>
                                    <ComboBox Grid.Row="3" Grid.Column="1"
                                              Margin="12,0,0,0"
                                              SelectedValue="{Binding RdpColorDepth}"
                                              SelectedValuePath="Tag"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="16-bit" Tag="16"/>
                                        <ComboBoxItem Content="24-bit" Tag="24"/>
                                        <ComboBoxItem Content="32-bit" Tag="32"/>
                                    </ComboBox>
                                </Grid>
                                <StackPanel Margin="0,14,0,0">
                                    <CheckBox Content="Enable Network Level Authentication" IsChecked="{Binding RdpNla}" Style="{StaticResource FormCheckBoxStyle}"/>
                                    <CheckBox Content="Use multiple monitors" IsChecked="{Binding RdpMultiMonitor}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                    <CheckBox Content="Allow dynamic resolution updates" IsChecked="{Binding RdpDynamicResolution}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                    <CheckBox Content="Capture local microphone" IsChecked="{Binding RdpAudioCapture}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Expander Header="Device redirection" IsExpanded="True">
                            <Expander.Style>
                                <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Expander.Style>
                            <StackPanel Margin="0,12,0,0">
                                <CheckBox Content="Redirect clipboard" IsChecked="{Binding RedirectClipboard}" Style="{StaticResource FormCheckBoxStyle}"/>
                                <CheckBox Content="Redirect drives" IsChecked="{Binding RedirectDrives}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Redirect printers" IsChecked="{Binding RedirectPrinters}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Redirect COM ports" IsChecked="{Binding RdpRedirectComPorts}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Redirect smart cards" IsChecked="{Binding RdpRedirectSmartCards}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Redirect webcam" IsChecked="{Binding RdpRedirectWebcam}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Redirect USB devices" IsChecked="{Binding RdpRedirectUsb}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Advanced RDP behavior" IsExpanded="False">
                            <Expander.Style>
                                <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Expander.Style>
                            <StackPanel Margin="0,12,0,0">
                                <CheckBox Content="Use global RDP defaults" IsChecked="{Binding RdpUseGlobalDefaults}" Style="{StaticResource FormCheckBoxStyle}"/>
                                <CheckBox Content="Enable anti-idle keepalive" IsChecked="{Binding RdpAntiIdle}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Use bitmap caching" IsChecked="{Binding RdpBitmapCaching}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Enable RDP compression" IsChecked="{Binding RdpCompression}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                <CheckBox Content="Automatically reconnect" IsChecked="{Binding RdpAutoReconnect}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Expander>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="SSH options" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Session mode and SSH feature flags used by the shell or file transfer connection."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SSH mode" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                    <ComboBox Grid.Column="1"
                                              SelectedValue="{Binding SshMode}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="Embedded"/>
                                        <ComboBoxItem Content="External"/>
                                    </ComboBox>
                                </Grid>
                                <StackPanel Margin="0,14,0,0">
                                    <CheckBox Content="Enable compression" IsChecked="{Binding SshCompression}" Style="{StaticResource FormCheckBoxStyle}"/>
                                    <CheckBox Content="Forward SSH agent" IsChecked="{Binding SshAgentForwarding}" Style="{StaticResource FormCheckBoxStyle}" Margin="0,6,0,0"/>
                                    <CheckBox Content="Enable X11 forwarding"
                                              IsChecked="{Binding SshX11Forwarding}"
                                              Margin="0,6,0,0">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource FormCheckBoxStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Local Shell settings (visible only for Local type) -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Local shell" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Configure the shell executable and startup arguments."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Executable" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                              IsEditable="True"
                                              Text="{Binding LocalShellExecutable, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="powershell.exe"/>
                                        <ComboBoxItem Content="pwsh.exe"/>
                                        <ComboBoxItem Content="cmd.exe"/>
                                        <ComboBoxItem Content="bash"/>
                                        <ComboBoxItem Content="wsl.exe"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Arguments" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding LocalShellArguments, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Working directory" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding LocalShellWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                </Grid>
                                <CheckBox Content="Run as Administrator (requires gsudo or Windows 11 sudo)"
                                          IsChecked="{Binding LocalShellElevated}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Citrix settings (visible only for Citrix type) -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Citrix Workspace" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Configure the StoreFront URL and application name, or provide a direct ICA file."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="StoreFront URL" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding CitrixStoreFrontUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Application name" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding CitrixAppName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="ICA file path" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding CitrixIcaFilePath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                </Grid>
                                <TextBlock Text="Provide either a StoreFront URL + application name, or a direct ICA file path."
                                           Style="{StaticResource HintTextStyle}"/>
                                <CheckBox Content="Seamless mode"
                                          IsChecked="{Binding CitrixSeamlessMode}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,12,0,0"/>
                                <CheckBox Content="Use SSO (Kerberos)"
                                          IsChecked="{Binding CitrixUseSso}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Info" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Organization" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Use grouping metadata to keep the server list organized."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Environment" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Favorite" Style="{StaticResource LabelStyle}" Margin="12,14,0,4"/>
                                    <ComboBox Grid.Row="3" Grid.Column="0"
                                              SelectedValue="{Binding Environment}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Production"/>
                                        <ComboBoxItem Content="Staging"/>
                                        <ComboBoxItem Content="Lab"/>
                                        <ComboBoxItem Content="Personal"/>
                                    </ComboBox>
                                    <CheckBox Grid.Row="3" Grid.Column="1"
                                              Margin="12,2,0,0"
                                              Content="Mark as favorite"
                                              IsChecked="{Binding IsFavorite}"
                                              Style="{StaticResource FormCheckBoxStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Metadata" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Optional tags and Wake-on-LAN metadata for this server entry."
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock Text="Tags" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                <TextBox Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBlock Text="MAC address" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                <TextBox Text="{Binding MacAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorBrush}"
                   FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    IsCancel="True"
                    Width="90"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button Content="Save"
                    IsDefault="True"
                    Width="90"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
