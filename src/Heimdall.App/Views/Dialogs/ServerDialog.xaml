                                            <CheckBox x:Name="DlgSrv_PerfEnableCompositionCb" TabIndex="86" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_DisableUdpCb" TabIndex="87" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpDisableUdp}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,12,0,0"/>
                                        </StackPanel>
