                                                                  AutomationProperties.Name="{loc:Translate ServerDialogResolutionMoreOptions}"
                                                                  Style="{DynamicResource ThemedExpanderStyle}">
                                                            <StackPanel Margin="0,12,0,0">
                                                                <TextBlock Text="{loc:Translate ServerDialogResolutionModeLabel}"
                                                                           Style="{StaticResource LabelStyle}"
                                                                           Margin="0,0,0,4"/>
                                                                <ComboBox x:Name="DlgSrv_RdpResolutionModeCombo"
                                                                          TabIndex="64"
                                                                          AutomationProperties.Name="{loc:Translate ServerDialogResolutionModeLabel}"
                                                                          SelectedValue="{Binding RdpResolutionMode}"
                                                                          SelectedValuePath="Tag"
                                                                          Style="{StaticResource DialogFormComboBoxStyle}">
                                                                    <ComboBoxItem Content="{loc:Translate ServerDialogResolutionModeFitWindow}"
                                                                                  Tag="{x:Static config:RdpResolutionMode.FitWindow}"/>
                                                                    <ComboBoxItem Content="{loc:Translate ServerDialogResolutionModeFixed}"
                                                                                  Tag="{x:Static config:RdpResolutionMode.Fixed}"/>
                                                                    <ComboBoxItem Content="{loc:Translate ServerDialogResolutionModeSmartSizing}"
                                                                                  Tag="{x:Static config:RdpResolutionMode.SmartSizing}"/>
                                                                    <ComboBoxItem Content="{loc:Translate ServerDialogResolutionModeMultimon}"
                                                                                  Tag="{x:Static config:RdpResolutionMode.Multimon}"
                                                                                  IsEnabled="{Binding IsMultimonAvailable}"
                                                                                  ToolTipService.ShowOnDisabled="True"
                                                                                  ToolTip="{loc:Translate ServerDialogResolutionModeMultimonUnavailableTooltip}"/>
                                                                </ComboBox>

                                                                <StackPanel Margin="0,12,0,0"
                                                                            Visibility="{Binding ShowRdpFixedResolutionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="{loc:Translate ServerDialogRdpResolutionPresetLabel}"
                                                                               Style="{StaticResource LabelStyle}"
                                                                               Margin="0,0,0,4"/>
                                                                    <ComboBox x:Name="DlgSrv_RdpResolutionPresetCombo"
                                                                              TabIndex="64"
                                                                              AutomationProperties.Name="{loc:Translate ServerDialogRdpResolutionPresetLabel}"
                                                                              SelectionChanged="OnRdpResolutionPresetSelectionChanged"
                                                                              Style="{StaticResource DialogFormComboBoxStyle}"
                                                                              Margin="0,0,0,12">
