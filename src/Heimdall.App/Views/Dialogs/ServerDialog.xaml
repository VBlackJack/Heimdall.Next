                                            Padding="5,0" Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasTunnelingTabErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding TunnelingTabErrorCount}"
                                                   Foreground="{DynamicResource TextOnAccentBrush}" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <TabItem.Style>
                                <Style TargetType="TabItem" BasedOn="{StaticResource ThemedTabItemStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter Property="IsEnabled" Value="False"/>
