                                                                        <ComboBoxItem Content="1280×720" Tag="1280x720"/>
                                                                        <ComboBoxItem Content="1366×768" Tag="1366x768"/>
                                                                        <ComboBoxItem Content="1920×1080" Tag="1920x1080"/>
                                                                        <ComboBoxItem Content="2560×1440" Tag="2560x1440"/>
                                                                        <ComboBoxItem Content="3840×2160" Tag="3840x2160"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                <Grid Margin="0,0,0,0"
                                                                      Visibility="{Binding ShowRdpFixedResolutionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                                               Text="{loc:Translate ServerDialogRdpFixedWidth}"
                                                                               Style="{StaticResource LabelStyle}"
                                                                               Margin="0,0,0,4"/>
                                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                                               Text="{loc:Translate ServerDialogRdpFixedHeight}"
                                                                               Style="{StaticResource LabelStyle}"
                                                                               Margin="12,0,0,4"/>
                                                                    <TextBox x:Name="DlgSrv_RdpFixedWidthBox"
                                                                             Grid.Row="1" Grid.Column="0"
                                                                             TabIndex="65"
                                                                             AutomationProperties.Name="{loc:Translate ServerDialogRdpFixedWidth}"
                                                                             Text="{Binding RdpFixedWidth, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                                             Style="{StaticResource DialogFormTextBoxStyle}"/>
                                                                    <TextBox x:Name="DlgSrv_RdpFixedHeightBox"
                                                                             Grid.Row="1" Grid.Column="1"
                                                                             TabIndex="66"
                                                                             Margin="12,0,0,0"
                                                                             AutomationProperties.Name="{loc:Translate ServerDialogRdpFixedHeight}"
                                                                             Text="{Binding RdpFixedHeight, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                                             Style="{StaticResource DialogFormTextBoxStyle}"/>
                                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                                               Text="{Binding RdpFixedWidthError}"
                                                                               Style="{StaticResource FieldValidationErrorStyle}"
                                                                               Visibility="{Binding RdpFixedWidthError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                                                               Text="{Binding RdpFixedHeightError}"
                                                                               Style="{StaticResource FieldValidationErrorStyle}"
                                                                               Margin="12,2,0,0"
                                                                               Visibility="{Binding RdpFixedHeightError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                </Grid>

                                                                <CheckBox Content="{loc:Translate ServerDialogRdpInitialSmartSizing}"
                                                                          TabIndex="67"
                                                                          AutomationProperties.Name="{loc:Translate ServerDialogRdpInitialSmartSizing}"
                                                                          IsChecked="{Binding RdpInitialSmartSizing}"
                                                                          Style="{StaticResource DialogFormCheckBoxStyle}"
                                                                          Margin="0,12,0,0"
                                                                          Visibility="{Binding ShowRdpInitialSmartSizing, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                                <StackPanel Margin="0,12,0,0"
                                                                            Visibility="{Binding ShowRdpResizeEnableDelay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="{loc:Translate ServerDialogRdpResizeDelay}"
                                                                               Style="{StaticResource LabelStyle}"
                                                                               Margin="0,0,0,4"/>
                                                                    <TextBox x:Name="DlgSrv_RdpResizeDelayBox"
                                                                             TabIndex="68"
                                                                             AutomationProperties.Name="{loc:Translate ServerDialogRdpResizeDelay}"
                                                                             Tag="{Binding RdpResizeEnableDelayPlaceholder}"
                                                                             Text="{Binding RdpResizeEnableDelayMs, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', ValidatesOnNotifyDataErrors=True}"
                                                                             Style="{StaticResource WatermarkTextBoxStyle}"/>
                                                                    <TextBlock Text="{Binding RdpResizeEnableDelayMsError}"
                                                                               Style="{StaticResource FieldValidationErrorStyle}"
                                                                               Visibility="{Binding RdpResizeEnableDelayMsError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                </StackPanel>

                                                                <TextBlock Text="{loc:Translate ServerDialogResolutionModeMultimonNote}"
                                                                           Style="{StaticResource DialogHintTextStyle}"
                                                                           Margin="0,12,0,0"
                                                                           Visibility="{Binding ShowRdpMultimonNote, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                                <Border Style="{StaticResource InsetCardStyle}"
                                                                        Margin="0,12,0,0"
                                                                        Visibility="{Binding ShowRdpSelectedMonitors, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <StackPanel>
                                                                        <DockPanel LastChildFill="False">
                                                                            <TextBlock Text="{loc:Translate ServerDialogSelectedMonitorsTitle}"
                                                                                       Style="{StaticResource LabelStyle}"
                                                                                       DockPanel.Dock="Left"
                                                                                       VerticalAlignment="Center"/>
                                                                            <Button Content="{loc:Translate ServerDialogRefreshMonitors}"
                                                                                    Command="{Binding RefreshMonitorsCommand}"
                                                                                    Style="{StaticResource ToolbarGhostButtonStyle}"
                                                                                    FontSize="{StaticResource FontSizeCaption}"
                                                                                    Padding="8,2"
                                                                                    MinHeight="0"
                                                                                    HorizontalAlignment="Right"
                                                                                    DockPanel.Dock="Right"/>
                                                                        </DockPanel>
                                                                        <TextBlock Text="{loc:Translate ServerDialogSelectedMonitorsCaption}"
                                                                                   Style="{StaticResource DialogHintTextStyle}"
                                                                                   Margin="0,4,0,8"
                                                                                   TextWrapping="Wrap"/>
                                                                        <ItemsControl ItemsSource="{Binding AvailableMonitors}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <CheckBox Content="{Binding Label}"
                                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              ToolTip="{Binding DeviceName}"
                                                                                              ToolTipService.ShowOnDisabled="True"
                                                                                              AutomationProperties.Name="{Binding Label}"
                                                                                              Style="{StaticResource DialogFormCheckBoxStyle}"
                                                                                              Margin="0,4,0,0"/>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Expander>

                                                        <CheckBox x:Name="DlgSrv_RdpMultimonToggle"
                                                                  Content="{loc:Translate ServerDialogRdpEnableMultimon}"
                                                                  ToolTip="{loc:Translate ServerDialogRdpEnableMultimonHint}"
                                                                  ToolTipService.ShowOnDisabled="True"
                                                                  IsChecked="{Binding IsMultimonModeSelected, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsMultimonAvailable}"
                                                                  AutomationProperties.Name="{loc:Translate ServerDialogRdpEnableMultimon}"
                                                                  Style="{StaticResource DialogFormCheckBoxStyle}"
                                                                  Margin="0,12,0,0"/>

                                                        <TextBlock Margin="0,12,0,0"
                                                                   Visibility="{Binding CanSwitchToAuto, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                   HorizontalAlignment="Left">
                                                            <Hyperlink Command="{Binding SwitchToAutoCommand}"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       AutomationProperties.Name="{loc:Translate ServerDialogResolutionModeSwitchToAuto}">
                                                                <Run Text="{loc:Translate ServerDialogResolutionModeSwitchToAuto}"/>
                                                            </Hyperlink>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Margin="0,14,0,0">
                                                    <TextBlock Text="{loc:Translate ServerDialogRdpSecuritySection}"
                                                               Style="{StaticResource LabelStyle}"
                                                               Margin="0,0,0,4"/>
                                                    <CheckBox x:Name="DlgSrv_NlaCb" TabIndex="69" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpNla}" Style="{StaticResource DialogFormCheckBoxStyle}"/>

                                                    <TextBlock Text="{loc:Translate ServerDialogRdpDisplaySection}"
                                                               Style="{StaticResource LabelStyle}"
                                                               Margin="0,12,0,4"/>
                                                    <CheckBox x:Name="DlgSrv_DynamicResCb" TabIndex="70" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpDynamicResolution}" Style="{StaticResource DialogFormCheckBoxStyle}"/>

                                                    <TextBlock Text="{loc:Translate ServerDialogRdpAudioSection}"
                                                               Style="{StaticResource LabelStyle}"
                                                               Margin="0,12,0,4"/>
                                                    <CheckBox x:Name="DlgSrv_AudioCaptureCb" TabIndex="71" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpAudioCapture}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- RDP device redirection -->
                                    <Expander x:Name="DlgSrv_DeviceRedirExpander" IsExpanded="True">
                                        <Expander.Style>
                                            <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RdpUseGlobalDefaults}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <StackPanel Margin="0,12,0,0">
                                            <CheckBox x:Name="DlgSrv_RedirClipboardCb" TabIndex="68" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RedirectClipboard}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            <CheckBox x:Name="DlgSrv_RedirDrivesCb" TabIndex="69" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RedirectDrives}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_RedirPrintersCb" TabIndex="70" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RedirectPrinters}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_RedirComPortsCb" TabIndex="71" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpRedirectComPorts}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_RedirSmartCardsCb" TabIndex="72" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpRedirectSmartCards}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <CheckBox x:Name="DlgSrv_RedirWebcamCb"
                                                          TabIndex="73"
                                                          AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                          IsChecked="{Binding RdpRedirectWebcam}"
                                                          ToolTip="{loc:Translate RdpRedirectWebcamHint}"
                                                          ToolTipService.ShowOnDisabled="True">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource DialogFormCheckBoxStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RdpMode}" Value="Embedded">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                                <TextBlock Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           FontStyle="Italic"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Text="{loc:Translate RdpRedirectWebcamExternalOnlyBadge}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RdpMode}" Value="Embedded">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <CheckBox x:Name="DlgSrv_RedirUsbCb" TabIndex="74" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpRedirectUsb}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Expander>

                                    <!-- RDP advanced behavior -->
                                    <Expander x:Name="DlgSrv_AdvancedRdpExpander" IsExpanded="False">
                                        <Expander.Style>
                                            <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <StackPanel Margin="0,12,0,0">
                                            <CheckBox x:Name="DlgSrv_GlobalDefaultsCb" TabIndex="75" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpUseGlobalDefaults}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RdpUseGlobalDefaults}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <CheckBox x:Name="DlgSrv_AntiIdleCb" TabIndex="76" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpAntiIdle}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                                <CheckBox x:Name="DlgSrv_BitmapCacheCb" TabIndex="77" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpBitmapCaching}" ToolTip="{loc:Translate RdpBitmapCachingHint}" ToolTipService.ShowOnDisabled="True" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                                <CheckBox x:Name="DlgSrv_RdpCompressionCb" TabIndex="78" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpCompression}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                                <CheckBox x:Name="DlgSrv_AutoReconnectCb" TabIndex="79" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpAutoReconnect}" ToolTip="{loc:Translate RdpAutoReconnectHint}" ToolTipService.ShowOnDisabled="True" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                                <CheckBox x:Name="DlgSrv_RdpAdminModeCb"
                                                          TabIndex="88"
                                                          AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                          IsChecked="{Binding RdpAdminMode}"
                                                          ToolTip="{loc:Translate RdpAdminModeHint}"
                                                          Margin="0,12,0,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource DialogFormCheckBoxStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RdpMode}" Value="External">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                                <CheckBox x:Name="DlgSrv_RdpFullScreenCb"
                                                          TabIndex="89"
                                                          AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                          IsChecked="{Binding RdpFullScreen}"
                                                          ToolTip="{loc:Translate RdpFullScreenHint}"
                                                          Margin="0,6,0,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource DialogFormCheckBoxStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RdpMode}" Value="External">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <!-- RDP experience/performance -->
                                    <Expander x:Name="DlgSrv_RdpExperienceExpander" IsExpanded="False">
                                        <Expander.Style>
                                            <Style TargetType="Expander" BasedOn="{StaticResource ThemedExpanderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RdpUseGlobalDefaults}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <StackPanel Margin="0,12,0,0">
                                            <CheckBox x:Name="DlgSrv_PerfDisableWallpaperCb" TabIndex="80" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfDisableWallpaper}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableThemesCb" TabIndex="81" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfDisableThemes}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableAnimationsCb" TabIndex="82" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfDisableAnimations}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableDragCb" TabIndex="83" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfDisableDrag}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableCursorShadowCb" TabIndex="84" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfDisableCursorShadow}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfEnableFontSmoothingCb" TabIndex="85" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfEnableFontSmoothing}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfEnableCompositionCb" TabIndex="86" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpPerfEnableComposition}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_DisableUdpCb" TabIndex="87" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" IsChecked="{Binding RdpDisableUdp}" ToolTip="{loc:Translate RdpDisableUdpHint}" ToolTipService.ShowOnDisabled="True" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,12,0,0"/>
                                        </StackPanel>
                                    </Expander>

                                    <!-- SSH options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_SshOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_SshOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <Grid Margin="0,16,0,0">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="DlgSrv_SshModeLabel" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                                <ComboBox Grid.Column="1"
                                                          AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_SshModeLabel}"
                                                          TabIndex="80"
                                                          SelectedValue="{Binding SshMode}"
                                                          SelectedValuePath="Tag"
                                                          Style="{StaticResource DialogFormComboBoxStyle}">
                                                    <ComboBoxItem x:Name="DlgSrv_SshModeEmbedded" Content="" Tag="Embedded"/>
                                                    <ComboBoxItem x:Name="DlgSrv_SshModeExternal" Content="" Tag="External"/>
                                                </ComboBox>
                                            </Grid>
                                            <StackPanel Margin="0,14,0,0">
                                                <CheckBox x:Name="DlgSrv_SshCompressionCb" TabIndex="81" AutomationProperties.Name="{loc:Translate A11yServerSshCompression}" IsChecked="{Binding SshCompression}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                                <CheckBox x:Name="DlgSrv_SshAgentFwdCb" TabIndex="82" AutomationProperties.Name="{loc:Translate A11yServerSshAgentForwarding}" IsChecked="{Binding SshAgentForwarding}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                                <CheckBox x:Name="DlgSrv_SshX11Cb"
                                                          TabIndex="83"
                                                          AutomationProperties.Name="{loc:Translate A11yServerSshX11Forwarding}"
                                                          IsChecked="{Binding SshX11Forwarding}"
                                                          Margin="0,6,0,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource DialogFormCheckBoxStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </StackPanel>
                                            <StackPanel Margin="0,14,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Style="{StaticResource LabelStyle}"
                                                           Text="{loc:Translate ServerDialogPostConnectStepsLabel}"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Style="{StaticResource DialogHintTextStyle}"
                                                           Text="{loc:Translate ServerDialogPostConnectStepsHint}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>
                                                <ListView ItemsSource="{Binding PostConnectSteps}"
                                                          SelectedItem="{Binding SelectedPostConnectStep}"
                                                          MinHeight="150"
                                                          MaxHeight="240"
                                                          TabIndex="84"
                                                          Background="{DynamicResource CardBrush}"
                                                          BorderBrush="{DynamicResource BorderBrush}"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:PostConnectStepItemViewModel}">
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="88"/>
                                                                    <ColumnDefinition Width="132"/>
                                                                    <ColumnDefinition Width="78"/>
                                                                    <ColumnDefinition Width="78"/>
                                                                    <ColumnDefinition Width="84"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding Enabled}"
                                                                          VerticalAlignment="Center"
                                                                          AutomationProperties.Name="{loc:Translate ServerDialogPostConnectEnabled}"/>
                                                                <Grid Grid.Column="1" Margin="8,0,8,0">
                                                                    <TextBox VerticalAlignment="Center"
                                                                             Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                                                                             AutomationProperties.Name="{loc:Translate ServerDialogPostConnectInput}">
                                                                        <TextBox.Style>
                                                                            <Style TargetType="TextBox" BasedOn="{StaticResource DialogFormTextBoxStyle}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBox.Style>
                                                                    </TextBox>
                                                                    <Border Padding="8,6"
                                                                            CornerRadius="{StaticResource CornerRadiusMd}"
                                                                            Background="{DynamicResource SurfaceBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                                            BorderThickness="1"
                                                                            Visibility="Collapsed"
                                                                            ToolTip="{loc:Translate TooltipPostConnectLinkedHint}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Setter Property="ToolTip" Value="{loc:Translate TooltipPostConnectLinkedHint}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsBroken}" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                                                        <Setter Property="ToolTip" Value="{loc:Translate TooltipPostConnectLibraryBroken}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{loc:Translate LabelPostConnectLibraryLinkedPrefix}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                            <TextBlock Text="{Binding DisplayInput}"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                       FontWeight="SemiBold"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text=" · "
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       Visibility="{Binding IsBroken, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                            <TextBlock Text="{loc:Translate LabelPostConnectLibraryBroken}"
                                                                                       Foreground="{DynamicResource ErrorBrush}"
                                                                                       Visibility="{Binding IsBroken, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                                <TextBox Grid.Column="2"
                                                                         Margin="0,0,8,0"
                                                                         Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                                         VerticalAlignment="Center"
                                                                         Style="{StaticResource DialogFormTextBoxStyle}"
                                                                         AutomationProperties.Name="{loc:Translate ServerDialogPostConnectDelay}"/>
                                                                <ComboBox Grid.Column="3"
                                                                          ItemsSource="{Binding DataContext.PostConnectFailureOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Label"
                                                                          SelectedValuePath="Value"
                                                                           SelectedValue="{Binding OnFailure}"
                                                                           VerticalAlignment="Center"
                                                                           Style="{StaticResource DialogFormComboBoxStyle}"
                                                                           AutomationProperties.Name="{loc:Translate ServerDialogPostConnectOnFailure}"/>
                                                                <Button Grid.Column="4"
                                                                        Content="{loc:Translate BtnPostConnectLinkLibrary}"
                                                                        Command="{Binding DataContext.LinkCommandLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,0,0,0"
                                                                        AutomationProperties.Name="{loc:Translate BtnPostConnectLinkLibrary}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Grid.Column="5"
                                                                        Content="{loc:Translate BtnPostConnectChangeLibrary}"
                                                                        Command="{Binding DataContext.ChangeCommandLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,0,0,0"
                                                                        AutomationProperties.Name="{loc:Translate A11yPostConnectChangeLibrary}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Grid.Column="6"
                                                                        Content="{loc:Translate BtnPostConnectUnlinkLibrary}"
                                                                        Command="{Binding DataContext.UnlinkCommandLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,0,0,0"
                                                                        AutomationProperties.Name="{loc:Translate BtnPostConnectUnlinkLibrary}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Text="{loc:Translate ServerDialogPostConnectColumnsHint}"/>
                                                    <Button Grid.Column="1"
                                                            Content="{loc:Translate ServerDialogPostConnectAddStep}"
                                                            Command="{Binding AddPostConnectStepCommand}"
                                                            Margin="8,0,0,0"
                                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                                    <Button Grid.Column="2"
                                                            Content="{loc:Translate ServerDialogPostConnectRemoveStep}"
                                                            Command="{Binding RemovePostConnectStepCommand}"
                                                            Margin="8,0,0,0"
                                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                                    <Button Grid.Column="3"
                                                            Content="{loc:Translate ServerDialogPostConnectMoveUp}"
                                                            Command="{Binding MovePostConnectStepUpCommand}"
                                                            Margin="8,0,0,0"
                                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                                    <Button Grid.Column="4"
                                                            Content="{loc:Translate ServerDialogPostConnectMoveDown}"
                                                            Command="{Binding MovePostConnectStepDownCommand}"
                                                            Margin="8,0,0,0"
                                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                                </Grid>
                                                <Border Margin="0,12,0,0"
                                                        Padding="10"
                                                        CornerRadius="{StaticResource CornerRadiusMd}"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Visibility="{Binding HasLegacyPostConnectCommand, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Text="{loc:Translate ServerDialogPostConnectLegacyLabel}"/>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource DialogHintTextStyle}"
                                                                   Text="{loc:Translate ServerDialogPostConnectLegacyHint}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBox Margin="0,8,0,0"
                                                                 Text="{Binding LegacyPostConnectCommandText, Mode=OneWay}"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 Height="64"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 Background="{DynamicResource SurfaceBrush}"
                                                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                                            <Run Text="{loc:Translate ServerDialogPostConnectDelayLabel}"/>
                                                            <Run Text=": "/>
                                                            <Run Text="{Binding LegacyPostConnectDelayText, Mode=OneWay}"/>
                                                            <Run Text=" ms"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Local Shell advanced options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_LocalShellTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_LocalShellDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_WorkingDirLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_WorkingDirBox" TabIndex="84"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelWorkingDir}"
                                                     Text="{Binding LocalShellWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <DockPanel Margin="0,12,0,0">
                                                <TextBlock x:Name="DlgSrv_ElevationModeLabel" Text=""
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="DlgSrv_ElevationModeCmb"
                                                          TabIndex="85" Width="200"
                                                          AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_ElevationModeLabel}"
                                                          Background="{DynamicResource CardBrush}"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          BorderBrush="{DynamicResource BorderBrush}"
                                                          VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Citrix advanced options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_CitrixTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_CitrixDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_IcaFileLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_IcaFileBox" TabIndex="86"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelIcaFilePath}"
                                                     Text="{Binding CitrixIcaFilePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <TextBlock x:Name="DlgSrv_CitrixHint"
                                                       Style="{StaticResource DialogHintTextStyle}" Margin="0,8,0,0"/>
                                            <CheckBox x:Name="DlgSrv_SeamlessCb"
                                                      TabIndex="87"
                                                      AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                      IsChecked="{Binding CitrixSeamlessMode}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,12,0,0"/>
                                            <CheckBox x:Name="DlgSrv_SsoCb"
                                                      TabIndex="88"
                                                      AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}"
                                                      IsChecked="{Binding CitrixUseSso}"
                                                      ToolTip="{loc:Translate CitrixUseSsoTooltip}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- FTP options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_FtpOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_FtpOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <CheckBox x:Name="DlgSrv_FtpPassiveCb"
                                                      TabIndex="93"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogFtpPassiveMode}"
                                                      IsChecked="{Binding FtpPassiveMode}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,14,0,0"/>
                                            <CheckBox x:Name="DlgSrv_FtpSslCb"
                                                      TabIndex="94"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogFtpSsl}"
                                                      IsChecked="{Binding FtpUseSsl}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- VNC options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_VncOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_VncOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <CheckBox x:Name="DlgSrv_VncViewOnlyCb"
                                                      TabIndex="95"
                                                      AutomationProperties.Name="{loc:Translate ServerDialogVncViewOnly}"
                                                      IsChecked="{Binding VncViewOnly}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Telnet options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_TelnetOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TelnetOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TelnetSecurityWarning"
                                                       Foreground="{DynamicResource WarningTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ============================================ -->
                        <!-- Tab: Info (organization + metadata)          -->
                        <!-- ============================================ -->
                        <TabItem x:Name="DlgSrv_TabInfo"
                                 AutomationProperties.Name="{loc:Translate ServerDialogTabInfo}"
                                 Style="{DynamicResource ThemedTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="{StaticResource SpacingSm}">
                                    <Border Style="{StaticResource DialogSectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_OrgTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_OrgDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="DlgSrv_FolderLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                                <TextBox x:Name="DlgSrv_FolderBox" Grid.Row="1" Grid.Column="0"
                                                         TabIndex="100"
                                                         AutomationProperties.Name="{loc:Translate ServerDialogLabelFolder}"
                                                         Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DialogFormTextBoxStyle}"/>
                                                <TextBlock x:Name="DlgSrv_EnvironmentLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                                <TextBlock x:Name="DlgSrv_FavoriteLabel" Grid.Row="2" Grid.Column="1" Style="{StaticResource LabelStyle}" Margin="12,14,0,4"/>
                                                <ComboBox x:Name="DlgSrv_EnvironmentCmb" Grid.Row="3" Grid.Column="0"
                                                          TabIndex="101"
                                                          AutomationProperties.Name="{loc:Translate ServerDialogLabelEnvironment}"
                                                          SelectedValue="{Binding Environment}"
                                                          SelectedValuePath="Tag"
                                                          Style="{StaticResource DialogFormComboBoxStyle}">
                                                    <ComboBoxItem x:Name="DlgSrv_EnvNone" Content="" Tag="None"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvProduction" Content="" Tag="Production"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvStaging" Content="" Tag="Staging"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvLab" Content="" Tag="Lab"/>
                                                    <ComboBoxItem x:Name="DlgSrv_EnvPersonal" Content="" Tag="Personal"/>
                                                </ComboBox>
                                                <CheckBox Grid.Row="3" Grid.Column="1"
                                                          Margin="12,2,0,0"
                                                          x:Name="DlgSrv_MarkFavoriteCb"
                                                          TabIndex="102"
                                                          AutomationProperties.Name="{loc:Translate ServerDialogMarkFavorite}"
                                                          IsChecked="{Binding IsFavorite}"
                                                          Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DialogSectionCardStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_MetadataTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_MetadataDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <TextBlock x:Name="DlgSrv_TagsLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                            <TextBox x:Name="DlgSrv_TagsBox" TabIndex="103"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelTags}"
                                                     Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            <TextBlock x:Name="DlgSrv_MacAddressLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                            <TextBox x:Name="DlgSrv_MacAddressBox" TabIndex="104"
                                                     AutomationProperties.Name="{loc:Translate ServerDialogLabelMacAddress}"
                                                     Text="{Binding MacAddress, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DialogFormTextBoxStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>

                </StackPanel> <!-- end FormFieldsPanel -->

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Margin="0,8,0,0">
            <TextBlock Text="{Binding OriginDisplayName}"
                       AutomationProperties.Name="{loc:Translate A11yProfileOrigin}"
                       FontSize="{StaticResource FontSizeSmallCaption}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Visibility="{Binding IsOriginBadgeVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Validation error -->
            <TextBlock Text="{Binding ValidationError}"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="DlgSrv_CancelBtn"
                    IsCancel="True"
                    AutomationProperties.Name="{loc:Translate ServerDialogBtnCancel}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="DlgSrv_SaveBtn"
                    IsDefault="True"
                    AutomationProperties.Name="{loc:Translate ServerDialogBtnSave}"
                    MinWidth="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
