                                                              TabIndex="62"
                                                              AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_AudioModeLabel}"
                                                              SelectedValue="{Binding RdpAudioMode}"
                                                              SelectedValuePath="Tag"
                                                              Style="{StaticResource DialogFormComboBoxStyle}">
                                                        <ComboBoxItem x:Name="DlgSrv_AudioDisabled" Tag="0"/>
                                                        <ComboBoxItem x:Name="DlgSrv_AudioLocal" Tag="1"/>
                                                        <ComboBoxItem x:Name="DlgSrv_AudioRemote" Tag="2"/>
                                                    </ComboBox>
                                                    <ComboBox x:Name="DlgSrv_RdpColorDepthCombo" Grid.Row="3" Grid.Column="1"
                                                              TabIndex="63"
                                                              AutomationProperties.Name="{loc:Translate A11yServerRdpColorDepth}"
                                                              Margin="12,0,0,0"
                                                              SelectedValue="{Binding RdpColorDepth}"
                                                              SelectedValuePath="Tag"
                                                              Style="{StaticResource DialogFormComboBoxStyle}">
                                                        <ComboBoxItem x:Name="DlgSrv_Color16" Tag="16"/>
                                                        <ComboBoxItem x:Name="DlgSrv_Color24" Tag="24"/>
                                                        <ComboBoxItem x:Name="DlgSrv_Color32" Tag="32"/>
                                                    </ComboBox>
                                                    <!-- Inline validation: Audio Mode / Color Depth -->
                                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                                               Text="{Binding AudioModeError}"
                                                               Style="{StaticResource FieldValidationErrorStyle}"
                                                               Visibility="{Binding AudioModeError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                                               Text="{Binding ColorDepthError}"
                                                               Style="{StaticResource FieldValidationErrorStyle}"
                                                               Margin="12,2,0,0"
                                                               Visibility="{Binding ColorDepthError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </Grid>
                                                <Border Style="{StaticResource InsetCardStyle}" Margin="0,16,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="{loc:Translate ServerDialogResolutionProfileTitle}"
                                                                   Style="{StaticResource LabelStyle}"/>
                                                        <TextBlock Text="{loc:Translate ServerDialogResolutionProfileDesc}"
                                                                   Style="{StaticResource DialogHintTextStyle}"
                                                                   Margin="0,4,0,12"/>

                                                        <Border x:Name="DlgSrv_AutoResolutionCallout"
                                                                Padding="12"
                                                                Margin="0,0,0,12"
                                                                CornerRadius="{StaticResource CornerRadiusLg}"
                                                                Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource AccentBrush}"
                                                                BorderThickness="1"
                                                                Visibility="{Binding IsAutoResolutionMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{loc:Translate ServerDialogResolutionModeAutoTitle}"
