                                            Padding="5,0" Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasOptionsTabErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding OptionsTabErrorCount}"
                                                   Foreground="{DynamicResource TextOnAccentBrush}" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="{StaticResource SpacingSm}">
