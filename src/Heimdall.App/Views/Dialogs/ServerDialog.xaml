                                <CheckBox x:Name="DlgSrv_SeamlessCb"
                                          TabIndex="91"
                                          IsChecked="{Binding CitrixSeamlessMode}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,12,0,0"/>
                                <CheckBox x:Name="DlgSrv_SsoCb"
                                          TabIndex="92"
                                          IsChecked="{Binding CitrixUseSso}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- FTP options (visible only for FTP type) -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_FtpOptionsTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_FtpOptionsDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox x:Name="DlgSrv_FtpPassiveCb"
                                          TabIndex="93"
                                          IsChecked="{Binding FtpPassiveMode}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,14,0,0"/>
                                <CheckBox x:Name="DlgSrv_FtpSslCb"
                                          TabIndex="94"
                                          IsChecked="{Binding FtpUseSsl}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- VNC options (visible only for VNC type) -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_VncOptionsTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_VncOptionsDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox x:Name="DlgSrv_VncViewOnlyCb"
                                          TabIndex="95"
                                          IsChecked="{Binding VncViewOnly}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Telnet options (visible only for Telnet type) -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_TelnetOptionsTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_TelnetOptionsDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock x:Name="DlgSrv_TelnetSecurityWarning"
                                           Foreground="{DynamicResource WarningTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="DlgSrv_TabInfo" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="{StaticResource SpacingSm}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_OrgTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_OrgDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="DlgSrv_FolderLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             TabIndex="100"
                                             Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <TextBlock x:Name="DlgSrv_EnvironmentLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                    <TextBlock x:Name="DlgSrv_FavoriteLabel" Grid.Row="2" Grid.Column="1" Style="{StaticResource LabelStyle}" Margin="12,14,0,4"/>
                                    <ComboBox Grid.Row="3" Grid.Column="0"
                                              TabIndex="101"
                                              SelectedValue="{Binding Environment}"
                                              SelectedValuePath="Tag"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem x:Name="DlgSrv_EnvNone" Content="" Tag="None"/>
                                        <ComboBoxItem x:Name="DlgSrv_EnvProduction" Content="" Tag="Production"/>
                                        <ComboBoxItem x:Name="DlgSrv_EnvStaging" Content="" Tag="Staging"/>
                                        <ComboBoxItem x:Name="DlgSrv_EnvLab" Content="" Tag="Lab"/>
                                        <ComboBoxItem x:Name="DlgSrv_EnvPersonal" Content="" Tag="Personal"/>
                                    </ComboBox>
                                    <CheckBox Grid.Row="3" Grid.Column="1"
                                              Margin="12,2,0,0"
                                              x:Name="DlgSrv_MarkFavoriteCb"
                                              TabIndex="102"
                                              IsChecked="{Binding IsFavorite}"
                                              Style="{StaticResource FormCheckBoxStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_MetadataTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_MetadataDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock x:Name="DlgSrv_TagsLabel" Style="{StaticResource LabelStyle}" Margin="0,14,0,4"/>
                                <TextBox TabIndex="103" Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                                <TextBlock x:Name="DlgSrv_MacAddressLabel" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                                <TextBox TabIndex="104" Text="{Binding MacAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="DlgSrv_CancelBtn"
                    IsCancel="True"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="DlgSrv_SaveBtn"
                    IsDefault="True"
                    MinWidth="90"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
