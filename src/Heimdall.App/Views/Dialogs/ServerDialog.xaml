<Window x:Class="Heimdall.App.Views.Dialogs.ServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:ServerDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="650"
        SizeToContent="Height"
        MaxHeight="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="550"
        MinHeight="500"
        ShowInTaskbar="False"
        Closing="OnWindowClosing">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="DiagramNodeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Width" Value="165"/>
            <Setter Property="MinHeight" Value="86"/>
        </Style>

        <Style x:Key="ArrowCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        </Style>

        <Style x:Key="FormCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        </Style>

        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        </Style>

        <Style x:Key="RdpOnlySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SshOnlySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SshFamilySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SSH">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="SFTP">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Gateway/routing sections: hidden for Local shell, Citrix, and VNC -->
        <Style x:Key="NetworkSectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewaySectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DirectSectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsesGateway}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManualTunnelPortStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding UsesGateway}" Value="True"/>
                        <Condition Binding="{Binding UseAutomaticTunnelPort}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabControl" Grid.Row="0" Style="{DynamicResource ThemedTabControlStyle}">
            <TabItem x:Name="DlgSrv_TabConnection" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="{StaticResource SpacingSm}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_ConnectionBasicsTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_ConnectionBasicsDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="DlgSrv_DisplayNameLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="DlgSrv_ConnectionTypeLabel" Grid.Row="0" Grid.Column="1" Style="{StaticResource LabelStyle}" Margin="12,0,0,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             TabIndex="0"
                                             Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              TabIndex="1"
                                              Margin="12,0,0,0"
                                              SelectedValue="{Binding ConnectionType}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource FormComboBoxStyle}">
                                        <ComboBoxItem Content="RDP"/>
                                        <ComboBoxItem Content="SSH"/>
                                        <ComboBoxItem Content="SFTP"/>
                                        <ComboBoxItem Content="FTP"/>
                                        <ComboBoxItem Content="Local"/>
                                        <ComboBoxItem Content="Citrix"/>
                                        <ComboBoxItem Content="VNC"/>
                                        <ComboBoxItem Content="Telnet"/>
                                    </ComboBox>
                                    <!-- Server/Port row: hidden for Local shell and Citrix -->
                                    <TextBlock x:Name="DlgSrv_ServerLabel" Grid.Row="2" Grid.Column="0" Margin="0,14,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EndpointPortLabel}" Margin="12,14,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Grid.Row="3" Grid.Column="0"
                                             TabIndex="2"
                                             Text="{Binding RemoteServer, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBox Grid.Row="3" Grid.Column="1"
                                             TabIndex="3"
                                             Margin="12,0,0,0"
                                             Width="120"
                                             HorizontalAlignment="Left"
                                             Text="{Binding EndpointPort, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                                <TextBlock Text="{Binding EndpointPortHelpText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_GatewayRoutingTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_GatewayRoutingDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox x:Name="DlgSrv_DirectConnectCb"
                                          TabIndex="4"
                                          IsChecked="{Binding DirectConnection}"
                                          Style="{StaticResource FormCheckBoxStyle}"
                                          Margin="0,14,0,0"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              TabIndex="5"
                                              ItemsSource="{Binding AvailableGateways}"
                                              SelectedValue="{Binding SelectedGatewayId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayText"
                                              IsEnabled="{Binding CanSelectGateway}"
                                              Style="{StaticResource FormComboBoxStyle}"/>
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Padding="12,6"
                                            x:Name="DlgSrv_TestConnectionBtn"
                                            Command="{Binding TestGatewayCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                </Grid>
                                <TextBlock Text="{Binding GatewayExplanation}" Style="{StaticResource HintTextStyle}"/>
                                <Border Margin="0,12,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedGatewayTitle}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding GatewayRouteText}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding GatewayTestMessage}"
                                           Foreground="{DynamicResource InfoBrush}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding GatewayTestMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_ConnectionPathTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding ConnectionPathHeadline}" Style="{StaticResource SectionDescriptionStyle}"/>
                                <StackPanel Margin="0,16,0,0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource DirectSectionStyle}">
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_DirectYourPc" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="12,16,12,0" Width="78">
                                        <TextBlock Text="->" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeTitle}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding SessionKindLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource DiagramNodeStyle}">
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_DirectDestination" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Viewbox Margin="0,16,0,0"
                                         Stretch="Uniform"
                                         StretchDirection="DownOnly"
                                         Style="{StaticResource GatewaySectionStyle}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Border Style="{StaticResource DiagramNodeStyle}">
                                            <StackPanel>
                                                <TextBlock x:Name="DlgSrv_GatewayYourPc" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Margin="12,16,12,0" Width="78">
                                            <TextBlock Text="&#x2192;" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeTitle}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ClientToGatewayLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource DiagramNodeStyle}">
                                            <StackPanel>
                                                <TextBlock x:Name="DlgSrv_GatewayNode" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SelectedGatewayTitle}" Style="{StaticResource HintTextStyle}"/>
                                                <TextBlock Text="{Binding SelectedGatewayEndpoint}" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Margin="12,16,12,0" Width="78">
                                            <TextBlock Text="&#x2192;" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{StaticResource FontSizeTitle}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding GatewayToServerLabel}" Style="{StaticResource ArrowCaptionStyle}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource DiagramNodeStyle}">
                                            <StackPanel>
                                                <TextBlock x:Name="DlgSrv_GatewayDestination" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Viewbox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="DlgSrv_TabTunneling"
                     ToolTipService.ShowOnDisabled="True">
                <TabItem.Style>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ThemedTabItemStyle}">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="FTP">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="VNC">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="Telnet">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabItem.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="{StaticResource SpacingSm}">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_TunnelingTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_TunnelingDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <TextBlock x:Name="DlgSrv_TunnelingHint"
                                           Style="{StaticResource HintTextStyle}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_DirectConnTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_DirectConnDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_LocalTunnelPortTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DlgSrv_LocalTunnelPortDesc"
                                           Style="{StaticResource SectionDescriptionStyle}"/>
                                <CheckBox x:Name="DlgSrv_AutoTunnelPortCb"
                                          TabIndex="20"
                                          IsChecked="{Binding UseAutomaticTunnelPort}"
                                          Style="{StaticResource FormCheckBoxStyle}"
                                          Margin="0,14,0,0"/>
                                <TextBlock Text="{Binding LocalTunnelPortDisplay}" Style="{StaticResource HintTextStyle}" Margin="0,8,0,0"/>
                                <Grid Margin="0,12,0,0" Style="{StaticResource ManualTunnelPortStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DlgSrv_ManualPortLabel" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                    <TextBox Grid.Column="1"
                                             TabIndex="21"
                                             Width="140"
                                             HorizontalAlignment="Left"
                                             Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="DlgSrv_TunnelMappingTitle" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding TunnelSummary}" Style="{StaticResource SectionDescriptionStyle}"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="DlgSrv_ChainLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GatewayRouteText}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,0"/>
                                    <TextBlock x:Name="DlgSrv_LocalEndpointLabel" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ClientNodeCaption}" Style="{StaticResource HintTextStyle}" Margin="0,12,0,0"/>
                                    <TextBlock x:Name="DlgSrv_RemoteDestLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DestinationNodeCaption}" Style="{StaticResource HintTextStyle}" Margin="0,12,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="DlgSrv_TabAuthentication"
                     ToolTipService.ShowOnDisabled="True">
                <TabItem.Style>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ThemedTabItemStyle}">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="Citrix">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionType}" Value="Local">
                                <Setter Property="IsEnabled" Value="False"/>
