<Window x:Class="Heimdall.App.Views.Dialogs.ServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Heimdall.App.Converters"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:ServerDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="600" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <!-- Label style for form fields -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Standard form TextBox style -->
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Standard form ComboBox style -->
        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Standard form CheckBox style -->
        <Style x:Key="FormCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Standard form PasswordBox style -->
        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Style="{DynamicResource ThemedTabControlStyle}">

            <!-- General Tab -->
            <TabItem Header="General" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="Display Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 AutomationProperties.Name="Display Name"/>

                        <TextBlock Text="Connection Type" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding ConnectionType}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="Connection Type">
                            <ComboBoxItem Content="RDP"/>
                            <ComboBoxItem Content="SSH"/>
                            <ComboBoxItem Content="SFTP"/>
                        </ComboBox>

                        <TextBlock Text="Remote Server" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding RemoteServer, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 AutomationProperties.Name="Remote Server"/>

                        <TextBlock Text="Port" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding RemotePort}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"
                                 MaxLength="5"
                                 AutomationProperties.Name="Remote Port"/>

                        <TextBlock Text="Local Tunnel Port" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding LocalPort}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"
                                 MaxLength="5"
                                 AutomationProperties.Name="Local Tunnel Port"/>

                        <TextBlock Text="Group" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding Group}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 AutomationProperties.Name="Group"/>

                        <TextBlock Text="Gateway" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableGateways}"
                                  SelectedValue="{Binding SelectedGatewayId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="DisplayText"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="Gateway"/>
                        <CheckBox Content="Direct Connection (no gateway)"
                                  IsChecked="{Binding DirectConnection}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- SSH Tab -->
            <TabItem Header="SSH" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="SSH Username" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding SshUsername}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 AutomationProperties.Name="SSH Username"/>

                        <TextBlock Text="SSH Port" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding SshPort}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"
                                 MaxLength="5"
                                 AutomationProperties.Name="SSH Port"/>

                        <TextBlock Text="SSH Key Path" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <DockPanel>
                            <Button Content="Browse"
                                    DockPanel.Dock="Right"
                                    Command="{Binding BrowseSshKeyCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="4,0,0,0"
                                    Click="OnBrowseSshKeyClick"/>
                            <TextBox Text="{Binding SshKeyPath}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     AutomationProperties.Name="SSH Key Path"/>
                        </DockPanel>

                        <TextBlock Text="SSH Password" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <PasswordBox x:Name="SshPasswordBox"
                                     Style="{StaticResource FormPasswordBoxStyle}"
                                     AutomationProperties.Name="SSH Password"/>

                        <TextBlock Text="Mode" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding SshMode}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="SSH Mode">
                            <ComboBoxItem Content="Embedded"/>
                            <ComboBoxItem Content="External"/>
                        </ComboBox>

                        <CheckBox Content="Compression"
                                  IsChecked="{Binding SshCompression}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,12,0,0"/>
                        <CheckBox Content="X11 Forwarding"
                                  IsChecked="{Binding SshX11Forwarding}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>
                        <CheckBox Content="Agent Forwarding"
                                  IsChecked="{Binding SshAgentForwarding}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- RDP Tab -->
            <TabItem Header="RDP" Style="{DynamicResource ThemedTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="RDP Username" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding RdpUsername}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 AutomationProperties.Name="RDP Username"/>

                        <TextBlock Text="RDP Password" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <PasswordBox x:Name="RdpPasswordBox"
                                     Style="{StaticResource FormPasswordBoxStyle}"
                                     AutomationProperties.Name="RDP Password"/>

                        <TextBlock Text="Mode" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding RdpMode}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="RDP Mode">
                            <ComboBoxItem Content="Embedded"/>
                            <ComboBoxItem Content="External"/>
                        </ComboBox>

                        <TextBlock Text="Redirections" Style="{StaticResource LabelStyle}"
                                   FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <CheckBox Content="Clipboard"
                                  IsChecked="{Binding RedirectClipboard}"
                                  Style="{StaticResource FormCheckBoxStyle}"/>
                        <CheckBox Content="Drives"
                                  IsChecked="{Binding RedirectDrives}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>
                        <CheckBox Content="Printers"
                                  IsChecked="{Binding RedirectPrinters}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>

                        <TextBlock Text="Audio" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding RdpAudioMode}"
                                  SelectedValuePath="Tag"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="Audio Mode">
                            <ComboBoxItem Content="Disabled" Tag="0"/>
                            <ComboBoxItem Content="Local Playback" Tag="1"/>
                            <ComboBoxItem Content="Remote Playback" Tag="2"/>
                        </ComboBox>

                        <TextBlock Text="Aspect Ratio" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding RdpAspectRatio}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource FormComboBoxStyle}"
                                  AutomationProperties.Name="Aspect Ratio">
                            <ComboBoxItem Content="Stretch"/>
                            <ComboBoxItem Content="Preserve"/>
                        </ComboBox>

                        <CheckBox Content="NLA (Network Level Authentication)"
                                  IsChecked="{Binding RdpNla}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,12,0,0"/>
                        <CheckBox Content="Multi-Monitor"
                                  IsChecked="{Binding RdpMultiMonitor}"
                                  Style="{StaticResource FormCheckBoxStyle}"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Metadata Tab -->
            <TabItem Header="Metadata" Style="{DynamicResource ThemedTabItemStyle}">
                <StackPanel Margin="8">
                    <TextBlock Text="Project" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableProjects}"
                              SelectedValue="{Binding SelectedProjectId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Style="{StaticResource FormComboBoxStyle}"
                              AutomationProperties.Name="Project"/>

                    <TextBlock Text="Tags (comma-separated)" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Tags}"
                             Style="{StaticResource FormTextBoxStyle}"
                             AutomationProperties.Name="Tags"/>

                    <TextBlock Text="MAC Address (for Wake-on-LAN)" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding MacAddress}"
                             Style="{StaticResource FormTextBoxStyle}"
                             AutomationProperties.Name="MAC Address"/>

                    <TextBlock Text="Environment" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <ComboBox SelectedValue="{Binding Environment}"
                              SelectedValuePath="Content"
                              Style="{StaticResource FormComboBoxStyle}"
                              AutomationProperties.Name="Environment">
                        <ComboBoxItem Content="None"/>
                        <ComboBoxItem Content="Production"/>
                        <ComboBoxItem Content="Staging"/>
                        <ComboBoxItem Content="Lab"/>
                        <ComboBoxItem Content="Personal"/>
                    </ComboBox>

                    <CheckBox Content="Favorite"
                              IsChecked="{Binding IsFavorite}"
                              Style="{StaticResource FormCheckBoxStyle}"
                              Margin="0,12,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Validation error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="{DynamicResource ErrorBrush}"
                   FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    IsCancel="True"
                    Width="80"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button Content="Save"
                    IsDefault="True"
                    Width="80"
                    Click="OnSaveClick"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
