                                                       Style="{StaticResource FieldValidationErrorStyle}"
                                                       Visibility="{Binding LocalPortError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_SocksSectionTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_SocksDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"
                                                       TextWrapping="Wrap"/>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="DlgSrv_SocksPortLabel" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                                <TextBox x:Name="DlgSrv_SocksPortBox" Grid.Column="1"
                                                         TabIndex="22"
                                                         AutomationProperties.Name="{Binding Text, ElementName=DlgSrv_SocksPortLabel}"
                                                         Width="140"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding SocksProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DialogFormTextBoxStyle}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding SocksProxyDisplay}" Style="{StaticResource DialogHintTextStyle}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UsesGateway}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_RemoteFwdSectionTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
