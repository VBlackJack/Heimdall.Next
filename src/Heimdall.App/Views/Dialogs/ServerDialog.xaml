                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <StackPanel Margin="0,12,0,0">
                                            <CheckBox x:Name="DlgSrv_PerfDisableWallpaperCb" TabIndex="80" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" Style="{StaticResource DialogFormCheckBoxStyle}"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableThemesCb" TabIndex="81" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableAnimationsCb" TabIndex="82" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
                                            <CheckBox x:Name="DlgSrv_PerfDisableDragCb" TabIndex="83" AutomationProperties.Name="{Binding Content, RelativeSource={RelativeSource Self}}" Style="{StaticResource DialogFormCheckBoxStyle}" Margin="0,6,0,0"/>
