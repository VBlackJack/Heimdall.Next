                                                    Margin="0,14,0,0"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ============================================ -->
                        <!-- Tab: Options                                 -->
                        <!-- ============================================ -->
                        <TabItem x:Name="DlgSrv_TabOptions"
                                 AutomationProperties.Name="{loc:Translate ServerDialogTabOptions}"
                                 Style="{DynamicResource ThemedTabItemStyle}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="DlgSrv_TabOptionsText"/>
                                    <Border CornerRadius="8"
                                            Background="{DynamicResource ErrorTextBrush}"
                                            MinWidth="18" Height="18"
                                            Padding="5,0" Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasOptionsTabErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding OptionsTabErrorCount}"
                                                   Foreground="{DynamicResource TextOnAccentBrush}" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="{StaticResource SpacingSm}">
                                    <WrapPanel x:Name="DlgSrv_RdpOptionsToc"
                                               Margin="0,0,0,12">
                                        <WrapPanel.Style>
                                            <Style TargetType="WrapPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </WrapPanel.Style>
                                        <Button Content="{loc:Translate ServerDialogOptionsTocDisplay}"
                                                Tag="DlgSrv_RdpOptionsTitle"
                                                Click="OnOptionsTocChipClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="10,4"
                                                FontSize="{StaticResource FontSizeCaption}"
                                                Margin="0,0,6,6"
                                                MinHeight="0"/>
                                        <Button Content="{loc:Translate ServerDialogOptionsTocAudio}"
                                                Tag="DlgSrv_AudioModeLabel"
                                                Click="OnOptionsTocChipClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="10,4"
                                                FontSize="{StaticResource FontSizeCaption}"
                                                Margin="0,0,6,6"
                                                MinHeight="0"/>
                                        <Button Content="{loc:Translate ServerDialogOptionsTocDevices}"
                                                Tag="DlgSrv_DeviceRedirExpander"
                                                Click="OnOptionsTocChipClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="10,4"
                                                FontSize="{StaticResource FontSizeCaption}"
                                                Margin="0,0,6,6"
                                                MinHeight="0"/>
                                        <Button Content="{loc:Translate ServerDialogOptionsTocPerformance}"
                                                Tag="DlgSrv_AdvancedRdpExpander"
                                                Click="OnOptionsTocChipClick"
                                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                Padding="10,4"
                                                FontSize="{StaticResource FontSizeCaption}"
                                                Margin="0,0,6,6"
                                                MinHeight="0"/>
                                    </WrapPanel>

                                    <TextBlock Text="{loc:Translate ServerDialogRdpUsingGlobalDefaultsBanner}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DialogHintTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ConnectionType}" Value="RDP"/>
                                                            <Condition Binding="{Binding RdpUseGlobalDefaults}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- RDP options -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionCardStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionType}" Value="RDP">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock x:Name="DlgSrv_RdpOptionsTitle" Style="{StaticResource DialogSectionTitleStyle}"/>
                                            <TextBlock x:Name="DlgSrv_RdpOptionsDesc"
                                                       Style="{StaticResource DialogSectionDescriptionStyle}"/>
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RdpUseGlobalDefaults}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Grid Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock x:Name="DlgSrv_SessionModeLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
