<Window x:Class="Heimdall.App.Views.Dialogs.SnapshotRestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Dialogs"
        d:DataContext="{d:DesignInstance Type=vm:SnapshotRestoreDialogViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="640"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DialogCommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding MessageText}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="{StaticResource FontSizeBodyLarge}"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <TextBlock Text="{Binding WarningText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="{Binding SavedAtText}"
                   Foreground="{DynamicResource TextDisabledBrush}"
                   FontSize="{StaticResource FontSizeCaption}"/>

        <CheckBox Grid.Row="3"
                  Margin="0,12,0,0"
                  Content="{Binding SelectAllText}"
                  IsChecked="{Binding AllSelected}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  AutomationProperties.Name="{Binding SelectAllText}"/>

        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding SessionColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"
                           Margin="4,0,8,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding ProtocolColumnHeader}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"
                           Margin="8,0,4,8"/>

                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SnapshotRestoreItemViewModel}">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsSelected}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              AutomationProperties.Name="{Binding DisplayName}"/>

                                    <TextBlock Grid.Column="1"
                                               Margin="8,2,0,0"
                                               Text="{Binding ProtocolText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="DontRestoreButton"
                    Content="{Binding DontRestoreText}"
                    AutomationProperties.Name="{Binding DontRestoreText}"
                    Command="{Binding DontRestoreCommand}"
                    MinWidth="120"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Style="{DynamicResource SecondaryButtonStyle}"/>
            <Button x:Name="RestoreSelectedButton"
                    Content="{Binding RestoreSelectedText}"
                    AutomationProperties.Name="{Binding RestoreSelectedText}"
                    Command="{Binding RestoreSelectedCommand}"
                    MinWidth="140"
                    IsDefault="True"
                    Style="{DynamicResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
