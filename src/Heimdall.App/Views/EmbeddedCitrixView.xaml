<UserControl x:Class="Heimdall.App.Views.EmbeddedCitrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Session header bar -->
        <Border Grid.Row="0"
                Padding="8,3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="TerminateButton"
                        DockPanel.Dock="Right"
                        Click="OnTerminateClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"
                        AutomationProperties.Name="Disconnect session"/>
                <Button x:Name="BringToFrontButton"
                        DockPanel.Dock="Right"
                        Click="OnBringToFrontClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="4,0,0,0"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Bring to front"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                    <Ellipse x:Name="HealthDot"
                             Width="8" Height="8"
                             Fill="{DynamicResource SuccessBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Embedded window host (SetParent mode) -->
        <Grid x:Name="EmbeddedContainer" Grid.Row="1" Visibility="Collapsed"
              ClipToBounds="True" Background="Black">
            <wfi:WindowsFormsHost x:Name="FormsHost"/>
        </Grid>

        <!-- External session info panel (fallback mode) -->
        <Border x:Name="InfoPanel" Grid.Row="1"
                Margin="{StaticResource SpacingXl}"
                Padding="{StaticResource SpacingXl}"
                CornerRadius="{StaticResource CornerRadiusXl}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel MaxWidth="460">
                <TextBlock Text="&#xE753;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="{StaticResource IconSizeXLarge}"
                           Foreground="{DynamicResource InfoBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock x:Name="TitleText"
                           FontSize="{StaticResource FontSizeDisplay}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="StoreFrontText"
                           Margin="0,12,0,0"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="AppNameText"
                           Margin="0,4,0,0"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SessionInfoText"
                           Margin="0,16,0,0"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
