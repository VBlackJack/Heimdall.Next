<UserControl x:Class="Heimdall.App.Views.EmbeddedEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="8,4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnSave" DockPanel.Dock="Right"
                        Click="OnSaveClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="12,3" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"/>
                <Button x:Name="BtnClose" DockPanel.Dock="Right"
                        Click="OnCloseClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,3" FontSize="{StaticResource FontSizeCaption}" Margin="4,0,0,0"/>
                <TextBlock x:Name="FileNameText"
                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- AvalonEdit Editor -->
        <avalon:TextEditor x:Name="Editor"
                           Grid.Row="1"
                           FontFamily="{StaticResource FontFamilyMonospace}"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           ShowLineNumbers="True"
                           WordWrap="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="CursorPositionText"
                           DockPanel.Dock="Right"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="SyntaxLabel"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
