<UserControl x:Class="Heimdall.App.Views.EmbeddedRdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="SessionHeaderBar" Grid.Row="0"
                Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="CancelReconnectButton"
                        DockPanel.Dock="Right"
                        Click="OnCancelReconnectClick"
                        Visibility="Collapsed"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="SendCtrlAltDelButton"
                        DockPanel.Dock="Right"
                        Content="&#xE765;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSendCtrlAltDelClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2"
                        FontSize="{StaticResource FontSizeBody}"
                        Margin="4,0"/>
                <Button x:Name="SplitButton"
                        DockPanel.Dock="Right"
                        Content="&#xE8A9;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSplitClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"/>
                <Button x:Name="ResolutionButton"
                        DockPanel.Dock="Right"
                        Content="&#xE740;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"
                        Click="OnResolutionButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ResolutionMenu" FontFamily="Segoe UI">
                            <MenuItem x:Name="ResMenuFit" Click="OnResolutionMenuClick" Tag="Fit"/>
                            <Separator/>
                            <MenuItem Header="1920 x 1080" Click="OnResolutionMenuClick" Tag="1920x1080"/>
                            <MenuItem Header="1680 x 1050" Click="OnResolutionMenuClick" Tag="1680x1050"/>
                            <MenuItem Header="1600 x 900" Click="OnResolutionMenuClick" Tag="1600x900"/>
                            <MenuItem Header="1440 x 900" Click="OnResolutionMenuClick" Tag="1440x900"/>
                            <MenuItem Header="1366 x 768" Click="OnResolutionMenuClick" Tag="1366x768"/>
                            <MenuItem Header="1280 x 1024" Click="OnResolutionMenuClick" Tag="1280x1024"/>
                            <MenuItem Header="1280 x 720" Click="OnResolutionMenuClick" Tag="1280x720"/>
                            <MenuItem Header="1024 x 768" Click="OnResolutionMenuClick" Tag="1024x768"/>
                            <Separator/>
                            <MenuItem Header="2560 x 1440" Click="OnResolutionMenuClick" Tag="2560x1440"/>
                            <MenuItem Header="3840 x 2160" Click="OnResolutionMenuClick" Tag="3840x2160"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="AutofillSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="AutofillStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <Button x:Name="AntiIdleBadge"
                            Click="OnAntiIdleBadgeClick"
                            Visibility="Collapsed"
                            Margin="8,0,0,0"
                            Padding="4,1"
                            VerticalAlignment="Center"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Border Margin="16,0,16,16"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}">
                <Grid x:Name="SurfaceContainer" ClipToBounds="True">
                    <wfi:WindowsFormsHost x:Name="FormsHost"/>
                </Grid>
            </Border>

            <!-- Reconnect overlay (shown on unexpected disconnect) -->
            <Border x:Name="ReconnectOverlay"
                    Style="{StaticResource FadeInPanelStyle}"
                    Visibility="Collapsed"
                    Background="{DynamicResource OverlayBackground}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="460">
                    <TextBlock x:Name="ReconnectMessageText"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.LiveSetting="Polite" />
                    <TextBlock x:Name="ReconnectSecondaryText"
                               Margin="0,8,0,0"
                               FontSize="{StaticResource FontSizeBody}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="Collapsed" />
                    <TextBlock x:Name="ReconnectCodeText"
                               Margin="0,6,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0">
                        <Button x:Name="OverlayReconnectButton"
                                Click="OnOverlayReconnectClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="OverlayCloseButton"
                                Click="OnOverlayCloseClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection progress indicator -->
            <ProgressBar x:Name="RdpLoadingBar"
                         VerticalAlignment="Top"
                         Height="2"
                         Margin="16,0,16,0"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
