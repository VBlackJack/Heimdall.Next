<UserControl x:Class="Heimdall.App.Views.EmbeddedRdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="SessionHeaderBar" Grid.Row="0"
                Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate BtnDisconnectSession}"
                        Click="OnDisconnectClick"
                        ToolTip="{loc:Translate TooltipDisconnectSession}"
                        AutomationProperties.Name="{loc:Translate A11yDisconnectSession}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="CancelReconnectButton"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate BtnCancelReconnect}"
                        Click="OnCancelReconnectClick"
                        ToolTip="{loc:Translate TooltipCancelReconnect}"
                        AutomationProperties.Name="{loc:Translate A11yCancelReconnect}"
                        Visibility="Collapsed"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="SendCtrlAltDelButton"
                        DockPanel.Dock="Right"
                        Content="&#xE765;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSendCtrlAltDelClick"
                        ToolTip="{loc:Translate TooltipSendCtrlAltDel}"
                        AutomationProperties.Name="{loc:Translate A11ySendCtrlAltDel}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2"
                        FontSize="{StaticResource FontSizeBody}"
                        Margin="4,0"/>
                <Button x:Name="SplitButton"
                        DockPanel.Dock="Right"
                        Content="&#xE8A9;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSplitClick"
                        ToolTip="{loc:Translate TooltipSplitSession}"
                        AutomationProperties.Name="{loc:Translate A11ySplitSession}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"/>
                <Button x:Name="ResolutionButton"
                        DockPanel.Dock="Right"
                        Content="&#xE740;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        AutomationProperties.Name="{loc:Translate A11yChangeResolution}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"
                        Click="OnResolutionButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ResolutionMenu" FontFamily="Segoe UI">
                            <MenuItem x:Name="ResMenuFit"
                                      Header="{loc:Translate RdpResolutionFitToWindow}"
                                      Click="OnResolutionMenuClick"
                                      Tag="Fit"/>
                            <Separator/>
                            <!-- Preset items populated dynamically by PopulateResolutionMenu()
                                 from AppSettings.RdpResolutionPresets, with a built-in fallback. -->
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{loc:Translate A11yConnectionStatus}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="AutofillSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="AutofillStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="StabilizingSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="StabilizingStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <Button x:Name="AntiIdleBadge"
                            Click="OnAntiIdleBadgeClick"
                            ToolTip="{loc:Translate TooltipAntiIdleActive}"
                            AutomationProperties.Name="{loc:Translate A11yAntiIdleActive}"
                            Visibility="Collapsed"
                            Margin="8,0,0,0"
                            Padding="4,1"
                            VerticalAlignment="Center"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Border Margin="16,0,16,16"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}">
                <Grid x:Name="SurfaceContainer" ClipToBounds="True">
                    <wfi:WindowsFormsHost x:Name="FormsHost"/>
                </Grid>
            </Border>

            <!-- Reconnect overlay (shown on unexpected disconnect) -->
            <Border x:Name="ReconnectOverlay"
                    Style="{StaticResource FadeInPanelStyle}"
                    Visibility="Collapsed"
                    Background="{DynamicResource OverlayBackground}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="460">
                    <Border x:Name="OverlaySeverityStrip"
                            Height="4"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource ErrorBrush}"
                            CornerRadius="2"/>
                    <TextBlock x:Name="OverlaySeverityIcon"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="32"
                               Text="&#xE783;"
                               Foreground="{DynamicResource ErrorBrush}"
                               Focusable="False"
                               IsHitTestVisible="False"
                               AutomationProperties.Name=""
                               AutomationProperties.IsOffscreenBehavior="Onscreen"/>
                    <TextBlock x:Name="ReconnectMessageText"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.LiveSetting="Polite" />
                    <TextBlock x:Name="ReconnectSecondaryText"
                               Margin="0,8,0,0"
                               FontSize="{StaticResource FontSizeBody}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="Collapsed" />
                    <TextBlock x:Name="ReconnectCodeText"
                               Margin="0,6,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0">
                        <Button x:Name="OverlayReconnectButton"
                                Click="OnOverlayReconnectClick"
                                Content="{loc:Translate BtnReconnectSession}"
                                AutomationProperties.Name="{loc:Translate A11yReconnectSession}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="OverlayCloseButton"
                                Click="OnOverlayCloseClick"
                                Content="{loc:Translate BtnCloseOverlay}"
                                AutomationProperties.Name="{loc:Translate A11yCloseOverlay}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection progress indicator -->
            <ProgressBar x:Name="RdpLoadingBar"
                         VerticalAlignment="Top"
                         Height="2"
                         Margin="16,0,16,0"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
