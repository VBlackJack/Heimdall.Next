<UserControl x:Class="Heimdall.App.Views.EmbeddedRdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="SessionHeaderBar" Grid.Row="0"
                Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                KeyboardNavigation.TabNavigation="Local"
                KeyboardNavigation.ControlTabNavigation="Local">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        TabIndex="0"
                        Content="{loc:Translate BtnDisconnectSession}"
                        Click="OnDisconnectClick"
                        ToolTip="{loc:Translate TooltipDisconnectSession}"
                        AutomationProperties.Name="{loc:Translate A11yDisconnectSession}"
                        Visibility="Collapsed"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="CancelReconnectButton"
                        DockPanel.Dock="Right"
                        TabIndex="0"
                        Content="{loc:Translate BtnCancelReconnect}"
                        Click="OnCancelReconnectClick"
                        ToolTip="{loc:Translate TooltipCancelReconnect}"
                        AutomationProperties.Name="{loc:Translate A11yCancelReconnect}"
                        Visibility="Collapsed"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <Button x:Name="CancelConnectButton"
                        DockPanel.Dock="Right"
                        TabIndex="0"
                        Content="{loc:Translate BtnCancelConnect}"
                        Click="OnCancelConnectClick"
                        ToolTip="{loc:Translate TooltipCancelConnect}"
                        AutomationProperties.Name="{loc:Translate A11yCancelConnect}"
                        Visibility="Collapsed"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"/>
                <StackPanel x:Name="HealthDot"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="8,0,4,0"
                            VerticalAlignment="Center"
                            ToolTip="{loc:Translate TooltipHealthDot}"
                            AutomationProperties.Name="{loc:Translate A11yHealthDot}"
                            AutomationProperties.LiveSetting="Polite"
                            Focusable="False"
                            KeyboardNavigation.IsTabStop="False">
                    <Border x:Name="HealthDotColor"
                            Width="10"
                            Height="10"
                            CornerRadius="5"
                            VerticalAlignment="Center"
                            Background="{DynamicResource TextDisabledBrush}"/>
                    <TextBlock x:Name="HealthDotGlyph"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="2,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"/>
                </StackPanel>
                <Button x:Name="FullscreenButton"
                        DockPanel.Dock="Right"
                        TabIndex="1"
                        Content="&#xE1D9;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnFullscreenButtonClick"
                        ToolTip="{loc:Translate TooltipFullscreenToggle}"
                        AutomationProperties.Name="{loc:Translate A11yFullscreenToggle}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2"
                        FontSize="{StaticResource FontSizeBody}"
                        Margin="4,0"/>
                <Button x:Name="SendKeysButton"
                        DockPanel.Dock="Right"
                        TabIndex="2"
                        Content="&#xE92E;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSendKeysButtonClick"
                        ToolTip="{loc:Translate TooltipSendKeysMenu}"
                        AutomationProperties.Name="{loc:Translate A11ySendKeysMenu}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2"
                        FontSize="{StaticResource FontSizeBody}"
                        Margin="4,0">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SendKeysMenu" FontFamily="Segoe UI">
                            <MenuItem x:Name="SendKeysCtrlAltDel"
                                      Header="{loc:Translate RdpSendKeysCtrlAltDel}"
                                      Click="OnSendKeysCtrlAltDelClick"/>
                            <Separator/>
                            <MenuItem x:Name="SendKeysWindows"
                                      Header="{loc:Translate RdpSendKeysWindows}"
                                      Click="OnSendKeysWindowsClick"/>
                            <MenuItem x:Name="SendKeysAltTab"
                                      Header="{loc:Translate RdpSendKeysAltTab}"
                                      Click="OnSendKeysAltTabClick"/>
                            <MenuItem x:Name="SendKeysCtrlEsc"
                                      Header="{loc:Translate RdpSendKeysCtrlEsc}"
                                      Click="OnSendKeysCtrlEscClick"/>
                            <Separator/>
                            <MenuItem x:Name="SendKeysPrintScreen"
                                      Header="{loc:Translate RdpSendKeysPrintScreen}"
                                      Click="OnSendKeysPrintScreenClick"/>
                            <MenuItem x:Name="SendKeysEscape"
                                      Header="{loc:Translate RdpSendKeysEscape}"
                                      Click="OnSendKeysEscapeClick"/>
                            <Separator/>
                            <MenuItem x:Name="SendKeysShortcutsHelp"
                                      Header="{loc:Translate RdpShortcutsHelpMenuItem}"
                                      Click="OnSendKeysShortcutsHelpClick"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="SplitButton"
                        DockPanel.Dock="Right"
                        TabIndex="3"
                        Content="&#xE8A9;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSplitClick"
                        ToolTip="{loc:Translate TooltipSplitSession}"
                        AutomationProperties.Name="{loc:Translate A11ySplitSession}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"/>
                <Button x:Name="ResolutionButton"
                        DockPanel.Dock="Right"
                        TabIndex="4"
                        Content="&#xE740;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        AutomationProperties.Name="{loc:Translate A11yChangeResolution}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"
                        Click="OnResolutionButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ResolutionMenu" FontFamily="Segoe UI">
                            <MenuItem x:Name="ResMenuSkipStabilization"
                                      Header="{loc:Translate RdpResolutionSkipStabilization}"
                                      Click="OnSkipStabilizationClick"
                                      Visibility="Collapsed"/>
                            <Separator x:Name="ResMenuSkipStabilizationSeparator"
                                       Visibility="Collapsed"/>
                            <MenuItem x:Name="ResMenuFit"
                                      Header="{loc:Translate RdpResolutionFitToWindow}"
                                      Click="OnResolutionMenuClick"
                                      Tag="Fit"/>
                            <Separator/>
                            <!-- Preset items populated dynamically by PopulateResolutionMenu()
                                 from AppSettings.RdpResolutionPresets, with a built-in fallback. -->
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="{loc:Translate A11yConnectionStatus}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="AutofillSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="AutofillStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="StabilizingSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="StabilizingStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="ReconnectElapsedSeparator"
                               Text=" &#x2022; "
                               Margin="6,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="ReconnectElapsedText"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"/>
                    <StackPanel x:Name="ConnectionPhaseStepper"
                                Orientation="Horizontal"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Focusable="False"
                                KeyboardNavigation.IsTabStop="False"
                                Visibility="Collapsed"
                                AutomationProperties.Name="{loc:Translate A11yConnectionPhaseStepper}"
                                AutomationProperties.LiveSetting="Polite">
                        <Border x:Name="PhaseSegmentPreparing"
                                Width="14"
                                Height="3"
                                Margin="0,0,3,0"
                                CornerRadius="1.5"
                                Background="{DynamicResource TextDisabledBrush}"/>
                        <Border x:Name="PhaseSegmentConnecting"
                                Width="14"
                                Height="3"
                                Margin="0,0,3,0"
                                CornerRadius="1.5"
                                Background="{DynamicResource TextDisabledBrush}"/>
                        <Border x:Name="PhaseSegmentLoading"
                                Width="14"
                                Height="3"
                                Margin="0,0,3,0"
                                CornerRadius="1.5"
                                Background="{DynamicResource TextDisabledBrush}"/>
                        <Border x:Name="PhaseSegmentConnected"
                                Width="14"
                                Height="3"
                                CornerRadius="1.5"
                                Background="{DynamicResource TextDisabledBrush}"/>
                    </StackPanel>
                    <Button x:Name="AntiIdleBadge"
                            TabIndex="5"
                            Click="OnAntiIdleBadgeClick"
                            ToolTip="{loc:Translate TooltipAntiIdleActive}"
                            AutomationProperties.Name="{loc:Translate A11yAntiIdleActive}"
                            Visibility="Collapsed"
                            Margin="8,0,0,0"
                            Padding="4,1"
                            VerticalAlignment="Center"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border x:Name="RedirectionIndicatorsPanel"
                            Margin="12,0,0,0"
                            Padding="6,1"
                            CornerRadius="4"
                            Background="{DynamicResource CardBrush}"
                            Focusable="False"
                            KeyboardNavigation.IsTabStop="False"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RedirIconClipboard"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelClipboard}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelClipboard}"/>
                            <TextBlock x:Name="RedirIconDrives"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelDrives}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelDrives}"/>
                            <TextBlock x:Name="RedirIconPrinters"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelPrinters}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelPrinters}"/>
                            <TextBlock x:Name="RedirIconComPorts"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelComPorts}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelComPorts}"/>
                            <TextBlock x:Name="RedirIconSmartCards"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelSmartCards}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelSmartCards}"/>
                            <TextBlock x:Name="RedirIconUsb"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelUsb}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelUsb}"/>
                            <TextBlock x:Name="RedirIconAudio"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelAudio}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelAudio}"/>
                            <TextBlock x:Name="RedirIconMultiMonitor"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="{loc:Translate RdpRedirectionLabelMultiMonitor}"
                                       AutomationProperties.HelpText="{loc:Translate RdpRedirectionLabelMultiMonitor}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Border Margin="16,0,16,16"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}">
                <Border Background="{DynamicResource SurfaceBrush}"
                        ClipToBounds="True">
                    <Grid x:Name="SurfaceContainer"
                          Background="{DynamicResource SurfaceBrush}"
                          ClipToBounds="True">
                        <wfi:WindowsFormsHost x:Name="FormsHost"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              KeyboardNavigation.IsTabStop="False"
                                              KeyboardNavigation.TabNavigation="None"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Reconnect overlay (shown on unexpected disconnect) -->
            <Border x:Name="ReconnectOverlay"
                    Style="{StaticResource FadeInPanelStyle}"
                    Visibility="Collapsed"
                    Focusable="True"
                    KeyboardNavigation.IsTabStop="False"
                    Background="{DynamicResource OverlayBackground}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutomationProperties.IsDialog="True"
                    AutomationProperties.Name="{loc:Translate A11yRdpReconnectDialog}"
                    PreviewKeyDown="OnReconnectOverlayPreviewKeyDown">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="460">
                    <Border x:Name="OverlaySeverityStrip"
                            Height="4"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource ErrorBrush}"
                            CornerRadius="2"/>
                    <TextBlock x:Name="OverlaySeverityIcon"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="32"
                               Text="&#xE783;"
                               Foreground="{DynamicResource ErrorBrush}"
                               Focusable="False"
                               IsHitTestVisible="False"
                               AutomationProperties.Name=""
                               AutomationProperties.IsOffscreenBehavior="Onscreen"/>
                    <TextBlock x:Name="ReconnectMessageText"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.LiveSetting="Polite" />
                    <TextBlock x:Name="ReconnectSecondaryText"
                               Margin="0,8,0,0"
                               FontSize="{StaticResource FontSizeBody}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="Collapsed" />
                    <TextBlock x:Name="ReconnectCodeText"
                               Margin="0,6,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0"
                                KeyboardNavigation.TabNavigation="Cycle">
                        <Button x:Name="OverlayReconnectButton"
                                TabIndex="0"
                                Click="OnOverlayReconnectClick"
                                Content="{loc:Translate BtnReconnectSession}"
                                AutomationProperties.Name="{loc:Translate A11yReconnectSession}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="OverlayCopyErrorButton"
                                TabIndex="1"
                                Click="OnOverlayCopyErrorClick"
                                Content="{loc:Translate BtnCopyErrorOverlay}"
                                ToolTip="{loc:Translate TooltipCopyErrorOverlay}"
                                AutomationProperties.Name="{loc:Translate A11yCopyErrorOverlay}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="8,0,0,0"/>
                        <Button x:Name="OverlayEditProfileButton"
                                TabIndex="2"
                                Click="OnOverlayEditProfileClick"
                                Content="{loc:Translate BtnEditProfileOverlay}"
                                ToolTip="{loc:Translate TooltipEditProfileOverlay}"
                                AutomationProperties.Name="{loc:Translate A11yEditProfileOverlay}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="8,0,0,0"
                                Visibility="Collapsed"/>
                        <Button x:Name="OverlayCloseButton"
                                TabIndex="3"
                                Click="OnOverlayCloseClick"
                                Content="{loc:Translate BtnCloseOverlay}"
                                AutomationProperties.Name="{loc:Translate A11yCloseOverlay}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="{StaticResource FontSizeBodyLarge}"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection progress indicator -->
            <ProgressBar x:Name="RdpLoadingBar"
                         VerticalAlignment="Top"
                         Height="2"
                         Margin="16,0,16,0"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         IsHitTestVisible="False"/>

            <Border x:Name="TransientToast"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,16,0,0"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Padding="12,6"
                    Background="{DynamicResource OverlayBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Focusable="False"
                    KeyboardNavigation.IsTabStop="False"
                    Panel.ZIndex="50"
                    AutomationProperties.LiveSetting="Polite"
                    AutomationProperties.Name="{loc:Translate A11yRdpTransientToast}">
                <TextBlock x:Name="TransientToastText"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="{StaticResource FontSizeBody}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
