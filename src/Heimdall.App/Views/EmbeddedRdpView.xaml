<UserControl x:Class="Heimdall.App.Views.EmbeddedRdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,10"
                Padding="14,10"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Content="Disconnect"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="DetailTextBlock"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Background="Black"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid x:Name="SurfaceContainer" ClipToBounds="True">
                <wfi:WindowsFormsHost x:Name="FormsHost"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
