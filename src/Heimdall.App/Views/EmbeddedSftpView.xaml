<UserControl x:Class="Heimdall.App.Views.EmbeddedSftpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave"
             KeyDown="OnViewKeyDown">
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header strip -->
        <Border Grid.Row="0"
                Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate SftpBtnClose}"
                        ToolTip="{loc:Translate TooltipDisconnectSession}"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"
                        AutomationProperties.Name="{loc:Translate A11yDisconnectSession}"/>
                <Button x:Name="ReconnectButton"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate SftpBtnReconnect}"
                        ToolTip="{loc:Translate TooltipReconnectSession}"
                        Click="OnReconnectClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="8,2"
                        FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0"
                        Visibility="Collapsed"
                        AutomationProperties.Name="{loc:Translate A11yReconnectSession}"/>
                <Button x:Name="SplitButton"
                        DockPanel.Dock="Right"
                        Content="&#xE8A9;"
                        ToolTip="{loc:Translate TooltipSplitSession}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding RequestSplitCommand}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0"
                        AutomationProperties.Name="{loc:Translate A11ySplitSession}"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="250"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="{Binding StatusText}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 1: Toolbar -->
        <Border Grid.Row="1"
                Padding="8,4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <!-- Right side: filter + hidden toggle -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBox x:Name="FilterTextBox"
                             Width="160"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Tag="{loc:Translate SftpFilterPlaceholder}"
                             FontSize="{StaticResource FontSizeCaption}"
                             VerticalContentAlignment="Center"
                             Margin="8,0,0,0"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="{loc:Translate A11yTxtSearchFiles}"/>
                    <CheckBox x:Name="ToggleHiddenCheckBox"
                              Content=".*"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="{StaticResource FontSizeCaption}"
                              Margin="8,0,0,0"
                              IsChecked="{Binding ShowHidden}"
                              ToolTip="{loc:Translate SftpToggleHidden}"
                              AutomationProperties.Name="{loc:Translate SftpToggleHidden}"
                              />
                </StackPanel>

                <!-- Left side: navigation + actions (Segoe MDL2 Assets icons) -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnBack"
                            Content="&#xE72B;"
                            ToolTip="{loc:Translate TooltipNavigateBack}"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding NavigateBackCommand}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeBody}"
                            IsEnabled="False"
                            AutomationProperties.Name="{loc:Translate A11yNavigateBack}"/>
                    <Button x:Name="BtnUp"
                            Content="&#xE74A;"
                            ToolTip="{loc:Translate TooltipNavigateUp}"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding NavigateUpCommand}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0,0,0"
                            AutomationProperties.Name="{loc:Translate A11yNavigateUp}"/>
                    <Button x:Name="BtnHome"
                            Content="&#xE80F;"
                            ToolTip="{loc:Translate TooltipNavigateHome}"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding NavigateHomeCommand}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0,0,0"
                            AutomationProperties.Name="{loc:Translate A11yNavigateHome}"/>
                    <Button x:Name="BtnRefresh"
                            Content="&#xE72C;"
                            ToolTip="{loc:Translate TooltipRefreshDirectory}"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding RefreshCommand}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeBody}" Margin="4,0,0,0"
                            AutomationProperties.Name="{loc:Translate A11yRefreshDirectory}"/>

                    <Border Style="{StaticResource ToolbarVerticalSeparatorStyle}"
                            AutomationProperties.AutomationId="Toolbar.Sftp.NavigationActionsSeparator"/>

                    <Button x:Name="BtnUpload"
                            Click="OnUploadClick"
                            ToolTip="{loc:Translate TooltipUploadFiles}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"
                            AutomationProperties.Name="{loc:Translate A11yUploadFiles}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="BtnUploadText" Text="{loc:Translate SftpBtnUpload}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNewFolder"
                            Command="{Binding CreateFolderCommand}"
                            ToolTip="{loc:Translate TooltipCreateFolder}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name="{loc:Translate A11yCreateFolder}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="BtnNewFolderText" Text="{loc:Translate SftpBtnNewFolder}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>

                    <Border Style="{StaticResource ToolbarVerticalSeparatorStyle}"
                            AutomationProperties.AutomationId="Toolbar.Sftp.ActionsPrivilegeSeparator"/>

                    <ToggleButton x:Name="BtnSudoMode"
                                  Command="{Binding ToggleSudoModeCommand}"
                                  ToolTip="{loc:Translate SftpSudoModeTooltip}"
                                  Padding="8,2" FontSize="{StaticResource FontSizeCaption}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Background="Transparent"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.Name="{loc:Translate SftpSudoModeTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="BtnSudoModeText" Text="{loc:Translate SftpSudoModeLabel}" VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ToggleButton>

                    <Border Style="{StaticResource ToolbarVerticalSeparatorStyle}"
                            AutomationProperties.AutomationId="Toolbar.Sftp.PrivilegeBookmarksSeparator"/>

                    <!-- Bookmarks overflow menu -->
                    <Button x:Name="BtnBookmarkMenu"
                            Content="&#xE734;"
                            ToolTip="{loc:Translate SftpBtnBookmark}"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            Padding="8,2" FontSize="{StaticResource FontSizeBody}"
                            Click="OnBookmarkMenuClick"
                            AutomationProperties.Name="{loc:Translate SftpBtnBookmark}">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="BookmarkContextMenu"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem x:Name="MnuBookmarkAdd"
                                          Header="{loc:Translate SftpBtnBookmark}"
                                          Command="{Binding AddBookmarkCommand}"
                                          AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="MnuBookmarkManage" Header="{loc:Translate SftpBtnBookmarks}" Click="OnBookmarksClick"
                                          AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 2: Path bar -->
        <Border Grid.Row="2"
                Padding="8,4"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnGoPath"
                        DockPanel.Dock="Right"
                        Content="&#xE76C;"
                        ToolTip="{loc:Translate SftpBtnGoPath}"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding GoToPathCommand}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="8,2" FontSize="{StaticResource FontSizeBody}"
                        Margin="4,0,0,0"
                        AutomationProperties.Name="{loc:Translate SftpBtnGoPath}"/>
                <TextBox x:Name="PathTextBox"
                         Style="{DynamicResource ThemedTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBody}"
                         FontFamily="{StaticResource FontFamilyMonospace}"
                         VerticalContentAlignment="Center"
                         Text="{Binding PathBarText, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{loc:Translate A11yTxtPath}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding GoToPathCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- Row 3: File list -->
        <ListView x:Name="FileListView"
                  Grid.Row="3"
                  Margin="0"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderThickness="0"
                  ItemsSource="{Binding Files}"
                  SelectionMode="Extended"
                  AlternationCount="2"
                  MouseDoubleClick="OnFileDoubleClick"
                  SelectionChanged="OnSelectionChanged"
                  GridViewColumnHeader.Click="OnColumnHeaderClick"
                  SizeChanged="OnFileListSizeChanged"
                  AutomationProperties.Name="{loc:Translate A11yLstFiles}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridViewColumn x:Name="ColName" Width="320" Header="{loc:Translate SftpColName}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="FileIcon"
                                               Text="&#xE7C3;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{StaticResource FontSizeBodyLarge}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="FileIcon" Property="Text" Value="&#xE8B7;"/>
                                        <Setter TargetName="FileIcon" Property="Foreground" Value="{DynamicResource InfoBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColSize" Width="80" Header="{loc:Translate SftpColSize}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}, ConverterParameter=dir}"
                                           TextAlignment="Right" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColDate" Width="140" Header="{loc:Translate SftpColModified}"
                                    DisplayMemberBinding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                    <GridViewColumn x:Name="ColPermissions" Width="80" Header="{loc:Translate SftpColPermissions}"
                                    DisplayMemberBinding="{Binding Permissions}"/>
                    <GridViewColumn x:Name="ColOwner" Width="55" Header="{loc:Translate SftpColOwner}"
                                    DisplayMemberBinding="{Binding Owner}"/>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="4,4"/>
                    <Setter Property="MinHeight" Value="26"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding FullPath}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"/>
                                    <TextBlock Text="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                                    <TextBlock Text="{Binding Permissions}"/>
                                </StackPanel>
                            </ToolTip>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <!-- Hover: flat Dracula Current Line -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                        </MultiTrigger>
                        <!-- Selected: Current Line + left accent border (VS Code style) -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        </Trigger>
                        <!-- Keyboard focus: dotted border to distinguish from selected -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                            <Setter Property="BorderThickness" Value="1,1,1,1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ContextMenu>
                <ContextMenu x:Name="FileContextMenu"
                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                             Opened="OnContextMenuOpened">
                    <MenuItem x:Name="CtxOpen" Header="{loc:Translate SftpCtxOpen}" Click="OnCtxOpenClick" InputGestureText="Enter"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxEdit" Header="{loc:Translate SftpCtxEdit}" Click="OnCtxEditClick"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxEditExternal" Header="{loc:Translate SftpCtxEditExternal}" Click="OnCtxEditExternalClick"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDownload" Header="{loc:Translate SftpBtnDownload}" Click="OnCtxDownloadClick"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxRename" Header="{loc:Translate SftpBtnRename}" Command="{Binding RenameSelectedCommand}" InputGestureText="F2"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8AC;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDelete" Header="{loc:Translate SftpBtnDelete}" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="{StaticResource FontSizeSubtitle}"
                                       Foreground="{DynamicResource ErrorTextBrush}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxChmod" Header="{loc:Translate SftpCtxChmod}" Command="{Binding ChmodSelectedCommand}"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D7;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxCopyPath" Header="{loc:Translate SftpCopyPath}" Click="OnCtxCopyPathClick" InputGestureText="Ctrl+C"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxProperties" Header="{loc:Translate SftpCtxProperties}" Command="{Binding ShowSelectedPropertiesCommand}"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxUploadHere" Header="{loc:Translate SftpCtxUploadHere}" Click="OnUploadClick"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInTerminal" Header="{loc:Translate SftpCtxOpenInTerminal}" Command="{Binding OpenSelectedInTerminalCommand}"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE756;" FontSize="{StaticResource FontSizeSubtitle}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- Row 3 overlay: Loading indicator -->
        <ProgressBar x:Name="LoadingBar"
                     Grid.Row="3"
                     VerticalAlignment="Top"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Row 3 overlay: Empty directory message -->
        <TextBlock x:Name="EmptyDirectoryText"
                   Grid.Row="3"
                   Text="{loc:Translate SftpEmptyDirectory}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   FontSize="{StaticResource FontSizeBodyLarge}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   IsHitTestVisible="False"
                   Visibility="{Binding ShowEmptyDirectory, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Row 3 overlay: Drag-drop feedback -->
        <Border x:Name="DragOverlay"
                Grid.Row="3"
                Background="{DynamicResource DragDropOverlayBackground}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                CornerRadius="{StaticResource CornerRadiusSm}"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="DragDropOverlayText"
                       Text="{loc:Translate SftpDragDropOverlay}"
                       FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Row 4: Transfer progress bar -->
        <Border x:Name="TransferPanel"
                Grid.Row="4"
                Padding="8,4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <DockPanel>
                <Button x:Name="BtnCancelTransfer"
                        DockPanel.Dock="Right"
                        Content="&#xE711;"
                        ToolTip="{loc:Translate TooltipCancelTransfer}"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnCancelTransferClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}"
                        Margin="8,0,0,0"
                        AutomationProperties.Name="{loc:Translate A11yCancelTransfer}"/>
                <StackPanel>
                    <TextBlock x:Name="TransferText"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ProgressBar x:Name="TransferProgressBar"
                                 Height="6" Margin="0,4,0,0"
                                 Minimum="0" Maximum="100"
                                  Foreground="{DynamicResource AccentBrush}"
                                  Background="{DynamicResource HighlightBrush}"
                                  AutomationProperties.Name="{loc:Translate A11yPrgTransfer}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 5: Status bar -->
        <Border Grid.Row="5"
                Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="ItemCountText"
                           DockPanel.Dock="Right"
                           Text="{Binding ItemCountText}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="SelectionInfoText"
                           DockPanel.Dock="Right"
                           Text="{Binding SelectionInfoText}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Margin="0,0,12,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <!-- Connection health dot -->
                <Ellipse x:Name="HealthDot"
                         Width="8" Height="8"
                         Margin="0,0,6,0"
                         Fill="{DynamicResource SuccessBrush}"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBarText"
                           Text="{Binding StatusText}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
