<UserControl x:Class="Heimdall.App.Views.EmbeddedSshView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}"
             Focusable="True">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header strip -->
        <Border Grid.Row="0"
                Margin="16,16,16,10"
                Padding="14,10"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Content="Disconnect"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Terminal surface -->
        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Background="#1E1E2E"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                ClipToBounds="True">
            <Grid>
                <wv2:WebView2 x:Name="TerminalWebView"
                              Focusable="True"
                              DefaultBackgroundColor="#1E1E2E" />

                <Border x:Name="FallbackPanel"
                        Visibility="Collapsed"
                        Background="#1E1E2E"
                        Padding="28">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                MaxWidth="420">
                        <TextBlock Text="Embedded SSH terminal unavailable"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="FallbackMessageText"
                                   Margin="0,12,0,0"
                                   Text="WebView2 could not be initialized on this machine."
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
