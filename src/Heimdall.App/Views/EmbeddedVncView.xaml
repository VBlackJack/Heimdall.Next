<UserControl x:Class="Heimdall.App.Views.EmbeddedVncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}"
             Focusable="True">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header strip -->
        <Border Grid.Row="0"
                Padding="8,3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="11"
                        Margin="8,0,0,0"/>

                <Button x:Name="ReconnectButton"
                        DockPanel.Dock="Right"
                        Click="OnReconnectClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="8,2"
                        FontSize="11"
                        Margin="8,0,0,0"
                        Visibility="Collapsed"/>

                <Button x:Name="SplitButton"
                        DockPanel.Dock="Right"
                        Content="&#xE8A9;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="OnSplitClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="12" Margin="4,0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Connection progress indicator -->
        <ProgressBar x:Name="VncLoadingBar"
                     Grid.Row="1"
                     VerticalAlignment="Top"
                     Panel.ZIndex="1"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"/>

        <!-- VNC surface -->
        <Grid Grid.Row="1" ClipToBounds="True">
            <wv2:WebView2 x:Name="VncWebView"
                          Focusable="True" />

            <!-- Reconnect overlay (shown on unexpected disconnect) -->
            <Border x:Name="ReconnectOverlay"
                    Visibility="Collapsed"
                    Background="{DynamicResource OverlayBackground}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="400">
                    <TextBlock x:Name="ReconnectMessageText"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0">
                        <Button x:Name="OverlayReconnectButton"
                                Click="OnOverlayReconnectClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"
                                FontSize="13"
                                Margin="0,0,8,0"/>
                        <Button x:Name="OverlayCloseButton"
                                Click="OnOverlayCloseClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6"
                                FontSize="13"
                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="FallbackPanel"
                    Visibility="Collapsed"
                    Background="{DynamicResource BackgroundBrush}"
                    Padding="28">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="420">
                    <TextBlock x:Name="FallbackTitleText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="FallbackMessageText"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
