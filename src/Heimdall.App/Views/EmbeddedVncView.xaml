<UserControl x:Class="Heimdall.App.Views.EmbeddedVncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}"
             Focusable="True">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header strip -->
        <Border Grid.Row="0"
                Padding="8,3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="DisconnectButton"
                        DockPanel.Dock="Right"
                        Click="OnDisconnectClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2"
                        FontSize="11"
                        Margin="8,0,0,0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SessionTitleText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Margin="8,0,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- VNC surface -->
        <Grid Grid.Row="1" ClipToBounds="True">
            <wv2:WebView2 x:Name="VncWebView"
                          Focusable="True"
                          DefaultBackgroundColor="#1E1E2E" />

            <Border x:Name="FallbackPanel"
                    Visibility="Collapsed"
                    Background="{DynamicResource BackgroundBrush}"
                    Padding="28">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="420">
                    <TextBlock x:Name="FallbackTitleText"
                               Text="Embedded VNC viewer unavailable"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="FallbackMessageText"
                               Margin="0,12,0,0"
                               Text="WebView2 could not be initialized on this machine."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
