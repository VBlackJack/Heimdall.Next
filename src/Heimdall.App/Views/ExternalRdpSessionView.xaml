<UserControl x:Class="Heimdall.App.Views.ExternalRdpSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Heimdall.App.Localization">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Border MaxWidth="560"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{loc:Translate RdpExternalTabTitle}"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,12,0,0"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="{loc:Translate RdpExternalTabServer}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="DisplayNameTextBlock"
                               Grid.Row="0"
                               Grid.Column="2"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,8,0,0"
                               Text="{loc:Translate RdpExternalTabEndpoint}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="EndpointTextBlock"
                               Grid.Row="1"
                               Grid.Column="2"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,8,0,0"
                               Text="{loc:Translate RdpExternalTabProcess}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="ProcessTextBlock"
                               Grid.Row="2"
                               Grid.Column="2"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
                <TextBlock Text="{loc:Translate RdpExternalTabCloseHint}"
                           Margin="0,18,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
