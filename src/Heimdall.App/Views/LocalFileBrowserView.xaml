<UserControl x:Class="Heimdall.App.Views.LocalFileBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
        <conv:FileIconConverter x:Key="FileIconConverter"/>
        <conv:FileIconColorConverter x:Key="FileIconColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="6,4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
            <TextBox x:Name="FilterTextBox"
                     DockPanel.Dock="Right"
                     Width="160"
                     Style="{DynamicResource SearchTextBoxStyle}"
                     Tag=""
                     FontSize="{StaticResource FontSizeCaption}"
                     VerticalContentAlignment="Center"
                     Margin="8,0,0,0"
                      TextChanged="OnFilterTextChanged"
                      AutomationProperties.Name="{loc:Translate A11yTxtSearchFiles}"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                        x:Name="BtnBack" Click="OnBackClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeCaption}" IsEnabled="False"
                        AutomationProperties.Name="{loc:Translate SftpTooltipBack}"/>
                <Button x:Name="BtnUp" Content="&#xE74A;" FontFamily="Segoe MDL2 Assets"
                        Click="OnUpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="3,0,0,0"
                        AutomationProperties.Name="{loc:Translate SftpTooltipUp}"/>
                <Button x:Name="BtnHome" Content="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                        Click="OnHomeClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="3,0,0,0"
                        AutomationProperties.Name="{loc:Translate SftpTooltipHome}"/>
                <Button x:Name="BtnRefresh" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                        Click="OnRefreshClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeCaption}" Margin="3,0,0,0"
                        AutomationProperties.Name="{loc:Translate SftpTooltipRefresh}"/>
            </StackPanel>
            </DockPanel>
        </Border>

        <!-- Path bar -->
        <Border Grid.Row="1" Padding="6,3"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBox x:Name="PathTextBox"
                     Style="{DynamicResource ThemedTextBoxStyle}"
                     FontSize="{StaticResource FontSizeCaption}" FontFamily="{StaticResource FontFamilyMonospace}"
                     VerticalContentAlignment="Center"
                     KeyDown="OnPathKeyDown"
                     AutomationProperties.Name="{loc:Translate A11yTxtPath}"/>
        </Border>

        <!-- File list -->
        <ListView x:Name="FileListView"
                  Grid.Row="2"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderThickness="0"
                  SelectionMode="Extended"
                  AlternationCount="2"
                  MouseDoubleClick="OnFileDoubleClick"
                  SizeChanged="OnFileListSizeChanged"
                  AutomationProperties.Name="{loc:Translate A11yLstFiles}"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn x:Name="ColName" Width="250" Header="{loc:Translate LocalFileBrowserColName}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Icon"
                                               Text="{Binding Name, Converter={StaticResource FileIconConverter}}"
                                               Foreground="{Binding Name, Converter={StaticResource FileIconColorConverter}}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="Icon" Property="Text" Value="&#xE8B7;"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource InfoBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColSize" Width="80" Header="{loc:Translate LocalFileBrowserColSize}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}, ConverterParameter=dir}"
                                           TextAlignment="Right" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColDate" Width="130" Header="{loc:Translate LocalFileBrowserColModified}"
                                    DisplayMemberBinding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="3,3"/>
                    <Setter Property="MinHeight" Value="26"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                            <Setter Property="BorderThickness" Value="1,1,1,1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ContextMenu>
                <ContextMenu Opened="OnContextMenuOpened">
                    <MenuItem x:Name="CtxOpen" Header="" Click="OnCtxOpen" InputGestureText="Enter"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenWith" Header="" Click="OnCtxOpenWith"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7AC;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInExplorer" Header="" Click="OnCtxOpenInExplorer"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInTerminal" Header="" Click="OnCtxOpenInTerminal"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE756;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInEditor" Header="" Click="OnCtxOpenInEditor"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxRunInShell" Header="" Click="OnCtxRunInShell"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxCopy" Header="" Click="OnCtxCopy" InputGestureText="Ctrl+C"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxPaste" Header="" Click="OnCtxPaste" InputGestureText="Ctrl+V"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77F;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxCopyPath" Header="" Click="OnCtxCopyPath"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxRename" Header="" Click="OnCtxRename" InputGestureText="F2"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8AC;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDelete" Header="" Click="OnCtxDelete" InputGestureText="Del"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxNewFolder" Header="" Click="OnCtxNewFolder"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxProperties" Header="" Click="OnCtxProperties"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxRefresh" Header="" Click="OnRefreshClick" InputGestureText="F5"
                              AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Self}}">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="{StaticResource FontSizeSubtitle}"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- Row 2 overlay: Loading indicator -->
        <ProgressBar x:Name="LoadingBar"
                     Grid.Row="2"
                     VerticalAlignment="Top"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="Collapsed"/>

        <!-- Row 2 overlay: Empty directory message -->
        <TextBlock x:Name="EmptyDirectoryText"
                   Grid.Row="2"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   FontSize="{StaticResource FontSizeBodyLarge}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="{StaticResource SessionHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
