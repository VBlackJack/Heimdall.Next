<UserControl x:Class="Heimdall.App.Views.LocalFileBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
        <conv:FileIconConverter x:Key="FileIconConverter"/>
        <conv:FileIconColorConverter x:Key="FileIconColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="6,4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
            <TextBox x:Name="FilterTextBox"
                     DockPanel.Dock="Right"
                     Width="160"
                     Style="{DynamicResource SearchTextBoxStyle}"
                     Tag="Filter..."
                     FontSize="11"
                     VerticalContentAlignment="Center"
                     Margin="8,0,0,0"
                     TextChanged="OnFilterTextChanged"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                        x:Name="BtnBack" Click="OnBackClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="11" IsEnabled="False"
                        ToolTip="Back"/>
                <Button Content="&#xE74A;" FontFamily="Segoe MDL2 Assets"
                        Click="OnUpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="11" Margin="3,0,0,0"
                        ToolTip="Up"/>
                <Button Content="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                        Click="OnHomeClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="11" Margin="3,0,0,0"
                        ToolTip="Home"/>
                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                        Click="OnRefreshClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        Padding="6,2" FontSize="11" Margin="3,0,0,0"
                        ToolTip="Refresh"/>
            </StackPanel>
            </DockPanel>
        </Border>

        <!-- Path bar -->
        <Border Grid.Row="1" Padding="6,3"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBox x:Name="PathTextBox"
                     Style="{DynamicResource ThemedTextBoxStyle}"
                     FontSize="11" FontFamily="Consolas"
                     VerticalContentAlignment="Center"
                     KeyDown="OnPathKeyDown"/>
        </Border>

        <!-- File list -->
        <ListView x:Name="FileListView"
                  Grid.Row="2"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderThickness="0"
                  SelectionMode="Extended"
                  AlternationCount="2"
                  MouseDoubleClick="OnFileDoubleClick"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Icon"
                                               Text="{Binding Name, Converter={StaticResource FileIconConverter}}"
                                               Foreground="{Binding Name, Converter={StaticResource FileIconColorConverter}}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="Icon" Property="Text" Value="&#xE8B7;"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource InfoBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Size" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}, ConverterParameter=dir}"
                                           TextAlignment="Right" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Modified" Width="130"
                                    DisplayMemberBinding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="3,3"/>
                    <Setter Property="MinHeight" Value="24"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ContextMenu>
                <ContextMenu Opened="OnContextMenuOpened">
                    <MenuItem x:Name="CtxOpen" Header="Open" Click="OnCtxOpen" InputGestureText="Enter">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenWith" Header="Open With..." Click="OnCtxOpenWith">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7AC;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInExplorer" Header="Open in Explorer" Click="OnCtxOpenInExplorer">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInTerminal" Header="Open in Terminal" Click="OnCtxOpenInTerminal">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE756;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxOpenInEditor" Header="Open in Editor" Click="OnCtxOpenInEditor">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxRunInShell" Header="Run in Shell" Click="OnCtxRunInShell">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxCopy" Header="Copy" Click="OnCtxCopy" InputGestureText="Ctrl+C">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxPaste" Header="Paste" Click="OnCtxPaste" InputGestureText="Ctrl+V">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77F;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxCopyPath" Header="Copy path" Click="OnCtxCopyPath">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxRename" Header="Rename" Click="OnCtxRename" InputGestureText="F2">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8AC;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDelete" Header="Delete" Click="OnCtxDelete" InputGestureText="Del">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxNewFolder" Header="New Folder" Click="OnCtxNewFolder">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="CtxProperties" Header="Properties" Click="OnCtxProperties">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxRefresh" Header="Refresh" Click="OnRefreshClick" InputGestureText="F5">
                        <MenuItem.Icon><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- Row 2 overlay: Loading indicator -->
        <ProgressBar x:Name="LoadingBar"
                     Grid.Row="2"
                     VerticalAlignment="Top"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Visibility="Collapsed"/>

        <!-- Row 2 overlay: Empty directory message -->
        <TextBlock x:Name="EmptyDirectoryText"
                   Grid.Row="2"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="8,3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
