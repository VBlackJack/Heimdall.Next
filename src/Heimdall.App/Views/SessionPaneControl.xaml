<UserControl x:Class="Heimdall.App.Views.SessionPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Heimdall.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">
    <UserControl.Resources>
        <converters:SessionFailureStageToLabelConverter x:Key="SessionFailureStageToLabelConverter"/>
    </UserControl.Resources>
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <Border x:Name="PaneBorder" ClipToBounds="True"
                BorderThickness="0" BorderBrush="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ContentPresenter x:Name="HostPresenter" ClipToBounds="True"/>
        </Border>

        <!-- Loading overlay (visible while HostControl is null during connection) -->
        <Border x:Name="LoadingOverlay"
                Visibility="Collapsed"
                Background="{DynamicResource OverlayBackground}"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="160" Height="3"
                             Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Title}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Status}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Disconnect overlay (visible when status is Disconnected/Error and content exists) -->
        <Border x:Name="DisconnectedOverlay"
                Visibility="Collapsed"
                Background="{DynamicResource OverlayBackground}"
                IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="280">
                <TextBlock Text="&#xE711;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="{StaticResource FontSizeHeadline}"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Title}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Status}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,16"/>
                <Expander x:Name="FailureDetailsExpander"
                          AutomationProperties.AutomationId="SessionTab.FailureDetailsExpander"
                          Header="{loc:Translate ToolNetMapColDetails}"
                          Style="{StaticResource ThemedExpanderStyle}"
                          Visibility="{Binding HasFailureDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,0,0,16">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{loc:Translate SessionDiagnosticLabelStage}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding FailureDetails.Stage, Converter={StaticResource SessionFailureStageToLabelConverter}}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   AutomationProperties.AutomationId="SessionTab.FailureStage"/>

                        <TextBlock Grid.Row="1"
                                   Text="{loc:Translate SessionDiagnosticLabelCode}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Visibility="{Binding FailureDetails.Code, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="{Binding FailureDetails.Code}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   AutomationProperties.AutomationId="SessionTab.FailureCode"
                                   Visibility="{Binding FailureDetails.Code, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="2"
                                   Text="{loc:Translate SessionDiagnosticLabelDetail}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Visibility="{Binding FailureDetails.Detail, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Text="{Binding FailureDetails.Detail}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.AutomationId="SessionTab.FailureDetail"
                                   Visibility="{Binding FailureDetails.Detail, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0,6,0,0"/>
                    </Grid>
                </Expander>
                <WrapPanel HorizontalAlignment="Center">
                    <Button x:Name="ReconnectButton"
                            AutomationProperties.Name="{loc:Translate SplitReconnectSecondary}"
                            Content="{loc:Translate SessionPaneBtnReconnectShort}"
                            ToolTip="{loc:Translate SplitReconnectSecondary}"
                            Margin="3,3"
                            MinWidth="108"
                            Padding="10,5"/>
                    <Button x:Name="ClosePaneButton"
                            AutomationProperties.Name="{loc:Translate SplitCloseSecondary}"
                            Content="{loc:Translate SessionPaneBtnCloseShort}"
                            ToolTip="{loc:Translate SplitCloseSecondary}"
                            Margin="3,3"
                            MinWidth="108"
                            Padding="10,5"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
