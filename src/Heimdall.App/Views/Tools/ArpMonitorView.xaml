<UserControl x:Class="Heimdall.App.Views.Tools.ArpMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Heimdall.App.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:ArpEntryStateToResourceKeyConverter x:Key="ArpEntryStateToResourceKeyConverter"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="6"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="7"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Input strip -->
        <Border Grid.Row="2" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnToggle" Content=""
                        Click="OnToggleClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        VerticalAlignment="Center"
                        TabIndex="0"/>
                <Button x:Name="BtnScanNow" Content=""
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                        VerticalAlignment="Center"
                        IsEnabled="False"
                        TabIndex="1"/>
                <TextBlock x:Name="LblInterval" Text=""
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ComboBox x:Name="CmbInterval" Width="80"
                          SelectedIndex="1"
                          VerticalAlignment="Center"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          TabIndex="2">
                    <ComboBoxItem x:Name="Interval5s" Content="" Tag="5000"/>
                    <ComboBoxItem x:Name="Interval10s" Content="" Tag="10000"/>
                    <ComboBoxItem x:Name="Interval30s" Content="" Tag="30000"/>
                    <ComboBoxItem x:Name="Interval60s" Content="" Tag="60000"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Alert banner -->
        <Border x:Name="AlertBanner" Grid.Row="3"
                Visibility="{Binding IsAlertVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Padding="{StaticResource PaddingAlertBanner}" Margin="8,8,8,0"
                Background="{DynamicResource WarningBrush}"
                CornerRadius="{StaticResource CornerRadiusSm}">
            <DockPanel>
                <Button x:Name="BtnDismissAlert" DockPanel.Dock="Right"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"
                        Command="{Binding DismissAlertCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" Margin="{StaticResource MarginInlineControl}"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                        TabIndex="3"/>
                <StackPanel>
                    <TextBlock x:Name="TxtAlertTitle" Text="{Binding AlertTitle}"
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource BackgroundBrush}"/>
                    <TextBlock x:Name="TxtAlertMessage" Text="{Binding AlertMessage}"
                               FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap"
                               Foreground="{DynamicResource BackgroundBrush}"
                               AutomationProperties.LiveSetting="Assertive"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ProgressBar x:Name="LoadingBar" Grid.Row="4"
                     Style="{StaticResource ToolLoadingBarStyle}"/>

        <TextBlock x:Name="TxtError" Grid.Row="4"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="12,8,12,0"
                   VerticalAlignment="Top"/>

        <!-- Empty state -->
        <Border x:Name="EmptyStatePanel" Grid.Row="5"
                Style="{StaticResource ToolEmptyStateStyle}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE968;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState"
                           Text="{Binding EmptyStateText}"
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- ARP DataGrid -->
        <Border x:Name="GridPanel" Grid.Row="5"
                Style="{StaticResource ToolResultsCardStyle}"
                Margin="{StaticResource SpacingSm}"
                Padding="0">
            <DataGrid x:Name="ArpGrid"
                      ItemsSource="{Binding Entries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{DynamicResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{DynamicResource ThemedDataGridCellStyle}"
                      RowStyle="{DynamicResource ThemedDataGridRowStyle}"
                      AutomationProperties.LiveSetting="Polite"
                      TabIndex="4">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColIp" Binding="{Binding Ip}" Width="140"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColMac" Binding="{Binding Mac}" Width="160"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColVendor" Binding="{Binding Vendor}" Width="140"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTemplateColumn x:Name="ColStatus" Width="90" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusDisplay}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                            <Binding Path="State" Converter="{StaticResource ArpEntryStateToResourceKeyConverter}"/>
                                            <Binding Path="DataContext.ThemeRevision" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="ColFirstSeen" Binding="{Binding FirstSeen}" Width="90"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColLastSeen" Binding="{Binding LastSeen}" Width="90"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Command="{Binding CopyAllCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        TabIndex="5"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTotal" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Text="{Binding TotalText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="TxtLastRefresh" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Text="{Binding LastRefreshText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
