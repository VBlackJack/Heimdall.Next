<UserControl x:Class="Heimdall.App.Views.Tools.ArpMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="BtnToggle" Content=""
                            Click="OnToggleClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnScanNow" Content=""
                            Click="OnScanNowClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            IsEnabled="False"
                            AutomationProperties.Name=""/>
                    <TextBlock x:Name="LblInterval" Text=""
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="CmbInterval" Width="80"
                              SelectedIndex="1"
                              VerticalAlignment="Center"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              AutomationProperties.Name="">
                        <ComboBoxItem x:Name="Interval5s" Content="" Tag="5000"/>
                        <ComboBoxItem x:Name="Interval10s" Content="" Tag="10000"/>
                        <ComboBoxItem x:Name="Interval30s" Content="" Tag="30000"/>
                        <ComboBoxItem x:Name="Interval60s" Content="" Tag="60000"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Alert banner (hidden by default) -->
        <Border x:Name="AlertBanner" Grid.Row="1" Visibility="Collapsed"
                Padding="12,8" Margin="8,8,8,0"
                Background="{DynamicResource WarningBrush}"
                CornerRadius="{StaticResource CornerRadiusSm}">
            <DockPanel>
                <Button x:Name="BtnDismissAlert" DockPanel.Dock="Right"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        Click="OnDismissAlertClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="4,2" Margin="8,0,0,0"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
                <StackPanel>
                    <TextBlock x:Name="TxtAlertTitle" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource BackgroundBrush}"/>
                    <TextBlock x:Name="TxtAlertMessage" Text=""
                               FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap"
                               Foreground="{DynamicResource BackgroundBrush}"
                               AutomationProperties.LiveSetting="Assertive"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Empty state -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- ARP DataGrid -->
        <Border x:Name="GridPanel" Grid.Row="2" Visibility="Collapsed" Margin="{StaticResource SpacingSm}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DataGrid x:Name="ArpGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      AutomationProperties.LiveSetting="Polite"
                      AutomationProperties.Name="">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColIp" Binding="{Binding Ip}" Width="140"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColMac" Binding="{Binding Mac}" Width="160"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColVendor" Binding="{Binding Vendor}" Width="140"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTemplateColumn x:Name="ColStatus" Width="90" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusDisplay}" Foreground="{Binding StatusBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="ColFirstSeen" Binding="{Binding FirstSeen}" Width="90"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColLastSeen" Binding="{Binding LastSeen}" Width="90"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTotal" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="TxtLastRefresh" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
