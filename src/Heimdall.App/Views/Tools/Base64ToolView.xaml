<UserControl x:Class="Heimdall.App.Views.Tools.Base64ToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Mode toggle + labels -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox x:Name="ChkUrlSafe"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          AutomationProperties.Name=""/>
                <CheckBox x:Name="ChkFileMode"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Checked="OnFileModeChanged" Unchecked="OnFileModeChanged"
                          VerticalAlignment="Center"
                          AutomationProperties.Name=""/>
            </StackPanel>
            <TextBlock x:Name="InputLabel"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Input text area -->
        <TextBox x:Name="InputText" Grid.Row="1"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                 Background="{DynamicResource SurfaceBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="1"
                 Padding="{StaticResource PaddingInput}"
                 Tag="text to encode/decode"
                 TextChanged="OnInputTextChanged"
                 AutomationProperties.Name=""/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8">
            <Button x:Name="BtnEncode" Click="OnEncodeClick"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,8,0"
                    AutomationProperties.Name=""/>
            <Button x:Name="BtnDecode" Click="OnDecodeClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                    AutomationProperties.Name=""/>
        </StackPanel>

        <!-- Output text area -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="OutputLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"/>
            <TextBox x:Name="OutputText" Grid.Row="1"
                     IsReadOnly="True" AutomationProperties.LiveSetting="Polite"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="{StaticResource PaddingInput}"
                     AutomationProperties.Name=""/>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="4" Margin="0,8,0,0">
            <Button x:Name="BtnCopyOutput" DockPanel.Dock="Right"
                    Click="OnCopyOutputClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}"
                    AutomationProperties.Name=""/>
            <Button x:Name="BtnBrowseFile" DockPanel.Dock="Right"
                    Click="OnBrowseFileClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,8,0"
                    Visibility="Collapsed"
                    AutomationProperties.Name=""/>
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
