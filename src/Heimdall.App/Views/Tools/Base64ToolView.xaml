<UserControl x:Class="Heimdall.App.Views.Tools.Base64ToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="8"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Mode toggle + labels -->
        <DockPanel Grid.Row="0" Margin="{StaticResource MarginStackItem}">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox x:Name="ChkUrlSafe"
                          TabIndex="1"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>
                <CheckBox x:Name="ChkFileMode"
                          TabIndex="2"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Checked="OnFileModeChanged" Unchecked="OnFileModeChanged"
                          VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="InputLabel"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Input text area -->
        <TextBox x:Name="InputText" Grid.Row="1"
                 TabIndex="0"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                 Background="{DynamicResource SurfaceBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="1"
                 Padding="{StaticResource PaddingInput}"
                 Tag=""
                 TextChanged="OnInputTextChanged"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8">
            <Button x:Name="BtnEncode" Click="OnEncodeClick"
                    TabIndex="3"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineSm}"/>
            <Button x:Name="BtnDecode" Click="OnDecodeClick"
                    TabIndex="4"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"/>
        </StackPanel>

        <!-- Output text area -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="OutputLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"/>

            <Border x:Name="EmptyStatePanel" Grid.Row="1"
                    Style="{StaticResource ToolEmptyStateStyle}"
                   >
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE943;"
                               Style="{StaticResource ToolEmptyStateIconStyle}"
                               Focusable="False"/>
                    <TextBlock x:Name="TxtEmptyState" Text=""
                               Style="{StaticResource ToolEmptyStateTextStyle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="ResultsPanel" Grid.Row="1" Visibility="Collapsed">
                <TextBox x:Name="OutputText"
                         TabIndex="5"
                         IsReadOnly="True" AutomationProperties.LiveSetting="Polite"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="{StaticResource PaddingInput}"/>
            </Border>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="4" Margin="{StaticResource MarginSubsectionTop}">
            <Button x:Name="BtnCopyOutput" DockPanel.Dock="Right"
                    TabIndex="7"
                    Click="OnCopyOutputClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}"/>
            <Button x:Name="BtnBrowseFile" DockPanel.Dock="Right"
                    TabIndex="6"
                    Click="OnBrowseFileClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineSm}"
                    Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
