<UserControl x:Class="Heimdall.App.Views.Tools.CertInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Profile bar (visible in scan mode only) -->
        <Border x:Name="ProfileBar" Grid.Row="1" Visibility="Collapsed"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnProfileQuick" Click="OnProfileClick" Tag="quick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnProfileExtended" Click="OnProfileClick" Tag="extended"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnProfileCustom" Click="OnProfileClick" Tag="custom"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        AutomationProperties.Name=""/>
                <TextBox x:Name="TxtCustomPorts" Visibility="Collapsed"
                         Width="260"
                         Style="{StaticResource WatermarkTextBoxStyle}"
                         Tag="443, 8443, 993..."
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="4,0,0,0"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         VerticalAlignment="Center"
                         AutomationProperties.Name=""/>
            </StackPanel>
        </Border>

        <!-- Progress bar with percentage overlay (scan mode) -->
        <Grid x:Name="ScanProgressPanel" Grid.Row="2" Visibility="Collapsed">
            <ProgressBar x:Name="ScanProgress"
                         Height="20" Minimum="0" Maximum="100"
                         IsIndeterminate="False"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"
                         AutomationProperties.Name=""/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgressPercent" Text="0%"
                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="  —  " FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtProgressCount" Text="0 / 0"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Input row -->
                <TextBlock x:Name="LblHost" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnCheck" DockPanel.Dock="Right"
                            Content="" Click="OnCheckClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtPort" DockPanel.Dock="Right"
                             Text="" Width="70"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="port"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" Margin="8,0,0,0"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                    <TextBlock DockPanel.Dock="Right" Text=":"
                               FontSize="{StaticResource FontSizeBodyLarge}" Margin="4,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtHost" Text=""
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="hostname"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Route via gateway -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRouteVia" Width="240"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,12" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorTextBrush}"/>

                <!-- Empty state hint -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xEB95;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"
                                   AutomationProperties.Name=""/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Loading indicator (single port mode) -->
                <ProgressBar x:Name="LoadingBar" IsIndeterminate="True"
                             Visibility="Collapsed" Height="4" Margin="0,0,0,12"
                             AutomationProperties.Name=""/>

                <!-- ===== Single-port result panels ===== -->
                <StackPanel x:Name="SingleResultPanel" Visibility="Collapsed">
                    <!-- Expiration status banner -->
                    <Border x:Name="ExpirationBanner" Visibility="Collapsed"
                            CornerRadius="{StaticResource CornerRadiusSm}" Padding="12,8" Margin="0,0,0,12">
                        <TextBlock x:Name="TxtExpiration" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                    </Border>

                    <!-- Certificate details -->
                    <Border x:Name="DetailsPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12"
                            AutomationProperties.LiveSetting="Polite">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="LblSubject" Grid.Row="0" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Name="TxtSubject" Grid.Row="0" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblIssuer" Grid.Row="2" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Name="TxtIssuer" Grid.Row="2" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblValidFrom" Grid.Row="4" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtValidFrom" Grid.Row="4" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblValidTo" Grid.Row="6" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtValidTo" Grid.Row="6" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblSerial" Grid.Row="8" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSerial" Grid.Row="8" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblThumbprint" Grid.Row="10" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtThumbprint" Grid.Row="10" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblSigAlg" Grid.Row="12" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSigAlg" Grid.Row="12" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblKeySize" Grid.Row="14" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtKeySize" Grid.Row="14" Grid.Column="2" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>

                            <TextBlock x:Name="LblSans" Grid.Row="16" Grid.Column="0" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <ItemsControl x:Name="SansList" Grid.Row="16" Grid.Column="2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- TLS Version + Hostname Match -->
                    <Border x:Name="TlsHostPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,12,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock x:Name="LblTlsVersion" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Width="120"/>
                                <TextBlock x:Name="TxtTlsVersion" Text=""
                                           FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock x:Name="TxtHostnameMatch" Text=""
                                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Certificate Chain -->
                    <Border x:Name="ChainPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock x:Name="LblChainTitle" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl x:Name="ChainList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,4" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Subject}" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Expiry}" FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Copy button (single mode) -->
                    <Button x:Name="BtnCopy" Click="OnCopyClick"
                            Visibility="Collapsed"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name=""/>
                </StackPanel>

                <!-- ===== Multi-port scan results ===== -->
                <StackPanel x:Name="ScanResultsPanel" Visibility="Collapsed">

                    <!-- No results message -->
                    <TextBlock x:Name="TxtScanNoResults" Visibility="Collapsed"
                               FontSize="{StaticResource FontSizeBody}" Margin="0,12,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>

                    <!-- Stacked certificate cards -->
                    <ItemsControl x:Name="ScanResultsList"
                                  AutomationProperties.LiveSetting="Polite">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                                        Padding="16,12" Margin="0,0,0,12"
                                        AutomationProperties.Name="{Binding PortLabel}">
                                    <StackPanel>
                                        <!-- Card header: port label + expiration badge -->
                                        <DockPanel Margin="0,0,0,10">
                                            <Border DockPanel.Dock="Right"
                                                    Background="{Binding ExpirationBrush}"
                                                    CornerRadius="{StaticResource CornerRadiusSm}"
                                                    Padding="8,3">
                                                <TextBlock Text="{Binding ExpirationText}"
                                                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextOnAccentBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding PortLabel}"
                                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>

                                        <!-- Details grid -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SubjectLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Subject}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding IssuerLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Issuer}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding ValidFromLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ValidFrom}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding ValidToLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding ValidTo}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"/>

                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{Binding SerialLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding Serial}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="10" Grid.Column="0" Text="{Binding ThumbprintLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding Thumbprint}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="12" Grid.Column="0" Text="{Binding SigAlgorithmLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="12" Grid.Column="2" Text="{Binding SigAlgorithm}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"/>

                                            <TextBlock Grid.Row="14" Grid.Column="0" Text="{Binding KeySizeLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Row="14" Grid.Column="2" Text="{Binding KeySizeText}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- TLS version + hostname match -->
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding TlsVersionLabel}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Width="90"/>
                                            <TextBlock Text="{Binding TlsVersion}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding HostnameMatchText}"
                                                   FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                                   Foreground="{Binding HostnameMatchBrush}"
                                                   Margin="0,0,0,4"/>

                                        <!-- SANs -->
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding SansLabel}" DockPanel.Dock="Left"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Top" Margin="0,0,8,0"/>
                                            <ItemsControl ItemsSource="{Binding Sans}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>

                                        <!-- Chain (expandable) -->
                                        <Expander Header="{Binding ChainHeader}" IsExpanded="False"
                                                  AutomationProperties.Name="{Binding ChainHeader}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0">
                                            <ItemsControl ItemsSource="{Binding Chain}" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1" Padding="0,2" Margin="0,0,0,2">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Subject}" FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Expiry}" FontSize="{StaticResource FontSizeSmallCaption}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Footer: summary + actions -->
                    <DockPanel x:Name="ScanFooterPanel" Visibility="Collapsed" Margin="0,0,0,12">
                        <Button x:Name="BtnExportCsv" DockPanel.Dock="Right"
                                Click="OnExportCsvClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="8,0,0,0"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnCopyAll" DockPanel.Dock="Right"
                                Click="OnCopyAllClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}"
                                AutomationProperties.Name=""/>
                        <TextBlock x:Name="TxtScanSummary" Text=""
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
