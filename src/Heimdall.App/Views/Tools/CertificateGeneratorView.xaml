<UserControl x:Class="Heimdall.App.Views.Tools.CertificateGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Subject section -->
            <Border Grid.Row="0" Padding="{StaticResource SpacingMd}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}">
                <StackPanel>
                    <TextBlock x:Name="SubjectSectionLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <!-- Common Name -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="CnLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <TextBox x:Name="CnInput"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"
                                 AutomationProperties.Name=""/>
                    </DockPanel>
                    <!-- Organization -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="OrgLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <TextBox x:Name="OrgInput"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"
                                 AutomationProperties.Name=""/>
                    </DockPanel>
                    <!-- Country -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="CountryLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <TextBox x:Name="CountryInput"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" MaxLength="2"
                                 AutomationProperties.Name=""/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Options section -->
            <Border Grid.Row="1" Padding="{StaticResource SpacingMd}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}">
                <StackPanel>
                    <TextBlock x:Name="OptionsSectionLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <!-- Key Size -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="KeySizeLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <ComboBox x:Name="KeySizeCombo"
                                  SelectedIndex="0"
                                  MinWidth="200"
                                  AutomationProperties.Name="">
                            <ComboBoxItem x:Name="CertRsa2048Item" Content="" Tag="RSA2048"/>
                            <ComboBoxItem x:Name="CertRsa4096Item" Content="" Tag="RSA4096"/>
                        </ComboBox>
                    </DockPanel>
                    <!-- Validity Days -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="ValidityLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <TextBox x:Name="ValidityInput"
                                 Text="365"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" Width="100"
                                 HorizontalAlignment="Left"
                                 AutomationProperties.Name=""/>
                    </DockPanel>
                    <!-- SANs -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="SanLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="160"/>
                        <TextBox x:Name="SanInput"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"
                                 AutomationProperties.Name=""/>
                    </DockPanel>
                    <TextBlock x:Name="SanHint"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="160,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Type selector -->
            <Border Grid.Row="2" Padding="{StaticResource SpacingMd}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}">
                <StackPanel>
                    <TextBlock x:Name="TypeSectionLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RadioSelfSigned"
                                     IsChecked="True"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Margin="0,0,20,0"
                                     AutomationProperties.Name=""/>
                        <RadioButton x:Name="RadioCaLeaf"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     AutomationProperties.Name=""/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Generate button -->
            <Button x:Name="BtnGenerate" Grid.Row="3"
                    Click="OnGenerateClick"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginSectionSeparator}"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name=""/>

            <!-- Fingerprint -->
            <Border Grid.Row="4" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="FingerprintPanel">
                <DockPanel>
                    <TextBlock x:Name="FingerprintLabel"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Width="100"
                               FontWeight="SemiBold"/>
                    <Button x:Name="BtnCopyFingerprint" DockPanel.Dock="Right"
                            Click="OnCopyFingerprintClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="FingerprintOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                </DockPanel>
            </Border>

            <!-- Certificate PEM (self-signed) / CA Certificate (CA+Leaf) -->
            <Border Grid.Row="5" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="CertPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="CertLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyCert"
                                Click="OnCopyCertClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="CertOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             AutomationProperties.Name=""/>
                </DockPanel>
            </Border>

            <!-- Private Key -->
            <Border Grid.Row="6" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="KeyPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="KeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyKey"
                                Click="OnCopyKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnShowKey"
                                Click="OnToggleKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="KeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             AutomationProperties.Name=""/>
                </DockPanel>
            </Border>

            <!-- Leaf Certificate (CA+Leaf mode only) -->
            <Border Grid.Row="7" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="LeafPanel">
                <StackPanel>
                    <!-- Leaf Cert -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="LeafCertLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyLeafCert"
                                Click="OnCopyLeafCertClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="LeafCertOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="160"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             Margin="{StaticResource MarginSectionBottom}"
                             AutomationProperties.Name=""/>
                    <!-- Leaf Key -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="LeafKeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyLeafKey"
                                Click="OnCopyLeafKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnShowLeafKey"
                                Click="OnToggleLeafKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="LeafKeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="160"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             AutomationProperties.Name=""/>
                </StackPanel>
            </Border>

            <!-- Export buttons -->
            <StackPanel Grid.Row="8" Orientation="Horizontal"
                        Visibility="Collapsed" x:Name="ExportPanel"
                        Margin="{StaticResource MarginSectionBottom}">
                <Button x:Name="BtnSavePem"
                        Click="OnSavePemClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,8,0"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnSavePfx"
                        Click="OnSavePfxClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        AutomationProperties.Name=""/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
