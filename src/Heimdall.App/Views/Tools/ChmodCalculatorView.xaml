<UserControl x:Class="Heimdall.App.Views.Tools.ChmodCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Permission matrix: 3x3 grid with headers -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <TextBlock x:Name="HeaderRead" Grid.Row="0" Grid.Column="1"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock x:Name="HeaderWrite" Grid.Row="0" Grid.Column="2"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock x:Name="HeaderExecute" Grid.Row="0" Grid.Column="3"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

            <!-- Owner row -->
            <TextBlock x:Name="LabelOwner" Grid.Row="1" Grid.Column="0"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <CheckBox x:Name="ChkOwnerR" Grid.Row="1" Grid.Column="1"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkOwnerW" Grid.Row="1" Grid.Column="2"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkOwnerX" Grid.Row="1" Grid.Column="3"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />

            <!-- Group row -->
            <TextBlock x:Name="LabelGroup" Grid.Row="2" Grid.Column="0"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <CheckBox x:Name="ChkGroupR" Grid.Row="2" Grid.Column="1"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkGroupW" Grid.Row="2" Grid.Column="2"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkGroupX" Grid.Row="2" Grid.Column="3"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />

            <!-- Others row -->
            <TextBlock x:Name="LabelOthers" Grid.Row="3" Grid.Column="0"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,4"/>
            <CheckBox x:Name="ChkOthersR" Grid.Row="3" Grid.Column="1"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkOthersW" Grid.Row="3" Grid.Column="2"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
            <CheckBox x:Name="ChkOthersX" Grid.Row="3" Grid.Column="3"
                      HorizontalAlignment="Center"
                      Checked="OnPermissionChanged" Unchecked="OnPermissionChanged"
                      />
        </Grid>

        <!-- Octal + Symbolic display -->
        <Border Grid.Row="1" Padding="{StaticResource SpacingMd}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="OctalLabel" Grid.Column="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="OctalInput" Grid.Column="1"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                         MaxLength="3"
                         Background="Transparent"
                         Foreground="{DynamicResource AccentBrush}"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         TextChanged="OnOctalTextChanged"
                         />

                <TextBlock x:Name="SymbolicLabel" Grid.Column="3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="SymbolicDisplay" Grid.Column="4"
                           FontFamily="Consolas" FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Symbolic input -->
        <Border Grid.Row="2" Padding="{StaticResource SpacingMd}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="SymbolicInputLabel"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"/>
                <TextBox x:Name="SymbolicInput"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeSubtitle}"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="0,0,0,1"
                         Padding="4,2"
                         KeyDown="OnSymbolicInputKeyDown"/>
                <TextBlock x:Name="SymbolicInputError"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           FontSize="{StaticResource FontSizeCaption}" Margin="0,2,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Command preview -->
        <Border Grid.Row="3" Padding="{StaticResource SpacingMd}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CommandPreviewLabel" Grid.Column="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="CommandPreviewText" Grid.Column="1"
                           FontFamily="Consolas" FontSize="{StaticResource FontSizeSubtitle}"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnCopyCommand" Grid.Column="2"
                        Click="OnCopyCommandClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Copy buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,16">
            <Button x:Name="BtnCopyOctal" Click="OnCopyOctalClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,8,0"/>
            <Button x:Name="BtnCopySymbolic" Click="OnCopySymbolicClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}"/>
        </StackPanel>

        <!-- Presets -->
        <StackPanel Grid.Row="5">
            <TextBlock x:Name="PresetsLabel"
                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,6"/>
            <WrapPanel Orientation="Horizontal">
                <Button Content="644" Click="OnPresetClick" Tag="644"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="16,4" Margin="0,0,6,6"
                        />
                <Button Content="755" Click="OnPresetClick" Tag="755"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="16,4" Margin="0,0,6,6"
                        />
                <Button Content="600" Click="OnPresetClick" Tag="600"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="16,4" Margin="0,0,6,6"
                        />
                <Button Content="700" Click="OnPresetClick" Tag="700"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="16,4" Margin="0,0,6,6"
                        />
                <Button Content="777" Click="OnPresetClick" Tag="777"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="16,4" Margin="0,0,6,6"
                        />
            </WrapPanel>
        </StackPanel>
        </Grid>
    </Grid>
</UserControl>
