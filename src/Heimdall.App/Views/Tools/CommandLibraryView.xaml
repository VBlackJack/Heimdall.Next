<UserControl x:Class="Heimdall.App.Views.Tools.CommandLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:vm="clr-namespace:Heimdall.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:CommandLibraryViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ ROW 0 — HEADER ═══════════ -->
        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="?"
                        Command="{Binding ToggleHelpCommand}"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="15"/>
                <Button DockPanel.Dock="Right"
                        Content="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding ToggleHistoryCommand}"
                        ToolTip="{loc:Translate ToolCmdLibBtnHistory}"
                        AutomationProperties.Name="{loc:Translate ToolCmdLibBtnHistory}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="14" MinWidth="28" Height="28"
                        Padding="4"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="14"/>
                <Button DockPanel.Dock="Right"
                        Content="&#xE895;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding SyncCommand}"
                        ToolTip="{loc:Translate ToolCmdLibBtnSync}"
                        AutomationProperties.Name="{loc:Translate ToolCmdLibBtnSync}"
                        IsEnabled="{Binding IsSyncing, Converter={StaticResource InvertBoolConverter}}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="14" MinWidth="28" Height="28"
                        Padding="4"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="13"/>
                <Button DockPanel.Dock="Right"
                        Content="&#xE8B5;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding ImportCommand}"
                        ToolTip="{loc:Translate ToolCmdLibBtnImport}"
                        AutomationProperties.Name="{loc:Translate ToolCmdLibBtnImport}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="14" MinWidth="28" Height="28"
                        Padding="4"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="12"/>
                <Button DockPanel.Dock="Right"
                        Content="&#xEDE1;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding ExportCommand}"
                        ToolTip="{loc:Translate ToolCmdLibBtnExport}"
                        AutomationProperties.Name="{loc:Translate ToolCmdLibBtnExport}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="14" MinWidth="28" Height="28"
                        Padding="4"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="11"/>
                <Button DockPanel.Dock="Right"
                        Content="&#xE710;" FontFamily="Segoe MDL2 Assets"
                        Command="{Binding AddActionCommand}"
                        ToolTip="{loc:Translate ToolCmdLibBtnAdd}"
                        AutomationProperties.Name="{loc:Translate ToolCmdLibBtnAdd}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontSize="14" MinWidth="28" Height="28"
                        Padding="4"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="10"/>
                <TextBlock Text="{loc:Translate ToolCmdLibTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SyncStatusMessage}"
                           Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibilityConverter}}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="{StaticResource MarginInlineControl}"/>
            </DockPanel>
        </Border>

        <!-- ═══════════ ROW 1 — HELP PANEL ═══════════ -->
        <Border Grid.Row="1"
                Style="{StaticResource ToolHelpPanelStyle}"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Command="{Binding ToggleHelpCommand}"
                        AutomationProperties.Name="{loc:Translate BtnClose}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="16"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding HelpContentText}" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ ROW 2 — FILTERS ═══════════ -->
        <Border Grid.Row="2"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search bar — always full width -->
                <Grid Grid.Row="0">
                    <TextBox Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="{loc:Translate ToolCmdLibSearchPlaceholder}"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="{loc:Translate ToolCmdLibSearchPlaceholder}"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Padding="8,6,28,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TabIndex="0"/>
                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                            FontSize="{StaticResource FontSizeSmallCaption}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="{StaticResource MarginInlineXs}" Padding="4"
                            Style="{DynamicResource ToolbarGhostButtonStyle}" MinHeight="0"
                            Command="{Binding ClearSearchCommand}"
                            AutomationProperties.Name="{loc:Translate A11yClearSearch}"
                            Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- Filter controls — wrappable -->
                <WrapPanel Grid.Row="1" Margin="0,6,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResultCountText}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,2,8,2"
                               MinWidth="65"/>
                    <Button Content="&#x2605;"
                            Command="{Binding ToggleFavoritesFilterCommand}"
                            ToolTip="{loc:Translate ToolCmdLibFilterFavorites}"
                            AutomationProperties.Name="{loc:Translate ToolCmdLibFilterFavorites}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            FontSize="14" MinWidth="28" Height="28" Padding="4"
                            Margin="0,2,8,2"
                            Foreground="{Binding FavoritesFilterBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"/>
                    <ComboBox Width="180" Margin="0,2,8,2"
                              FontSize="{StaticResource FontSizeBody}"
                              ItemsSource="{Binding CategoryFilterItems}"
                              SelectedIndex="{Binding CategoryFilterIndex, Mode=TwoWay}"
                              ToolTip="{loc:Translate ToolCmdLibDialogLblCategory}"
                              AutomationProperties.Name="{loc:Translate ToolCmdLibDialogLblCategory}"
                              TabIndex="1"/>
                    <ComboBox Width="130" Margin="0,2,8,2"
                              FontSize="{StaticResource FontSizeBody}"
                              ItemsSource="{Binding PlatformFilterItems}"
                              SelectedIndex="{Binding PlatformFilterIndex, Mode=TwoWay}"
                              ToolTip="{loc:Translate ToolCmdLibDialogLblPlatform}"
                              AutomationProperties.Name="{loc:Translate ToolCmdLibDialogLblPlatform}"
                              TabIndex="2"/>
                    <ComboBox Width="120" Margin="0,2,0,2"
                              FontSize="{StaticResource FontSizeBody}"
                              ItemsSource="{Binding RiskFilterItems}"
                              SelectedIndex="{Binding RiskFilterIndex, Mode=TwoWay}"
                              ToolTip="{loc:Translate ToolCmdLibDialogLblRisk}"
                              AutomationProperties.Name="{loc:Translate ToolCmdLibDialogLblRisk}"
                              TabIndex="3"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="3"
                     Style="{StaticResource ToolLoadingBarStyle}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- ═══════════ ROW 4 — ACTION LIST ═══════════ -->
        <ListView Grid.Row="4"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding ActionsView}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  AutomationProperties.Name="{loc:Translate ToolCmdLibTitle}"
                  TabIndex="4">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="{StaticResource ToolFooterPadding}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SurfaceBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource CardBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Padding="12,8,12,4"
                                    Background="{DynamicResource BackgroundBrush}">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <!-- Favorite toggle -->
                        <!-- 24x24 kept intentionally: dense list-row context, favorite toggling rides a larger row hit area. -->
                        <Button DockPanel.Dock="Right"
                                Content="{Binding FavoriteIcon}"
                                Command="{Binding DataContext.ToggleFavoriteByIdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Source.Id}"
                                ToolTip="{Binding FavoriteTooltip}"
                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                FontSize="14" Width="24" Height="24"
                                VerticalAlignment="Center" Margin="{StaticResource MarginInlineStart}"
                                Foreground="{DynamicResource WarningTextBrush}"/>
                        <!-- Risk badge -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="{StaticResource CornerRadiusSm}" Padding="4,1"
                                VerticalAlignment="Center" Margin="{StaticResource MarginLabelInline}"
                                ToolTip="{Binding RiskLabel}">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource ResourceKeyToBrushConverter}">
                                    <Binding Path="RiskBrushKey"/>
                                    <Binding Path="DataContext.ThemeRevision" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </Border.Background>
                            <TextBlock Text="{Binding RiskBadge}"
                                       FontSize="{StaticResource FontSizeSmallCaption}"
                                       FontWeight="Bold" Foreground="{DynamicResource BadgeTextBrush}"/>
                        </Border>
                        <!-- Platform badge -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding PlatformLabel}"
                                   FontSize="{StaticResource FontSizeSmallCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource MarginInlineControl}"/>
                        <!-- Title + description -->
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Description}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- No results -->
        <TextBlock Grid.Row="4"
                   Text="{loc:Translate ToolCmdLibNoResults}"
                   Visibility="{Binding IsNoResultsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                   Style="{StaticResource ToolEmptyStateTextStyle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Empty state -->
        <Border Grid.Row="4"
                Style="{StaticResource ToolEmptyStateStyle}"
                Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock Text="{Binding EmptyStateMessage}"
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- ═══════════ ROW 5 — GENERATOR PANEL ═══════════ -->
        <Border Grid.Row="5"
                Visibility="{Binding IsGeneratorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                MaxHeight="450">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,8">
                        <DockPanel Margin="{StaticResource MarginStackItem}">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Visibility="{Binding HasMultipleTemplates, Converter={StaticResource BoolToVisibilityConverter}}">
                                <RadioButton Content="{loc:Translate ToolCmdLibPlatformWindows}"
                                             GroupName="TemplatePlatform"
                                             IsChecked="{Binding UseWindowsTemplate, Mode=TwoWay}"
                                             AutomationProperties.Name="{loc:Translate ToolCmdLibPlatformWindows}"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                                <RadioButton Content="{loc:Translate ToolCmdLibPlatformLinux}"
                                             GroupName="TemplatePlatform"
                                             IsChecked="{Binding UseLinuxTemplate, Mode=TwoWay}"
                                             AutomationProperties.Name="{loc:Translate ToolCmdLibPlatformLinux}"
                                             FontSize="{StaticResource FontSizeCaption}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ActiveTemplateName}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding Parameters}"
                                      Margin="{StaticResource MarginLabelBottom}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="{StaticResource MarginLabelBottom}"
                                               ToolTip="{Binding DisplayTooltip}">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding DisplayLabel}" Width="130"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding DisplayTooltip}"
                                                 FontSize="{StaticResource FontSizeBody}"
                                                 FontFamily="Consolas"
                                                 Padding="{StaticResource PaddingInput}"
                                                 Background="{DynamicResource CardBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Validation errors (shown when parameters are invalid) -->
                        <TextBlock Text="{Binding ValidationError}"
                                   Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource ErrorTextBrush}"
                                   TextWrapping="Wrap" Margin="{StaticResource MarginLabelBottom}"/>

                        <TextBox Text="{Binding GeneratedCommand, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="{StaticResource FontSizeBody}"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Margin="{StaticResource MarginStackItem}"/>

                        <!-- Notes / Examples / Links (collapsed when empty) -->
                        <StackPanel Visibility="{Binding HasDetailContent, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="{StaticResource MarginLabelBottom}">
                            <TextBlock Text="{Binding SelectedActionNotes}"
                                       Visibility="{Binding HasSelectedNotes, Converter={StaticResource BoolToVisibilityConverter}}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="{StaticResource MarginLabelBottom}"/>
                            <ItemsControl ItemsSource="{Binding SelectedActionExamples}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,3" Margin="0,2,0,0"
                                                Background="{DynamicResource BackgroundBrush}"
                                                CornerRadius="{StaticResource CornerRadiusSm}" Cursor="Hand"
                                                Tag="{Binding Command}">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.ApplyExampleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding Command}"/>
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                        Command="{Binding DataContext.CopyExampleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Command}"
                                                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                                                        FontSize="11" Width="22" Height="22"
                                                        Padding="2" VerticalAlignment="Top"
                                                        Focusable="False"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Command}"
                                                               FontFamily="Consolas"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="{StaticResource FontSizeSmallCaption}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding SelectedActionLinks}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="{StaticResource FontSizeCaption}">
                                            <Hyperlink NavigateUri="{Binding Url}"
                                                       RequestNavigate="OnLinkNavigate"
                                                       Foreground="{DynamicResource AccentBrush}">
                                                <Run Text="{Binding Title, Mode=OneWay}"/>
                                            </Hyperlink>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Action buttons — always visible below scroll area -->
                <DockPanel Grid.Row="1" Margin="12,0,12,12">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Command="{Binding EditSelectedCommand}"
                                Content="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                Visibility="{Binding CanEditSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="{loc:Translate ToolCmdLibBtnEdit}"
                                AutomationProperties.Name="{loc:Translate ToolCmdLibBtnEdit}"
                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                FontSize="14" MinWidth="28" Height="28"
                                Padding="4"
                                Margin="{StaticResource MarginInlineXs}" TabIndex="7"/>
                        <Button Command="{Binding DeleteSelectedCommand}"
                                Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                Visibility="{Binding CanEditSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="{loc:Translate ToolCmdLibBtnDelete}"
                                AutomationProperties.Name="{loc:Translate ToolCmdLibBtnDelete}"
                                Style="{DynamicResource ToolbarGhostButtonStyle}"
                                FontSize="14" MinWidth="28" Height="28"
                                Padding="4"
                                TabIndex="8"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="BtnCopy"
                                Command="{Binding CopyCommand}"
                                IsEnabled="{Binding IsCommandValid}"
                                Content="{loc:Translate ToolCmdLibBtnCopy}"
                                AutomationProperties.Name="{loc:Translate ToolCmdLibBtnCopy}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="{StaticResource MarginInlineSm}" TabIndex="5"/>
                        <Button x:Name="BtnSend"
                                Command="{Binding SendCommand}"
                                IsEnabled="{Binding IsSendEnabled}"
                                Visibility="{Binding IsSendVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Content="{loc:Translate ToolCmdLibBtnSend}"
                                AutomationProperties.Name="{loc:Translate ToolCmdLibBtnSend}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}"
                                FontSize="{StaticResource FontSizeBody}"
                                TabIndex="6"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ═══════════ ROW 6 — HISTORY PANEL ═══════════ -->
        <Border Grid.Row="6"
                Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                MaxHeight="300">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="12,8,12,4">
                    <Button DockPanel.Dock="Right"
                            Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                            Command="{Binding ClearHistoryCommand}"
                            ToolTip="{loc:Translate ToolCmdLibHistoryClear}"
                            AutomationProperties.Name="{loc:Translate ToolCmdLibHistoryClear}"
                            Style="{DynamicResource ToolbarGhostButtonStyle}"
                            FontSize="14" MinWidth="28" Height="28"
                            Padding="4"/>
                    <TextBlock Text="{loc:Translate ToolCmdLibHistoryTitle}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Translate ToolCmdLibCopied}"
                               Visibility="{Binding IsHistoryCopyFeedbackVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource SuccessTextBrush}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource MarginInlineControl}"/>
                </DockPanel>
                <ListView ItemsSource="{Binding HistoryEntries}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.CopyHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding GeneratedCommand}"/>
                                            </Border.InputBindings>
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SurfaceBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource CardBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                        Command="{Binding DataContext.CopyHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding GeneratedCommand}"
                                        ToolTip="{loc:Translate ToolCmdLibBtnCopy}"
                                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                                        FontSize="11" Width="22" Height="22"
                                        Padding="2" VerticalAlignment="Center"
                                        Margin="{StaticResource MarginInlineStart}" Focusable="False"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Timestamp}"
                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource MarginInlineControl}"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding ActionTitle}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <TextBlock Text="{Binding GeneratedCommand}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   TextWrapping="NoWrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock Text="{loc:Translate ToolCmdLibHistoryEmpty}"
                           Visibility="{Binding IsHistoryEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{StaticResource ToolEmptyStateTextStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,8,0,8"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
