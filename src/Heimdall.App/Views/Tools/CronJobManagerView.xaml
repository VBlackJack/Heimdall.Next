<UserControl x:Class="Heimdall.App.Views.Tools.CronJobManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="10"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="11"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Empty state hint (hidden once content is loaded) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE787;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar" Grid.Row="2"
                     Style="{StaticResource ToolLoadingBarStyle}"
                     VerticalAlignment="Top"/>

        <!-- Content -->
        <TabControl x:Name="ModeTabControl" Grid.Row="2"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Margin="0">

            <!-- Paste Crontab Mode -->
            <TabItem x:Name="TabPasteCrontab">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock x:Name="LblPasteInstructions" Grid.Row="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackItem}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Paste area -->
                    <TextBox x:Name="TxtCrontabInput" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TabIndex="0"/>

                    <!-- Parse button -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource MarginSubsectionTop}">
                        <Button x:Name="BtnParse" Content=""
                                Click="OnParseClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}"
                                TabIndex="1"/>
                        <Button x:Name="BtnClearPaste" Content=""
                                Click="OnClearPasteClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                                TabIndex="2"/>
                    </StackPanel>

                    <!-- Error message -->
                    <TextBlock x:Name="TxtCronError" Grid.Row="3" Text=""
                               Style="{StaticResource ToolInlineErrorTextStyle}"
                               Margin="{StaticResource MarginSubsectionTop}"/>

                    <!-- Parsed entries DataGrid -->
                    <Border x:Name="CronResultsPanel" Grid.Row="4"
                            Style="{StaticResource ToolResultsCardStyle}"
                            Margin="{StaticResource MarginSubsectionTop}"
                            Padding="0">
                        <DataGrid x:Name="CronResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.LiveSetting="Polite"
                                  TabIndex="3"
                                  SelectionChanged="OnCronEntrySelected">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColCronSchedule" Binding="{Binding Schedule}" Width="160"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronCommand" Binding="{Binding Command}" Width="*"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronNextRun" Binding="{Binding NextRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronDescription" Binding="{Binding Description}" Width="200"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Detail panel -->
                    <Border x:Name="CronDetailPanel" Grid.Row="5" Visibility="Collapsed"
                            Margin="{StaticResource MarginSubsectionTop}" Padding="{StaticResource PaddingAlertBanner}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                        <StackPanel>
                            <TextBlock x:Name="TxtDetailHeader" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="{StaticResource MarginLabelBottom}"/>
                            <TextBlock x:Name="TxtDetailSchedule" Text=""
                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtDetailCommand" Text=""
                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtDetailDescription" Text=""
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Windows Tasks Mode -->
            <TabItem x:Name="TabWindowsTasks">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls row -->
                    <DockPanel Grid.Row="0" Margin="{StaticResource MarginStackItem}">
                        <Button x:Name="BtnRefreshTasks" Content=""
                                Click="OnRefreshTasksClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Left"
                                TabIndex="4"/>
                        <TextBlock x:Name="TxtTasksLoading" Text="" Visibility="Collapsed"
                                   FontSize="{StaticResource FontSizeBody}" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Error message -->
                    <TextBlock x:Name="TxtTasksError" Grid.Row="1" Text=""
                               Style="{StaticResource ToolInlineErrorTextStyle}"
                               Margin="{StaticResource MarginStackItem}"/>

                    <!-- Windows Tasks DataGrid -->
                    <Border x:Name="TasksResultsPanel" Grid.Row="2"
                            Style="{StaticResource ToolResultsCardStyle}"
                            Padding="0">
                        <DataGrid x:Name="TasksResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.LiveSetting="Polite"
                                  TabIndex="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColTaskName" Binding="{Binding Name}" Width="*"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskStatus" Binding="{Binding Status}" Width="100"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskNextRun" Binding="{Binding NextRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastRun" Binding="{Binding LastRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastResult" Binding="{Binding LastResult}" Width="100"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopyAll" Content=""
                        Click="OnCopyAllClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        TabIndex="6"/>
                <TextBlock x:Name="TxtStatus" Text=""
                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
