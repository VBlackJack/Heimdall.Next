<UserControl x:Class="Heimdall.App.Views.Tools.CronJobManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <TabControl x:Name="ModeTabControl" Grid.Row="1"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Margin="0">

            <!-- Paste Crontab Mode -->
            <TabItem x:Name="TabPasteCrontab">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock x:Name="LblPasteInstructions" Grid.Row="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Paste area -->
                    <TextBox x:Name="TxtCrontabInput" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>

                    <!-- Parse button -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnParse" Content=""
                                Click="OnParseClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"/>
                        <Button x:Name="BtnClearPaste" Content=""
                                Click="OnClearPasteClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,6" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Error message -->
                    <TextBlock x:Name="TxtCronError" Grid.Row="3" Text="" Visibility="Collapsed"
                               FontSize="{StaticResource FontSizeBody}" Margin="0,8,0,0"
                               Foreground="{DynamicResource ErrorTextBrush}"/>

                    <!-- Parsed entries DataGrid -->
                    <Border Grid.Row="4" Margin="0,8,0,0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                        <DataGrid x:Name="CronResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  SelectionChanged="OnCronEntrySelected">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColCronSchedule" Binding="{Binding Schedule}" Width="160"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronCommand" Binding="{Binding Command}" Width="*"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronNextRun" Binding="{Binding NextRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronDescription" Binding="{Binding Description}" Width="200"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Detail panel -->
                    <Border x:Name="CronDetailPanel" Grid.Row="5" Visibility="Collapsed"
                            Margin="0,8,0,0" Padding="12,8"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                        <StackPanel>
                            <TextBlock x:Name="TxtDetailHeader" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtDetailSchedule" Text=""
                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtDetailCommand" Text=""
                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtDetailDescription" Text=""
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Windows Tasks Mode -->
            <TabItem x:Name="TabWindowsTasks">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls row -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="BtnRefreshTasks" Content=""
                                Click="OnRefreshTasksClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="TxtTasksLoading" Text="" Visibility="Collapsed"
                                   FontSize="{StaticResource FontSizeBody}" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Error message -->
                    <TextBlock x:Name="TxtTasksError" Grid.Row="1" Text="" Visibility="Collapsed"
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                               Foreground="{DynamicResource ErrorTextBrush}"/>

                    <!-- Windows Tasks DataGrid -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                        <DataGrid x:Name="TasksResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColTaskName" Binding="{Binding Name}" Width="250"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskStatus" Binding="{Binding Status}" Width="100"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskNextRun" Binding="{Binding NextRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastRun" Binding="{Binding LastRun}" Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastResult" Binding="{Binding LastResult}" Width="100"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopyAll" Content=""
                        Click="OnCopyAllClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" DockPanel.Dock="Right"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text=""
                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
