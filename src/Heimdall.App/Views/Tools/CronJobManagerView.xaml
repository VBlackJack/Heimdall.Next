<UserControl x:Class="Heimdall.App.Views.Tools.CronJobManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        Content="?"
                        Command="{Binding ToggleHelpCommand}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        TabIndex="10"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.AutomationId="CronJob.HelpButton"/>
                <TextBlock x:Name="HeaderTitle"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{loc:Translate ToolCronJobTitle}"/>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                       
                       
                        Content="&#xE711;"
                        Command="{Binding ToggleHelpCommand}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="11"
                        AutomationProperties.AutomationId="CronJob.CloseHelpButton"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"
                               Text="{Binding HelpText}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border x:Name="EmptyStatePanel"
                Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE787;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState"
                           Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <ProgressBar x:Name="LoadingBar"
                     Grid.Row="2"
                     Style="{StaticResource ToolLoadingBarStyle}"
                     VerticalAlignment="Top"/>

        <TabControl x:Name="ModeTabControl"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Margin="0"
                    SelectedIndex="{Binding ModeIndex, Mode=TwoWay}">
            <TabItem x:Name="TabPasteCrontab"
                     Header="{loc:Translate ToolCronJobTabPaste}">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="LblPasteInstructions"
                               Grid.Row="0"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="{StaticResource MarginStackItem}"
                               Text="{loc:Translate ToolCronJobPasteInstructions}"
                               TextWrapping="Wrap"/>

                    <TextBox x:Name="TxtCrontabInput"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             Background="{DynamicResource CardBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontFamily="Consolas"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="{StaticResource PaddingInput}"
                             TabIndex="0"
                             Text="{Binding CrontabInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalScrollBarVisibility="Auto"
                             AutomationProperties.AutomationId="CronJob.CrontabInput"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="{StaticResource MarginSubsectionTop}">
                        <Button x:Name="BtnParse"
                                Content="{loc:Translate ToolCronJobBtnParse}"
                                Command="{Binding ParseCommand}"
                                Padding="{StaticResource PaddingButtonPrimary}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                TabIndex="1"
                                AutomationProperties.AutomationId="CronJob.ParseButton"/>
                        <Button x:Name="BtnClearPaste"
                                Content="{loc:Translate ToolCronJobBtnClear}"
                                Command="{Binding ClearPasteCommand}"
                                Margin="{StaticResource MarginInlineControl}"
                                Padding="{StaticResource PaddingButtonPrimary}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                TabIndex="2"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtCronError"
                               Grid.Row="3"
                               Margin="{StaticResource MarginSubsectionTop}"
                               Style="{StaticResource ToolInlineErrorTextStyle}"
                               Text="{Binding CronErrorText}"
                               Visibility="{Binding HasCronError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border x:Name="CronResultsPanel"
                            Grid.Row="4"
                            Margin="{StaticResource MarginSubsectionTop}"
                            Padding="0"
                            Style="{StaticResource ToolResultsCardStyle}">
                        <DataGrid x:Name="CronResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.LiveSetting="Polite"
                                  TabIndex="3"
                                  ItemsSource="{Binding CronEntries}"
                                  SelectedItem="{Binding SelectedCronEntry, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColCronSchedule"
                                                    Binding="{Binding Schedule}"
                                                    Header="{loc:Translate ToolCronJobColSchedule}"
                                                    Width="160"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronCommand"
                                                    Binding="{Binding Command}"
                                                    Header="{loc:Translate ToolCronJobColCommand}"
                                                    Width="*"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronNextRun"
                                                    Binding="{Binding NextRun}"
                                                    Header="{loc:Translate ToolCronJobColNextRun}"
                                                    Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColCronDescription"
                                                    Binding="{Binding Description}"
                                                    Header="{loc:Translate ToolCronJobColDescription}"
                                                    Width="200"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border x:Name="CronDetailPanel"
                            Grid.Row="5"
                            Margin="{StaticResource MarginSubsectionTop}"
                            Padding="{StaticResource PaddingAlertBanner}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusSm}"
                            AutomationProperties.AutomationId="CronJob.DetailPanel"
                            Visibility="{Binding IsCronDetailVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock x:Name="TxtDetailHeader"
                                       Margin="{StaticResource MarginLabelBottom}"
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{Binding DetailHeaderText}"/>
                            <TextBlock x:Name="TxtDetailSchedule"
                                       Margin="0,0,0,2"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="{Binding DetailScheduleText}"/>
                            <TextBlock x:Name="TxtDetailCommand"
                                       Margin="0,0,0,2"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="{Binding DetailCommandText}"
                                       AutomationProperties.AutomationId="CronJob.DetailCommand"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtDetailDescription"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding DetailNextRunsText}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabWindowsTasks"
                     Header="{loc:Translate ToolCronJobTabWindows}">
                <Grid Margin="{StaticResource SpacingMd}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="{StaticResource MarginStackItem}">
                        <Button x:Name="BtnRefreshTasks"
                                Content="{loc:Translate ToolCronJobBtnRefresh}"
                                Command="{Binding RefreshTasksCommand}"
                                DockPanel.Dock="Left"
                                Padding="{StaticResource PaddingButtonPrimary}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                TabIndex="4"/>
                        <TextBlock x:Name="TxtTasksLoading"
                                   Margin="12,0,0,0"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding TasksLoadingText}"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </DockPanel>

                    <TextBlock x:Name="TxtTasksError"
                               Grid.Row="1"
                               Margin="{StaticResource MarginStackItem}"
                               Style="{StaticResource ToolInlineErrorTextStyle}"
                               Text="{Binding TasksErrorText}"
                               Visibility="{Binding HasTasksError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border x:Name="TasksResultsPanel"
                            Grid.Row="2"
                            Padding="0"
                            Style="{StaticResource ToolResultsCardStyle}">
                        <DataGrid x:Name="TasksResultsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.LiveSetting="Polite"
                                  TabIndex="5"
                                  ItemsSource="{Binding TaskEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColTaskName"
                                                    Binding="{Binding Name}"
                                                    Header="{loc:Translate ToolCronJobColTaskName}"
                                                    Width="*"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskStatus"
                                                    Binding="{Binding Status}"
                                                    Header="{loc:Translate ToolCronJobColTaskStatus}"
                                                    Width="100"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskNextRun"
                                                    Binding="{Binding NextRun}"
                                                    Header="{loc:Translate ToolCronJobColNextRun}"
                                                    Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastRun"
                                                    Binding="{Binding LastRun}"
                                                    Header="{loc:Translate ToolCronJobColLastRun}"
                                                    Width="180"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <DataGridTextColumn x:Name="ColTaskLastResult"
                                                    Binding="{Binding LastResult}"
                                                    Header="{loc:Translate ToolCronJobColLastResult}"
                                                    Width="100"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopyAll"
                        Content="{loc:Translate ToolCronJobBtnCopy}"
                        Command="{Binding CopyAllCommand}"
                        DockPanel.Dock="Right"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        ToolTip="{loc:Translate ToolBtnCopyToClipboard}"
                        VerticalAlignment="Center"
                        TabIndex="6"
                        AutomationProperties.AutomationId="CronJob.CopyAllButton"/>
                <TextBlock x:Name="TxtStatus"
                           FontFamily="Consolas"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           AutomationProperties.AutomationId="CronJob.StatusText"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
