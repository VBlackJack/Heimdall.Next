<UserControl x:Class="Heimdall.App.Views.Tools.CrontabBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Quick presets -->
                <TextBlock x:Name="LblPresets" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Margin="0,0,0,16">
                    <Button x:Name="BtnPresetEveryMin" Click="OnPresetClick" Tag="* * * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnPresetEveryHour" Click="OnPresetClick" Tag="0 * * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnPresetDailyMidnight" Click="OnPresetClick" Tag="0 0 * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnPresetWeekdays9am" Click="OnPresetClick" Tag="0 9 * * 1-5"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnPresetWeeklySunday" Click="OnPresetClick" Tag="0 0 * * 0"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnPresetMonthly1st" Click="OnPresetClick" Tag="0 0 1 * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,6,6" FontSize="{StaticResource FontSizeBody}"/>
                </WrapPanel>

                <!-- Selectors -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Minute -->
                    <TextBlock x:Name="LblMinute" Grid.Row="0" Grid.Column="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMinute" Grid.Row="0" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Hour -->
                    <TextBlock x:Name="LblHour" Grid.Row="2" Grid.Column="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbHour" Grid.Row="2" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Day of Month -->
                    <TextBlock x:Name="LblDayOfMonth" Grid.Row="4" Grid.Column="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbDayOfMonth" Grid.Row="4" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Month -->
                    <TextBlock x:Name="LblMonth" Grid.Row="6" Grid.Column="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMonth" Grid.Row="6" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Day of Week -->
                    <TextBlock x:Name="LblDayOfWeek" Grid.Row="8" Grid.Column="0" Text=""
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbDayOfWeek" Grid.Row="8" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />
                </Grid>

                <!-- Generated cron expression -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource SpacingMd}" Margin="0,0,0,8">
                    <DockPanel>
                        <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                                Click="OnCopyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                />
                        <TextBox x:Name="TxtCronExpression" Text="* * * * *"
                                 FontSize="{StaticResource FontSizeHeadline}" FontFamily="Consolas" FontWeight="Bold"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 />
                    </DockPanel>
                </Border>

                <!-- Human-readable description -->
                <TextBlock x:Name="TxtDescription" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" Margin="0,0,0,16"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>

                <!-- Manual edit -->
                <TextBlock x:Name="LblManualEdit" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtManualInput" Text=""
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="0,0,0,4"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="* * * * *"
                         TextChanged="OnManualInputChanged"
                         />
                <TextBlock x:Name="TxtValidationError" Text=""
                           FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <!-- Next executions -->
                <TextBlock x:Name="LblNextRuns" Text=""
                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="12,8">
                    <ItemsControl x:Name="NextRunsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
