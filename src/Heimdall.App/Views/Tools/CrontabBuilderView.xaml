<UserControl x:Class="Heimdall.App.Views.Tools.CrontabBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel MaxWidth="600">

                <!-- Quick presets -->
                <TextBlock x:Name="LblPresets" Text=""
                           FontSize="12" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Margin="0,0,0,16">
                    <Button x:Name="BtnPresetEveryMin" Click="OnPresetClick" Tag="* * * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                    <Button x:Name="BtnPresetEveryHour" Click="OnPresetClick" Tag="0 * * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                    <Button x:Name="BtnPresetDailyMidnight" Click="OnPresetClick" Tag="0 0 * * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                    <Button x:Name="BtnPresetWeekdays9am" Click="OnPresetClick" Tag="0 9 * * 1-5"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                    <Button x:Name="BtnPresetWeeklySunday" Click="OnPresetClick" Tag="0 0 * * 0"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                    <Button x:Name="BtnPresetMonthly1st" Click="OnPresetClick" Tag="0 0 1 * *"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,6" FontSize="12"/>
                </WrapPanel>

                <!-- Selectors -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Minute -->
                    <TextBlock x:Name="LblMinute" Grid.Row="0" Grid.Column="0" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMinute" Grid.Row="0" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Hour -->
                    <TextBlock x:Name="LblHour" Grid.Row="2" Grid.Column="0" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbHour" Grid.Row="2" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Day of Month -->
                    <TextBlock x:Name="LblDayOfMonth" Grid.Row="4" Grid.Column="0" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbDayOfMonth" Grid.Row="4" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Month -->
                    <TextBlock x:Name="LblMonth" Grid.Row="6" Grid.Column="0" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMonth" Grid.Row="6" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />

                    <!-- Day of Week -->
                    <TextBlock x:Name="LblDayOfWeek" Grid.Row="8" Grid.Column="0" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbDayOfWeek" Grid.Row="8" Grid.Column="1"
                              SelectionChanged="OnSelectorChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              />
                </Grid>

                <!-- Generated cron expression -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="12" Margin="0,0,0,8">
                    <DockPanel>
                        <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                                Click="OnCopyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="12,4" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                />
                        <TextBox x:Name="TxtCronExpression" Text="* * * * *"
                                 FontSize="22" FontFamily="Consolas" FontWeight="Bold"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 />
                    </DockPanel>
                </Border>

                <!-- Human-readable description -->
                <TextBlock x:Name="TxtDescription" Text=""
                           FontSize="13" Margin="0,0,0,16"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>

                <!-- Manual edit -->
                <TextBlock x:Name="LblManualEdit" Text=""
                           FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtManualInput" Text=""
                         FontSize="13" FontFamily="Consolas"
                         Padding="8,6" Margin="0,0,0,4"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TextChanged="OnManualInputChanged"
                         />
                <TextBlock x:Name="TxtValidationError" Text=""
                           FontSize="11" Margin="0,0,0,12"
                           FontWeight="SemiBold"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <!-- Next executions -->
                <TextBlock x:Name="LblNextRuns" Text=""
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="12,8">
                    <ItemsControl x:Name="NextRunsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
