<UserControl x:Class="Heimdall.App.Views.Tools.CveLookupView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:CveSeverityToBrushConverter x:Key="CveSeverityToBrush" />
        <conv:CveSearchStateToVisibilityConverter x:Key="CveStateToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                        Content="?"
                        Command="{Binding ToggleHelpCommand}"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        TabIndex="2"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}" />

                <TextBlock FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Text="{loc:Translate ToolCveTitle}" />

                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <TextBox x:Name="TxtInput"
                             MinWidth="200"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             FontFamily="Consolas"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             TabIndex="0"
                             Tag="{loc:Translate ToolCveInput}"
                             Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="{loc:Translate ToolCveInput}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return"
                                        Command="{Binding DataContext.SearchCommand, ElementName=Root}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button x:Name="BtnSearch"
                            Margin="{StaticResource MarginInlineControl}"
                            Padding="{StaticResource PaddingButtonPrimary}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{loc:Translate ToolCveBtnSearch}"
                            Command="{Binding SearchCommand}"
                            Content="{loc:Translate ToolCveBtnSearch}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            TabIndex="1" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                       
                       
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Content="&#xE711;"
                        Command="{Binding ToggleHelpCommand}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        ToolTip="{loc:Translate BtnClose}"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="{loc:Translate BtnClose}" />

                <ScrollViewer MaxHeight="200"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"
                               Text="{Binding HelpText}"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Border x:Name="EmptyStatePanel"
                    Visibility="{Binding State, Converter={StaticResource CveStateToVisibility}, ConverterParameter=Empty}"
                    Style="{StaticResource ToolEmptyStateStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;"
                               Focusable="False"
                               Style="{StaticResource ToolEmptyStateIconStyle}" />
                    <TextBlock Style="{StaticResource ToolEmptyStateTextStyle}"
                               Text="{loc:Translate ToolCveEmptyState}" />
                    <TextBlock Margin="{StaticResource MarginSubsectionTop}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               Text="{Binding DbInfoText}"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>

            <Border x:Name="NoResultsPanel"
                    Visibility="{Binding State, Converter={StaticResource CveStateToVisibility}, ConverterParameter=NoResults}"
                    Style="{StaticResource ToolEmptyStateStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;"
                               Focusable="False"
                               Foreground="{DynamicResource SuccessBrush}"
                               Style="{StaticResource ToolEmptyStateIconStyle}" />
                    <TextBlock Style="{StaticResource ToolEmptyStateTextStyle}"
                               Text="{loc:Translate ToolCveNoResults}" />
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="ResultsPanel"
                          Visibility="{Binding State, Converter={StaticResource CveStateToVisibility}, ConverterParameter=HasResults}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="{StaticResource ContentAreaMargin}">
                    <TextBlock Margin="0,8,0,12"
                               AutomationProperties.LiveSetting="Polite"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding SummaryText}" />

                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="{StaticResource MarginStackItem}"
                                        Padding="12,10"
                                        Background="{DynamicResource CardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusSm}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding CveId}"
                                                       VerticalAlignment="Center" />
                                            <Border Margin="{StaticResource MarginInlineControl}"
                                                    Padding="{StaticResource PaddingButtonHelp}"
                                                    Background="{Binding Severity, Converter={StaticResource CveSeverityToBrush}}"
                                                    CornerRadius="{StaticResource CornerRadiusXs}"
                                                    VerticalAlignment="Center">
                                                <TextBlock FontSize="{StaticResource FontSizeSmallCaption}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextOnAccentBrush}"
                                                           Text="{Binding SeverityLabel}" />
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Row="0"
                                                Grid.Column="1"
                                                Padding="{StaticResource PaddingButtonPreset}"
                                                Background="{Binding Severity, Converter={StaticResource CveSeverityToBrush}}"
                                                CornerRadius="{StaticResource CornerRadiusXs}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                                       Text="{Binding CvssLabel}" />
                                        </Border>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,4,0,0"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,4,0,0"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextDisabledBrush}">
                                            <Run Text="{Binding AffectedLabel, Mode=OneTime}" />
                                            <Run FontFamily="Consolas"
                                                 Text="{Binding AffectedVersions, Mode=OneTime}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="3"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy"
                        DockPanel.Dock="Right"
                        Padding="{StaticResource PaddingButtonCopy}"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="{loc:Translate ToolCveBtnCopy}"
                        Command="{Binding CopyCommand}"
                        Content="{loc:Translate ToolCveBtnCopy}"
                        Style="{DynamicResource SecondaryButtonStyle}" />
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding DbInfoText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
