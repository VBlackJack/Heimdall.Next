<UserControl x:Class="Heimdall.App.Views.Tools.DateTimeConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}"
                        AutomationProperties.LiveSetting="Polite">

                <!-- Input -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnNow" DockPanel.Dock="Right"
                            Content="" Click="OnNowClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtInput" Text=""
                             Style="{DynamicResource WatermarkTextBoxStyle}"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Tag="timestamp, ISO 8601, or date string"
                             TextChanged="OnInputTextChanged"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Detected format -->
                <TextBlock x:Name="TxtDetectedFormat" Text=""
                           FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginSectionSeparator}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Unix Timestamp -->
                <TextBlock x:Name="LblUnixTimestamp" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <Button x:Name="BtnCopyUnix" DockPanel.Dock="Right"
                            Content="" Click="OnCopyUnixClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtUnixTimestamp" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- ISO 8601 UTC -->
                <TextBlock x:Name="LblIsoUtc" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <Button x:Name="BtnCopyIsoUtc" DockPanel.Dock="Right"
                            Content="" Click="OnCopyIsoUtcClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtIsoUtc" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- ISO 8601 Local -->
                <TextBlock x:Name="LblIsoLocal" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <Button x:Name="BtnCopyIsoLocal" DockPanel.Dock="Right"
                            Content="" Click="OnCopyIsoLocalClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtIsoLocal" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Local time display -->
                <TextBlock x:Name="LblLocalTime" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <Button x:Name="BtnCopyLocalTime" DockPanel.Dock="Right"
                            Content="" Click="OnCopyLocalTimeClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtLocalTime" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Timezone converter -->
                <TextBlock x:Name="LblTimezone" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,4">
                    <Button x:Name="BtnCopyTzTime" DockPanel.Dock="Right"
                            Content="" Click="OnCopyTzTimeClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name=""/>
                    <ComboBox x:Name="CmbTimezone" MinWidth="200" MaxWidth="400"
                              VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,8,0"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              SelectionChanged="OnTimezoneChanged"
                              AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtTzTime" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Relative time -->
                <TextBlock x:Name="LblRelativeTime" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,12,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtRelativeTime" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
