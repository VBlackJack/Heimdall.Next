<UserControl x:Class="Heimdall.App.Views.Tools.DefaultCredentialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtHost" Text="" Width="200"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="hostname or IP"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="12,0,4,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbRouteVia" Width="180"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name=""/>
                    <Button x:Name="BtnScan" Content=""
                            Click="OnScanClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Options row -->
        <Border Grid.Row="1" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <CheckBox x:Name="ChkShowPasswords" DockPanel.Dock="Right"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="12,0,0,0"
                          Checked="OnShowPasswordsChanged" Unchecked="OnShowPasswordsChanged"
                          AutomationProperties.Name=""/>
                <CheckBox x:Name="ChkAutoDetect" IsChecked="True"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name=""/>
            </DockPanel>
        </Border>

        <!-- Warning banner (always visible) -->
        <Border Grid.Row="2" Padding="{StaticResource PaddingAlertBanner}" Margin="8,8,8,0"
                Background="{DynamicResource WarningBrush}"
                CornerRadius="{StaticResource CornerRadiusSm}">
            <DockPanel>
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeMedium}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource BackgroundBrush}"/>
                <TextBlock x:Name="TxtWarning" Text=""
                           FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap"
                           Foreground="{DynamicResource BackgroundBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Validation error + Progress -->
        <Grid Grid.Row="3">
            <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                       FontSize="{StaticResource FontSizeBody}" Margin="12,4,12,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource ErrorTextBrush}"/>
            <Grid x:Name="ProgressPanel" Visibility="Collapsed">
                <ProgressBar x:Name="ScanProgress"
                             Height="20" Minimum="0" Maximum="100"
                             IsIndeterminate="False"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtProgressStatus" Text=""
                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Empty state hint -->
        <Border x:Name="EmptyStatePanel" Grid.Row="4"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Results DataGrid -->
        <Border x:Name="ResultsBorder" Grid.Row="4" Margin="{StaticResource SpacingSm}" Visibility="Collapsed"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      AutomationProperties.Name=""
                      AutomationProperties.LiveSetting="Polite">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColService" Binding="{Binding Service}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColPort" Binding="{Binding Port}" Width="70"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColUser" Binding="{Binding Username}" Width="120"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColPass" Binding="{Binding DisplayPassword}" Width="120"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding StatusText}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColDetail" Binding="{Binding Detail}" Width="*"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer stats bar -->
        <Border Grid.Row="5" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnExportCsv" Content=""
                        Click="OnExportCsvClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right" Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtSummary" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
