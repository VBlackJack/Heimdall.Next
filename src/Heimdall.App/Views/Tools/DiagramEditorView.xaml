<UserControl x:Class="Heimdall.App.Views.Tools.DiagramEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with file operations -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?" Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"
                        AutomationProperties.Name=""/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HeaderTitle" Text="" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="BtnNew" Content="" Click="OnNewClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="16,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnOpen" Content="" Click="OnOpenClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnSave" Content="" Click="OnSaveClick"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnExportPng" Content="" Click="OnExportPngClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnInsertLine" Content="" Click="OnInsertLineClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="12,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnFormat" Content="" Click="OnFormatClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnUndo" Content="" Click="OnUndoClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="8,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnRedo" Content="" Click="OnRedoClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnZoomOut" Content="" Click="OnZoomOutClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnActualSize" Content="" Click="OnActualSizeClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnZoomIn" Content="" Click="OnZoomInClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnDuplicate" Content="" Click="OnDuplicateClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnDelete" Content="" Click="OnDeleteClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="{StaticResource PaddingButtonToolbar}" FontSize="{StaticResource FontSizeCaption}"
                            AutomationProperties.Name=""/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 hosting draw.io via iframe -->
        <wv2:WebView2 Grid.Row="1" x:Name="DiagramWebView" Focusable="True"/>

        <!-- Fallback if WebView2 unavailable -->
        <Border Grid.Row="1" x:Name="FallbackPanel" Visibility="Collapsed"
                Background="{DynamicResource BackgroundBrush}" Padding="28">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                <TextBlock x:Name="FallbackTitle" FontSize="{StaticResource FontSizeDisplay}" FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="FallbackMessage" FontSize="{StaticResource FontSizeBody}" Margin="0,12,0,0"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
