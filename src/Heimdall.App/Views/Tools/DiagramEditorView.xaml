<UserControl x:Class="Heimdall.App.Views.Tools.DiagramEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with file operations -->
        <Border Grid.Row="0" Padding="8,6" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?" Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="12" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HeaderTitle" Text="" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="BtnNew" Content="" Click="OnNewClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" Margin="16,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnOpen" Content="" Click="OnOpenClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnSave" Content="" Click="OnSaveClick"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnExportPng" Content="" Click="OnExportPngClick"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 hosting draw.io -->
        <Grid Grid.Row="1" ClipToBounds="True">
            <wv2:WebView2 x:Name="DiagramWebView" Focusable="True"/>

            <!-- Fallback if WebView2 unavailable -->
            <Border x:Name="FallbackPanel" Visibility="Collapsed"
                    Background="{DynamicResource BackgroundBrush}" Padding="28">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                    <TextBlock x:Name="FallbackTitle" FontSize="20" FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="FallbackMessage" FontSize="12" Margin="0,12,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
