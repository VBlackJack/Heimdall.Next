<UserControl x:Class="Heimdall.App.Views.Tools.DnsBatchResolverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Return" Modifiers="Control" Command="{Binding ResolveCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        Content="?"
                        Command="{Binding ToggleHelpCommand}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        TabIndex="4"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"/>
                <Button x:Name="BtnResolve"
                        DockPanel.Dock="Right"
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        VerticalAlignment="Center"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        TabIndex="1"/>
                <TextBlock x:Name="HeaderTitle"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{loc:Translate ToolDnsBatchTitle}"/>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                       
                       
                        Content="&#xE711;"
                        Command="{Binding ToggleHelpCommand}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        TabIndex="5"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="{loc:Translate BtnClose}"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"
                               Text="{Binding HelpText}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="{StaticResource SpacingLg}"
                Background="{DynamicResource BackgroundBrush}">
            <TextBox x:Name="TxtHostnames"
                     MinHeight="80"
                     MaxHeight="160"
                     AcceptsReturn="True"
                     AutomationProperties.Name="{loc:Translate ToolDnsBatchInputPlaceholder}"
                     Background="{DynamicResource CardBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     FontFamily="Consolas"
                     FontSize="{StaticResource FontSizeBody}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Padding="{StaticResource PaddingInput}"
                     Style="{StaticResource WatermarkTextBoxStyle}"
                     TabIndex="0"
                     Tag="{Binding InputPlaceholder}"
                     Text="{Binding HostnamesInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Border>

        <StackPanel Grid.Row="3">
            <TextBlock x:Name="TxtError"
                       Text="{Binding ErrorText}"
                       Style="{StaticResource ToolInlineErrorTextStyle}"
                       Visibility="{Binding ShowError, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ProgressBar x:Name="LoadingBar"
                         Style="{StaticResource ToolLoadingBarStyle}"/>
        </StackPanel>

        <Border x:Name="EmptyStatePanel"
                Grid.Row="4"
                Style="{StaticResource ToolEmptyStateStyle}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE774;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState"
                           Text="{Binding EmptyStateText}"
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <Border x:Name="ResultsPanel"
                Grid.Row="4"
                Margin="{StaticResource SpacingSm}"
                Padding="0"
                Style="{StaticResource ToolResultsCardStyle}">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      Background="Transparent"
                      BorderThickness="0"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="True"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      IsReadOnly="True"
                      ItemsSource="{Binding Results}"
                      RowBackground="Transparent"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      TabIndex="2"
                      AutomationProperties.LiveSetting="Polite">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColHostname"
                                        Binding="{Binding Hostname}"
                                        Header="{loc:Translate ToolDnsBatchColHostname}"
                                        Width="*"/>
                    <DataGridTextColumn x:Name="ColIpv4"
                                        Binding="{Binding Ipv4}"
                                        Header="{loc:Translate ToolDnsBatchColIpv4}"
                                        Width="140"/>
                    <DataGridTextColumn x:Name="ColIpv6"
                                        Binding="{Binding Ipv6}"
                                        Header="{loc:Translate ToolDnsBatchColIpv6}"
                                        Width="220"/>
                    <DataGridTextColumn x:Name="ColTime"
                                        Binding="{Binding ResolveTimeMs}"
                                        Header="{loc:Translate ToolDnsBatchColTime}"
                                        Width="80"/>
                    <DataGridTextColumn x:Name="ColStatus"
                                        Binding="{Binding Status}"
                                        Header="{loc:Translate ToolDnsBatchColStatus}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="5"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy"
                        DockPanel.Dock="Right"
                        Click="OnCopyClick"
                        Content="{loc:Translate ToolBtnCopyToClipboard}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}"
                        VerticalAlignment="Center"
                        TabIndex="3"
                        AutomationProperties.Name="{loc:Translate ToolBtnCopyToClipboard}"/>
                <TextBlock x:Name="TxtStatus"
                           FontFamily="Consolas"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
