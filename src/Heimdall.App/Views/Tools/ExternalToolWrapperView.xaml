<UserControl x:Class="Heimdall.App.Views.Tools.ExternalToolWrapperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="10"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="11"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Arguments bar -->
        <Border Grid.Row="2" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnRun" DockPanel.Dock="Right"
                        Content="" Click="OnRunClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                        VerticalAlignment="Stretch"
                        TabIndex="2"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnStop" DockPanel.Dock="Right"
                        Content="" Click="OnStopClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                        VerticalAlignment="Stretch" Visibility="Collapsed"
                        TabIndex="3"
                        AutomationProperties.Name=""/>
                <TextBox x:Name="TxtArguments"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}"
                         AutomationProperties.Name=""
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TabIndex="1"/>
            </DockPanel>
        </Border>

        <!-- Results area -->
        <Grid Grid.Row="3">
            <!-- Loading indicator -->
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="3"
                         VerticalAlignment="Top" Visibility="Collapsed"/>

            <!-- CSV DataGrid mode -->
            <DataGrid x:Name="ResultsGrid" Visibility="Collapsed"
                      AutoGenerateColumns="True" IsReadOnly="True"
                      CanUserSortColumns="True" CanUserReorderColumns="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      Background="{DynamicResource BackgroundBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      RowBackground="{DynamicResource BackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      FontSize="{StaticResource FontSizeBody}"
                      AutomationProperties.Name=""/>

            <!-- Text output mode -->
            <TextBox x:Name="TxtOutput"
                     FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                     Padding="{StaticResource PaddingInput}"
                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AutomationProperties.Name=""
                     AutomationProperties.LiveSetting="Polite"
                     Background="{DynamicResource BackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderThickness="0"/>

            <!-- Error display -->
            <TextBlock x:Name="TxtError" TextWrapping="Wrap" Visibility="Collapsed"
                       FontSize="{StaticResource FontSizeBody}" Margin="16"
                       Foreground="{DynamicResource ErrorBrush}"/>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="4" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                        Content="" Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="4"
                        AutomationProperties.Name=""/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtProviderBadge" Text=""
                               FontSize="{StaticResource FontSizeSmallCaption}" FontWeight="SemiBold"
                               Padding="6,2" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Background="{DynamicResource ToolExternalBrush}"/>
                    <TextBlock x:Name="TxtStatus" Text=""
                               FontSize="{StaticResource FontSizeSmallCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtExePath" Text=""
                               FontSize="{StaticResource FontSizeSmallCaption}"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
