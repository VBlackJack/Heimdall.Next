<UserControl x:Class="Heimdall.App.Views.Tools.HackerSimulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar — dark hacker aesthetic (double-click terminal to toggle) -->
        <Border x:Name="ToolbarBorder" Grid.Row="0" Padding="{StaticResource PaddingInput}"
                Background="{DynamicResource HackerSimToolbarBrush}" BorderBrush="{DynamicResource HackerSimBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <WrapPanel VerticalAlignment="Center" ItemHeight="28">
                    <TextBlock x:Name="LblScenario"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <ComboBox x:Name="CmbScenario"
                              Width="260" Margin="0,0,8,0"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Background="{DynamicResource HackerSimSurfaceBrush}" Foreground="{DynamicResource HackerSimTextPrimaryBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                              DisplayMemberPath="Display"
                              SelectionChanged="OnScenarioSelectionChanged"
                              AutomationProperties.Name=""/>

                    <Button x:Name="BtnFavorite"
                            Click="OnFavoriteClick"
                            FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{DynamicResource HackerSimButtonForegroundBrush}" Background="{DynamicResource HackerSimButtonBackgroundBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                            Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,12,0" Cursor="Hand"
                            AutomationProperties.Name=""/>

                    <CheckBox x:Name="ChkRandomMode"
                              Click="OnRandomModeClick"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Foreground="{DynamicResource HackerSimHighlightBrush}" VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblSearch"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <TextBox x:Name="TxtScenarioSearch"
                             Width="180" Margin="0,0,12,0"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                             Background="{DynamicResource HackerSimSurfaceBrush}" Foreground="{DynamicResource HackerSimTextPrimaryBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                             TextChanged="OnScenarioSearchChanged"
                             AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblCategory"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <ComboBox x:Name="CmbCategory"
                              Width="135" Margin="0,0,12,0"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Background="{DynamicResource HackerSimSurfaceBrush}" Foreground="{DynamicResource HackerSimTextPrimaryBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                              DisplayMemberPath="Display"
                              SelectionChanged="OnScenarioFilterChanged"
                              AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblRealism"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <ComboBox x:Name="CmbRealism"
                              Width="135" Margin="0,0,12,0"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Background="{DynamicResource HackerSimSurfaceBrush}" Foreground="{DynamicResource HackerSimTextPrimaryBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                              DisplayMemberPath="Display"
                              SelectionChanged="OnScenarioFilterChanged"
                              AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblSpeed"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,4,0"/>

                    <Slider x:Name="SliderSpeed"
                            Width="100" Minimum="0.25" Maximum="3.0" Value="1.0"
                            TickFrequency="0.25" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ValueChanged="OnSpeedChanged"
                            AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblSpeedValue"
                               Text="1.00x" FontFamily="Consolas"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimAccentBrush}" VerticalAlignment="Center"
                               Margin="4,0,0,0" MinWidth="34"/>

                    <Button x:Name="BtnStartStop"
                            Click="OnStartStopClick"
                            FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                            Foreground="{DynamicResource HackerSimAccentBrush}" Background="{DynamicResource HackerSimButtonBackgroundBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="12,0,0,0" Cursor="Hand"
                            AutomationProperties.Name=""/>
                </WrapPanel>

                <TextBlock x:Name="LblCurrentScenario"
                           FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource HackerSimAccentBrush}" VerticalAlignment="Center"
                           Margin="2,6,0,0"/>

                <TextBlock x:Name="LblScenarioSubtitle"
                           FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource HackerSimTextSecondaryBrush}" VerticalAlignment="Center"
                           Margin="2,2,0,0"
                           TextWrapping="Wrap"/>

                <WrapPanel VerticalAlignment="Center" ItemHeight="28" Margin="0,8,0,0">
                    <TextBlock x:Name="LblPlaylist"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <ComboBox x:Name="CmbPlaylist"
                              Width="220" Margin="0,0,12,0"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Background="{DynamicResource HackerSimSurfaceBrush}" Foreground="{DynamicResource HackerSimTextPrimaryBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                              DisplayMemberPath="Display"
                              SelectionChanged="OnPlaylistSelectionChanged"
                              AutomationProperties.Name=""/>

                    <Button x:Name="BtnReplaySeed"
                            Click="OnReplaySeedClick"
                            FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{DynamicResource HackerSimTextPrimaryBrush}" Background="{DynamicResource HackerSimButtonBackgroundBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                            Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,8,0" Cursor="Hand"
                            AutomationProperties.Name=""/>

                    <Button x:Name="BtnExportTranscript"
                            Click="OnExportTranscriptClick"
                            FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{DynamicResource HackerSimTextPrimaryBrush}" Background="{DynamicResource HackerSimButtonBackgroundBrush}" BorderBrush="{DynamicResource HackerSimInputBorderBrush}"
                            Padding="{StaticResource PaddingButtonToolbar}" Margin="0,0,12,0" Cursor="Hand"
                            AutomationProperties.Name=""/>

                    <CheckBox x:Name="ChkVintageMonitor"
                              Click="OnVintageMonitorClick"
                              FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                              Foreground="{DynamicResource HackerSimTextSecondaryBrush}" VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              AutomationProperties.Name=""/>

                    <TextBlock x:Name="LblSeed"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimTextMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <TextBlock x:Name="LblSeedValue"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource HackerSimAccentBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Terminal area -->
        <Grid x:Name="TerminalGrid" Grid.Row="1" Background="Black" ClipToBounds="True">
            <Canvas x:Name="MatrixCanvas" Visibility="Collapsed"
                    ClipToBounds="True" SizeChanged="OnMatrixCanvasSizeChanged"/>

            <Border x:Name="TerminalBorder" Visibility="Visible">
                <ScrollViewer x:Name="TerminalScroller"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <TextBlock x:Name="TerminalOutput"
                               FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource HackerSimAccentBrush}" Padding="{StaticResource PaddingAlertBanner}"
                               TextWrapping="Wrap">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="3"
                                              ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </ScrollViewer>
            </Border>

            <Grid x:Name="VintageOverlay" Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.16">
                <Rectangle>
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,4,4" ViewportUnits="Absolute"
                                      Viewbox="0,0,4,4" ViewboxUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="{DynamicResource HackerSimOverlayBrush}" Geometry="M 0,0 L 4,0 4,1 0,1 Z"/>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Border Background="{DynamicResource HackerSimGlowBrush}"/>
                <Border BorderBrush="{DynamicResource HackerSimGlowStrongBrush}" BorderThickness="1"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
