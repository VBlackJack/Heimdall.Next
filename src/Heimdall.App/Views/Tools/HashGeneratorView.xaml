<UserControl x:Class="Heimdall.App.Views.Tools.HashGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel MaxWidth="700">

                <!-- Input text -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         FontSize="13" FontFamily="Consolas"
                         Padding="8,6" Height="120"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TextChanged="OnInputTextChanged"
                         />

                <!-- File hash zone -->
                <Border x:Name="DropZoneBorder" Margin="0,12,0,0" Padding="12,8"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
                        DragEnter="OnDragEnter" DragLeave="OnDragLeave">
                    <DockPanel>
                        <Button x:Name="BtnBrowseFile" DockPanel.Dock="Right"
                                Click="OnBrowseFileClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="12,6" Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFileDropZone"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                </Border>

                <!-- File hash progress bar -->
                <ProgressBar x:Name="FileHashProgress" Height="4"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             Margin="0,4,0,0"/>

                <!-- File hash status -->
                <DockPanel Margin="0,4,0,0">
                    <Button x:Name="BtnClearFile" DockPanel.Dock="Right"
                            Content="" Click="OnClearFileClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="8,0,0,0"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtFileStatus" Text=""
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- All hash results -->
                <TextBlock x:Name="LblResults" Text=""
                           FontSize="12" Margin="0,16,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="12,8" Margin="0,0,0,8">
                    <StackPanel x:Name="HashResultsPanel" />
                </Border>

                <!-- Byte length indicator -->
                <TextBlock x:Name="TxtByteLength" Text=""
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Verify field -->
                <TextBlock x:Name="LblVerify" Text=""
                           FontSize="12" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtVerify" Text=""
                         FontSize="13" FontFamily="Consolas"
                         Padding="8,6" Margin="0,0,0,4"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TextChanged="OnVerifyTextChanged"
                         />
                <TextBlock x:Name="TxtVerifyResult" Text=""
                           FontSize="12" Margin="0,0,0,8"
                           FontWeight="SemiBold"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
