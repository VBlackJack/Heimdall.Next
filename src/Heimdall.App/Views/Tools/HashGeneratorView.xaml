<UserControl x:Class="Heimdall.App.Views.Tools.HashGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="4"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Input text -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         TabIndex="0"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Height="120"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag=""
                         TextChanged="OnInputTextChanged"/>

                <!-- File hash zone -->
                <Border x:Name="DropZoneBorder" Margin="{StaticResource MarginSectionTop}" Padding="{StaticResource PaddingAlertBanner}"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
                        DragEnter="OnDragEnter" DragLeave="OnDragLeave">
                    <DockPanel>
                        <Button x:Name="BtnBrowseFile" DockPanel.Dock="Right"
                                TabIndex="1"
                                Click="OnBrowseFileClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFileDropZone"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                </Border>

                <!-- File hash progress bar -->
                <ProgressBar x:Name="FileHashProgress" Style="{StaticResource ToolLoadingBarStyle}"
                             Background="{DynamicResource SurfaceBrush}"
                             Margin="0,4,0,0"/>

                <!-- File hash status -->
                <DockPanel Margin="0,4,0,0">
                    <Button x:Name="BtnClearFile" DockPanel.Dock="Right"
                            TabIndex="2"
                            Content="" Click="OnClearFileClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtFileStatus" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Empty state -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D7;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <!-- All hash results -->
                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">
                    <TextBlock x:Name="LblResults" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,8"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingAlertBanner}" Margin="0,0,0,8">
                        <StackPanel x:Name="HashResultsPanel"
                                    AutomationProperties.LiveSetting="Polite"/>
                    </Border>

                    <!-- Byte length indicator -->
                    <TextBlock x:Name="TxtByteLength" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Verify field -->
                <TextBlock x:Name="LblVerify" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtVerify" Text=""
                         TabIndex="3"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="0,0,0,4"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag=""
                         TextChanged="OnVerifyTextChanged"/>
                <TextBlock x:Name="TxtVerifyResult" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                           FontWeight="SemiBold"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
