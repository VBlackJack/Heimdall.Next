<UserControl x:Class="Heimdall.App.Views.Tools.HmacGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Algorithm selector -->
                <TextBlock x:Name="LblAlgorithm" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CmbAlgorithm"
                          Margin="0,0,0,16"
                          Padding="8,6" FontSize="{StaticResource FontSizeBodyLarge}"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          SelectionChanged="OnAlgorithmChanged"
                          />

                <!-- Secret key with show/hide toggle -->
                <TextBlock x:Name="LblKey" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,16">
                    <Button x:Name="BtnToggleKey" DockPanel.Dock="Right"
                            Content="&#xE7B3;"
                            FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSubtitle}"
                            Click="OnToggleKeyVisibility"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,6" Margin="6,0,0,0"
                            AutomationProperties.Name="Toggle key visibility"
                            VerticalAlignment="Stretch"/>
                    <Grid>
                        <PasswordBox x:Name="PwdKey"
                                     FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                     Padding="8,6"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     PasswordChanged="OnKeyPasswordChanged"
                                     />
                        <TextBox x:Name="TxtKey" Text=""
                                 Style="{DynamicResource WatermarkTextBoxStyle}"
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="8,6"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Tag="secret key"
                                 TextChanged="OnInputChanged"
                                 Visibility="Collapsed"
                                 />
                    </Grid>
                </DockPanel>

                <!-- Input message -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="8,6" Height="120"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="message"
                         TextChanged="OnInputChanged"
                         />

                <!-- Output format toggle -->
                <TextBlock x:Name="LblFormat" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RdoHex" Content="Hex" IsChecked="True"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,0"
                                 Checked="OnFormatChanged"
                                 />
                    <RadioButton x:Name="RdoBase64" Content="Base64"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Checked="OnFormatChanged"
                                 />
                </StackPanel>

                <!-- Output -->
                <TextBlock x:Name="LblOutput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                            Content="" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="12,6" Margin="8,0,0,0"
                            VerticalAlignment="Stretch"/>
                    <TextBox x:Name="TxtOutput" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="8,6"
                             IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             />
                </DockPanel>

                <!-- Byte length indicator -->
                <TextBlock x:Name="TxtByteLength" Text=""
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Verify field -->
                <TextBlock x:Name="LblVerify" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtVerify" Text=""
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="8,6" Margin="0,0,0,4"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="paste HMAC to verify"
                         TextChanged="OnVerifyTextChanged"
                         />
                <TextBlock x:Name="TxtVerifyResult" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                           FontWeight="SemiBold"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
