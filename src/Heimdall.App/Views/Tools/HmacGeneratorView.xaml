<UserControl x:Class="Heimdall.App.Views.Tools.HmacGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="8"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Algorithm selector -->
                <TextBlock x:Name="LblAlgorithm" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CmbAlgorithm"
                          TabIndex="0"
                          Margin="{StaticResource MarginSectionSeparator}"
                          Padding="{StaticResource PaddingInput}" FontSize="{StaticResource FontSizeBodyLarge}"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          SelectionChanged="OnAlgorithmChanged"/>

                <!-- Secret key with show/hide toggle -->
                <TextBlock x:Name="LblKey" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionSeparator}">
                    <Button x:Name="BtnToggleKey" DockPanel.Dock="Right"
                            TabIndex="2"
                            Content="&#xE7B3;"
                            FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSubtitle}"
                            Click="OnToggleKeyVisibility"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingInput}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"/>
                    <Grid>
                        <PasswordBox x:Name="PwdKey"
                                     TabIndex="1"
                                     FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                     Padding="{StaticResource PaddingInput}"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     PasswordChanged="OnKeyPasswordChanged"/>
                        <TextBox x:Name="TxtKey" Text=""
                                 TabIndex="1"
                                 Style="{DynamicResource WatermarkTextBoxStyle}"
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Tag=""
                                 TextChanged="OnInputChanged"
                                 Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>

                <!-- Input message -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         TabIndex="3"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Height="120"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag=""
                         TextChanged="OnInputChanged"/>

                <!-- Output format toggle -->
                <TextBlock x:Name="LblFormat" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginSectionBottom}">
                    <RadioButton x:Name="RdoHex" Content="" IsChecked="True"
                                 TabIndex="4"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,0"
                                 Checked="OnFormatChanged"/>
                    <RadioButton x:Name="RdoBase64" Content=""
                                 TabIndex="5"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Checked="OnFormatChanged"/>
                </StackPanel>

                <!-- Empty state -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                       >
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D7;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Output -->
                <TextBlock x:Name="LblOutput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                            TabIndex="6"
                            Content="" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"/>
                    <TextBox x:Name="TxtOutput" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             IsReadOnly="True"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.LiveSetting="Polite"/>
                </DockPanel>

                <!-- Byte length indicator -->
                <TextBlock x:Name="TxtByteLength" Text=""
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Verify field -->
                <TextBlock x:Name="LblVerify" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtVerify" Text=""
                         TabIndex="7"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="{StaticResource MarginLabelBottom}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag=""
                         TextChanged="OnVerifyTextChanged"/>
                <TextBlock x:Name="TxtVerifyResult" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackItem}"
                           FontWeight="SemiBold"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
