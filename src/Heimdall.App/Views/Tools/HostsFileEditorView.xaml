<UserControl x:Class="Heimdall.App.Views.Tools.HostsFileEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="6"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnReload" Click="OnReloadClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginLabelInline}" FontSize="{StaticResource FontSizeBody}"
                            VerticalAlignment="Center"
                            TabIndex="1"/>
                    <Button x:Name="BtnSave" Click="OnSaveClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" FontSize="{StaticResource FontSizeBody}"
                            VerticalAlignment="Center"
                            TabIndex="2"/>
                </StackPanel>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="7"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Empty state hint (hidden once entries are loaded) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8A5;" Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="HostsGrid" Grid.Row="2"
                  TabIndex="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  RowBackground="{DynamicResource CardBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  Margin="0"
                  CellEditEnding="OnCellEditEnding">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn x:Name="ColEnabled" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn x:Name="ColIpAddress" Binding="{Binding IpAddress, UpdateSourceTrigger=LostFocus}" Width="180"
                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                <DataGridTextColumn x:Name="ColHostname" Binding="{Binding Hostname, UpdateSourceTrigger=LostFocus}" Width="*"
                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                <DataGridTextColumn x:Name="ColComment" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Width="200"
                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="ErrorText" Grid.Row="3"
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="{StaticResource SpacingMd}"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{StaticResource SpacingMd}">
            <Button x:Name="BtnAddEntry" Click="OnAddEntryClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginLabelInline}" FontSize="{StaticResource FontSizeBody}"
                    TabIndex="3"/>
            <Button x:Name="BtnDeleteSelected" Click="OnDeleteSelectedClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" FontSize="{StaticResource FontSizeBody}"
                    TabIndex="4"/>
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="5" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtLastModified" DockPanel.Dock="Right"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtFilePath"
                           FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
