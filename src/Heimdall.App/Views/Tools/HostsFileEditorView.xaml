<UserControl x:Class="Heimdall.App.Views.Tools.HostsFileEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnReload" Click="OnReloadClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="0,0,6,0" FontSize="{StaticResource FontSizeBody}"
                            VerticalAlignment="Center"/>
                    <Button x:Name="BtnSave" Click="OnSaveClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="10,4" FontSize="{StaticResource FontSizeBody}"
                            VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="HostsGrid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  RowBackground="{DynamicResource CardBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  Margin="0"
                  CellEditEnding="OnCellEditEnding">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn x:Name="ColEnabled" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn x:Name="ColIpAddress" Binding="{Binding IpAddress, UpdateSourceTrigger=LostFocus}" Width="180"
                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                <DataGridTextColumn x:Name="ColHostname" Binding="{Binding Hostname, UpdateSourceTrigger=LostFocus}" Width="*"
                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                <DataGridTextColumn x:Name="ColComment" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Width="200"
                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,8">
            <Button x:Name="BtnAddEntry" Click="OnAddEntryClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="10,4" Margin="0,0,6,0" FontSize="{StaticResource FontSizeBody}"/>
            <Button x:Name="BtnDeleteSelected" Click="OnDeleteSelectedClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="10,4" FontSize="{StaticResource FontSizeBody}"/>
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtLastModified" DockPanel.Dock="Right"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtFilePath"
                           FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
