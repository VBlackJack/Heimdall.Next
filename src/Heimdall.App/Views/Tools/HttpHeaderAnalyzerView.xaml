<UserControl x:Class="Heimdall.App.Views.Tools.HttpHeaderAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:HeaderStatusToBrushConverter x:Key="HeaderStatusToBrushConverter"/>
        <conv:HeaderStatusToIconConverter x:Key="HeaderStatusToIconConverter"/>
        <conv:HeaderStatusToTextConverter x:Key="HeaderStatusToTextConverter"/>
        <conv:HttpGradeToBrushConverter x:Key="HttpGradeToBrushConverter"/>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        Width="24"
                        Height="24"
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        Content="?"
                        Click="OnHelpClick"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        TabIndex="5"/>
                <TextBlock x:Name="HeaderTitle"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        Width="24"
                        Height="24"
                        Content="&#xE711;"
                        Click="OnCloseHelpClick"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        TabIndex="6"
                        VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      Padding="{StaticResource SpacingLg}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">
                <TextBlock x:Name="LblUrl"
                           Margin="{StaticResource MarginLabelBottom}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <Button x:Name="BtnCheck"
                            DockPanel.Dock="Right"
                            Margin="{StaticResource MarginInlineControl}"
                            Padding="{StaticResource PaddingButtonPrimary}"
                            Click="OnCheckClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            TabIndex="0"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtUrl"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontFamily="Consolas"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             TabIndex="1"
                             Tag=""
                             Text="{Binding UrlInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                </DockPanel>

                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <TextBlock x:Name="LblRouteVia"
                               Margin="{StaticResource MarginInlineSm}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbRouteVia"
                              Width="240"
                              Background="{DynamicResource CardBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              SelectionChanged="OnRouteViaChanged"
                              TabIndex="2"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock x:Name="TxtError"
                           Style="{StaticResource ToolInlineErrorTextStyle}"/>

                <ProgressBar x:Name="LoadingBar"
                             Style="{StaticResource ToolLoadingBarStyle}"/>

                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE774;"
                                   Focusable="False"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"/>
                        <TextBlock x:Name="TxtEmptyState"
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">
                    <Border x:Name="GradeBanner"
                            Margin="{StaticResource MarginSectionBottom}"
                            Padding="16,10"
                            HorizontalAlignment="Left"
                            Background="{Binding Grade, Converter={StaticResource HttpGradeToBrushConverter}}"
                            CornerRadius="{StaticResource CornerRadiusSm}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtGradeLabel"
                                       Margin="{StaticResource MarginInlineSm}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"/>
                            <TextBlock x:Name="TxtGrade"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeHeadline}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                       Text="{Binding GradeText}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="TxtSecuritySection"
                               Margin="{StaticResource MarginStackItem}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Border Margin="{StaticResource MarginSectionBottom}"
                            Padding="{StaticResource PaddingSectionCard}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusSm}">
                        <ItemsControl x:Name="SecurityHeadersList"
                                      ItemsSource="{Binding SecurityHeaders}"
                                      AutomationProperties.LiveSetting="Polite">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Width="24"
                                                   VerticalAlignment="Top"
                                                   AutomationProperties.Name="{Binding Status, Converter={StaticResource HeaderStatusToTextConverter}}"
                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Status, Converter={StaticResource HeaderStatusToBrushConverter}}"
                                                   Text="{Binding Status, Converter={StaticResource HeaderStatusToIconConverter}}"/>
                                        <StackPanel>
                                            <TextBlock FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding DisplayName}"/>
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding DisplayValue}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       Text="{Binding Recommendation}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding Recommendation, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock x:Name="TxtDisclosureSection"
                               Margin="{StaticResource MarginStackItem}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Border Margin="{StaticResource MarginSectionBottom}"
                            Padding="{StaticResource PaddingSectionCard}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusSm}">
                        <ItemsControl x:Name="DisclosureHeadersList"
                                      ItemsSource="{Binding DisclosureHeaders}"
                                      AutomationProperties.LiveSetting="Polite">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Width="24"
                                                   VerticalAlignment="Top"
                                                   AutomationProperties.Name="{Binding Status, Converter={StaticResource HeaderStatusToTextConverter}}"
                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Status, Converter={StaticResource HeaderStatusToBrushConverter}}"
                                                   Text="{Binding Status, Converter={StaticResource HeaderStatusToIconConverter}}"/>
                                        <StackPanel>
                                            <TextBlock FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding DisplayName}"/>
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding DisplayValue}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       Text="{Binding Recommendation}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding Recommendation, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Expander x:Name="RawHeadersExpander"
                              Margin="{StaticResource MarginSectionBottom}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="{StaticResource FontSizeBody}"
                              IsExpanded="False">
                        <Border Margin="0,4,0,0"
                                Padding="{StaticResource PaddingSectionCard}"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusSm}">
                            <TextBox x:Name="TxtRawHeaders"
                                     MaxHeight="300"
                                     AcceptsReturn="True"
                                     AutomationProperties.LiveSetting="Polite"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     IsReadOnly="True"
                                     TabIndex="3"
                                     Text="{Binding RawResponse}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </Expander>

                    <Button x:Name="BtnCopyReport"
                            HorizontalAlignment="Left"
                            Click="OnCopyReportClick"
                            IsEnabled="{Binding HasResults}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            TabIndex="4"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatus"
                       FontFamily="Consolas"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
