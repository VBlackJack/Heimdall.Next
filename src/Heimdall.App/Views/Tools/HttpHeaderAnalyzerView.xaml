<UserControl x:Class="Heimdall.App.Views.Tools.HttpHeaderAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Input Row -->
                <TextBlock x:Name="LblUrl" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnCheck" DockPanel.Dock="Right"
                            Content="" Click="OnCheckClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtUrl" Text=""
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Route via gateway -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRouteVia" Width="240"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text=""
                           Style="{StaticResource ToolInlineErrorTextStyle}"/>

                <!-- Loading indicator -->
                <ProgressBar x:Name="LoadingBar"
                             Style="{StaticResource ToolLoadingBarStyle}"
                             AutomationProperties.Name=""/>

                <!-- Empty state hint -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE774;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   AutomationProperties.Name=""/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Results -->
                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                    <!-- Grade badge -->
                    <Border x:Name="GradeBanner"
                            CornerRadius="{StaticResource CornerRadiusSm}" Padding="16,10" Margin="{StaticResource MarginSectionBottom}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtGradeLabel" Text=""
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtGrade" Text=""
                                       FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Security Headers section -->
                    <TextBlock x:Name="TxtSecuritySection" Text=""
                               FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginSectionBottom}">
                        <ItemsControl x:Name="SecurityHeadersList"
                                      AutomationProperties.LiveSetting="Polite">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="{Binding StatusIcon}" DockPanel.Dock="Left"
                                                   FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="Bold"
                                                   Foreground="{Binding StatusBrush}" Width="24"
                                                   VerticalAlignment="Top"
                                                   AutomationProperties.Name="{Binding Status}"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Recommendation}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding RecommendationVisibility}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Information Disclosure section -->
                    <TextBlock x:Name="TxtDisclosureSection" Text=""
                               FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginSectionBottom}">
                        <ItemsControl x:Name="DisclosureHeadersList"
                                      AutomationProperties.LiveSetting="Polite">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="{Binding StatusIcon}" DockPanel.Dock="Left"
                                                   FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="Bold"
                                                   Foreground="{Binding StatusBrush}" Width="24"
                                                   VerticalAlignment="Top"
                                                   AutomationProperties.Name="{Binding Status}"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Recommendation}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextDisabledBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding RecommendationVisibility}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Raw Headers (collapsible) -->
                    <Expander x:Name="RawHeadersExpander" IsExpanded="False"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginSectionBottom}"
                              AutomationProperties.Name="">
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                                Padding="{StaticResource PaddingSectionCard}" Margin="0,4,0,0">
                            <TextBox x:Name="TxtRawHeaders" Text=""
                                     FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MaxHeight="300"
                                     AutomationProperties.Name=""
                                     AutomationProperties.LiveSetting="Polite"/>
                        </Border>
                    </Expander>

                    <!-- Copy button -->
                    <Button x:Name="BtnCopyReport" Click="OnCopyReportClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name=""/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatus" Text=""
                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
