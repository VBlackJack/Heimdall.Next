<UserControl x:Class="Heimdall.App.Views.Tools.JsonFormatterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Tools"
             d:DataContext="{d:DesignInstance Type=vm:JsonFormatterViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="JsonFormatter.HelpButton"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        Content="?"
                        Click="OnHelpClick"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold" />
                <TextBlock Text="{loc:Translate ToolJsonTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                AutomationProperties.AutomationId="JsonFormatter.HelpPanel"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="JsonFormatter.CloseHelpButton"
                       
                       
                        Content="&#xE711;"
                        Click="OnCloseHelpClick"
                        AutomationProperties.Name="{loc:Translate BtnClose}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        VerticalAlignment="Top" />
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               Text=""
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{loc:Translate ToolJsonInputLabel}"
                           Grid.Row="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}"
                           Margin="{StaticResource MarginLabelBottom}" />
                <TextBox x:Name="InputText"
                         AutomationProperties.AutomationId="JsonFormatter.InputField"
                         Grid.Row="1"
                         TabIndex="0"
                         Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="{StaticResource PaddingInput}"
                         Tag="{loc:Translate ToolWatermarkPasteJson}"
                         AutomationProperties.Name="{loc:Translate ToolJsonInputLabel}" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,8">
                <Button x:Name="BtnPrettify"
                        AutomationProperties.AutomationId="JsonFormatter.PrettifyButton"
                        Content="{loc:Translate ToolJsonBtnPrettify}"
                        Command="{Binding PrettifyCommand}"
                        TabIndex="1"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        Margin="{StaticResource MarginInlineSm}"
                        AutomationProperties.Name="{loc:Translate ToolJsonBtnPrettify}" />
                <Button x:Name="BtnMinify"
                        AutomationProperties.AutomationId="JsonFormatter.MinifyButton"
                        Content="{loc:Translate ToolJsonBtnMinify}"
                        Command="{Binding MinifyCommand}"
                        TabIndex="2"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name="{loc:Translate ToolJsonBtnMinify}" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{loc:Translate ToolJsonOutputLabel}"
                           Grid.Row="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}"
                           Margin="{StaticResource MarginLabelBottom}" />

                <Border x:Name="EmptyStatePanel"
                        AutomationProperties.AutomationId="JsonFormatter.EmptyStatePanel"
                        Grid.Row="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ToolEmptyStateStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmptyState}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE943;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False" />
                        <TextBlock Text="{loc:Translate ToolJsonEmptyState}"
                                   Style="{StaticResource ToolEmptyStateTextStyle}" />
                    </StackPanel>
                </Border>

                <Border x:Name="ResultsPanel"
                        AutomationProperties.AutomationId="JsonFormatter.ResultsPanel"
                        Grid.Row="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResult}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBox x:Name="OutputText"
                             AutomationProperties.AutomationId="JsonFormatter.OutputField"
                             Text="{Binding OutputText}"
                             TabIndex="3"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             AutomationProperties.Name="{loc:Translate ToolJsonOutputLabel}"
                             AutomationProperties.LiveSetting="Polite"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Padding="{StaticResource PaddingInput}" />
                </Border>
            </Grid>

            <DockPanel Grid.Row="3" Margin="{StaticResource MarginSubsectionTop}">
                <Button x:Name="BtnCopyOutput"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="JsonFormatter.CopyOutputButton"
                        Content="{loc:Translate ToolJsonBtnCopy}"
                        TabIndex="5"
                        Click="OnCopyOutputClick"
                        ToolTip="{loc:Translate ToolBtnCopyToClipboard}"
                        AutomationProperties.Name="{loc:Translate ToolJsonBtnCopy}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" />
                <TextBlock x:Name="StatusText"
                           AutomationProperties.AutomationId="JsonFormatter.StatusText"
                           Text="{Binding StatusText}"
                           FontSize="{StaticResource FontSizeCaption}"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusForegroundBrushKey}" Value="ErrorBrush">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
