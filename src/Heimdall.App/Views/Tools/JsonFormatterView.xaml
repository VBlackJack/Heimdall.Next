<UserControl x:Class="Heimdall.App.Views.Tools.JsonFormatterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="6"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input text area -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="InputLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"/>
            <TextBox x:Name="InputText" Grid.Row="1"
                     TabIndex="0"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="{StaticResource PaddingInput}"
                     Tag=""
                     TextChanged="OnInputTextChanged"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8">
            <Button x:Name="BtnPrettify" Click="OnPrettifyClick"
                    TabIndex="1"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineSm}"/>
            <Button x:Name="BtnMinify" Click="OnMinifyClick"
                    TabIndex="2"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"/>
        </StackPanel>

        <!-- Output text area -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="OutputLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"/>

            <Border x:Name="EmptyStatePanel" Grid.Row="1"
                    Style="{StaticResource ToolEmptyStateStyle}"
                   >
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE943;"
                               Style="{StaticResource ToolEmptyStateIconStyle}"
                               Focusable="False"/>
                    <TextBlock x:Name="TxtEmptyState" Text=""
                               Style="{StaticResource ToolEmptyStateTextStyle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="ResultsPanel" Grid.Row="1" Visibility="Collapsed">
                <TextBox x:Name="OutputText"
                         TabIndex="3"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         AutomationProperties.LiveSetting="Polite"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="{StaticResource PaddingInput}"/>
            </Border>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="3" Margin="{StaticResource MarginSubsectionTop}">
            <Button x:Name="BtnCopyOutput" DockPanel.Dock="Right"
                    TabIndex="5"
                    Click="OnCopyOutputClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}"/>
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
