<UserControl x:Class="Heimdall.App.Views.Tools.JwtParserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="6"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Input -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         TabIndex="0"
                         FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag=""
                         TextChanged="OnInputTextChanged"/>

                <!-- Expiration status -->
                <Border x:Name="ExpirationBorder" Margin="{StaticResource MarginSectionTop}"
                        Padding="10,6" CornerRadius="{StaticResource CornerRadiusSm}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtExpiration" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"/>
                </Border>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginSectionTop}"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <!-- Empty state -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D7;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Header section -->
                <DockPanel Margin="0,16,0,4">
                    <Button x:Name="BtnCopyHeader" DockPanel.Dock="Right" Click="OnCopyHeaderClick"
                            TabIndex="1"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginInlineControl}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblHeader" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource JwtHeaderBrush}" VerticalAlignment="Center"/>
                </DockPanel>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource JwtHeaderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusSm}" Padding="{StaticResource SpacingSm}" Margin="{StaticResource MarginSectionBottom}">
                    <TextBox x:Name="TxtHeader" Text=""
                             FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource JwtHeaderBrush}"
                             AutomationProperties.LiveSetting="Polite"/>
                </Border>

                <!-- Payload section -->
                <DockPanel Margin="0,4,0,4">
                    <Button x:Name="BtnCopyPayload" DockPanel.Dock="Right" Click="OnCopyPayloadClick"
                            TabIndex="2"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginInlineControl}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblPayload" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource JwtPayloadBrush}" VerticalAlignment="Center"/>
                </DockPanel>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource JwtPayloadBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusSm}" Padding="{StaticResource SpacingSm}" Margin="{StaticResource MarginSectionBottom}">
                    <TextBox x:Name="TxtPayload" Text=""
                             FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource JwtPayloadBrush}"
                             AutomationProperties.LiveSetting="Polite"/>
                </Border>

                <!-- Signature section -->
                <DockPanel Margin="0,4,0,4">
                    <Button x:Name="BtnCopySignature" DockPanel.Dock="Right" Click="OnCopySignatureClick"
                            TabIndex="3"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginInlineControl}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblSignature" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource JwtSignatureBrush}" VerticalAlignment="Center"/>
                </DockPanel>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource JwtSignatureBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusSm}" Padding="{StaticResource SpacingSm}" Margin="{StaticResource MarginSectionBottom}">
                    <TextBox x:Name="TxtSignature" Text=""
                             FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource JwtSignatureBrush}"
                             AutomationProperties.LiveSetting="Polite"/>
                </Border>

                <!-- Signature Verification section -->
                <Border x:Name="VerifySection" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource SpacingMd}" Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <TextBlock x:Name="LblVerifyTitle" Text=""
                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,8"/>

                        <!-- Unsupported algorithm message (for RS/ES) -->
                        <TextBlock x:Name="TxtUnsupportedAlg" Text=""
                                   Visibility="Collapsed"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- HMAC verification controls -->
                        <StackPanel x:Name="HmacVerifyPanel" Visibility="Collapsed">
                            <TextBlock x:Name="LblSecret" Text=""
                                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <DockPanel Margin="0,0,0,8">
                                <Button x:Name="BtnVerify" DockPanel.Dock="Right"
                                        TabIndex="5"
                                        Content="" Click="OnVerifyClick"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                                        VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtSecret" Text=""
                                         TabIndex="4"
                                         FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                         Padding="{StaticResource PaddingInput}"
                                         Background="{DynamicResource BackgroundBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock x:Name="TxtVerifyResult" Text=""
                                       Visibility="Collapsed"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
