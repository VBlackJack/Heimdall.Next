<UserControl x:Class="Heimdall.App.Views.Tools.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="10"/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="11"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- File path + Browse + Tail -->
        <Border Grid.Row="2" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="FilePathInput" Grid.Column="0"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="{DynamicResource CardBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Padding="{StaticResource PaddingInput}"
                         VerticalAlignment="Center"
                         Tag=""
                         KeyDown="OnFilePathKeyDown"
                         TabIndex="0"/>
                <Button x:Name="BtnBrowse" Grid.Column="1"
                        Click="OnBrowseClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineStart}"
                        VerticalAlignment="Center"
                        TabIndex="1"/>
                <ToggleButton x:Name="BtnTail" Grid.Column="2"
                              Checked="OnTailChecked"
                              Unchecked="OnTailUnchecked"
                              Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineStart}"
                              VerticalAlignment="Center"
                              TabIndex="2"/>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="FilterInput" Grid.Column="0"
                             Style="{DynamicResource WatermarkTextBoxStyle}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Background="{DynamicResource CardBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Padding="{StaticResource PaddingInput}"
                             VerticalAlignment="Center"
                             Tag=""
                             KeyDown="OnFilterKeyDown"
                             TabIndex="3"/>
                    <Button x:Name="BtnApplyFilter" Grid.Column="1"
                            Click="OnApplyFilterClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineStart}"
                            VerticalAlignment="Center"
                            TabIndex="4"/>
                    <Button x:Name="BtnClearFilter" Grid.Column="2"
                            Click="OnClearFilterClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineStart}"
                            VerticalAlignment="Center"
                            TabIndex="5"/>
                </Grid>

                <WrapPanel Grid.Row="1" Margin="{StaticResource MarginSubsectionTop}" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkCaseSensitive"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center"
                              TabIndex="6"/>
                    <TextBlock x:Name="EncodingLabel"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="EncodingCombo"
                              SelectedIndex="0"
                              MinWidth="120"
                              SelectionChanged="OnEncodingChanged"
                              VerticalAlignment="Center"
                              TabIndex="7">
                        <ComboBoxItem x:Name="EncUtf8Item" Content="" Tag="UTF-8"/>
                        <ComboBoxItem x:Name="EncAsciiItem" Content="" Tag="ASCII"/>
                        <ComboBoxItem x:Name="EncUtf16Item" Content="" Tag="UTF-16"/>
                        <ComboBoxItem x:Name="EncWin1252Item" Content="" Tag="Windows-1252"/>
                    </ComboBox>
                </WrapPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="ErrorText" Grid.Row="4"
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="{StaticResource ToolFooterPadding}"/>

        <!-- Empty state hint (hidden once a file is loaded) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="5"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE7BC;" Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Log display -->
        <Border x:Name="ResultsPanel" Grid.Row="5"
                Style="{StaticResource ToolResultsCardStyle}"
                Margin="{StaticResource SpacingSm}"
                Padding="0">
            <RichTextBox x:Name="LogViewer"
                         IsReadOnly="True" AutomationProperties.LiveSetting="Polite"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="{StaticResource SpacingSm}"
                         TabIndex="8">
                <FlowDocument x:Name="LogDocument" PageWidth="10000"/>
            </RichTextBox>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="6" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopyLog" DockPanel.Dock="Right" Click="OnCopyLogClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" FontSize="{StaticResource FontSizeCaption}"
                        Margin="{StaticResource MarginInlineControl}" VerticalAlignment="Center"
                        TabIndex="9"/>
                <TextBlock x:Name="TailStatusText" DockPanel.Dock="Right"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                           Margin="{StaticResource MarginInlineControl}"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="StatsText"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
