<UserControl x:Class="Heimdall.App.Views.Tools.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- File path + Browse + Tail -->
        <Border Grid.Row="1" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <ToggleButton x:Name="BtnTail" DockPanel.Dock="Right"
                              Checked="OnTailChecked"
                              Unchecked="OnTailUnchecked"
                              Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                              VerticalAlignment="Center"/>
                <Button x:Name="BtnBrowse" DockPanel.Dock="Right"
                        Click="OnBrowseClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                        VerticalAlignment="Center"/>
                <TextBox x:Name="FilePathInput"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="{DynamicResource CardBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Padding="4,2"
                         VerticalAlignment="Center"
                         Tag="log file path"
                         KeyDown="OnFilePathKeyDown"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <ComboBox x:Name="EncodingCombo" DockPanel.Dock="Right"
                          SelectedIndex="0"
                          MinWidth="120" Margin="8,0,0,0"
                          SelectionChanged="OnEncodingChanged"
                          VerticalAlignment="Center">
                    <ComboBoxItem x:Name="EncUtf8Item" Content="" Tag="UTF-8"/>
                    <ComboBoxItem x:Name="EncAsciiItem" Content="" Tag="ASCII"/>
                    <ComboBoxItem x:Name="EncUtf16Item" Content="" Tag="UTF-16"/>
                    <ComboBoxItem x:Name="EncWin1252Item" Content="" Tag="Windows-1252"/>
                </ComboBox>
                <TextBlock x:Name="EncodingLabel" DockPanel.Dock="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,4,0"/>
                <CheckBox x:Name="ChkCaseSensitive" DockPanel.Dock="Right"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Button x:Name="BtnClearFilter" DockPanel.Dock="Right"
                        Click="OnClearFilterClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="4,0,0,0"
                        VerticalAlignment="Center"/>
                <Button x:Name="BtnApplyFilter" DockPanel.Dock="Right"
                        Click="OnApplyFilterClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="4,0,0,0"
                        VerticalAlignment="Center"/>
                <TextBox x:Name="FilterInput"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="{DynamicResource CardBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Padding="4,2"
                         VerticalAlignment="Center"
                         Tag="filter text"
                         KeyDown="OnFilterKeyDown"/>
            </DockPanel>
        </Border>

        <!-- Empty state hint (hidden once a file is loaded) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="3"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"
                           AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Log display -->
        <RichTextBox x:Name="LogViewer" Grid.Row="3"
                     IsReadOnly="True"
                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                     Background="{DynamicResource CardBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderThickness="0"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Padding="{StaticResource SpacingSm}">
            <FlowDocument x:Name="LogDocument" PageWidth="10000"/>
        </RichTextBox>

        <!-- Stats bar -->
        <Border Grid.Row="4" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopyLog" DockPanel.Dock="Right" Click="OnCopyLogClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" FontSize="{StaticResource FontSizeCaption}"
                        Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TailStatusText" DockPanel.Dock="Right"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="StatsText"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
