<UserControl x:Class="Heimdall.App.Views.Tools.NetworkCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="13"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="14"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Mode selector -->
                <TextBlock x:Name="LblMode" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginDetailRow}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Margin="{StaticResource MarginSectionSeparator}">
                    <RadioButton x:Name="RbSupernet" GroupName="Mode"
                                 IsChecked="True" Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,4" FontSize="{StaticResource FontSizeBodyLarge}"
                                 TabIndex="0"/>
                    <RadioButton x:Name="RbRangeToCidr" GroupName="Mode"
                                 Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,4" FontSize="{StaticResource FontSizeBodyLarge}"
                                 TabIndex="1"/>
                    <RadioButton x:Name="RbVlanPlanner" GroupName="Mode"
                                 Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="{StaticResource MarginLabelBottom}" FontSize="{StaticResource FontSizeBodyLarge}"
                                 TabIndex="2"/>
                </WrapPanel>

                <!-- ═══ Supernet panel ═══ -->
                <Border x:Name="PanelSupernet"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <TextBlock x:Name="LblSupernetInput" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtSupernetInput"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" Margin="{StaticResource MarginStackItem}"
                                 TabIndex="3"/>
                        <Button x:Name="BtnSupernetCompute" Click="OnSupernetComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"
                                TabIndex="4"/>
                    </StackPanel>
                </Border>

                <!-- ═══ Range to CIDR panel ═══ -->
                <Border x:Name="PanelRangeToCidr" Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblStartIp" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                            <TextBox x:Name="TxtStartIp" Grid.Column="1"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="{StaticResource PaddingInput}"
                                     TabIndex="5"/>
                            <TextBlock x:Name="LblEndIp" Grid.Column="3"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                            <TextBox x:Name="TxtEndIp" Grid.Column="4"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="{StaticResource PaddingInput}"
                                     TabIndex="6"/>
                        </Grid>
                        <Button x:Name="BtnRangeCompute" Click="OnRangeComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginSubsectionTop}" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"
                                TabIndex="7"/>
                    </StackPanel>
                </Border>

                <!-- ═══ VLAN Planner panel ═══ -->
                <Border x:Name="PanelVlanPlanner" Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{StaticResource SpacingRowGapGrid}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="LblHostsNeeded" Grid.Row="0" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                            <TextBox x:Name="TxtHostsNeeded" Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     MaxWidth="150" HorizontalAlignment="Left"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="{StaticResource PaddingInput}"
                                     TabIndex="8"/>
                            <TextBlock x:Name="LblBaseNetwork" Grid.Row="2" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                            <TextBox x:Name="TxtBaseNetwork" Grid.Row="2" Grid.Column="1"
                                     Style="{StaticResource WatermarkTextBoxStyle}"
                                     Text="" FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     MaxWidth="200" HorizontalAlignment="Left"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="{StaticResource PaddingInput}"
                                     TabIndex="9"/>
                        </Grid>
                        <Button x:Name="BtnVlanCompute" Click="OnVlanComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginSubsectionTop}" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"
                                TabIndex="10"/>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackItem}" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorTextBrush}"/>

                <!-- Empty state hint -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                       >
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE968;" Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Results -->
                <Border x:Name="ResultsPanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource MarginStackItem}">
                    <DockPanel>
                        <Button x:Name="BtnCopyResult" DockPanel.Dock="Top"
                                Click="OnCopyResultClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginStackItem}"
                                HorizontalAlignment="Left" FontSize="{StaticResource FontSizeCaption}"
                                TabIndex="11"/>
                        <TextBox x:Name="TxtResult"
                                 IsReadOnly="True"
                                 TabIndex="12"
                                 AutomationProperties.LiveSetting="Polite"
                                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MaxHeight="300"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0"/>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
