<UserControl x:Class="Heimdall.App.Views.Tools.NetworkCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Mode selector -->
                <TextBlock x:Name="LblMode" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Margin="0,0,0,16">
                    <RadioButton x:Name="RbSupernet" GroupName="Mode"
                                 IsChecked="True" Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,4" FontSize="13"/>
                    <RadioButton x:Name="RbRangeToCidr" GroupName="Mode"
                                 Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,16,4" FontSize="13"/>
                    <RadioButton x:Name="RbVlanPlanner" GroupName="Mode"
                                 Checked="OnModeChanged"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,0,4" FontSize="13"/>
                </WrapPanel>

                <!-- ═══ Supernet panel ═══ -->
                <Border x:Name="PanelSupernet"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="LblSupernetInput" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtSupernetInput"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="8,6" Margin="0,0,0,8"/>
                        <Button x:Name="BtnSupernetCompute" Click="OnSupernetComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="14,6" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                </Border>

                <!-- ═══ Range to CIDR panel ═══ -->
                <Border x:Name="PanelRangeToCidr" Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblStartIp" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtStartIp" Grid.Column="1"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="6,4"/>
                            <TextBlock x:Name="LblEndIp" Grid.Column="3"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtEndIp" Grid.Column="4"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="6,4"/>
                        </Grid>
                        <Button x:Name="BtnRangeCompute" Click="OnRangeComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="14,6" Margin="0,8,0,0" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                </Border>

                <!-- ═══ VLAN Planner panel ═══ -->
                <Border x:Name="PanelVlanPlanner" Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="LblHostsNeeded" Grid.Row="0" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtHostsNeeded" Grid.Row="0" Grid.Column="1"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     MaxWidth="150" HorizontalAlignment="Left"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="6,4"/>
                            <TextBlock x:Name="LblBaseNetwork" Grid.Row="2" Grid.Column="0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtBaseNetwork" Grid.Row="2" Grid.Column="1"
                                     Text="10.0.0.0" FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     MaxWidth="200" HorizontalAlignment="Left"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="6,4"/>
                        </Grid>
                        <Button x:Name="BtnVlanCompute" Click="OnVlanComputeClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="14,6" Margin="0,8,0,0" HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorBrush}"/>

                <!-- Results -->
                <Border x:Name="ResultsPanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12" Margin="0,0,0,8">
                    <DockPanel>
                        <Button x:Name="BtnCopyResult" DockPanel.Dock="Top"
                                Click="OnCopyResultClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="0,0,0,8"
                                HorizontalAlignment="Left" FontSize="{StaticResource FontSizeCaption}"/>
                        <TextBox x:Name="TxtResult"
                                 IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MaxHeight="300"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0"/>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
