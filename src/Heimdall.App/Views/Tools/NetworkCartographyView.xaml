<UserControl x:Class="Heimdall.App.Views.Tools.NetworkCartographyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Row 1: Scan parameters -->
        <Border Grid.Row="1" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock x:Name="LblSubnet" Text="" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtSubnet" Text="" Width="180"
                         Style="{StaticResource WatermarkTextBoxStyle}"
                         Tag="192.168.1.0/24"
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         VerticalAlignment="Center"
                         AutomationProperties.Name=""/>

                <TextBlock x:Name="LblDepth" Text="" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="16,0,6,0"/>
                <ComboBox x:Name="CmbDepth" Width="160"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name=""/>

                <CheckBox x:Name="ChkSkipPing"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="16,0,0,0"
                          AutomationProperties.Name=""/>
                <CheckBox x:Name="ChkReverseDns" IsChecked="True"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="16,0,0,0"
                          AutomationProperties.Name=""/>
                <CheckBox x:Name="ChkUseKnowledgeBase"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="16,0,0,0"
                          AutomationProperties.Name=""/>

                <TextBlock x:Name="LblRouteVia" Text=""
                           FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="16,0,4,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CmbRouteVia" Width="180"
                          SelectionChanged="OnRouteViaChanged"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name=""/>

                <Button x:Name="BtnStart" Content=""
                        Click="OnStartClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnStop" Content=""
                        Click="OnStopClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="8,0,0,0"
                        VerticalAlignment="Center" IsEnabled="False"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtScanProgress" Text=""
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"
                           Margin="8,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- Row 2: Progress -->
        <StackPanel Grid.Row="2" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar x:Name="ScanProgress" Height="4"
                         Minimum="0" Maximum="100"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"
                         AutomationProperties.Name=""/>
            <TextBlock x:Name="TxtStatus" Text="" FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="12,2,12,4"/>
        </StackPanel>

        <!-- Empty state hint -->
        <Border x:Name="EmptyStatePanel" Grid.Row="3"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE826;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"
                           AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Row 3: Results DataGrid -->
        <Border Grid.Row="3" Margin="{StaticResource SpacingSm}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AutomationProperties.Name=""
                      AutomationProperties.LiveSetting="Polite"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      RowDetailsVisibilityMode="Collapsed">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColIp" Binding="{Binding IpAddress}" Width="120"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColHostname" Binding="{Binding Hostname}" Width="180"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColRole" Binding="{Binding PrimaryRoleName}" Width="150"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColConfidence" Binding="{Binding Confidence}" Width="80"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColOs" Binding="{Binding OsGuess}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColManufacturer" Binding="{Binding Manufacturer}" Width="140"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColPorts" Binding="{Binding PortSummary}" Width="200"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColServices" Binding="{Binding ServiceSummary}" Width="200"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColTls" Binding="{Binding TlsStatus}" Width="180"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColDetails" Binding="{Binding DetailsSummary}" Width="200"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColVlan" Binding="{Binding VlanSegment}" Width="150"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Row 4: Stats + Export -->
        <Border Grid.Row="4" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ComboBox x:Name="CmbHistory" Width="220" Margin="0,0,8,0"
                              SelectionChanged="OnHistorySelected"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name=""/>
                    <Button x:Name="BtnExportDrawio" Content=""
                            Click="OnExportDrawioClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,4,0"
                            VerticalAlignment="Center" IsEnabled="False"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnEditDiagram" Content=""
                            Click="OnEditDiagramClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,4,0"
                            VerticalAlignment="Center" IsEnabled="False"
                            AutomationProperties.Name=""/>
                    <Button x:Name="BtnExportCsv" Content=""
                            Click="OnExportCsvClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}"
                            VerticalAlignment="Center" IsEnabled="False"
                            AutomationProperties.Name=""/>
                </StackPanel>
                <TextBlock x:Name="TxtStats" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatsSeparator" Text=" | " Foreground="{DynamicResource TextDisabledBrush}" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeBody}" Margin="4,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="TxtKbStats" Text="" FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnClearKb" Content="" Click="OnClearKbClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="8,0,0,0" FontSize="{StaticResource FontSizeCaption}"
                        VerticalAlignment="Center"
                        AutomationProperties.Name=""/>
            </DockPanel>
        </Border>

        <!-- Row 5: Diff results -->
        <Border Grid.Row="5" x:Name="DiffPanel" Visibility="Collapsed"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtDiff" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                       Foreground="{DynamicResource AccentBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
