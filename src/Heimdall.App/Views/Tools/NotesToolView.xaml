<UserControl x:Class="Heimdall.App.Views.Tools.NotesToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:tools="clr-namespace:Heimdall.App.Views.Tools"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="16"/>
                <Button x:Name="BtnMarkdownHelp" DockPanel.Dock="Right"
                        Click="OnMarkdownHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="15"/>
                <Button x:Name="BtnOpenFolder" DockPanel.Dock="Right"
                        Click="OnOpenFolderClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="14"/>
                <Button x:Name="BtnToggleSidebar" DockPanel.Dock="Left"
                        Click="OnToggleSidebarClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonToolbar}" Margin="{StaticResource MarginInlineSm}"
                        FontFamily="{StaticResource FontFamilyMonospace}"
                        FontSize="{StaticResource FontSizeBody}"
                        Content="&#x2630;"
                        TabIndex="0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtUnsaved" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource WarningBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="{StaticResource MarginInlineControl}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="17"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid x:Name="NotesLayoutGrid" Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarBorder" Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}"
                    Padding="{StaticResource SpacingMd}"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Compact toolbar: search + buttons -->
                    <Grid Margin="{StaticResource MarginStackItem}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="SearchTextBox"
                                 Grid.Row="0"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Padding="{StaticResource PaddingInput}"
                                 TextChanged="OnSearchTextChanged"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 TabIndex="1"/>
                        <WrapPanel Grid.Row="1" Margin="{StaticResource MarginSubsectionTop}" HorizontalAlignment="Right">
                            <Button x:Name="BtnCollapseAll"
                                    Click="OnCollapseAllClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonHelp}" Margin="{StaticResource MarginInlineStart}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    Content="&#x25B2;"
                                    TabIndex="2"/>
                            <Button x:Name="BtnExpandAll"
                                    Click="OnExpandAllClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonHelp}" Margin="{StaticResource MarginInlineStart}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    Content="&#x25BC;"
                                    TabIndex="3"/>
                            <Button x:Name="BtnNewNote"
                                    Click="OnNewNoteClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineStart}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    TabIndex="4"/>
                        </WrapPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="{StaticResource MarginLabelBottom}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource MarginStackItem}">
                            <TextBlock x:Name="SortLabelText"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"/>
                            <ComboBox x:Name="SortOrderComboBox"
                                      Margin="{StaticResource MarginInlineControl}"
                                      Width="160"
                                      HorizontalAlignment="Left"
                                      SelectedValuePath="Tag"
                                      SelectionChanged="OnSortOrderSelectionChanged"
                                      TabIndex="5">
                                <ComboBoxItem x:Name="SortNewestFirstItem" Tag="DateDescending"/>
                                <ComboBoxItem x:Name="SortOldestFirstItem" Tag="DateAscending"/>
                                <ComboBoxItem x:Name="SortNameAscItem" Tag="NameAscending"/>
                                <ComboBoxItem x:Name="SortNameDescItem" Tag="NameDescending"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock x:Name="TagsLabelText"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="{StaticResource MarginLabelBottom}"
                                   Visibility="Collapsed"/>
                        <WrapPanel x:Name="TagFilterWrapPanel"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <TreeView x:Name="NotesTreeView" Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              AllowDrop="True"
                              SelectedItemChanged="OnNotesTreeSelectionChanged"
                              ContextMenuOpening="OnTreeViewContextMenuOpening"
                              PreviewKeyDown="OnTreeViewPreviewKeyDown"
                              PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick"
                              PreviewMouseLeftButtonDown="OnTreeViewPreviewMouseLeftButtonDown"
                              PreviewMouseMove="OnTreeViewPreviewMouseMove"
                              DragOver="OnTreeViewInternalDragOver"
                              Drop="OnTreeViewInternalDrop"
                              TabIndex="6">
                        <TreeView.ContextMenu>
                            <ContextMenu x:Name="TreeContextMenu"/>
                        </TreeView.ContextMenu>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid Margin="2,3,8,3">
                                    <StackPanel x:Name="FolderPanel"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                        <TextBlock Text="{Binding Icon}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel x:Name="NotePanel">
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="NoteSummaryText"
                                                   Text="{Binding DisplaySummary}"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DisplayMeta}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="NoteTagsText"
                                                   Text="{Binding DisplayTags}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource InfoBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                        <Setter TargetName="FolderPanel" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="NotePanel" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DisplaySummary}" Value="">
                                        <Setter TargetName="NoteSummaryText" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DisplayTags}" Value="">
                                        <Setter TargetName="NoteTagsText" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <TextBlock x:Name="ListFooterText" Grid.Row="3"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}"/>
                </Grid>
            </Border>

            <GridSplitter x:Name="EditorSplitter" Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}"
                    Padding="{StaticResource SpacingMd}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="1" Margin="{StaticResource MarginSubsectionTop}" HorizontalAlignment="Right">
                            <Button x:Name="BtnNavBack" Content="&#x2190;"
                                    Click="OnNavBackClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonToolbar}" Margin="{StaticResource MarginInlineXs}"
                                    FontSize="{StaticResource FontSizeBody}"
                                    IsEnabled="False"
                                    TabIndex="7"/>
                            <Button x:Name="BtnNavForward" Content="&#x2192;"
                                    Click="OnNavForwardClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonToolbar}" Margin="{StaticResource MarginInlineSm}"
                                    FontSize="{StaticResource FontSizeBody}"
                                    IsEnabled="False"
                                    TabIndex="8"/>
                            <Button x:Name="BtnNoteActions"
                                    Click="OnNoteActionsClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineSm}"
                                    IsEnabled="False"
                                    TabIndex="9"/>
                            <Button x:Name="BtnCopyConfluence"
                                    Click="OnCopyConfluenceClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineXs}"
                                    TabIndex="10"/>
                            <Button x:Name="BtnExportConfluence"
                                    Click="OnExportConfluenceClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineXs}"
                                    TabIndex="11"/>
                            <Button x:Name="BtnExportHtml"
                                    Click="OnExportHtmlClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}"
                                    TabIndex="12"/>
                        </WrapPanel>
                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="SelectedNoteTitleText"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="SelectedNotePathText"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="{StaticResource MarginSectionTop}">
                        <!-- Milkdown (primary) — hidden until ready or if WebView2 unavailable -->
                        <tools:MilkdownEditorControl x:Name="MilkdownEditor"
                                                     TabIndex="13"
                                                     Visibility="Collapsed"/>

                        <!-- AvalonEdit (fallback) -->
                        <avalon:TextEditor x:Name="Editor"
                                           FontFamily="{StaticResource FontFamilyMonospace}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           ShowLineNumbers="True"
                                           WordWrap="True"
                                           Background="{DynamicResource SurfaceBrush}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           TabIndex="13"/>

                        <Border x:Name="EditorEmptyStatePanel"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusMd}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="280">
                                <TextBlock x:Name="EditorEmptyTitleText"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="EditorEmptyBodyText"
                                           Margin="0,10,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="StatusText" Grid.Row="2"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
