<UserControl x:Class="Heimdall.App.Views.Tools.NotesToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:services="clr-namespace:Heimdall.App.Services"
             xmlns:tools="clr-namespace:Heimdall.App.Views.Tools"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="NotesToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        </Style>

        <Style x:Key="NotesIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        </Style>

        <Style x:Key="NotesMetaLineTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.92"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NotesTagFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                       
                       
                        Margin="4,0,0,0"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.AutomationId="NotesTool.Help"
                        TabIndex="16"/>
                <Button x:Name="BtnMarkdownHelp"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate ToolNotesMarkdownHelpBtn}"
                        Click="OnMarkdownHelpClick"
                        Style="{StaticResource NotesToolbarButtonStyle}"
                        ToolTip="{loc:Translate TooltipMarkdownHelp}"
                        AutomationProperties.Name="{loc:Translate TooltipMarkdownHelp}"
                        AutomationProperties.AutomationId="NotesTool.MarkdownHelp"
                        TabIndex="15"/>
                <Button x:Name="BtnOpenFolder"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate ToolNotesBtnOpenFolder}"
                        Click="OnOpenFolderClick"
                        Style="{StaticResource NotesToolbarButtonStyle}"
                        ToolTip="{loc:Translate TooltipOpenNotesFolder}"
                        AutomationProperties.Name="{loc:Translate TooltipOpenNotesFolder}"
                        AutomationProperties.AutomationId="NotesTool.OpenFolder"
                        TabIndex="14"/>
                <Button x:Name="BtnToggleSidebar"
                        DockPanel.Dock="Left"
                        Click="OnToggleSidebarClick"
                        Style="{StaticResource NotesIconButtonStyle}"
                        FontFamily="{StaticResource FontFamilyMonospace}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Content="&#x2630;"
                        ToolTip="{loc:Translate TooltipToggleSidebar}"
                        AutomationProperties.Name="{loc:Translate TooltipToggleSidebar}"
                        AutomationProperties.AutomationId="NotesTool.ToggleSidebar"
                        TabIndex="0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               Text="{loc:Translate ToolNotesTitle}"
                               FontSize="{StaticResource FontSizeBodyLarge}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtUnsaved"
                               Text="{loc:Translate ToolNotesUnsaved}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="8,0,0,0"
                               Opacity="0.85"
                               AutomationProperties.AutomationId="NotesTool.UnsavedIndicator"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                       
                       
                        AutomationProperties.Name="{loc:Translate BtnClose}"
                        AutomationProperties.AutomationId="NotesTool.CloseHelp"
                        TabIndex="17"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               Text=""
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid x:Name="NotesLayoutGrid" Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="176"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarBorder"
                    Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}"
                    Padding="8"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="SearchTextBox"
                                 Grid.Row="0"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Padding="10,5"
                                 MinHeight="30"
                                 Tag="{loc:Translate ToolNotesSearchPlaceholder}"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 AutomationProperties.AutomationId="NotesTool.Search"
                                 AutomationProperties.Name="{loc:Translate ToolNotesSearchPlaceholder}"
                                 TabIndex="1"/>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Right">
                            <Button x:Name="BtnCollapseAll"
                                    Click="OnCollapseAllClick"
                                    Style="{StaticResource NotesIconButtonStyle}"
                                    Content="&#x25B2;"
                                    ToolTip="{loc:Translate TooltipCollapseAll}"
                                    AutomationProperties.Name="{loc:Translate TooltipCollapseAll}"
                                    AutomationProperties.AutomationId="NotesTool.CollapseAll"
                                    TabIndex="2"/>
                            <Button x:Name="BtnExpandAll"
                                    Click="OnExpandAllClick"
                                    Style="{StaticResource NotesIconButtonStyle}"
                                    Content="&#x25BC;"
                                    ToolTip="{loc:Translate TooltipExpandAll}"
                                    AutomationProperties.Name="{loc:Translate TooltipExpandAll}"
                                    AutomationProperties.AutomationId="NotesTool.ExpandAll"
                                    TabIndex="3"/>
                            <Button x:Name="BtnNewNote"
                                    Content="{loc:Translate ToolNotesBtnNew}"
                                    Click="OnNewNoteClick"
                                    Style="{StaticResource NotesToolbarButtonStyle}"
                                    Padding="12,4"
                                    ToolTip="{loc:Translate TooltipNewNote}"
                                    AutomationProperties.Name="{loc:Translate TooltipNewNote}"
                                    AutomationProperties.AutomationId="NotesTool.NewNote"
                                    TabIndex="4"/>
                        </WrapPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock x:Name="SortLabelText"
                                       Text="{loc:Translate ToolNotesSortLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Visibility="Collapsed"
                                       Opacity="0.7"/>
                            <TextBlock Text="&#xE8D4;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="SortOrderComboBox"
                                      Width="156"
                                      HorizontalAlignment="Left"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding SortOrder, Mode=TwoWay}"
                                      Padding="8,2"
                                      MinHeight="28"
                                      AutomationProperties.AutomationId="NotesTool.SortOrder"
                                      AutomationProperties.Name="{loc:Translate ToolNotesSortLabel}"
                                      TabIndex="5">
                                <ComboBoxItem x:Name="SortNewestFirstItem" Content="{loc:Translate ToolNotesSortDateDesc}" Tag="{x:Static services:NoteSortOrder.DateDescending}"/>
                                <ComboBoxItem x:Name="SortOldestFirstItem" Content="{loc:Translate ToolNotesSortDateAsc}" Tag="{x:Static services:NoteSortOrder.DateAscending}"/>
                                <ComboBoxItem x:Name="SortNameAscItem" Content="{loc:Translate ToolNotesSortNameAsc}" Tag="{x:Static services:NoteSortOrder.NameAscending}"/>
                                <ComboBoxItem x:Name="SortNameDescItem" Content="{loc:Translate ToolNotesSortNameDesc}" Tag="{x:Static services:NoteSortOrder.NameDescending}"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock x:Name="TagsLabelText"
                                   Text="{loc:Translate ToolNotesTagsLabel}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Visibility="Collapsed"
                                   Opacity="0"
                                   Height="0"
                                   Margin="0"
                                   IsHitTestVisible="False"/>

                        <ItemsControl x:Name="TagFilterWrapPanel"
                                      Margin="0,0,0,6"
                                      ItemsSource="{Binding TagFilters}"
                                      Visibility="{Binding HasTagFilters, Converter={StaticResource BoolToVisibilityConverter}}"
                                      AutomationProperties.AutomationId="NotesTool.TagFilters"
                                      AutomationProperties.Name="{loc:Translate ToolNotesTagsLabel}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding DisplayLabel}"
                                            Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Value}"
                                            Style="{StaticResource NotesTagFilterButtonStyle}"
                                            AutomationProperties.Name="{Binding DisplayLabel}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TreeView x:Name="NotesTreeView"
                              Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              AllowDrop="True"
                              ItemsSource="{Binding Notes}"
                              AutomationProperties.AutomationId="NotesTool.TreeView"
                              AutomationProperties.Name="{loc:Translate ToolNotesListTitle}"
                              SelectedItemChanged="OnNotesTreeSelectionChanged"
                              ContextMenuOpening="OnTreeViewContextMenuOpening"
                              PreviewKeyDown="OnTreeViewPreviewKeyDown"
                              PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick"
                              PreviewMouseLeftButtonDown="OnTreeViewPreviewMouseLeftButtonDown"
                              PreviewMouseMove="OnTreeViewPreviewMouseMove"
                              PreviewDragOver="OnTreeViewInternalDragOver"
                              PreviewDrop="OnTreeViewInternalDrop"
                              DragOver="OnTreeViewInternalDragOver"
                              Drop="OnTreeViewInternalDrop"
                              TabIndex="6">
                        <TreeView.ContextMenu>
                            <ContextMenu x:Name="TreeContextMenu"/>
                        </TreeView.ContextMenu>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Border x:Name="ItemChrome"
                                        Margin="0,0,1,0"
                                        Padding="4,2,4,2"
                                        CornerRadius="{StaticResource CornerRadiusMd}"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel x:Name="FolderPanel"
                                                    Grid.Column="1"
                                                    Grid.ColumnSpan="2"
                                                    Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="{Binding Icon}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       Opacity="0.88"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="FolderTitleText"
                                                       Text="{Binding Name}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Path x:Name="NoteGlyph"
                                              Grid.Column="1"
                                              Data="{StaticResource Geo.Tool.Notes}"
                                              Fill="{DynamicResource TextSecondaryBrush}"
                                              Width="12"
                                              Height="12"
                                              Stretch="Uniform"
                                              Opacity="0.8"
                                              Margin="0,1,5,0"
                                              VerticalAlignment="Top"/>

                                        <StackPanel x:Name="NotePanel"
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.ShowDuration="20000">
                                            <StackPanel.ToolTip>
                                                <ToolTip Background="{DynamicResource SurfaceBrush}"
                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                         Padding="10,8">
                                                    <StackPanel MaxWidth="320">
                                                        <TextBlock Text="{Binding DisplayTitle}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding DisplaySummary}"
                                                                   Margin="0,6,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </StackPanel.ToolTip>

                                            <TextBlock x:Name="NoteTitleText"
                                                       Text="{Binding DisplayTitle}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="Normal"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel x:Name="MetaLinePanel"
                                                        Orientation="Horizontal"
                                                        Margin="0,0,0,0">
                                                <TextBlock x:Name="NoteMetaText"
                                                           Text="{Binding DisplayMeta}"
                                                           Style="{StaticResource NotesMetaLineTextStyle}"/>
                                                <TextBlock x:Name="MetaSeparator"
                                                           Text="·"
                                                           Margin="4,0"
                                                           Style="{StaticResource NotesMetaLineTextStyle}"/>
                                                <TextBlock x:Name="NoteTagsText"
                                                           Text="{Binding DisplayTags}"
                                                           Style="{StaticResource NotesMetaLineTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                        <Setter TargetName="FolderPanel" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="NotePanel" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="NoteGlyph" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="ItemChrome" Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter TargetName="FolderTitleText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="NoteTitleText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="NoteGlyph" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DisplayMeta}" Value="">
                                        <Setter TargetName="NoteMetaText" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="MetaSeparator" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DisplayTags}" Value="">
                                        <Setter TargetName="NoteTagsText" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="MetaSeparator" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DisplayMeta}" Value=""/>
                                            <Condition Binding="{Binding DisplayTags}" Value=""/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="MetaLinePanel" Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <TextBlock x:Name="ListFooterText"
                               Grid.Row="3"
                               Margin="2,8,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding ListFooterText}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Opacity="0.62"/>
                </Grid>
            </Border>

            <GridSplitter x:Name="EditorSplitter"
                          Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          Opacity="0.45"
                          AutomationProperties.AutomationId="NotesTool.EditorSplitter"/>

            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusXl}"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="1" Margin="0,8,0,0" HorizontalAlignment="Right">
                            <Button x:Name="BtnNavBack"
                                    Content="&#x2190;"
                                    Command="{Binding GoBackCommand}"
                                    Style="{StaticResource NotesIconButtonStyle}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    IsEnabled="{Binding CanGoBack}"
                                    ToolTip="{loc:Translate TooltipNavBack}"
                                    AutomationProperties.Name="{loc:Translate TooltipNavBack}"
                                    AutomationProperties.AutomationId="NotesTool.NavBack"
                                    TabIndex="7"/>
                            <Button x:Name="BtnNavForward"
                                    Content="&#x2192;"
                                    Command="{Binding GoForwardCommand}"
                                    Style="{StaticResource NotesIconButtonStyle}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    IsEnabled="{Binding CanGoForward}"
                                    ToolTip="{loc:Translate TooltipNavForward}"
                                    AutomationProperties.Name="{loc:Translate TooltipNavForward}"
                                    AutomationProperties.AutomationId="NotesTool.NavForward"
                                    TabIndex="8"/>
                            <Button x:Name="BtnNoteActions"
                                    Content="{loc:Translate ToolNotesTplActions}"
                                    Click="OnNoteActionsClick"
                                    Style="{StaticResource NotesToolbarButtonStyle}"
                                    IsEnabled="{Binding HasSelection}"
                                    ToolTip="{loc:Translate ToolNotesTplActions}"
                                    AutomationProperties.Name="{loc:Translate ToolNotesTplActions}"
                                    AutomationProperties.AutomationId="NotesTool.NoteActions"
                                    TabIndex="9"/>
                            <Button x:Name="BtnCopyConfluence"
                                    Content="{loc:Translate ToolNotesBtnCopyConfluence}"
                                    Command="{Binding CopyConfluenceCommand}"
                                    Style="{StaticResource NotesToolbarButtonStyle}"
                                    IsEnabled="{Binding HasSelection}"
                                    ToolTip="{loc:Translate TooltipCopyConfluence}"
                                    AutomationProperties.Name="{loc:Translate TooltipCopyConfluence}"
                                    AutomationProperties.AutomationId="NotesTool.CopyConfluence"
                                    TabIndex="10"/>
                            <Button x:Name="BtnExportConfluence"
                                    Content="{loc:Translate ToolNotesBtnExportConfluence}"
                                    Command="{Binding ExportConfluenceCommand}"
                                    Style="{StaticResource NotesToolbarButtonStyle}"
                                    IsEnabled="{Binding HasSelection}"
                                    ToolTip="{loc:Translate TooltipExportConfluence}"
                                    AutomationProperties.Name="{loc:Translate TooltipExportConfluence}"
                                    AutomationProperties.AutomationId="NotesTool.ExportConfluence"
                                    TabIndex="11"/>
                            <Button x:Name="BtnExportHtml"
                                    Content="{loc:Translate ToolNotesBtnExportHtml}"
                                    Command="{Binding ExportHtmlCommand}"
                                    Style="{StaticResource NotesToolbarButtonStyle}"
                                    IsEnabled="{Binding HasSelection}"
                                    ToolTip="{loc:Translate TooltipExportHtml}"
                                    AutomationProperties.Name="{loc:Translate TooltipExportHtml}"
                                    AutomationProperties.AutomationId="NotesTool.ExportHtml"
                                    TabIndex="12"/>
                        </WrapPanel>

                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="SelectedNoteTitleText"
                                       Text="{Binding SelectedNoteTitle}"
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="SelectedNotePathText"
                                       Text="{Binding SelectedNotePathDisplay}"
                                       Margin="0,3,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       FontFamily="{StaticResource FontFamilyMonospace}"
                                       Opacity="0.78"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <tools:MilkdownEditorControl x:Name="MilkdownEditor"
                                                     AutomationProperties.AutomationId="NotesTool.MilkdownEditor"
                                                     TabIndex="13"
                                                     Visibility="Collapsed"/>

                        <avalon:TextEditor x:Name="Editor"
                                           FontFamily="{StaticResource FontFamilyMonospace}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           ShowLineNumbers="True"
                                           WordWrap="True"
                                           Background="{DynamicResource SurfaceBrush}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           AutomationProperties.AutomationId="NotesTool.AvalonEditor"
                                           TabIndex="13"/>

                        <Border x:Name="EditorEmptyStatePanel"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusMd}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="280">
                                <TextBlock x:Name="EditorEmptyTitleText"
                                           Text="{loc:Translate ToolNotesEmptyTitle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="EditorEmptyBodyText"
                                           Text="{loc:Translate ToolNotesEmptyBody}"
                                           Margin="0,10,0,0"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="StatusText"
                               Grid.Row="2"
                               Text="{Binding StatusMessage}"
                               Margin="0,8,0,0"
                               FontSize="{StaticResource FontSizeCaption}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Opacity" Value="0.72"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
