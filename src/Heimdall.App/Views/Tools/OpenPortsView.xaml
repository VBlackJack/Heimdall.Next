<UserControl x:Class="Heimdall.App.Views.Tools.OpenPortsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        Content="?"
                        Command="{Binding ToggleHelpCommand}"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        ToolTip="{loc:Translate ToolHelpTooltip}"/>
                <Button x:Name="BtnRefresh"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate ToolOpenPortsBtnRefresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}"
                        Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock Text="{loc:Translate ToolOpenPortsTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <TextBox x:Name="TxtFilter"
                         MinWidth="200"
                         Margin="16,0,0,0"
                         Style="{DynamicResource WatermarkTextBoxStyle}"
                         FontSize="{StaticResource FontSizeBodyLarge}"
                         Padding="{StaticResource PaddingInput}"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         VerticalAlignment="Center"
                         Tag="{loc:Translate ToolOpenPortsFilterPlaceholder}"
                         TextChanged="OnFilterChanged"/>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                Style="{StaticResource ToolHelpPanelStyle}"
                Visibility="{Binding IsHelpVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        Command="{Binding ToggleHelpCommand}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                       
                       />
                <ScrollViewer MaxHeight="200"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding HelpText}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <DataGrid x:Name="PortsGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Ports}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  Background="{DynamicResource BackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  RowBackground="{DynamicResource BackgroundBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  FontSize="{StaticResource FontSizeBody}">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColProtocol"
                                    Binding="{Binding Protocol}"
                                    Header="{loc:Translate ToolOpenPortsColProtocol}"
                                    Width="60"/>
                <DataGridTextColumn x:Name="ColLocalAddress"
                                    Binding="{Binding LocalAddress}"
                                    Header="{loc:Translate ToolOpenPortsColLocalAddr}"
                                    Width="150"/>
                <DataGridTextColumn x:Name="ColLocalPort"
                                    Binding="{Binding LocalPort}"
                                    Header="{loc:Translate ToolOpenPortsColLocalPort}"
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColRemoteAddress"
                                    Binding="{Binding RemoteAddress}"
                                    Header="{loc:Translate ToolOpenPortsColRemoteAddr}"
                                    Width="150"/>
                <DataGridTextColumn x:Name="ColRemotePort"
                                    Binding="{Binding RemotePort}"
                                    Header="{loc:Translate ToolOpenPortsColRemotePort}"
                                    Width="80"/>
                <DataGridTextColumn x:Name="ColState"
                                    Binding="{Binding State}"
                                    Header="{loc:Translate ToolOpenPortsColState}"
                                    Width="100"/>
                <DataGridTextColumn x:Name="ColPid"
                                    Binding="{Binding Pid}"
                                    Header="{loc:Translate ToolOpenPortsColPid}"
                                    Width="60"/>
                <DataGridTextColumn x:Name="ColProcessName"
                                    Binding="{Binding ProcessName}"
                                    Header="{loc:Translate ToolOpenPortsColProcess}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy"
                        DockPanel.Dock="Right"
                        Content="{loc:Translate ToolBtnCopyToClipboard}"
                        Command="{Binding CopyResultsCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}"
                        Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="TxtStatus"
                           Text="{Binding StatusText}"
                           FontSize="{StaticResource FontSizeSmallCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
