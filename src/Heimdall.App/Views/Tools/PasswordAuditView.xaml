<UserControl x:Class="Heimdall.App.Views.Tools.PasswordAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="{StaticResource ContentAreaMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><!-- Row 0: Password input + policy -->
                    <RowDefinition Height="Auto"/><!-- Row 1: Strength bar -->
                    <RowDefinition Height="Auto"/><!-- Row 2: Criteria breakdown -->
                    <RowDefinition Height="Auto"/><!-- Row 3: Empty state -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: Password input + Policy selector -->
                <StackPanel Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
                    <!-- Password input with show/hide toggle -->
                    <TextBlock x:Name="LblPassword"
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DockPanel Margin="{StaticResource MarginSectionBottom}">
                        <Button x:Name="BtnToggleVisibility" DockPanel.Dock="Right"
                                Content="&#xE7B3;"
                                FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSubtitle}"
                                Click="OnTogglePasswordVisibility"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingInput}" Margin="4,0,0,0"
                                AutomationProperties.Name=""
                                VerticalAlignment="Stretch"/>
                        <Grid>
                            <PasswordBox x:Name="PwdInput"
                                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                         Padding="{StaticResource PaddingInput}"
                                         Background="{DynamicResource CardBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         PasswordChanged="OnPasswordChanged"
                                         AutomationProperties.Name=""/>
                            <TextBox x:Name="TxtPasswordVisible"
                                     Style="{DynamicResource WatermarkTextBoxStyle}"
                                     FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                     Padding="{StaticResource PaddingInput}"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     TextChanged="OnPasswordTextChanged"
                                     Visibility="Collapsed"
                                     AutomationProperties.Name=""/>
                        </Grid>
                    </DockPanel>

                    <!-- Policy selector -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="LblPolicy"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbPolicy" Width="180"
                                  SelectedIndex="0"
                                  SelectionChanged="OnPolicySelectionChanged"
                                  Background="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  AutomationProperties.Name=""/>
                    </StackPanel>
                </StackPanel>

                <!-- ROW 1: Strength bar + score label -->
                <StackPanel x:Name="PanelStrength" Grid.Row="1" Margin="{StaticResource MarginSectionSeparator}" Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="LblStrength"
                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="StrengthScoreLabel"
                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </DockPanel>
                    <Border Height="10" CornerRadius="{StaticResource CornerRadiusSm}"
                            Background="{DynamicResource CardBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="StrengthBarFillColumn" Width="0*"/>
                                <ColumnDefinition x:Name="StrengthBarEmptyColumn" Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="{StaticResource CornerRadiusSm}"
                                    x:Name="StrengthBar"
                                    Background="{DynamicResource ErrorBrush}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ROW 2: Criteria breakdown -->
                <StackPanel x:Name="PanelCriteria" Grid.Row="2" Margin="0,0,0,8" Visibility="Collapsed">
                    <!-- Each criterion row is built dynamically in code-behind -->
                </StackPanel>

                <!-- ROW 3: Empty state message -->
                <TextBlock x:Name="EmptyStateText" Grid.Row="3"
                           FontSize="{StaticResource FontSizeBody}" FontStyle="Italic"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,32,0,0"
                           AutomationProperties.LiveSetting="Polite"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
