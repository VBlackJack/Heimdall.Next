<UserControl x:Class="Heimdall.App.Views.Tools.PasswordGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,12">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="12" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="16,0,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- Row 0: Mode selector -->
            <RowDefinition Height="Auto"/><!-- Row 1: Password output -->
            <RowDefinition Height="Auto"/><!-- Row 2: Strength indicator -->
            <RowDefinition Height="Auto"/><!-- Row 3: Mode-specific options -->
            <RowDefinition Height="Auto"/><!-- Row 4: Layout-safe checkbox -->
            <RowDefinition Height="Auto"/><!-- Row 5: Presets -->
            <RowDefinition Height="Auto"/><!-- Row 6: Advanced expander -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Mode selector ComboBox -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ModeLabel"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbMode" Width="160"
                          SelectedIndex="0"
                          SelectionChanged="OnModeSelectionChanged"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
            <TextBlock x:Name="ModeDescription"
                       FontSize="11" Margin="0,2,0,8"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- ROW 2: Password output with overlaid regenerate/copy buttons -->
        <Border Grid.Row="1" Padding="8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PasswordOutput" Grid.Column="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="16"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         GotFocus="OnPasswordOutputGotFocus"/>
                <StackPanel Grid.Column="1" Orientation="Vertical"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="BtnRegenerate" Click="OnGenerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="10,4" Margin="0,0,0,4" FontSize="11"/>
                    <Button x:Name="BtnCopy" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>


        <!-- ROW 3: Strength indicator + Phonetic -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <Border Height="10" CornerRadius="5" Background="{DynamicResource CardBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="StrengthBarFillColumn" Width="0*"/>
                        <ColumnDefinition x:Name="StrengthBarEmptyColumn" Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="5" x:Name="StrengthBar"
                            Background="{DynamicResource ErrorBrush}"/>
                </Grid>
            </Border>
            <TextBlock x:Name="StrengthLabel"
                       FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <DockPanel Margin="0,2,0,0">
                <TextBlock x:Name="CrackTimeText"
                           FontSize="11" DockPanel.Dock="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StrengthIssues"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource WarningBrush}"
                           TextWrapping="Wrap"/>
            </DockPanel>

            <!-- Phonetic pronunciation (always visible when password <= 32 chars) -->
            <StackPanel x:Name="PanelPhonetic" Margin="0,6,0,0" Visibility="Collapsed">
                <DockPanel>
                    <Button x:Name="BtnCopyPhonetic" DockPanel.Dock="Right" Click="OnCopyPhoneticClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="6,2" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PhoneticLabel"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="PhoneticText"
                           FontSize="11" Margin="0,2,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- ROW 4: Mode-specific core options -->
        <Grid Grid.Row="3" Margin="0,0,0,12">

            <!-- RANDOM mode panel -->
            <StackPanel x:Name="PanelRandom">
                <!-- Quick length buttons -->
                <WrapPanel x:Name="QuickLengthPanel" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="QuickLengthLabel" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="8" Click="OnQuickLength" Tag="8"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                    <Button Content="12" Click="OnQuickLength" Tag="12"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                    <Button Content="16" Click="OnQuickLength" Tag="16"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                    <Button Content="24" Click="OnQuickLength" Tag="24"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                    <Button Content="32" Click="OnQuickLength" Tag="32"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                    <Button Content="64" Click="OnQuickLength" Tag="64"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" Margin="0,0,4,0" FontSize="11" MinWidth="32"/>
                </WrapPanel>
                <!-- Length slider -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="LengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="LengthValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="LengthSlider"
                            Minimum="4" Maximum="128" Value="24"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <!-- 2-column checkbox grid -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="ChkUppercase" IsChecked="True"
                              Grid.Row="0" Grid.Column="0" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkLowercase" IsChecked="True"
                              Grid.Row="0" Grid.Column="1" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkDigits" IsChecked="True"
                              Grid.Row="1" Grid.Column="0" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkSymbols" IsChecked="True"
                              Grid.Row="1" Grid.Column="1" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnSymbolsChanged" Unchecked="OnSymbolsChanged"/>
                </Grid>
            </StackPanel>

            <!-- SYLLABLE mode panel -->
            <StackPanel x:Name="PanelSyllable" Visibility="Collapsed">
                <!-- Base length slider -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock x:Name="SylLengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="SylTotalLengthText"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="8,0,0,0" DockPanel.Dock="Right"/>
                    <TextBlock x:Name="SylLengthValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="SylLengthSlider"
                            Minimum="8" Maximum="32" Value="16"
                            IsSnapToTickEnabled="True" TickFrequency="2"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <!-- Case ComboBox -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="SylCaseLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <ComboBox x:Name="CmbSylCase" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DockPanel>
                <!-- Digits + Specials sliders side by side -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <TextBlock x:Name="SylDigitsLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="55"/>
                        <TextBlock x:Name="SylDigitsValueText"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" Width="30"
                                   TextAlignment="Center" DockPanel.Dock="Right"/>
                        <Slider x:Name="SylDigitsSlider"
                                Minimum="0" Maximum="6" Value="2"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnParameterChanged"
                                VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Grid.Column="2">
                        <TextBlock x:Name="SylSpecialsLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="55"/>
                        <TextBlock x:Name="SylSpecialsValueText"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" Width="30"
                                   TextAlignment="Center" DockPanel.Dock="Right"/>
                        <Slider x:Name="SylSpecialsSlider"
                                Minimum="0" Maximum="6" Value="1"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnParameterChanged"
                                VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
                <!-- Inline placement (visible when digits+specials > 0) -->
                <DockPanel x:Name="SylPlacementPanel" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="SylPlacementLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <ComboBox x:Name="CmbSylPlacement" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DockPanel>
            </StackPanel>

            <!-- PASSPHRASE mode panel -->
            <StackPanel x:Name="PanelPassphrase" Visibility="Collapsed">
                <!-- Word count slider -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="PpWordCountLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <TextBlock x:Name="PpWordCountValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="PpWordCountSlider"
                            Minimum="2" Maximum="8" Value="4"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <!-- Separator + Language on same row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PpSeparatorLabel" Grid.Column="0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtPpSeparator" Grid.Column="1" Text="-" Width="60"
                             FontFamily="Consolas" FontSize="13"
                             Padding="6,4"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TextChanged="OnParameterChanged"/>
                    <TextBlock x:Name="PpLanguageLabel" Grid.Column="3"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbPpLanguage" Grid.Column="4" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
                <!-- Checkboxes -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="ChkPpCapitalize" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkPpDigit" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnPpExtrasChanged" Unchecked="OnPpExtrasChanged"/>
                    <CheckBox x:Name="ChkPpSpecial" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnPpExtrasChanged" Unchecked="OnPpExtrasChanged"/>
                </WrapPanel>
                <!-- Inline placement (visible when digit or special checked) -->
                <DockPanel x:Name="PpPlacementPanel" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="PpPlacementLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <ComboBox x:Name="CmbPpPlacement" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DockPanel>
            </StackPanel>
        </Grid>

        <!-- ROW 5: Layout-safe checkbox (visible in Random and Syllable modes) -->
        <CheckBox x:Name="ChkLayoutSafe" Grid.Row="4" IsChecked="False" Margin="0,0,16,8"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>

        <!-- ROW 6: Presets filtered by mode -->
        <StackPanel x:Name="PanelPresets" Grid.Row="5" Margin="0,0,0,12">
            <TextBlock x:Name="PresetsLabel"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <!-- Random presets -->
            <WrapPanel x:Name="PresetsRandom" Orientation="Horizontal">
                <Button x:Name="BtnPresetPin4" Click="OnPresetPin4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetPin6" Click="OnPresetPin6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetWifi" Click="OnPresetWifi"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetApiKey" Click="OnPresetApiKey"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetMysql" Click="OnPresetMysql"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetSsh" Click="OnPresetSsh"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
            </WrapPanel>
            <!-- Passphrase presets -->
            <WrapPanel x:Name="PresetsPassphrase" Orientation="Horizontal" Visibility="Collapsed">
                <Button x:Name="BtnPresetPassphrase4" Click="OnPresetPassphrase4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetPassphrase6" Click="OnPresetPassphrase6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
            </WrapPanel>
            <!-- Save preset button -->
            <Button x:Name="BtnSavePreset" Click="OnSavePresetClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="8,2" Margin="0,4,0,0" FontSize="11"
                    HorizontalAlignment="Left"/>
            <!-- Saved (custom) presets -->
            <WrapPanel x:Name="PanelCustomPresets" Orientation="Horizontal" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ROW 7: Advanced Expander -->
        <Expander x:Name="AdvancedExpander" Grid.Row="6" IsExpanded="False" Margin="0,0,0,8"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <StackPanel Margin="0,8,0,0">
                <!-- Exclude ambiguous -->
                <CheckBox x:Name="ChkExcludeAmbiguous" IsChecked="False" Margin="0,0,16,8"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                <!-- CLI-safe -->
                <CheckBox x:Name="ChkCliSafe" IsChecked="False" Margin="0,0,16,8"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                <!-- Custom specials (visible when Symbols checked) -->
                <DockPanel x:Name="PanelCustomSpecials" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="CustomSpecialsLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="120"/>
                    <TextBox x:Name="TxtCustomSpecials"
                             FontFamily="Consolas" FontSize="13"
                             Padding="6,4"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TextChanged="OnParameterChanged"/>
                </DockPanel>

                <!-- Password history -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="0,8,0,0" Margin="0,4,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock x:Name="HistoryLabel" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnClearHistory" DockPanel.Dock="Right"
                                    Click="OnClearHistoryClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="6,2" FontSize="10" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <ItemsControl x:Name="HistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <Button DockPanel.Dock="Right" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                Click="OnHistoryCopyClick" Tag="{Binding}"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Padding="4,2" Margin="4,0,0,0" ToolTip="Copy"/>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Expander>
    </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
