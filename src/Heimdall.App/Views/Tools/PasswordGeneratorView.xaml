<UserControl x:Class="Heimdall.App.Views.Tools.PasswordGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="9"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- Row 0: Mode selector -->
            <RowDefinition Height="Auto"/><!-- Row 1: Password output -->
            <RowDefinition Height="Auto"/><!-- Row 2: Strength indicator -->
            <RowDefinition Height="Auto"/><!-- Row 3: Mode-specific options -->
            <RowDefinition Height="Auto"/><!-- Row 4: Layout-safe checkbox -->
            <RowDefinition Height="Auto"/><!-- Row 5: Presets -->
            <RowDefinition Height="Auto"/><!-- Row 6: Advanced options -->
            <RowDefinition Height="Auto"/><!-- Row 7: Password history -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Mode selector ComboBox -->
        <StackPanel Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ModeLabel"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                <ComboBox x:Name="CmbMode" Width="160"
                          TabIndex="0"
                          SelectedIndex="{Binding SelectedModeIndex, Mode=TwoWay}"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
            <TextBlock x:Name="ModeDescription"
                       FontSize="{StaticResource FontSizeCaption}" Margin="0,2,0,8"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- ROW 1: Password output with overlaid regenerate/copy buttons -->
        <StackPanel Grid.Row="1" Margin="{StaticResource MarginLabelBottom}">
            <Border Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PasswordOutput" Grid.Column="0"
                             TabIndex="1"
                             IsReadOnly="True" Focusable="True"
                             Text="{Binding GeneratedPassword, Mode=OneWay}"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeLarge}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             AutomationProperties.LiveSetting="Polite"
                             GotFocus="OnPasswordOutputGotFocus"/>
                    <StackPanel Grid.Column="1" Orientation="Vertical"
                                VerticalAlignment="Center" Margin="{StaticResource MarginInlineControl}">
                        <Button x:Name="BtnRegenerate" Command="{Binding GenerateCoreCommand}"
                                TabIndex="2"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginLabelBottom}" FontSize="{StaticResource FontSizeCaption}"/>
                        <Button x:Name="BtnCopy" Click="OnCopyClick"
                                TabIndex="3"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                </Grid>
            </Border>
            <TextBlock x:Name="KeyboardHintText"
                       FontSize="{StaticResource FontSizeSmallCaption}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ROW 2: Strength indicator + Phonetic -->
        <StackPanel Grid.Row="2" Margin="{StaticResource MarginSectionSeparator}">
            <Border x:Name="StrengthBarBorder" Height="10" CornerRadius="{StaticResource CornerRadiusSm}" Background="{DynamicResource CardBrush}"
                    Visibility="{Binding ShowStrength, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="StrengthBarFillColumn" Width="0*"/>
                        <ColumnDefinition x:Name="StrengthBarEmptyColumn" Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="{StaticResource CornerRadiusSm}" x:Name="StrengthBar"
                            Background="{DynamicResource ErrorBrush}"/>
                </Grid>
            </Border>
            <TextBlock x:Name="StrengthLabel"
                       Text="{Binding StrengthText}"
                       Visibility="{Binding ShowStrength, Converter={StaticResource BoolToVisibilityConverter}}"
                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       AutomationProperties.LiveSetting="Polite"/>
            <DockPanel Margin="0,2,0,0">
                <TextBlock x:Name="CrackTimeText"
                           Text="{Binding CrackTimeText}"
                           FontSize="{StaticResource FontSizeCaption}" DockPanel.Dock="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"/>
                <TextBlock x:Name="StrengthIssues"
                           Text="{Binding IssuesText}"
                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                           Foreground="{DynamicResource WarningTextBrush}"
                           TextWrapping="Wrap"
                           AutomationProperties.LiveSetting="Polite"/>
            </DockPanel>

            <!-- Syllable structure (visible in Syllable mode) -->
            <StackPanel x:Name="PanelSylStructure" Margin="0,6,0,0"
                        Visibility="{Binding ShowSyllableStructure, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="SylStructureLabel"
                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="SylStructureText"
                           Text="{Binding SyllableStructureText}"
                           FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Phonetic pronunciation (always visible when password <= 32 chars) -->
            <StackPanel x:Name="PanelPhonetic" Margin="0,6,0,0"
                        Visibility="{Binding ShowPhonetic, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel>
                    <Button x:Name="BtnCopyPhonetic" DockPanel.Dock="Right" Click="OnCopyPhoneticClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginInlineControl}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PhoneticLabel"
                               FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="PhoneticText"
                           Text="{Binding PhoneticText}"
                           FontSize="{StaticResource FontSizeCaption}" Margin="0,2,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </StackPanel>

        <!-- ROW 3: Mode-specific core options -->
        <Grid Grid.Row="3" Margin="{StaticResource MarginSectionBottom}">

            <!-- RANDOM mode panel -->
            <StackPanel x:Name="PanelRandom"
                        Visibility="{Binding IsRandomMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Quick length buttons -->
                <WrapPanel x:Name="QuickLengthPanel" Orientation="Horizontal" Margin="{StaticResource MarginStackItem}">
                    <TextBlock x:Name="QuickLengthLabel" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <Button x:Name="BtnLen8" Content="8" Click="OnQuickLength" Tag="8"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                    <Button x:Name="BtnLen12" Content="12" Click="OnQuickLength" Tag="12"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                    <Button x:Name="BtnLen16" Content="16" Click="OnQuickLength" Tag="16"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                    <Button x:Name="BtnLen24" Content="24" Click="OnQuickLength" Tag="24"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                    <Button x:Name="BtnLen32" Content="32" Click="OnQuickLength" Tag="32"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                    <Button x:Name="BtnLen64" Content="64" Click="OnQuickLength" Tag="64"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}" MinWidth="32"/>
                </WrapPanel>
                <!-- Length slider -->
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <TextBlock x:Name="LengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="LengthValueText"
                               Text="{Binding Length}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="LengthSlider"
                            TabIndex="4"
                            Minimum="4" Maximum="128"
                            Value="{Binding Length, Mode=TwoWay}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <!-- 2-column checkbox grid -->
                <Grid Margin="{StaticResource MarginLabelBottom}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="ChkUppercase" IsChecked="{Binding IncludeUppercase, Mode=TwoWay}"
                              TabIndex="5"
                              Grid.Row="0" Grid.Column="0" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkLowercase" IsChecked="{Binding IncludeLowercase, Mode=TwoWay}"
                              TabIndex="6"
                              Grid.Row="0" Grid.Column="1" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkDigits" IsChecked="{Binding IncludeDigits, Mode=TwoWay}"
                              TabIndex="7"
                              Grid.Row="1" Grid.Column="0" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkSymbols" IsChecked="{Binding IncludeSymbols, Mode=TwoWay}"
                              TabIndex="8"
                              Grid.Row="1" Grid.Column="1" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
            </StackPanel>

            <!-- SYLLABLE mode panel -->
            <StackPanel x:Name="PanelSyllable"
                        Visibility="{Binding IsSyllableMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Base length slider -->
                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <TextBlock x:Name="SylLengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="SylTotalLengthText"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                               Margin="{StaticResource MarginInlineControl}" DockPanel.Dock="Right"/>
                    <TextBlock x:Name="SylLengthValueText"
                               Text="{Binding SyllableLength}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="SylLengthSlider"
                            Minimum="8" Maximum="32"
                            Value="{Binding SyllableLength, Mode=TwoWay}"
                            IsSnapToTickEnabled="True" TickFrequency="2"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="SylStepNote"
                           FontSize="{StaticResource FontSizeSmallCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="80,0,0,4"/>
                <!-- Separator + Case on same row -->
                <Grid Margin="{StaticResource MarginSectionBottom}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SylSeparatorLabel" Grid.Column="0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <TextBox x:Name="TxtSylSeparator" Grid.Column="1" Width="60" MaxLength="4"
                             Text="{Binding SyllableSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="SylCaseLabel" Grid.Column="3"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <ComboBox x:Name="CmbSylCase" Grid.Column="4" Width="140"
                              SelectedIndex="{Binding SyllableCaseIndex, Mode=TwoWay}"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
                <!-- CVC checkbox -->
                <CheckBox x:Name="ChkSylCvc" IsChecked="{Binding SyllableCvc, Mode=TwoWay}" Margin="{StaticResource MarginLabelBottom}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Checked="OnSylCvcChanged" Unchecked="OnSylCvcChanged"/>
                <TextBlock x:Name="SylCvcHint"
                           FontSize="{StaticResource FontSizeSmallCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="20,0,0,8"/>
                <!-- Digits + Specials sliders side by side -->
                <Grid Margin="{StaticResource MarginSectionBottom}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <TextBlock x:Name="SylDigitsLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="55"/>
                        <TextBlock x:Name="SylDigitsValueText"
                                   Text="{Binding SyllableDigits}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}"
                                   VerticalAlignment="Center" Width="30"
                                   TextAlignment="Center" DockPanel.Dock="Right"/>
                        <Slider x:Name="SylDigitsSlider"
                                Minimum="0" Maximum="6"
                                Value="{Binding SyllableDigits, Mode=TwoWay}"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Grid.Column="2">
                        <TextBlock x:Name="SylSpecialsLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="55"/>
                        <TextBlock x:Name="SylSpecialsValueText"
                                   Text="{Binding SyllableSpecials}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}"
                                   VerticalAlignment="Center" Width="30"
                                   TextAlignment="Center" DockPanel.Dock="Right"/>
                        <Slider x:Name="SylSpecialsSlider"
                                Minimum="0" Maximum="6"
                                Value="{Binding SyllableSpecials, Mode=TwoWay}"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
                <!-- Inline placement (visible when digits+specials > 0) -->
                <StackPanel x:Name="SylPlacementPanel" Orientation="Horizontal" Margin="{StaticResource MarginStackItem}"
                            Visibility="{Binding ShowSyllablePlacement, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock x:Name="SylPlacementLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <ComboBox x:Name="CmbSylPlacement" Width="140"
                              SelectedIndex="{Binding SyllablePlacementIndex, Mode=TwoWay}"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- PASSPHRASE mode panel -->
            <StackPanel x:Name="PanelPassphrase"
                        Visibility="{Binding IsPassphraseMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Word count slider -->
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <TextBlock x:Name="PpWordCountLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <TextBlock x:Name="PpWordCountValueText"
                               Text="{Binding PassphraseWordCount}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="{StaticResource FontSizeSubtitle}"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="PpWordCountSlider"
                            Minimum="2" Maximum="8"
                            Value="{Binding PassphraseWordCount, Mode=TwoWay}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <!-- Separator + Language on same row -->
                <Grid Margin="{StaticResource MarginSectionBottom}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PpSeparatorLabel" Grid.Column="0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <TextBox x:Name="TxtPpSeparator" Grid.Column="1" Width="60" MaxLength="4"
                             Text="{Binding PassphraseSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="PpLanguageLabel" Grid.Column="3"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <ComboBox x:Name="CmbPpLanguage" Grid.Column="4" Width="140"
                              SelectedIndex="{Binding PassphraseLanguageIndex, Mode=TwoWay}"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
                <!-- Checkboxes -->
                <WrapPanel Orientation="Horizontal" Margin="{StaticResource MarginStackItem}">
                    <CheckBox x:Name="ChkPpCapitalize" IsChecked="{Binding PassphraseCapitalize, Mode=TwoWay}" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkPpDigit" IsChecked="{Binding PassphraseAddDigit, Mode=TwoWay}" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkPpSpecial" IsChecked="{Binding PassphraseAddSpecial, Mode=TwoWay}" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </WrapPanel>
                <!-- Inline placement (visible when digit or special checked) -->
                <StackPanel x:Name="PpPlacementPanel" Orientation="Horizontal" Margin="{StaticResource MarginStackItem}"
                            Visibility="{Binding ShowPassphrasePlacement, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock x:Name="PpPlacementLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineSm}"/>
                    <ComboBox x:Name="CmbPpPlacement" Width="140"
                              SelectedIndex="{Binding PassphrasePlacementIndex, Mode=TwoWay}"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ROW 4: Layout-safe checkbox (visible in Random and Syllable modes) -->
        <CheckBox x:Name="ChkLayoutSafe" Grid.Row="4" IsChecked="{Binding LayoutSafe, Mode=TwoWay}" Margin="0,0,16,8"
                  Visibility="{Binding ShowLayoutSafe, Converter={StaticResource BoolToVisibilityConverter}}"
                  Foreground="{DynamicResource TextPrimaryBrush}"/>

        <!-- ROW 5: Presets filtered by mode -->
        <StackPanel x:Name="PanelPresets" Grid.Row="5" Margin="{StaticResource MarginSectionBottom}">
            <TextBlock x:Name="PresetsLabel"
                       FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="{StaticResource MarginLabelBottom}"/>
            <!-- Random presets -->
            <WrapPanel x:Name="PresetsRandom" Orientation="Horizontal"
                       Visibility="{Binding IsRandomMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button x:Name="BtnPresetPin4" Click="OnPresetPin4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetPin6" Click="OnPresetPin6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetWifi" Click="OnPresetWifi"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetApiKey" Click="OnPresetApiKey"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetMysql" Click="OnPresetMysql"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetSsh" Click="OnPresetSsh"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
            </WrapPanel>
            <!-- Passphrase presets -->
            <WrapPanel x:Name="PresetsPassphrase" Orientation="Horizontal"
                       Visibility="{Binding IsPassphraseMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button x:Name="BtnPresetPassphrase4" Click="OnPresetPassphrase4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetPassphrase6" Click="OnPresetPassphrase6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
            </WrapPanel>
            <!-- Syllable presets -->
            <WrapPanel x:Name="PresetsSyllable" Orientation="Horizontal"
                       Visibility="{Binding IsSyllableMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button x:Name="BtnPresetSylEasy" Click="OnPresetSylEasy"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetSylBalanced" Click="OnPresetSylBalanced"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
                <Button x:Name="BtnPresetSylStrong" Click="OnPresetSylStrong"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,6,4" FontSize="{StaticResource FontSizeCaption}"/>
            </WrapPanel>
            <!-- Save preset button -->
            <Button x:Name="BtnSavePreset" Click="OnSavePresetClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPreset}" Margin="0,4,0,0" FontSize="{StaticResource FontSizeCaption}"
                    HorizontalAlignment="Left"/>
            <!-- Saved (custom) presets -->
            <WrapPanel x:Name="PanelCustomPresets" Orientation="Horizontal" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ROW 6: Advanced Expander -->
        <Expander x:Name="AdvancedExpander" Grid.Row="6" IsExpanded="False" Margin="{StaticResource MarginStackItem}"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <StackPanel Margin="{StaticResource MarginSubsectionTop}">
                <!-- Exclude ambiguous -->
                <CheckBox x:Name="ChkExcludeAmbiguous" IsChecked="{Binding ExcludeAmbiguous, Mode=TwoWay}" Margin="0,0,16,8"
                          Visibility="{Binding ShowExcludeAmbiguous, Converter={StaticResource BoolToVisibilityConverter}}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <!-- CLI-safe -->
                <CheckBox x:Name="ChkCliSafe" IsChecked="{Binding CliSafe, Mode=TwoWay}" Margin="0,0,16,8"
                          Visibility="{Binding HasActiveSpecials, Converter={StaticResource BoolToVisibilityConverter}}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <!-- Custom specials (visible when Symbols checked) -->
                <DockPanel x:Name="PanelCustomSpecials" Margin="{StaticResource MarginStackItem}"
                           Visibility="{Binding HasActiveSpecials, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock x:Name="CustomSpecialsLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="120"/>
                    <TextBox x:Name="TxtCustomSpecials" MaxLength="64"
                             Text="{Binding CustomSpecials, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </DockPanel>
                <!-- Clipboard auto-clear -->
                <CheckBox x:Name="ChkClipboardAutoClear" IsChecked="{Binding ClipboardAutoClear, Mode=TwoWay}" Margin="0,0,16,8"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
        </Expander>

        <!-- ROW 7: Password history -->
        <Border Grid.Row="7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="0,8,0,0" Margin="0,4,0,0">
            <StackPanel>
                <DockPanel Margin="{StaticResource MarginLabelBottom}">
                    <TextBlock x:Name="HistoryLabel" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="BtnClearHistory" DockPanel.Dock="Right"
                            Click="OnClearHistoryClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Right"/>
                </DockPanel>
                <TextBlock x:Name="HistoryEmptyText"
                           Visibility="{Binding IsHistoryEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                           FontSize="{StaticResource FontSizeCaption}" FontStyle="Italic"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
                <ItemsControl x:Name="HistoryList"
                              ItemsSource="{Binding PasswordHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,1">
                                <Button DockPanel.Dock="Right" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeCaption}"
                                        Click="OnHistoryCopyClick" Tag="{Binding}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Padding="{StaticResource PaddingButtonHelp}" Margin="{StaticResource MarginInlineStart}"
                                        Loaded="OnHistoryCopyButtonLoaded"/>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
