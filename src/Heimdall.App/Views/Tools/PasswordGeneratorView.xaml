<UserControl x:Class="Heimdall.App.Views.Tools.PasswordGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             KeyDown="OnKeyDown">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="TitleText" Grid.Row="0"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12"/>

        <!-- Mode selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RbModeRandom" GroupName="Mode"
                         IsChecked="True" Margin="0,0,16,0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Checked="OnModeChanged"/>
            <RadioButton x:Name="RbModeSyllable" GroupName="Mode"
                         Margin="0,0,16,0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Checked="OnModeChanged"/>
            <RadioButton x:Name="RbModePassphrase" GroupName="Mode"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Checked="OnModeChanged"/>
        </StackPanel>

        <!-- Presets -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock x:Name="PresetsLabel"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
                <Button x:Name="BtnPresetPin4" Click="OnPresetPin4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetPin6" Click="OnPresetPin6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetWifi" Click="OnPresetWifi"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetApiKey" Click="OnPresetApiKey"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetMysql" Click="OnPresetMysql"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
                <Button x:Name="BtnPresetPassphrase4" Click="OnPresetPassphrase4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,2" Margin="0,0,6,4" FontSize="11"/>
            </WrapPanel>
        </StackPanel>

        <!-- Password output -->
        <Border Grid.Row="3" Padding="8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="4"
                Margin="0,0,0,12">
            <DockPanel>
                <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="10,4" Margin="8,0,0,0"
                        VerticalAlignment="Center"/>
                <Button x:Name="BtnGenerate" DockPanel.Dock="Right"
                        Click="OnGenerateClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="10,4" Margin="8,0,0,0"
                        VerticalAlignment="Center"/>
                <TextBox x:Name="PasswordOutput"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="16"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"
                         VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Strength indicator -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Height="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="StrengthBarFillColumn" Width="0*"/>
                        <ColumnDefinition x:Name="StrengthBarEmptyColumn" Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="3" x:Name="StrengthBar"
                            Background="{DynamicResource ErrorBrush}"/>
                    <Border Grid.Column="1" CornerRadius="3"
                            Background="{DynamicResource CardBrush}"/>
                </Grid>
                <TextBlock x:Name="StrengthLabel" Grid.Column="1"
                           FontSize="11" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="StrengthIssues"
                       FontSize="11" Margin="0,4,0,0"
                       Foreground="{DynamicResource WarningBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Mode-specific options -->
        <Grid Grid.Row="5" Margin="0,0,0,12">

            <!-- Random mode panel -->
            <StackPanel x:Name="PanelRandom">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="LengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="LengthValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="LengthSlider"
                            Minimum="4" Maximum="128" Value="24"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <WrapPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkUppercase" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkLowercase" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkDigits" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkSymbols" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnSymbolsChanged" Unchecked="OnSymbolsChanged"/>
                    <CheckBox x:Name="ChkExcludeAmbiguous" IsChecked="False" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkCliSafe" IsChecked="False" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                </WrapPanel>
                <DockPanel x:Name="PanelCustomSpecials" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="CustomSpecialsLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="120"/>
                    <TextBox x:Name="TxtCustomSpecials"
                             FontFamily="Consolas" FontSize="13"
                             Padding="6,4"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TextChanged="OnParameterChanged"/>
                </DockPanel>
            </StackPanel>

            <!-- Syllable mode panel -->
            <StackPanel x:Name="PanelSyllable" Visibility="Collapsed">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="SylLengthLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="SylLengthValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="SylLengthSlider"
                            Minimum="8" Maximum="32" Value="16"
                            IsSnapToTickEnabled="True" TickFrequency="2"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="SylTotalLengthText" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="SylCaseLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <ComboBox x:Name="CmbSylCase" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="SylDigitsLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="SylDigitsValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="SylDigitsSlider"
                            Minimum="0" Maximum="6" Value="2"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="SylSpecialsLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="80"/>
                    <TextBlock x:Name="SylSpecialsValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="SylSpecialsSlider"
                            Minimum="0" Maximum="6" Value="1"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>

            <!-- Passphrase mode panel -->
            <StackPanel x:Name="PanelPassphrase" Visibility="Collapsed">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="PpWordCountLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <TextBlock x:Name="PpWordCountValueText"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Width="40"
                               TextAlignment="Center" DockPanel.Dock="Right"/>
                    <Slider x:Name="PpWordCountSlider"
                            Minimum="2" Maximum="8" Value="4"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnParameterChanged"
                            VerticalAlignment="Center"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="PpSeparatorLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <TextBox x:Name="TxtPpSeparator" Text="-" Width="60"
                             FontFamily="Consolas" FontSize="13"
                             Padding="6,4"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TextChanged="OnParameterChanged"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock x:Name="PpLanguageLabel"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Width="100"/>
                    <ComboBox x:Name="CmbPpLanguage" Width="140"
                              SelectedIndex="0"
                              SelectionChanged="OnParameterChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DockPanel>
                <WrapPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkPpCapitalize" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkPpDigit" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                    <CheckBox x:Name="ChkPpSpecial" IsChecked="True" Margin="0,0,16,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnParameterChanged" Unchecked="OnParameterChanged"/>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- Placement (shared by Syllable and Passphrase modes) -->
        <StackPanel x:Name="PanelPlacement" Grid.Row="6" Margin="0,0,0,12" Visibility="Collapsed">
            <DockPanel>
                <TextBlock x:Name="SylPlacementLabel"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Width="80"/>
                <ComboBox x:Name="CmbSylPlacement" Width="140"
                          SelectedIndex="0"
                          SelectionChanged="OnParameterChanged"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </DockPanel>
        </StackPanel>

        <!-- Entropy info -->
        <TextBlock x:Name="EntropyText" Grid.Row="7"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <!-- Phonetic pronunciation -->
        <StackPanel x:Name="PanelPhonetic" Grid.Row="8" Margin="0,0,0,8"
                    Visibility="Collapsed">
            <TextBlock x:Name="PhoneticLabel"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,2"/>
            <TextBlock x:Name="PhoneticText"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Keyboard layout display -->
        <StackPanel x:Name="PanelKeyboardLayout" Grid.Row="9" Margin="0,0,0,8"
                    Visibility="Collapsed">
            <DockPanel Margin="0,0,0,4">
                <TextBlock x:Name="KeyboardLayoutLabel"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbKeyboardLayout" Width="100"
                          SelectedIndex="0"
                          SelectionChanged="OnKeyboardLayoutChanged"
                          Background="{DynamicResource CardBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          FontSize="11"/>
            </DockPanel>
            <TextBlock x:Name="KeyboardLayoutText"
                       FontSize="11" FontFamily="Consolas"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
