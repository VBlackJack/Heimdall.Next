<UserControl x:Class="Heimdall.App.Views.Tools.PingToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtPingCount" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="12,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Right"
                           HorizontalAlignment="Right"/>
                <WrapPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblHost" Text=""
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtHost" Text="" MinWidth="140"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Tag="hostname or IP"
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <Button x:Name="BtnToggle" Content=""
                                Click="OnToggleClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnClear" Content=""
                                Click="OnClearClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnCopyLog" Content=""
                                Click="OnCopyLogClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnExportCsv" Content=""
                                Click="OnExportCsvClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblInterval" Text=""
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="CmbInterval" Width="70"
                                  SelectedIndex="1"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  AutomationProperties.Name="">
                            <ComboBoxItem x:Name="Ping500ms" Content="" Tag="500"/>
                            <ComboBoxItem x:Name="Ping1s" Content="" Tag="1000"/>
                            <ComboBoxItem x:Name="Ping2s" Content="" Tag="2000"/>
                            <ComboBoxItem x:Name="Ping5s" Content="" Tag="5000"/>
                            <ComboBoxItem x:Name="Ping10s" Content="" Tag="10000"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblTimeout" Text=""
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="TxtTimeout" Text="2000" Width="60"
                                 FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                        <TextBlock x:Name="LblCount" Text=""
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="TxtCount" Text="0" Width="50"
                                 FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- Graph -->
            <Border Grid.Row="0" Margin="8,8,8,4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                <Grid>
                    <Canvas x:Name="GraphCanvas" ClipToBounds="True"
                            SizeChanged="OnGraphCanvasSizeChanged"/>
                    <!-- Y-axis labels -->
                    <TextBlock x:Name="TxtYMax" Text="" FontSize="{StaticResource FontSizeCaption}"
                               FontFamily="Consolas" Margin="4,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtYMid" Text="" FontSize="{StaticResource FontSizeCaption}"
                               FontFamily="Consolas" Margin="4,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtYMin" Text="0 ms" FontSize="{StaticResource FontSizeCaption}"
                               FontFamily="Consolas" Margin="4,0,0,4"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <!-- Log -->
            <Border Grid.Row="2" Margin="8,4,8,8"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="8,4">
                    <TextBlock x:Name="TxtLog" Text=""
                               FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Stats Bar -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LblMin" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtMin" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource SuccessTextBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblAvg" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtAvg" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblMax" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtMax" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource WarningTextBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblJitter" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtJitter" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblLoss" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtLoss" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource ErrorTextBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
