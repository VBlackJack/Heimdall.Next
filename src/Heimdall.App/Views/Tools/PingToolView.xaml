<UserControl x:Class="Heimdall.App.Views.Tools.PingToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtPingCount" Text=""
                           FontSize="12" Margin="12,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Right"
                           HorizontalAlignment="Right"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtHost" Text="" Width="240"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                    <Button x:Name="BtnToggle" Content=""
                            Click="OnToggleClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- Graph -->
            <Border Grid.Row="0" Margin="8,8,8,4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Canvas x:Name="GraphCanvas" ClipToBounds="True"
                            SizeChanged="OnGraphCanvasSizeChanged"/>
                    <!-- Y-axis labels -->
                    <TextBlock x:Name="TxtYMax" Text="" FontSize="10"
                               FontFamily="Consolas" Margin="4,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtYMid" Text="" FontSize="10"
                               FontFamily="Consolas" Margin="4,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="0 ms" FontSize="10"
                               FontFamily="Consolas" Margin="4,0,0,4"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <!-- Log -->
            <Border Grid.Row="2" Margin="8,4,8,8"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="8,4">
                    <TextBlock x:Name="TxtLog" Text=""
                               FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Stats Bar -->
        <Border Grid.Row="2" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LblMin" Text="" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtMin" Text="—" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="12"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblAvg" Text="" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtAvg" Text="—" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="12"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblMax" Text="" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtMax" Text="—" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold"/>

                <TextBlock Text="  |  " FontSize="12"
                           Foreground="{DynamicResource BorderBrush}"/>

                <TextBlock x:Name="LblLoss" Text="" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock x:Name="TxtLoss" Text="—" FontSize="12" FontFamily="Consolas"
                           Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
