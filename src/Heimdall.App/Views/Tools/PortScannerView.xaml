<UserControl x:Class="Heimdall.App.Views.Tools.PortScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="6,2" FontSize="12" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtHost" Text="" Width="200"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                    <TextBox x:Name="TxtPorts" Text="22,80,443,3389,5900,8080" Width="260"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6" Margin="8,0,0,0"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="11" VerticalAlignment="Center" Margin="12,0,4,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbRouteVia" Width="180"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"/>
                    <Button x:Name="BtnScan" Content=""
                            Click="OnScanClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Presets + filter row -->
        <Border Grid.Row="1" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <CheckBox x:Name="ChkOpenOnly" DockPanel.Dock="Right"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="12,0,0,0"
                          Checked="OnOpenOnlyChanged" Unchecked="OnOpenOnlyChanged"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPresetWeb" Click="OnPresetClick" Tag="80,443,8080,8443"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnPresetSshRemote" Click="OnPresetClick" Tag="22,23,3389,5900"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnPresetDatabase" Click="OnPresetClick" Tag="3306,5432,1433,6379,27017"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnPresetCommon" Click="OnPresetClick" Tag="21,22,23,25,53,80,110,143,443,993,995,3389,5900,8080"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                    <Button x:Name="BtnPresetFull" Click="OnPresetClick" Tag="1-1024"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,3" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Validation error -->
        <TextBlock x:Name="TxtError" Grid.Row="2" Text="" Visibility="Collapsed"
                   FontSize="12" Margin="12,4,12,0"
                   Foreground="{DynamicResource ErrorBrush}"/>

        <!-- Progress bar with percentage overlay -->
        <Grid Grid.Row="2" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar x:Name="ScanProgress"
                         Height="20" Minimum="0" Maximum="100"
                         IsIndeterminate="False"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgressPercent" Text="0%"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="  —  " FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtProgressCount" Text="0 / 0"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Results DataGrid -->
        <Border Grid.Row="3" Margin="8"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColPort" Binding="{Binding Port}" Width="80"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColService" Binding="{Binding Service}" Width="150"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColResponseTime" Binding="{Binding ResponseTime}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColBanner" Binding="{Binding Banner}" Width="*"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="4" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnExportCsv" Content=""
                        Click="OnExportCsvClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" DockPanel.Dock="Right" Margin="4,0,0,0"
                        VerticalAlignment="Center"/>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblOpen" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtOpen" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="12"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblClosed" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtClosed" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="12"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblTotal" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtTotal" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
