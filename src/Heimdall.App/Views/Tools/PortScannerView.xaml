<UserControl x:Class="Heimdall.App.Views.Tools.PortScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtHost" Text="" Width="200"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                    <TextBox x:Name="TxtPorts" Text="22,80,443,3389,5900,8080" Width="260"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6" Margin="8,0,0,0"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                    <Button x:Name="BtnScan" Content=""
                            Click="OnScanClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Validation error -->
        <TextBlock x:Name="TxtError" Grid.Row="1" Text="" Visibility="Collapsed"
                   FontSize="12" Margin="12,4,12,0"
                   Foreground="{DynamicResource ErrorBrush}"/>

        <!-- Progress bar -->
        <ProgressBar x:Name="ScanProgress" Grid.Row="1"
                     Height="4" Minimum="0" Maximum="100"
                     IsIndeterminate="False" Visibility="Collapsed"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="{DynamicResource SurfaceBrush}"/>

        <!-- Results DataGrid -->
        <Border Grid.Row="2" Margin="8"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColPort" Binding="{Binding Port}" Width="80"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColService" Binding="{Binding Service}" Width="150"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColResponseTime" Binding="{Binding ResponseTime}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="3" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblOpen" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtOpen" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="12"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblClosed" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtClosed" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="12"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblTotal" Text="" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtTotal" Text="—" FontSize="12" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
