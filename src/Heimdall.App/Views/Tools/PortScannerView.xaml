<UserControl x:Class="Heimdall.App.Views.Tools.PortScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"
                        TabIndex="13"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Input strip -->
        <Border Grid.Row="2" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginFilterGroup}">
                    <TextBlock x:Name="LblHost" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginLabelInline}"/>
                    <TextBox x:Name="TxtHost" Text="" MinWidth="140"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             TabIndex="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginFilterGroup}">
                    <TextBlock x:Name="LblPorts" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginLabelInline}"/>
                    <TextBox x:Name="TxtPorts" Text="" MinWidth="140"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             TabIndex="1"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginFilterGroup}">
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineXs}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbRouteVia" Width="180"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              TabIndex="2"/>
                </StackPanel>

                <Button x:Name="BtnScan" Content=""
                        Click="OnScanClick"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="0,2,0,2"
                        VerticalAlignment="Center"
                        TabIndex="3"/>
                <Button x:Name="BtnStop" Content=""
                        Click="OnStopScanClick"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                        IsEnabled="{Binding IsScanning}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        Foreground="{DynamicResource ErrorBrush}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="0,2,0,2"
                        VerticalAlignment="Center"
                        TabIndex="3"/>
            </WrapPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"
                        TabIndex="14"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Presets + filter row -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <WrapPanel Margin="0,0,12,0">
                    <Button x:Name="BtnPresetWeb" Click="OnPresetClick" Tag="80,443,8080,8443"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}"
                            TabIndex="4"/>
                    <Button x:Name="BtnPresetSshRemote" Click="OnPresetClick" Tag="22,23,3389,5900"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}"
                            TabIndex="5"/>
                    <Button x:Name="BtnPresetDatabase" Click="OnPresetClick" Tag="3306,5432,1433,6379,27017"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}"
                            TabIndex="6"/>
                    <Button x:Name="BtnPresetCommon" Click="OnPresetClick" Tag="21,22,23,25,53,80,110,143,443,993,995,3389,5900,8080"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" Margin="{StaticResource MarginInlineXs}" FontSize="{StaticResource FontSizeCaption}"
                            TabIndex="7"/>
                    <Button x:Name="BtnPresetFull" Click="OnPresetClick" Tag="1-1024"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPreset}" FontSize="{StaticResource FontSizeCaption}"
                            TabIndex="8"/>
                </WrapPanel>

                <CheckBox x:Name="ChkOpenOnly"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="0,4,0,0"
                          Checked="OnOpenOnlyChanged" Unchecked="OnOpenOnlyChanged"
                          TabIndex="9"/>
            </WrapPanel>
        </Border>

        <!-- Validation error -->
        <TextBlock x:Name="TxtError" Grid.Row="4" Text=""
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="12,4,12,0"/>

        <!-- Progress bar with percentage overlay -->
        <Grid Grid.Row="4" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar x:Name="ScanProgress"
                         Style="{StaticResource ToolDeterminateProgressBarStyle}"
                         IsIndeterminate="False"
                         Background="{DynamicResource SurfaceBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgressPercent" Text="0%"
                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="  |  " FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtProgressCount" Text="0 / 0"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Empty state hint -->
        <Border x:Name="EmptyStatePanel" Grid.Row="5"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE71E;" Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Results DataGrid -->
        <Border x:Name="ResultsPanel" Grid.Row="5"
                Style="{StaticResource ToolResultsCardStyle}"
                Margin="{StaticResource SpacingSm}"
                Padding="0">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      TabIndex="10"
                      AutomationProperties.LiveSetting="Polite">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColPort" Binding="{Binding Port}" Width="80"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColService" Binding="{Binding Service}" Width="150"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColResponseTime" Binding="{Binding ResponseTime}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColBanner" Binding="{Binding Banner}" Width="*"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="6" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtOpen" Text="-" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessTextBrush}" FontWeight="SemiBold"
                               Margin="{StaticResource MarginInlineXs}"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="TxtClosed" Text="-" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource ErrorTextBrush}" FontWeight="SemiBold"
                               Margin="{StaticResource MarginInlineXs}"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="TxtTotal" Text="-" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"
                               Margin="{StaticResource MarginInlineXs}"/>
                </WrapPanel>

                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="{StaticResource MarginSubsectionTop}">
                    <Button x:Name="BtnCopy" Content=""
                            Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            VerticalAlignment="Center"
                            TabIndex="11"/>
                    <Button x:Name="BtnExportCsv" Content=""
                            Click="OnExportCsvClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            TabIndex="12"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
