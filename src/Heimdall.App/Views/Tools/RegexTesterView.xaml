<UserControl x:Class="Heimdall.App.Views.Tools.RegexTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pattern input -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="PatternLabel" DockPanel.Dock="Top"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"/>
            <TextBox x:Name="PatternText"
                     Style="{DynamicResource WatermarkTextBoxStyle}"
                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="6"
                     Tag="regex pattern"
                     TextChanged="OnPatternTextChanged"
/>
        </DockPanel>

        <!-- Regex flags -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="ChkIgnoreCase"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,16,0"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
            <CheckBox x:Name="ChkMultiline"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,16,0"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
            <CheckBox x:Name="ChkSingleline"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
        </StackPanel>

        <!-- Test text input -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TestTextLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"/>
            <Grid Grid.Row="1">
                <TextBox x:Name="TestText"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="6"
                         Tag="test string"
                         TextChanged="OnTestTextChanged"
/>
                <RichTextBox x:Name="HighlightDisplay"
                             IsReadOnly="True" IsHitTestVisible="False"
                             Visibility="Collapsed"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Padding="6"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             />
            </Grid>
        </Grid>

        <!-- Match count -->
        <DockPanel Grid.Row="3" Margin="0,8">
            <TextBlock x:Name="MatchCountText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" DockPanel.Dock="Right"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Empty state hint (hidden once matches appear) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="4"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,8,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"
                           AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Matches output -->
        <Grid x:Name="MatchesPanel" Grid.Row="4" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="MatchesLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"/>
            <ListBox x:Name="MatchesList" Grid.Row="1"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                     AutomationProperties.LiveSetting="Polite"
/>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="5" Margin="0,8,0,0">
            <Button x:Name="BtnCopyMatches" DockPanel.Dock="Right"
                    Click="OnCopyMatchesClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}"/>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
