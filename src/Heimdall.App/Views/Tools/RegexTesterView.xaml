<UserControl x:Class="Heimdall.App.Views.Tools.RegexTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pattern input -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="PatternLabel" DockPanel.Dock="Top"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="PatternText"
                     FontFamily="Consolas" FontSize="13"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="6"
                     TextChanged="OnPatternTextChanged"
/>
        </DockPanel>

        <!-- Regex flags -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="ChkIgnoreCase"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,16,0"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
            <CheckBox x:Name="ChkMultiline"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,16,0"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
            <CheckBox x:Name="ChkSingleline"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Checked="OnFlagChanged" Unchecked="OnFlagChanged"
/>
        </StackPanel>

        <!-- Test text input -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TestTextLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TestText" Grid.Row="1"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="13"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="6"
                     TextChanged="OnTestTextChanged"
/>
        </Grid>

        <!-- Match count -->
        <DockPanel Grid.Row="3" Margin="0,8">
            <TextBlock x:Name="MatchCountText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" DockPanel.Dock="Right"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Matches output -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="MatchesLabel" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <ListBox x:Name="MatchesList" Grid.Row="1"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     FontFamily="Consolas" FontSize="13"
/>
        </Grid>

        <!-- Status bar -->
        <DockPanel Grid.Row="5" Margin="0,8,0,0">
            <Button x:Name="BtnCopyMatches" DockPanel.Dock="Right"
                    Click="OnCopyMatchesClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="10,4"/>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
