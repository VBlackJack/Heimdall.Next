<UserControl x:Class="Heimdall.App.Views.Tools.SecNumCloudAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="11"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Row 2: Input section -->
        <Border Grid.Row="2" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Scope input + auto-detect + options -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="LblScope" Text="" FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="{StaticResource MarginLabelBottom}"/>
                    <TextBox x:Name="TxtScope" AcceptsReturn="True" TextWrapping="Wrap"
                             TabIndex="0"
                             Height="60" VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag=""
                             FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             TextChanged="OnScopeTextChanged"/>
                    <!-- Retained non-token 4px offset: no CommonControls token matches a top-only caption gap here. -->
                    <TextBlock x:Name="TxtDetected" Text="" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>

                    <!-- Options row -->
                    <WrapPanel Margin="{StaticResource MarginSubsectionTop}" VerticalAlignment="Center">
                        <TextBlock x:Name="LblDepth" Text="" FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="{StaticResource MarginLabelInline}"/>
                        <ComboBox x:Name="CmbDepth" Width="140"
                                  TabIndex="1"
                                  Background="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  VerticalAlignment="Center"/>

                        <!-- Retained non-token 16px inline offsets: existing spacing tokens do not cover this asymmetric WrapPanel layout exactly. -->
                        <CheckBox x:Name="ChkNetwork" IsChecked="True"
                                  TabIndex="2"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkCrypto" IsChecked="True"
                                  TabIndex="3"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkAccess" IsChecked="True"
                                  TabIndex="4"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="ChkOperations" IsChecked="True"
                                  TabIndex="5"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="16,0,0,0"/>

                        <!-- Retained mixed 16px/4px inline spacing: no exact token matches the route label + selector alignment. -->
                        <TextBlock x:Name="LblRouteVia" Text=""
                                   FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" Margin="16,0,4,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ComboBox x:Name="CmbRouteVia" Width="180"
                                  TabIndex="6"
                                  SelectionChanged="OnRouteViaChanged"
                                  Background="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  VerticalAlignment="Center"/>

                        <Button x:Name="BtnStartStop" Content=""
                                TabIndex="7"
                                Click="OnStartStopClick"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="16,0,0,0"
                                VerticalAlignment="Center"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Progress -->
        <StackPanel Grid.Row="3" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar x:Name="AuditProgress" Height="4"
                         Minimum="0" Maximum="100"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"/>
            <!-- Retained non-token asymmetric dock spacing: no exact CommonControls token maps to 12,2,12,4. -->
            <DockPanel Margin="12,2,12,4">
                <TextBlock x:Name="TxtPhase" Text="" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtCurrentCheck" Text="" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </StackPanel>

        <!-- Retained non-token inline error spacing: ToolInlineErrorTextStyle does not expose a matching top/bottom token. -->
        <TextBlock x:Name="TxtError" Grid.Row="4" Text=""
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="12,8,12,0"/>

        <!-- Row 3: Compliance badge -->
        <Border x:Name="ComplianceBadgePanel" Grid.Row="5" Visibility="Collapsed"
                Padding="{StaticResource PaddingSectionCard}" Margin="{StaticResource SpacingSm}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCompliancePercent" Text=""
                               FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                               VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="LblCompliance" Text=""
                               FontSize="{StaticResource FontSizeSubtitle}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="{StaticResource MarginInlineControl}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Retained non-token trailing 12px gaps: no exact token matches this horizontal metric summary spacing. -->
                    <TextBlock x:Name="TxtPassCount" Text="" FontSize="{StaticResource FontSizeBody}"
                               Margin="0,0,12,0" AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="TxtWarnCount" Text="" FontSize="{StaticResource FontSizeBody}"
                               Margin="0,0,12,0" AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="TxtFailCount" Text="" FontSize="{StaticResource FontSizeBody}"
                               AutomationProperties.LiveSetting="Polite"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Empty state hint -->
        <Border x:Name="EmptyStatePanel" Grid.Row="6"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Row 4: Results (chapter expanders) -->
        <ScrollViewer Grid.Row="6" x:Name="ResultsScroller" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ResultsPanel" Margin="{StaticResource ContentAreaMargin}"/>
        </ScrollViewer>

        <!-- Row 6: Footer -->
        <Border Grid.Row="7" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnExportHtml" Content=""
                            TabIndex="8"
                            Click="OnExportHtmlClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineXs}"
                            VerticalAlignment="Center" IsEnabled="False"/>
                    <Button x:Name="BtnExportCsv" Content=""
                            TabIndex="9"
                            Click="OnExportCsvClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineXs}"
                            VerticalAlignment="Center" IsEnabled="False"/>
                    <Button x:Name="BtnExportDrawio" Content=""
                            TabIndex="10"
                            Click="OnExportDrawioClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}"
                            VerticalAlignment="Center" IsEnabled="False"/>
                </StackPanel>
                <TextBlock x:Name="TxtFooterStats" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
