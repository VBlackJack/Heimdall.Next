<UserControl x:Class="Heimdall.App.Views.Tools.ServiceStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtFilter" Text="" Width="250"
                             FontSize="{StaticResource FontSizeBodyLarge}" Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             TextChanged="OnFilterChanged"/>
                    <CheckBox x:Name="ChkRunningOnly"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="OnRunningOnlyChanged" Unchecked="OnRunningOnlyChanged"/>
                    <CheckBox x:Name="ChkAutoRefresh"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="OnAutoRefreshChanged" Unchecked="OnAutoRefreshChanged"/>
                    <Button x:Name="BtnRefresh" Content=""
                            Click="OnRefreshClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="12,0,0,0"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Error message -->
        <TextBlock x:Name="TxtError" Grid.Row="1" Text="" Visibility="Collapsed"
                   FontSize="{StaticResource FontSizeBody}" Margin="12,8,12,0" TextWrapping="Wrap"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   VerticalAlignment="Top"/>

        <!-- Services DataGrid -->
        <Border Grid.Row="1" Margin="{StaticResource SpacingSm}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DataGrid x:Name="ServicesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColServiceName" Binding="{Binding Name}" Width="200"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColDisplayName" Binding="{Binding DisplayName}" Width="*"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStartType" Binding="{Binding StartType}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="ServiceContextMenu">
                        <MenuItem x:Name="MenuStart" Click="OnStartServiceClick"/>
                        <MenuItem x:Name="MenuStop" Click="OnStopServiceClick"/>
                        <MenuItem x:Name="MenuRestart" Click="OnRestartServiceClick"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="2" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" DockPanel.Dock="Right"
                        VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblTotal" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtTotal" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblRunning" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtRunning" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessTextBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblStopped" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtStopped" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource ErrorTextBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
