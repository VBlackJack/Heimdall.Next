<UserControl x:Class="Heimdall.App.Views.Tools.ServiceStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="7"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TxtFilter" Text="" MinWidth="200"
                             Style="{DynamicResource WatermarkTextBoxStyle}"
                             FontSize="{StaticResource FontSizeBodyLarge}" Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             Tag=""
                             TextChanged="OnFilterChanged"
                             TabIndex="0"
                             AutomationProperties.Name=""/>
                    <CheckBox x:Name="ChkRunningOnly"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="OnRunningOnlyChanged" Unchecked="OnRunningOnlyChanged"
                              TabIndex="1"
                              AutomationProperties.Name=""/>
                    <CheckBox x:Name="ChkAutoRefresh"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="OnAutoRefreshChanged" Unchecked="OnAutoRefreshChanged"
                              TabIndex="2"
                              AutomationProperties.Name=""/>
                    <Button x:Name="BtnRefresh" Content=""
                            Click="OnRefreshClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            TabIndex="3"
                            AutomationProperties.Name=""/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="8"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar" Grid.Row="2"
                     Style="{StaticResource ToolLoadingBarStyle}"
                     VerticalAlignment="Top"
                     AutomationProperties.Name=""/>

        <!-- Error message -->
        <TextBlock x:Name="TxtError" Grid.Row="2" Text=""
                   Style="{StaticResource ToolInlineErrorTextStyle}"
                   Margin="12,8,12,0"
                   VerticalAlignment="Top"/>

        <!-- Empty state hint (hidden once services are loaded) -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE770;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Services DataGrid -->
        <Border x:Name="ServicesPanel" Grid.Row="2"
                Style="{StaticResource ToolResultsCardStyle}"
                Margin="{StaticResource SpacingSm}"
                Padding="0">
            <DataGrid x:Name="ServicesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      TabIndex="4"
                      AutomationProperties.LiveSetting="Polite"
                      AutomationProperties.Name="">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColServiceName" Binding="{Binding Name}" Width="*"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColDisplayName" Binding="{Binding DisplayName}" Width="2*"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="100"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColStartType" Binding="{Binding StartType}" Width="120"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="ServiceContextMenu">
                        <MenuItem x:Name="MenuStart" Click="OnStartServiceClick"/>
                        <MenuItem x:Name="MenuStop" Click="OnStopServiceClick"/>
                        <MenuItem x:Name="MenuRestart" Click="OnRestartServiceClick"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        TabIndex="5"
                        AutomationProperties.Name=""/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblTotal" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtTotal" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblRunning" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtRunning" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource SuccessTextBrush}" FontWeight="SemiBold"/>

                    <TextBlock Text="  |  " FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource BorderBrush}"/>

                    <TextBlock x:Name="LblStopped" Text="" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtStopped" Text="—" FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                               Foreground="{DynamicResource ErrorTextBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
