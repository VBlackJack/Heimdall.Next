<UserControl x:Class="Heimdall.App.Views.Tools.SmbEnumeratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heimdall.App.Converters"
             xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Tools"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:SmbSeverityToBrushConverter x:Key="SmbSeverityBrush"/>
        <conv:SmbSeverityToIconConverter x:Key="SmbSeverityIcon"/>
        <conv:BoolToYesNoConverter x:Key="BoolYesNo"/>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="3"
                        Click="OnHelpClick"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <TextBlock x:Name="LblHost" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionBottom}">
                    <Button x:Name="BtnEnumerate" DockPanel.Dock="Right"
                            TabIndex="1"
                            Content="" Click="OnEnumerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtHost"
                             Text="{Binding HostInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="0"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"/>
                </DockPanel>

                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginInlineSm}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRouteVia" Width="240"
                              TabIndex="2"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginSectionBottom}" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorTextBrush}"/>

                <ProgressBar x:Name="LoadingBar" Style="{StaticResource ToolLoadingBarStyle}"/>

                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE774;"
                                   Style="{StaticResource ToolEmptyStateIconStyle}"
                                   Focusable="False"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   Style="{StaticResource ToolEmptyStateTextStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">
                    <Border Margin="{StaticResource MarginSectionBottom}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingSectionCard}"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <TextBlock x:Name="TxtCardIdentity" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="{StaticResource MarginStackItem}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="LblComputerName" Grid.Row="0" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValComputerName" Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Result.ComputerName, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblDomain" Grid.Row="1" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValDomain" Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Result.Domain, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblDnsName" Grid.Row="2" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValDnsName" Grid.Row="2" Grid.Column="1"
                                           Text="{Binding Result.DnsName, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                                <TextBlock x:Name="LblDnsDomain" Grid.Row="3" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValDnsDomain" Grid.Row="3" Grid.Column="1"
                                           Text="{Binding Result.DnsDomain, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                                <TextBlock x:Name="LblForest" Grid.Row="4" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValForest" Grid.Row="4" Grid.Column="1"
                                           Text="{Binding Result.Forest, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                                <TextBlock x:Name="LblOsBuild" Grid.Row="5" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValOsBuild" Grid.Row="5" Grid.Column="1"
                                           Text="{Binding Result.OsBuild, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblMac" Grid.Row="6" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValMac" Grid.Row="6" Grid.Column="1"
                                           Text="{Binding Result.MacAddress, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource MarginSectionBottom}"
                            Visibility="{Binding HasProtocolSection, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingSectionCard}"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <TextBlock x:Name="TxtCardProtocol" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="{StaticResource MarginStackItem}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="LblDialect" Grid.Row="0" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValDialect" Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Result.Dialect, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblSigning" Grid.Row="1" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValSigning" Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Result.SigningRequired, Converter={StaticResource BoolYesNo}}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblServerGuid" Grid.Row="2" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValServerGuid" Grid.Row="2" Grid.Column="1"
                                           Text="{Binding Result.ServerGuid, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                                <TextBlock x:Name="LblSystemTime" Grid.Row="3" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValSystemTime" Grid.Row="3" Grid.Column="1"
                                           Text="{Binding Result.SystemTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss UTC}, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>

                                <TextBlock x:Name="LblBootTime" Grid.Row="4" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                                <TextBlock x:Name="ValBootTime" Grid.Row="4" Grid.Column="1"
                                           Text="{Binding Result.BootTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss UTC}, TargetNullValue=-, FallbackValue=-}"
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FindingsPanel"
                            Visibility="{Binding HasFindings, Converter={StaticResource BoolToVisibility}}"
                            Margin="{StaticResource MarginSectionBottom}"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="{StaticResource PaddingSectionCard}"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <TextBlock x:Name="TxtCardFindings" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="{StaticResource MarginStackItem}"/>
                            <ItemsControl ItemsSource="{Binding Findings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SmbFindingViewItem}">
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                            <TextBlock Text="{Binding Severity, Converter={StaticResource SmbSeverityIcon}}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{Binding Severity, Converter={StaticResource SmbSeverityBrush}}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Text}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{Binding Severity, Converter={StaticResource SmbSeverityBrush}}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       AutomationProperties.Name="{Binding Text}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text=""
                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
