<UserControl x:Class="Heimdall.App.Views.Tools.SnmpWalkerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <WrapPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblHost" Text=""
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtHost" Text="" MinWidth="140"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Tag=""
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 TabIndex="0"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblCommunity" Text=""
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtCommunity" Text="" MinWidth="120"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Tag=""
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 TabIndex="1"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblOid" Text=""
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtOid" Text="" MinWidth="140"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Tag=""
                                 FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 TabIndex="2"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                        <TextBlock x:Name="LblRouteVia" Text=""
                                   FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ComboBox x:Name="CmbRouteVia" Width="180"
                                  SelectionChanged="OnRouteViaChanged"
                                  Background="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  VerticalAlignment="Center"
                                  TabIndex="3"
                                  AutomationProperties.Name=""/>
                    </StackPanel>
                    <Button x:Name="BtnWalk" Content=""
                            Click="OnWalkClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            TabIndex="4"
                            AutomationProperties.Name=""/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="15"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Presets row -->
        <Border Grid.Row="2" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnPresetSystem" Click="OnPresetClick" Tag="1.3.6.1.2.1.1"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        TabIndex="5"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnPresetInterfaces" Click="OnPresetClick" Tag="1.3.6.1.2.1.2"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        TabIndex="6"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnPresetIp" Click="OnPresetClick" Tag="1.3.6.1.2.1.4"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        TabIndex="7"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnPresetTcp" Click="OnPresetClick" Tag="1.3.6.1.2.1.6"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" Margin="0,0,4,0" FontSize="{StaticResource FontSizeCaption}"
                        TabIndex="8"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnPresetUdp" Click="OnPresetClick" Tag="1.3.6.1.2.1.7"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPreset}" FontSize="{StaticResource FontSizeCaption}"
                        TabIndex="9"
                        AutomationProperties.Name=""/>
            </StackPanel>
        </Border>

        <!-- Validation error + progress bar -->
        <StackPanel Grid.Row="3">
            <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                       FontSize="{StaticResource FontSizeBody}" Margin="12,4,12,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource ErrorTextBrush}"/>
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True"
                         Visibility="Collapsed" Height="4" Margin="0,0,0,0"
                         AutomationProperties.Name=""/>
        </StackPanel>

        <!-- Empty state hint -->
        <Border x:Name="EmptyStatePanel" Grid.Row="4"
                Style="{StaticResource ToolEmptyStateStyle}"
                Margin="0,24,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE968;" Style="{StaticResource ToolEmptyStateIconStyle}"
                           AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Walk Results DataGrid -->
        <Border x:Name="ResultsBorder" Grid.Row="4" Margin="{StaticResource SpacingSm}" Visibility="Collapsed"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      TabIndex="10"
                      AutomationProperties.Name=""
                      AutomationProperties.LiveSetting="Polite">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColOid" Binding="{Binding Oid}" Width="260"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <DataGridTextColumn x:Name="ColName" Binding="{Binding Name}" Width="180"
                                        Foreground="{DynamicResource AccentBrush}"/>
                    <DataGridTextColumn x:Name="ColType" Binding="{Binding Type}" Width="100"
                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <DataGridTextColumn x:Name="ColValue" Binding="{Binding Value}" Width="*"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Community bruteforce section -->
        <Border x:Name="CommunityPanel" Grid.Row="5" Padding="{StaticResource PaddingAlertBanner}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnTestCommunities" DockPanel.Dock="Left"
                        Click="OnTestCommunitiesClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        TabIndex="11"
                        AutomationProperties.Name=""/>
                <ItemsControl x:Name="CommunityResults" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="{StaticResource PaddingButtonHelp}" Margin="0,0,6,2" CornerRadius="{StaticResource CornerRadiusXs}"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Community}" FontFamily="Consolas"
                                               FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource SuccessTextBrush}"/>
                                    <TextBlock Text="{Binding SysName}" Margin="6,0,0,0"
                                               FontSize="{StaticResource FontSizeSmallCaption}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="6" Padding="{StaticResource ToolFooterPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button x:Name="BtnExportCsv" Content=""
                        Click="OnExportCsvClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right" Margin="{StaticResource MarginInlineControl}"
                        VerticalAlignment="Center"
                        TabIndex="12"
                        AutomationProperties.Name=""/>
                <Button x:Name="BtnCopy" Content=""
                        Click="OnCopyClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonPrimary}" DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        TabIndex="13"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="TxtStatus" Text=""
                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
