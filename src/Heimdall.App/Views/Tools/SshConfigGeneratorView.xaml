<UserControl x:Class="Heimdall.App.Views.Tools.SshConfigGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Form fields -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Host alias -->
                        <TextBlock x:Name="LblHostAlias" Grid.Row="0" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtHostAlias" Grid.Row="0" Grid.Column="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" FontFamily="Consolas"/>

                        <!-- HostName -->
                        <TextBlock x:Name="LblHostName" Grid.Row="2" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtHostName" Grid.Row="2" Grid.Column="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" FontFamily="Consolas"/>

                        <!-- User -->
                        <TextBlock x:Name="LblUser" Grid.Row="4" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtUser" Grid.Row="4" Grid.Column="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"/>

                        <!-- Port -->
                        <TextBlock x:Name="LblPort" Grid.Row="6" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtPort" Grid.Row="6" Grid.Column="1"
                                 Text="22"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" MaxWidth="100" HorizontalAlignment="Left"/>

                        <!-- IdentityFile -->
                        <TextBlock x:Name="LblIdentityFile" Grid.Row="8" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtIdentityFile" Grid.Row="8" Grid.Column="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" FontFamily="Consolas"/>

                        <!-- ProxyJump -->
                        <TextBlock x:Name="LblProxyJump" Grid.Row="10" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtProxyJump" Grid.Row="10" Grid.Column="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" FontFamily="Consolas"/>

                        <!-- ForwardAgent -->
                        <TextBlock x:Name="LblForwardAgent" Grid.Row="12" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkForwardAgent" Grid.Row="12" Grid.Column="1"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center"/>

                        <!-- ServerAliveInterval -->
                        <TextBlock x:Name="LblServerAliveInterval" Grid.Row="14" Grid.Column="0"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtServerAliveInterval" Grid.Row="14" Grid.Column="1"
                                 Text="60"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}" MaxWidth="100" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <WrapPanel Margin="0,0,0,12">
                    <Button x:Name="BtnGenerate" Click="OnGenerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="14,6" Margin="0,0,8,0" FontSize="{StaticResource FontSizeBody}"/>
                    <Button x:Name="BtnGenerateAll" Click="OnGenerateAllClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="14,6" FontSize="{StaticResource FontSizeBody}"/>
                </WrapPanel>

                <!-- Empty state hint (hidden once output is generated) -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"
                                   AutomationProperties.Name=""/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Output -->
                <Border x:Name="OutputPanel" Visibility="Collapsed" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="12,8" Margin="0,0,0,8">
                    <DockPanel>
                        <Button x:Name="BtnCopy" DockPanel.Dock="Top"
                                Click="OnCopyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,0,8"
                                HorizontalAlignment="Left" FontSize="{StaticResource FontSizeBody}"/>
                        <TextBox x:Name="TxtOutput"
                                 IsReadOnly="True"
                                 AutomationProperties.LiveSetting="Polite"
                                 FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MaxHeight="400"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0"/>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
