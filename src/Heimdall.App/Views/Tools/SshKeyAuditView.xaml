<UserControl x:Class="Heimdall.App.Views.Tools.SshKeyAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="5"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="6"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Input section -->
                <Border Grid.Row="0" Padding="{StaticResource SpacingMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button x:Name="BtnBrowse" DockPanel.Dock="Right"
                                    Click="OnBrowseClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                    VerticalAlignment="Top"
                                    TabIndex="1"
                                    AutomationProperties.Name=""/>
                            <TextBlock x:Name="InputLabel"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,0,4"/>
                        </DockPanel>
                        <TextBox x:Name="KeyInput"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="{StaticResource FontSizeBody}"
                                 MinHeight="120" MaxHeight="240"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"
                                 TextChanged="OnKeyInputTextChanged"
                                 TabIndex="0"
                                 AutomationProperties.Name=""/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyState" Grid.Row="1"
                           Style="{StaticResource ToolEmptyStateTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0"/>

                <!-- Parse error -->
                <TextBlock x:Name="ParseError" Grid.Row="1"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,8,0,0"/>

                <!-- Key type badge -->
                <StackPanel x:Name="BadgePanel" Grid.Row="2"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            Margin="{StaticResource MarginSectionBottom}">
                    <Border x:Name="AlgorithmBadge"
                            CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="12,4"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="AlgorithmBadgeText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                    </Border>
                    <Border x:Name="RatingBadge"
                            CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="12,4">
                        <TextBlock x:Name="RatingBadgeText"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Key details grid -->
                <Border x:Name="DetailsPanel" Grid.Row="3"
                        Padding="{StaticResource SpacingMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Visibility="Collapsed"
                        Margin="{StaticResource MarginSectionBottom}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Algorithm -->
                        <TextBlock x:Name="DetailAlgorithmLabel" Grid.Row="0" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DetailAlgorithmValue" Grid.Row="0" Grid.Column="1"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Key Size -->
                        <TextBlock x:Name="DetailKeySizeLabel" Grid.Row="1" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DetailKeySizeValue" Grid.Row="1" Grid.Column="1"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Fingerprint -->
                        <TextBlock x:Name="DetailFingerprintLabel" Grid.Row="2" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                            <Button x:Name="BtnCopyFingerprint" DockPanel.Dock="Right"
                                    Click="OnCopyFingerprintClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                    VerticalAlignment="Center"
                                    TabIndex="2"
                                    AutomationProperties.Name=""/>
                            <TextBox x:Name="DetailFingerprintValue"
                                     IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     AutomationProperties.Name=""/>
                        </DockPanel>

                        <!-- Format -->
                        <TextBlock x:Name="DetailFormatLabel" Grid.Row="3" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DetailFormatValue" Grid.Row="3" Grid.Column="1"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Type (public/private) -->
                        <TextBlock x:Name="DetailTypeLabel" Grid.Row="4" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="DetailTypeValue" Grid.Row="4" Grid.Column="1"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <!-- Encrypted -->
                        <TextBlock x:Name="DetailEncryptedLabel" Grid.Row="5" Grid.Column="0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailEncryptedValue" Grid.Row="5" Grid.Column="1"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Security assessment / Findings -->
                <Border x:Name="FindingsPanel" Grid.Row="4"
                        Padding="{StaticResource SpacingMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Visibility="Collapsed"
                        Margin="{StaticResource MarginSectionBottom}">
                    <StackPanel>
                        <TextBlock x:Name="FindingsTitle"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="FindingsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Icon}"
                                                   Foreground="{Binding IconBrush}"
                                                   FontWeight="Bold"
                                                   Width="20" VerticalAlignment="Top"/>
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
