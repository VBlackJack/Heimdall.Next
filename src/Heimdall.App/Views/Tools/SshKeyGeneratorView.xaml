<UserControl x:Class="Heimdall.App.Views.Tools.SshKeyGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="TitleText"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Options panel -->
            <Border Grid.Row="0" Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12">
                <StackPanel>
                    <!-- Algorithm -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="AlgorithmLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <ComboBox x:Name="AlgorithmCombo"
                                  SelectedIndex="1"
                                  MinWidth="200"
>
                            <ComboBoxItem Content="RSA (2048)"/>
                            <ComboBoxItem Content="RSA (4096)"/>
                            <ComboBoxItem Content="Ed25519" x:Name="Ed25519Item" IsEnabled="False"/>
                        </ComboBox>
                    </DockPanel>

                    <!-- Comment -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="CommentLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="CommentInput"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="4,2"
/>
                    </DockPanel>

                    <!-- Passphrase -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="PassphraseLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <PasswordBox x:Name="PassphraseInput"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="4,2"
/>
                    </DockPanel>
                    <TextBlock x:Name="PassphraseHint"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="120,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Generate button -->
            <Button x:Name="BtnGenerate" Grid.Row="1"
                    Click="OnGenerateClick"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="16,6" Margin="0,0,0,16"
                    HorizontalAlignment="Left"/>

            <!-- Fingerprint -->
            <Border Grid.Row="2" Padding="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" x:Name="FingerprintPanel">
                <DockPanel>
                    <TextBlock x:Name="FingerprintLabel"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Width="100"
                               FontWeight="SemiBold"/>
                    <Button x:Name="BtnCopyFingerprint" DockPanel.Dock="Right"
                            Click="OnCopyFingerprintClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="10,4" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="FingerprintOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
/>
                </DockPanel>
            </Border>

            <!-- Public key -->
            <Border Grid.Row="3" Padding="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" x:Name="PublicKeyPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="PublicKeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyPublicKey"
                                Click="OnCopyPublicKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="BtnSavePublicKey"
                                Click="OnSavePublicKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="4,0,0,0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox x:Name="PublicKeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             TextWrapping="Wrap"
                             MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
/>
                </DockPanel>
            </Border>

            <!-- Private key -->
            <Border Grid.Row="4" Padding="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" x:Name="PrivateKeyPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="PrivateKeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyPrivateKey"
                                Click="OnCopyPrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="BtnShowPrivateKey"
                                Click="OnTogglePrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="4,0,0,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="BtnSavePrivateKey"
                                Click="OnSavePrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,4" Margin="4,0,0,0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox x:Name="PrivateKeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
/>
                </DockPanel>
            </Border>

            <!-- Ed25519 notice -->
            <TextBlock x:Name="Ed25519Notice" Grid.Row="5"
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>
        </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
