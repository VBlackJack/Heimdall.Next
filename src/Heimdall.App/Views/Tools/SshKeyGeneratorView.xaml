<UserControl x:Class="Heimdall.App.Views.Tools.SshKeyGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="4"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Options panel -->
            <Border Grid.Row="0" Padding="{StaticResource SpacingMd}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}">
                <StackPanel>
                    <!-- Algorithm -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="AlgorithmLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <ComboBox x:Name="AlgorithmCombo"
                                  TabIndex="0"
                                  SelectedIndex="1"
                                  MinWidth="200"
                                  AutomationProperties.Name=""
>
                            <ComboBoxItem x:Name="Rsa2048Item" Content="" Tag="RSA2048"/>
                            <ComboBoxItem x:Name="Rsa4096Item" Content="" Tag="RSA4096"/>
                            <ComboBoxItem x:Name="Ed25519Item" Content="" Tag="Ed25519"/>
                        </ComboBox>
                    </DockPanel>

                    <!-- Comment -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="CommentLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="CommentInput"
                                 TabIndex="1"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="{DynamicResource CardBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="{StaticResource PaddingInput}"
                                 AutomationProperties.Name=""
/>
                    </DockPanel>

                    <!-- Passphrase -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="PassphraseLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <PasswordBox x:Name="PassphraseInput"
                                     TabIndex="2"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Padding="{StaticResource PaddingInput}"
                                     AutomationProperties.Name=""
/>
                    </DockPanel>
                    <TextBlock x:Name="PassphraseHint"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="120,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Generate button -->
            <Button x:Name="BtnGenerate" Grid.Row="1"
                    TabIndex="3"
                    Click="OnGenerateClick"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginSectionSeparator}"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name=""/>

            <TextBlock x:Name="ValidationText" Grid.Row="2"
                       Style="{StaticResource ToolInlineErrorTextStyle}"/>

            <!-- Fingerprint -->
            <Border Grid.Row="3" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="FingerprintPanel">
                <DockPanel>
                    <TextBlock x:Name="FingerprintLabel"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Width="100"
                               FontWeight="SemiBold"/>
                    <Button x:Name="BtnCopyFingerprint" DockPanel.Dock="Right"
                            Click="OnCopyFingerprintClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="FingerprintOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""
/>
                </DockPanel>
            </Border>

            <!-- Public key -->
            <Border Grid.Row="4" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="PublicKeyPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="PublicKeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyPublicKey"
                                Click="OnCopyPublicKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnSavePublicKey"
                                Click="OnSavePublicKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="PublicKeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             AutomationProperties.Name=""
/>
                </DockPanel>
            </Border>

            <!-- Private key -->
            <Border Grid.Row="5" Padding="{StaticResource SpacingSm}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                    Margin="{StaticResource MarginSectionBottom}"
                    Visibility="Collapsed" x:Name="PrivateKeyPanel">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="PrivateKeyLabel"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyPrivateKey"
                                Click="OnCopyPrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineControl}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnShowPrivateKey"
                                Click="OnTogglePrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                        <Button x:Name="BtnSavePrivateKey"
                                Click="OnSavePrivateKeyClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name=""/>
                    </StackPanel>
                    <TextBox x:Name="PrivateKeyOutput"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             AutomationProperties.Name=""
/>
                </DockPanel>
            </Border>

            <!-- Ed25519 notice -->
            <TextBlock x:Name="Ed25519Notice" Grid.Row="6"
                       FontSize="{StaticResource FontSizeCaption}" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>
        </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>
