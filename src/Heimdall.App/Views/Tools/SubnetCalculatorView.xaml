<UserControl x:Class="Heimdall.App.Views.Tools.SubnetCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel MaxWidth="600">

                <!-- Input -->
                <TextBlock x:Name="LblCidrInput" Text=""
                           FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,16">
                    <TextBox x:Name="TxtCidrInput" Text=""
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="12" Margin="0,0,0,12"
                           Foreground="{DynamicResource ErrorBrush}"/>

                <!-- Results -->
                <Border x:Name="ResultsPanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Network Address -->
                        <TextBlock x:Name="LblNetwork" Grid.Row="0" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtNetwork" Grid.Row="0" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyNetwork" Grid.Row="0" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="Network" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 2: Broadcast Address -->
                        <TextBlock x:Name="LblBroadcast" Grid.Row="2" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtBroadcast" Grid.Row="2" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyBroadcast" Grid.Row="2" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="Broadcast" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 4: Subnet Mask -->
                        <TextBlock x:Name="LblSubnetMask" Grid.Row="4" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtSubnetMask" Grid.Row="4" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyMask" Grid.Row="4" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="Mask" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 6: First Host -->
                        <TextBlock x:Name="LblFirstHost" Grid.Row="6" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFirstHost" Grid.Row="6" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyFirstHost" Grid.Row="6" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="FirstHost" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 8: Last Host -->
                        <TextBlock x:Name="LblLastHost" Grid.Row="8" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLastHost" Grid.Row="8" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyLastHost" Grid.Row="8" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="LastHost" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 10: Total Hosts -->
                        <TextBlock x:Name="LblTotalHosts" Grid.Row="10" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalHosts" Grid.Row="10" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyTotalHosts" Grid.Row="10" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="TotalHosts" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 12: CIDR Notation -->
                        <TextBlock x:Name="LblCidr" Grid.Row="12" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCidr" Grid.Row="12" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyCidr" Grid.Row="12" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="Cidr" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Row 14: Wildcard Mask -->
                        <TextBlock x:Name="LblWildcard" Grid.Row="14" Grid.Column="0" Text=""
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtWildcard" Grid.Row="14" Grid.Column="2" Text=""
                                   FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCopyWildcard" Grid.Row="14" Grid.Column="3" Click="OnCopyValueClick"
                                Tag="Wildcard" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="6,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
