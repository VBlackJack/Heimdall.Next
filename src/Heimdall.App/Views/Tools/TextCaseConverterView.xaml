<UserControl x:Class="Heimdall.App.Views.Tools.TextCaseConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Input -->
                <TextBlock x:Name="LblInput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="TxtInput" Text=""
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="text to convert"
                         TextChanged="OnInputChanged"/>

                <!-- Conversion buttons -->
                <TextBlock x:Name="LblConversions" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,16,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Margin="0,0,0,16">
                    <Button x:Name="BtnCamelCase" Content="" Click="OnCamelCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnPascalCase" Content="" Click="OnPascalCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnSnakeCase" Content="" Click="OnSnakeCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnKebabCase" Content="" Click="OnKebabCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnUpperCase" Content="" Click="OnUpperCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnLowerCase" Content="" Click="OnLowerCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnTitleCase" Content="" Click="OnTitleCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                    <Button x:Name="BtnConstantCase" Content="" Click="OnConstantCaseClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="0,0,6,6"/>
                </WrapPanel>

                <!-- Output -->
                <TextBlock x:Name="LblOutput" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                            Content="" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="8,0,0,0"
                            VerticalAlignment="Top"/>
                    <TextBox x:Name="TxtOutput" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" Height="100"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AutomationProperties.LiveSetting="Polite"/>
                </DockPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
