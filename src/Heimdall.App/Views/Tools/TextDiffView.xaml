<UserControl x:Class="Heimdall.App.Views.Tools.TextDiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Heimdall.App.Views.Tools"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="12"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"/>
                <TextBlock x:Name="HeaderTitle" DockPanel.Dock="Left"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="StatsText"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <Button x:Name="BtnCompare" Click="OnCompareClick"
                            TabIndex="2"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineXs}"/>
                    <Button x:Name="BtnSwap" Click="OnSwapClick"
                            TabIndex="3"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="4,0,4,0"/>
                    <Button x:Name="BtnClear" Click="OnClearClick"
                            TabIndex="4"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="{StaticResource MarginInlineStart}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Two input panels side by side -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Original -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="OriginalLabel" Grid.Row="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"/>
                <TextBox x:Name="OriginalText" Grid.Row="1"
                         TabIndex="0"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="{StaticResource PaddingInput}"
                         Tag=""/>
            </Grid>

            <!-- Right: Modified -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ModifiedLabel" Grid.Row="0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"/>
                <TextBox x:Name="ModifiedText" Grid.Row="1"
                         TabIndex="1"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Padding="{StaticResource PaddingInput}"
                         Tag=""/>
            </Grid>
        </Grid>

        <!-- Separator + options + Copy diff button -->
        <DockPanel Grid.Row="1" Margin="0,8">
            <TextBlock x:Name="DiffOutputLabel" DockPanel.Dock="Left"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
            <Button x:Name="BtnCopyDiff" DockPanel.Dock="Right"
                    TabIndex="8"
                    Click="OnCopyDiffClick"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="{StaticResource PaddingButtonCopy}" HorizontalAlignment="Right"/>
            <StackPanel Orientation="Horizontal" Margin="16,0,8,0" VerticalAlignment="Center">
                <CheckBox x:Name="ChkIgnoreWhitespace"
                          TabIndex="5"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          Checked="OnDiffOptionChanged" Unchecked="OnDiffOptionChanged"/>
                <CheckBox x:Name="ChkIgnoreCase"
                          TabIndex="6"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          Checked="OnDiffOptionChanged" Unchecked="OnDiffOptionChanged"/>
                <CheckBox x:Name="ChkAutoCompare"
                          TabIndex="7"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          VerticalAlignment="Center"
                          Checked="OnAutoCompareChanged" Unchecked="OnAutoCompareChanged"/>
            </StackPanel>
        </DockPanel>

        <!-- Empty state -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2"
                Style="{StaticResource ToolEmptyStateStyle}"
               >
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8AB;"
                           Style="{StaticResource ToolEmptyStateIconStyle}"
                           Focusable="False"/>
                <TextBlock x:Name="TxtEmptyState" Text=""
                           Style="{StaticResource ToolEmptyStateTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Diff output -->
        <Border x:Name="ResultsPanel" Grid.Row="2" Visibility="Collapsed"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="{StaticResource CornerRadiusXs}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DiffOutput"
                              TabIndex="9"
                              AutomationProperties.LiveSetting="Polite">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="{Binding Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding LeftLineNumber}"
                                           FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextAlignment="Right" Padding="2,1,6,1"/>
                                <TextBlock Grid.Column="1" Text="{Binding RightLineNumber}"
                                           FontFamily="Consolas" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextAlignment="Right" Padding="2,1,6,1"/>
                                <TextBlock Grid.Column="2" Text="{Binding Prefix}"
                                           FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{Binding PrefixForeground}"
                                           FontWeight="Bold" Padding="0,1,4,1"/>
                                <TextBlock Grid.Column="3"
                                           FontFamily="Consolas" FontSize="{StaticResource FontSizeBodyLarge}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Padding="0,1,4,1"
                                           local:InlineBindingHelper.InlineCollection="{Binding Inlines}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource MarginSubsectionTop}"/>
        </Grid>
    </Grid>
</UserControl>
