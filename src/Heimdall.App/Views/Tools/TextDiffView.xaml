<UserControl x:Class="Heimdall.App.Views.Tools.TextDiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Heimdall.App.Views.Tools"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:Heimdall.Core.Matching;assembly=Heimdall.Core"
             xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Tools"
             d:DataContext="{d:DesignInstance Type=vm:TextDiffViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="TextDiff.HelpButton"
                        Width="24"
                        Height="24"
                        Margin="{StaticResource MarginInlineControl}"
                        Content="?"
                        Click="OnHelpClick"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold" />
                <TextBlock Text="{loc:Translate ToolDiffTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatsText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Button x:Name="BtnCompare"
                            AutomationProperties.AutomationId="TextDiff.CompareButton"
                            Content="{loc:Translate ToolDiffBtnCompare}"
                            Command="{Binding DiffCommand}"
                            TabIndex="2"
                            AutomationProperties.Name="{loc:Translate ToolDiffBtnCompare}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}"
                            Margin="{StaticResource MarginInlineXs}" />
                    <Button x:Name="BtnSwap"
                            AutomationProperties.AutomationId="TextDiff.SwapButton"
                            Content="{loc:Translate ToolDiffBtnSwap}"
                            Command="{Binding SwapCommand}"
                            TabIndex="3"
                            AutomationProperties.Name="{loc:Translate ToolDiffBtnSwap}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            Margin="4,0,4,0" />
                    <Button x:Name="BtnClear"
                            AutomationProperties.AutomationId="TextDiff.ClearButton"
                            Content="{loc:Translate ToolDiffBtnClear}"
                            Command="{Binding ClearCommand}"
                            TabIndex="4"
                            AutomationProperties.Name="{loc:Translate ToolDiffBtnClear}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            Margin="{StaticResource MarginInlineStart}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                AutomationProperties.AutomationId="TextDiff.HelpPanel"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="TextDiff.CloseHelpButton"
                        Width="24"
                        Height="24"
                        Content="&#xE711;"
                        Click="OnCloseHelpClick"
                        AutomationProperties.Name="{loc:Translate BtnClose}"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        VerticalAlignment="Top" />
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               Text=""
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="{StaticResource ContentAreaMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{loc:Translate ToolDiffOriginalLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="{StaticResource MarginLabelBottom}" />
                    <TextBox x:Name="OriginalText"
                             AutomationProperties.AutomationId="TextDiff.OriginalText"
                             Grid.Row="1"
                             Text="{Binding OriginalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="0"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Padding="{StaticResource PaddingInput}"
                             Tag="{loc:Translate ToolWatermarkOriginalText}"
                             AutomationProperties.Name="{loc:Translate ToolDiffOriginalLabel}" />
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{loc:Translate ToolDiffModifiedLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="{StaticResource MarginLabelBottom}" />
                    <TextBox x:Name="ModifiedText"
                             AutomationProperties.AutomationId="TextDiff.ModifiedText"
                             Grid.Row="1"
                             Text="{Binding ModifiedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="1"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="{StaticResource FontSizeBodyLarge}"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Padding="{StaticResource PaddingInput}"
                             Tag="{loc:Translate ToolWatermarkModifiedText}"
                             AutomationProperties.Name="{loc:Translate ToolDiffModifiedLabel}" />
                </Grid>
            </Grid>

            <DockPanel Grid.Row="1" Margin="0,8">
                <TextBlock Text="{loc:Translate ToolDiffOutputLabel}"
                           DockPanel.Dock="Left"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalAlignment="Center" />
                <Button x:Name="BtnCopyDiff"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="TextDiff.CopyDiffButton"
                        Content="{loc:Translate ToolDiffBtnCopyDiff}"
                        TabIndex="8"
                        Click="OnCopyDiffClick"
                        ToolTip="{loc:Translate ToolBtnCopyToClipboard}"
                        AutomationProperties.Name="{loc:Translate ToolDiffBtnCopyDiff}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonCopy}" />
                <StackPanel Orientation="Horizontal" Margin="16,0,8,0" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkIgnoreWhitespace"
                              AutomationProperties.AutomationId="TextDiff.IgnoreWhitespaceCheck"
                              Content="{loc:Translate ToolDiffChkIgnoreWhitespace}"
                              IsChecked="{Binding IgnoreWhitespace, Mode=TwoWay}"
                              TabIndex="5"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              AutomationProperties.Name="{loc:Translate ToolDiffChkIgnoreWhitespace}" />
                    <CheckBox x:Name="ChkIgnoreCase"
                              AutomationProperties.AutomationId="TextDiff.IgnoreCaseCheck"
                              Content="{loc:Translate ToolDiffChkIgnoreCase}"
                              IsChecked="{Binding IgnoreCase, Mode=TwoWay}"
                              TabIndex="6"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              AutomationProperties.Name="{loc:Translate ToolDiffChkIgnoreCase}" />
                    <CheckBox x:Name="ChkAutoCompare"
                              AutomationProperties.AutomationId="TextDiff.AutoCompareCheck"
                              Content="{loc:Translate ToolDiffChkAutoCompare}"
                              IsChecked="{Binding AutoCompare, Mode=TwoWay}"
                              TabIndex="7"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="{loc:Translate ToolDiffChkAutoCompare}" />
                </StackPanel>
            </DockPanel>

            <Border x:Name="EmptyStatePanel" Grid.Row="2">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ToolEmptyStateStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8AB;"
                               Style="{StaticResource ToolEmptyStateIconStyle}"
                               Focusable="False" />
                    <TextBlock Text="{loc:Translate ToolTextDiffEmptyState}"
                               Style="{StaticResource ToolEmptyStateTextStyle}" />
                </StackPanel>
            </Border>

            <Border x:Name="ResultsPanel" Grid.Row="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusXs}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DiffOutput"
                                  ItemsSource="{Binding DiffLines}"
                                  AutomationProperties.LiveSetting="Polite">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DiffLineDisplay}">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Removed}">
                                                    <Setter Property="Background" Value="{DynamicResource DiffRemovedLineBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Added}">
                                                    <Setter Property="Background" Value="{DynamicResource DiffAddedLineBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding LeftLineNumber}"
                                               FontFamily="Consolas"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextAlignment="Right"
                                               Padding="2,1,6,1" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RightLineNumber}"
                                               FontFamily="Consolas"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextAlignment="Right"
                                               Padding="2,1,6,1" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Prefix}"
                                               FontFamily="Consolas"
                                               FontSize="{StaticResource FontSizeBodyLarge}"
                                               FontWeight="Bold"
                                               Padding="0,1,4,1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Removed}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffRemovedPrefixBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Added}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffAddedPrefixBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="3"
                                               FontFamily="Consolas"
                                               FontSize="{StaticResource FontSizeBodyLarge}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Padding="0,1,4,1"
                                               local:SegmentTextBlockHelper.Segments="{Binding Segments}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="local:SegmentTextBlockHelper.HighlightBrush" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Removed}">
                                                        <Setter Property="local:SegmentTextBlockHelper.HighlightBrush" Value="{DynamicResource DiffRemovedWordBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static core:DiffLineKind.Added}">
                                                        <Setter Property="local:SegmentTextBlockHelper.HighlightBrush" Value="{DynamicResource DiffAddedWordBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Text="{Binding StatusText}"
                       Grid.Row="3"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Margin="{StaticResource MarginSubsectionTop}" />
        </Grid>
    </Grid>
</UserControl>
