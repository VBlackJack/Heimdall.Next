<UserControl x:Class="Heimdall.App.Views.Tools.TlsAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Progress bar -->
        <Grid x:Name="ProgressPanel" Grid.Row="1" Visibility="Collapsed">
            <ProgressBar x:Name="AuditProgress"
                         Height="20" Minimum="0" Maximum="100"
                         IsIndeterminate="False"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceBrush}"
                         AutomationProperties.Name=""/>
            <TextBlock x:Name="TxtProgressStatus" Text=""
                       FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Input row -->
                <TextBlock x:Name="LblHost" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnAudit" DockPanel.Dock="Right"
                            Content="" Click="OnAuditClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtPort" DockPanel.Dock="Right"
                             Text="443" Width="70"
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="port"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" Margin="8,0,0,0"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                    <TextBlock DockPanel.Dock="Right" Text=":"
                               FontSize="{StaticResource FontSizeBodyLarge}" Margin="4,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtHost" Text=""
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="hostname"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Route via gateway -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock x:Name="LblRouteVia" Text=""
                               FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRouteVia" Width="240"
                              SelectionChanged="OnRouteViaChanged"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,12" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorTextBrush}"/>

                <!-- Empty state hint -->
                <Border x:Name="EmptyStatePanel"
                        Style="{StaticResource ToolEmptyStateStyle}"
                        Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource IconSizeEmptyState}"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtEmptyState" Text=""
                                   FontSize="{StaticResource FontSizeBodyLarge}" TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- ===== Results ===== -->
                <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                    <!-- Grade badge -->
                    <Border x:Name="GradeBadge" HorizontalAlignment="Center"
                            CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="24,12" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="LblGradeCaption" Text=""
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtGrade" Text=""
                                       FontSize="{StaticResource FontSizeHeadline}" FontWeight="Bold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                       HorizontalAlignment="Center"
                                       AutomationProperties.Name=""
                                       AutomationProperties.LiveSetting="Polite"/>
                        </StackPanel>
                    </Border>

                    <!-- Protocol support -->
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,0,0,12"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel>
                            <TextBlock x:Name="LblProtocols" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl x:Name="ProtocolList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="{Binding Icon}" DockPanel.Dock="Left"
                                                       FontSize="{StaticResource FontSizeBody}" Width="20"
                                                       Foreground="{Binding RatingBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Right"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{Binding RatingBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Cipher suites (TLS 1.2) -->
                    <Border x:Name="CipherPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="LblCiphers" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl x:Name="CipherList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,4" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1"
                                                        Background="{Binding StrengthBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusSm}"
                                                        Padding="6,2" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Strength}"
                                                               FontSize="{StaticResource FontSizeSmallCaption}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextOnAccentBrush}"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding KeyExchange}"
                                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Authentication}"
                                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Encryption}"
                                                           FontSize="{StaticResource FontSizeSmallCaption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Certificate summary -->
                    <Border x:Name="CertPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="LblCertSection" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="LblCertSubject" Grid.Row="0" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCertSubject" Grid.Row="0" Grid.Column="2" Text=""
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>

                                <TextBlock x:Name="LblCertIssuer" Grid.Row="2" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCertIssuer" Grid.Row="2" Grid.Column="2" Text=""
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>

                                <TextBlock x:Name="LblCertExpiry" Grid.Row="4" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCertExpiry" Grid.Row="4" Grid.Column="2" Text=""
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                <TextBlock x:Name="LblCertKeySize" Grid.Row="6" Grid.Column="0" Text=""
                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtCertKeySize" Grid.Row="6" Grid.Column="2" Text=""
                                           FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Findings -->
                    <Border x:Name="FindingsPanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                            Padding="16,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="LblFindings" Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl x:Name="FindingsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="{Binding Icon}" DockPanel.Dock="Left"
                                                       FontSize="{StaticResource FontSizeBody}" Width="20"
                                                       Foreground="{Binding Brush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Copy report button -->
                    <Button x:Name="BtnCopy" Click="OnCopyClick"
                            Visibility="Collapsed"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="0,0,0,12"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name=""/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
