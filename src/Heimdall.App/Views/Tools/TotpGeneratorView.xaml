<UserControl x:Class="Heimdall.App.Views.Tools.TotpGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        TabIndex="3"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        AutomationProperties.Name=""/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        AutomationProperties.Name=""/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Secret key input -->
                <TextBlock x:Name="LblSecret" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginSectionSeparator}">
                    <Button x:Name="BtnGenerate" DockPanel.Dock="Right"
                            TabIndex="1"
                            Content="" Click="OnGenerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name=""/>
                    <TextBox x:Name="TxtSecret" Text=""
                             TabIndex="0"
                             Style="{DynamicResource WatermarkTextBoxStyle}"
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Tag=""
                             KeyDown="OnInputKeyDown"
                             VerticalAlignment="Center"
                             AutomationProperties.Name=""/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginSectionBottom}" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorTextBrush}"/>

                <!-- TOTP code display -->
                <Border x:Name="CodePanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CornerRadiusSm}"
                        Padding="24,16" Margin="{StaticResource MarginSectionSeparator}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="LblCode" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <DockPanel HorizontalAlignment="Center" Margin="{StaticResource MarginSectionBottom}">
                            <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                                    TabIndex="2"
                                    Content="" Click="OnCopyClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonPrimary}" Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name=""/>
                            <TextBlock x:Name="TxtCode" Text="------"
                                       FontSize="{StaticResource IconSizeXLarge}" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Time remaining -->
                        <TextBlock x:Name="LblTimeRemaining" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="ProgressTime"
                                     Height="6" Width="300"
                                     Minimum="0" Maximum="30" Value="30"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource SurfaceBrush}"
                                     AutomationProperties.Name=""/>
                    </StackPanel>
                </Border>

                <!-- Info -->
                <TextBlock x:Name="TxtInfo" Text=""
                           FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
