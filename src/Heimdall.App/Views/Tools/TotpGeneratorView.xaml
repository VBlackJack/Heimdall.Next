<UserControl x:Class="Heimdall.App.Views.Tools.TotpGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel MaxWidth="600">

                <!-- Secret key input -->
                <TextBlock x:Name="LblSecret" Text=""
                           FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,16">
                    <Button x:Name="BtnGenerate" DockPanel.Dock="Right"
                            Content="" Click="OnGenerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtSecret" Text=""
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="12" Margin="0,0,0,12"
                           Foreground="{DynamicResource ErrorBrush}"/>

                <!-- TOTP code display -->
                <Border x:Name="CodePanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="24,16" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="LblCode" Text=""
                                   FontSize="12" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <DockPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                            <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                                    Content="" Click="OnCopyClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="12,6" Margin="12,0,0,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtCode" Text="------"
                                       FontSize="36" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Time remaining -->
                        <TextBlock x:Name="LblTimeRemaining" Text=""
                                   FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="ProgressTime"
                                     Height="6" Width="300"
                                     Minimum="0" Maximum="30" Value="30"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource SurfaceBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Info -->
                <TextBlock x:Name="TxtInfo" Text=""
                           FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
