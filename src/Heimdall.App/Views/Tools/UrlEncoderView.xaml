<UserControl x:Class="Heimdall.App.Views.Tools.UrlEncoderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Heimdall.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Heimdall.App.ViewModels.Tools"
             d:DataContext="{d:DesignInstance Type=vm:UrlEncoderViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="UrlEncoder.HelpButton"
                       
                       
                        Margin="{StaticResource MarginInlineControl}"
                        Padding="{StaticResource PaddingButtonHelp}"
                        Content="?"
                        Click="OnHelpClick"
                        ToolTip="{loc:Translate ToolHelpTooltip}"
                        AutomationProperties.Name="{loc:Translate ToolHelpTooltip}"
                        Style="{DynamicResource ToolHelpButtonStyle}"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="Bold" />
                <TextBlock Text="{loc:Translate ToolUrlEncTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border x:Name="HelpPanel"
                Grid.Row="1"
                AutomationProperties.AutomationId="UrlEncoder.HelpPanel"
                Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp"
                        DockPanel.Dock="Right"
                        AutomationProperties.AutomationId="UrlEncoder.CloseHelpButton"
                       
                       
                        Content="&#xE711;"
                        Click="OnCloseHelpClick"
                        AutomationProperties.Name="{loc:Translate BtnClose}"
                        Style="{DynamicResource ToolCloseHelpButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeBody}"
                        VerticalAlignment="Top" />
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent"
                               Text=""
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">
                <DockPanel Margin="{StaticResource MarginLabelBottom}">
                    <Button x:Name="BtnCopyDecoded"
                            DockPanel.Dock="Right"
                            AutomationProperties.AutomationId="UrlEncoder.CopyDecodedButton"
                            Content="{loc:Translate ToolUrlEncBtnCopy}"
                            Click="OnCopyDecodedClick"
                            ToolTip="{loc:Translate ToolBtnCopyToClipboard}"
                            AutomationProperties.Name="{loc:Translate ToolUrlEncBtnCopy}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Bottom" />
                    <TextBlock Text="{loc:Translate ToolUrlEncDecodedLabel}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" />
                </DockPanel>

                <TextBox x:Name="TxtDecoded"
                         AutomationProperties.AutomationId="UrlEncoder.DecodedField"
                         Text="{Binding DecodedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="{StaticResource FontSizeBodyLarge}"
                         FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}"
                         Margin="{StaticResource MarginStackItem}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="1"
                         Tag="{loc:Translate ToolWatermarkUrlToEncode}"
                         AutomationProperties.Name="{loc:Translate ToolUrlEncDecodedLabel}"
                         AutomationProperties.LiveSetting="Polite">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDecodeError}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <DockPanel Margin="0,8,0,4">
                    <Button x:Name="BtnCopyEncoded"
                            DockPanel.Dock="Right"
                            AutomationProperties.AutomationId="UrlEncoder.CopyEncodedButton"
                            Content="{loc:Translate ToolUrlEncBtnCopy}"
                            Click="OnCopyEncodedClick"
                            ToolTip="{loc:Translate ToolBtnCopyToClipboard}"
                            AutomationProperties.Name="{loc:Translate ToolUrlEncBtnCopy}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}"
                            Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Bottom" />
                    <TextBlock Text="{loc:Translate ToolUrlEncEncodedLabel}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" />
                </DockPanel>

                <TextBox x:Name="TxtEncoded"
                         AutomationProperties.AutomationId="UrlEncoder.EncodedField"
                         Text="{Binding EncodedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="{StaticResource FontSizeBodyLarge}"
                         FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}"
                         Margin="{StaticResource MarginStackItem}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"
                         Tag="{loc:Translate ToolWatermarkEncodedUrl}"
                         AutomationProperties.Name="{loc:Translate ToolUrlEncEncodedLabel}"
                         AutomationProperties.LiveSetting="Polite" />

                <CheckBox x:Name="ChkComponentEncoding"
                          AutomationProperties.AutomationId="UrlEncoder.ComponentEncodingCheck"
                          Margin="0,4,0,0"
                          Content="{loc:Translate ToolUrlEncComponentMode}"
                          IsChecked="{Binding ComponentMode, Mode=TwoWay}"
                          Foreground="{DynamicResource TextSecondaryBrush}"
                          AutomationProperties.Name="{loc:Translate ToolUrlEncComponentMode}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
