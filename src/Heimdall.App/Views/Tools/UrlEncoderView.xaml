<UserControl x:Class="Heimdall.App.Views.Tools.UrlEncoderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Decoded field -->
                <DockPanel Margin="0,0,0,4">
                    <Button x:Name="BtnCopyDecoded" DockPanel.Dock="Right"
                            Content="" Click="OnCopyDecodedClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="8,0,0,0"
                            VerticalAlignment="Bottom"
/>
                    <TextBlock x:Name="LblDecoded" Text=""
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom"/>
                </DockPanel>
                <TextBox x:Name="TxtDecoded" Text=""
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="0,0,0,8"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="80" MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="URL or text to encode/decode"
                         TextChanged="OnDecodedTextChanged"
/>

                <!-- Encoded field -->
                <DockPanel Margin="0,8,0,4">
                    <Button x:Name="BtnCopyEncoded" DockPanel.Dock="Right"
                            Content="" Click="OnCopyEncodedClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonCopy}" Margin="8,0,0,0"
                            VerticalAlignment="Bottom"
/>
                    <TextBlock x:Name="LblEncoded" Text=""
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom"/>
                </DockPanel>
                <TextBox x:Name="TxtEncoded" Text=""
                         FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                         Padding="{StaticResource PaddingInput}" Margin="0,0,0,8"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="80" MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Tag="encoded URL"
                         TextChanged="OnEncodedTextChanged"
                         AutomationProperties.LiveSetting="Polite"
/>

                <!-- Component encoding toggle -->
                <CheckBox x:Name="ChkComponentEncoding" Margin="0,4,0,0"
                          Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock x:Name="LblComponentEncoding" Text="" FontSize="{StaticResource FontSizeBody}"/>
                </CheckBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
