<UserControl x:Class="Heimdall.App.Views.Tools.UuidGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="{StaticResource MarginInlineControl}"
                        TabIndex="12"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Help panel -->
        <Border x:Name="HelpPanel" Grid.Row="1" Style="{StaticResource ToolHelpPanelStyle}">
            <DockPanel>
                <Button x:Name="BtnCloseHelp" DockPanel.Dock="Right" Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                        Click="OnCloseHelpClick"
                        Style="{DynamicResource ToolbarGhostButtonStyle}"
                        VerticalAlignment="Top" Width="24" Height="24"
                        TabIndex="13"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtHelpContent" Text="" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               LineHeight="20"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="{StaticResource ToolContentMaxWidth}">

                <!-- Single UUID generation -->
                <TextBlock x:Name="LblSingleResult" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginLabelBottom}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="{StaticResource MarginStackItem}">
                    <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                            Content="" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            TabIndex="1"/>
                    <Button x:Name="BtnGenerate" DockPanel.Dock="Right"
                            Content="" Click="OnGenerateClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                            VerticalAlignment="Stretch"
                            TabIndex="0"/>
                    <TextBox x:Name="TxtResult" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True"
                             AutomationProperties.LiveSetting="Polite"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </DockPanel>

                <!-- Options -->
                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginSectionSeparator}">
                    <ComboBox x:Name="CmbVersion" Width="160"
                              Margin="0,0,16,0"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              SelectionChanged="OnVersionChanged"
                              SelectedIndex="0"
                              TabIndex="2">
                        <ComboBoxItem Tag="4"/>
                        <ComboBoxItem Tag="7"/>
                    </ComboBox>
                    <CheckBox x:Name="ChkUppercase"
                              Margin="0,0,16,0"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnFormatChanged" Unchecked="OnFormatChanged"
                              TabIndex="3"/>
                    <CheckBox x:Name="ChkHyphens" IsChecked="True"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnFormatChanged" Unchecked="OnFormatChanged"
                              TabIndex="4"/>
                </StackPanel>

                <!-- Batch generation -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="0,16,0,0" Margin="{StaticResource MarginSubsectionTop}">
                    <StackPanel>
                        <TextBlock x:Name="LblBatch" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackItem}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <DockPanel Margin="{StaticResource MarginSectionBottom}">
                            <Button x:Name="BtnGenerateBatch" DockPanel.Dock="Right"
                                    Content="" Click="OnGenerateBatchClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginInlineControl}"
                                    VerticalAlignment="Stretch"
                                    TabIndex="6"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="LblCount" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginInlineSm}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCount" Text=""
                                         FontSize="{StaticResource FontSizeBodyLarge}" Width="60"
                                         Padding="{StaticResource PaddingInput}"
                                         Background="{DynamicResource CardBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         TabIndex="5"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Batch results -->
                        <TextBox x:Name="TxtBatchResults" Text=""
                                 FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}" MaxHeight="300"
                                 IsReadOnly="True"
                                 AutomationProperties.LiveSetting="Polite"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button x:Name="BtnCopyBatch" Content=""
                                Click="OnCopyBatchClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="{StaticResource MarginSubsectionTop}"
                                HorizontalAlignment="Left"
                                TabIndex="7"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
