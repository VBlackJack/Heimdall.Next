<UserControl x:Class="Heimdall.App.Views.Tools.UuidGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="{StaticResource ToolHeaderPadding}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button x:Name="BtnHelp" DockPanel.Dock="Right" Content="?"
                        Click="OnHelpClick"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="{StaticResource PaddingButtonHelp}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                        Width="24" Height="24" Margin="8,0,0,0"/>
                <TextBlock x:Name="HeaderTitle" Text=""
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Single UUID generation -->
                <TextBlock x:Name="LblSingleResult" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="BtnCopy" DockPanel.Dock="Right"
                            Content="" Click="OnCopyClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="8,0,0,0"
                            VerticalAlignment="Stretch"/>
                    <Button x:Name="BtnGenerate" DockPanel.Dock="Right"
                            Content="" Click="OnGenerateClick"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="{StaticResource PaddingButtonPrimary}" Margin="8,0,0,0"
                            VerticalAlignment="Stretch"/>
                    <TextBox x:Name="TxtResult" Text=""
                             FontSize="{StaticResource FontSizeBodyLarge}" FontFamily="Consolas"
                             Padding="{StaticResource PaddingInput}" IsReadOnly="True" AutomationProperties.LiveSetting="Polite"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource AccentBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
/>
                </DockPanel>

                <!-- Options -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ComboBox x:Name="CmbVersion" Width="160"
                              Margin="0,0,16,0"
                              Background="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              SelectionChanged="OnVersionChanged"
                              SelectedIndex="0">
                        <ComboBoxItem Tag="4"/>
                        <ComboBoxItem Tag="7"/>
                    </ComboBox>
                    <CheckBox x:Name="ChkUppercase"
                              Margin="0,0,16,0"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnFormatChanged" Unchecked="OnFormatChanged"
/>
                    <CheckBox x:Name="ChkHyphens" IsChecked="True"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="OnFormatChanged" Unchecked="OnFormatChanged"
/>
                </StackPanel>

                <!-- Batch generation -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="0,16,0,0" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock x:Name="LblBatch" Text=""
                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <DockPanel Margin="0,0,0,12">
                            <Button x:Name="BtnGenerateBatch" DockPanel.Dock="Right"
                                    Content="" Click="OnGenerateBatchClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="{StaticResource PaddingButtonPrimary}" Margin="8,0,0,0"
                                    VerticalAlignment="Stretch"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="LblCount" Text=""
                                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCount" Text="10"
                                         FontSize="{StaticResource FontSizeBodyLarge}" Width="60"
                                         Padding="{StaticResource PaddingInput}"
                                         Background="{DynamicResource CardBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Batch results -->
                        <TextBox x:Name="TxtBatchResults" Text=""
                                 FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                 Padding="{StaticResource PaddingInput}" Height="300"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource CardBrush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
/>
                        <Button x:Name="BtnCopyBatch" Content=""
                                Click="OnCopyBatchClick"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="{StaticResource PaddingButtonPrimary}" Margin="0,8,0,0"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
