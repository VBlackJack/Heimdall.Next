<UserControl x:Class="Heimdall.App.Views.Tools.WhoisLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="HeaderTitle" Text=""
                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource SpacingLg}">
            <StackPanel MaxWidth="700">

                <!-- Input Row -->
                <TextBlock x:Name="LblDomain" Text=""
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DockPanel Margin="0,0,0,16">
                    <Button x:Name="BtnLookup" DockPanel.Dock="Right"
                            Content="" Click="OnLookupClick"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtDomain" Text=""
                             Style="{StaticResource WatermarkTextBoxStyle}"
                             Tag="example.com or IP address"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6"
                             Background="{DynamicResource CardBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Error message -->
                <TextBlock x:Name="TxtError" Text="" Visibility="Collapsed"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,12" TextWrapping="Wrap"
                           Foreground="{DynamicResource ErrorBrush}"/>

                <!-- Results -->
                <Border x:Name="ResultsPanel" Visibility="Collapsed"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="16,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button x:Name="BtnCopyResults" DockPanel.Dock="Right" Click="OnCopyResultsClick"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="8,2" FontSize="{StaticResource FontSizeCaption}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResultHeader" Text=""
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBox x:Name="TxtResults" Text=""
                                 FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="500"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="12,6"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatus" Text=""
                       FontSize="{StaticResource FontSizeBody}" FontFamily="Consolas"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
